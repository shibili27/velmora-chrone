<div class="toast" id="toast"></div>

<script>
  // ── Nav scroll ──────────────────────────────────────────────────────────
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive: true });
  document.getElementById('hamburger').addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });

  // ── Reveal on scroll ────────────────────────────────────────────────────
  const observer = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) { setTimeout(() => entry.target.classList.add('visible'), i * 80); observer.unobserve(entry.target); }
    });
  }, { threshold: 0.06 });
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ── Toast ───────────────────────────────────────────────────────────────
  let toastTimer;
  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast show' + (type ? ' ' + type : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
  }

  function updateHeroCount(count) {
    const el = document.getElementById('heroCount');
    if (el) el.textContent = `${count} item${count !== 1 ? 's' : ''} saved`;
  }
  function updateCartBadge(count) {
    const el = document.getElementById('cartBadge');
    if (el) el.textContent = count;
  }

  // ── Confirm modal ───────────────────────────────────────────────────────
  const modal        = document.getElementById('confirmModal');
  const modalCancel  = document.getElementById('modalCancel');
  const modalConfirm = document.getElementById('modalConfirm');

  function openClearModal() {
    modal.classList.add('open');
    modalConfirm.focus();
  }
  function closeClearModal() {
    modal.classList.remove('open');
  }

  modal.addEventListener('click', e => { if (e.target === modal) closeClearModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeClearModal(); });
  modalCancel.addEventListener('click', closeClearModal);

  // ── Remove ALL ──────────────────────────────────────────────────────────
  modalConfirm.addEventListener('click', async () => {
    closeClearModal();
    modalConfirm.disabled = true;
    try {
      const res  = await fetch('/wishlist/clear', { method: 'DELETE' });
      const data = await res.json();
      if (res.ok) {
        document.querySelectorAll('.wish-card').forEach(c => c.classList.add('removing'));
        showToast('Wishlist cleared');
        setTimeout(() => window.location.reload(), 400);
      } else {
        showToast(data.message || 'Could not clear wishlist', 'err');
        modalConfirm.disabled = false;
      }
    } catch (_) {
      showToast('Something went wrong', 'err');
      modalConfirm.disabled = false;
    }
  });

  // ── Remove single item ──────────────────────────────────────────────────
  async function removeItem(itemId) {
    const card = document.getElementById(`wishCard-${itemId}`);
    if (card) card.classList.add('removing');
    try {
      const res  = await fetch(`/wishlist/remove/${itemId}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok) {
        if (card) card.classList.remove('removing');
        showToast(data.message || 'Failed to remove item', 'err');
        return;
      }
      setTimeout(() => {
        if (card) card.remove();
        const remaining = document.querySelectorAll('.wish-card').length;
        updateHeroCount(remaining);
        if (remaining === 0) window.location.reload();
      }, 300);
      showToast('Removed from wishlist');
    } catch (_) {
      if (card) card.classList.remove('removing');
      showToast('Something went wrong', 'err');
    }
  }

  // ── Move to cart ────────────────────────────────────────────────────────
  async function moveToCart(itemId) {
    try {
      const res  = await fetch('/wishlist/move-to-cart', {
        method : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body   : JSON.stringify({ itemId }),
      });
      const data = await res.json();
      if (!res.ok) { showToast(data.message || 'Could not add to cart', 'err'); return; }
      const card = document.getElementById(`wishCard-${itemId}`);
      if (card) {
        card.classList.add('removing');
        setTimeout(() => {
          card.remove();
          const remaining = document.querySelectorAll('.wish-card').length;
          updateHeroCount(remaining);
          if (remaining === 0) window.location.reload();
        }, 300);
      }
      if (data.cartCount !== undefined) updateCartBadge(data.cartCount);
      showToast('Added to cart', 'gold');
    } catch (_) {
      showToast('Something went wrong', 'err');
    }
  }

  // ── Cart badge on load ──────────────────────────────────────────────────
  fetch('/api/cart/count').then(r => r.json()).then(d => updateCartBadge(d.count || 0)).catch(() => {});

  // ── Prevent back-nav to cached page ────────────────────────────────────
  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));

  // ── SSE: live stock updates ─────────────────────────────────────────────
  (function () {
    const es = new EventSource('/sse/products');
    es.addEventListener('productUpdate', function (e) {
      const data = JSON.parse(e.data);
      const card = document.querySelector(`.wish-card[data-product-id="${data.productId}"]`);
      if (!card) return;
      const imgWrap = card.querySelector('.card-img-wrap');
      const addBtn  = card.querySelector('.btn-add-cart');
      const isOOS   = data.stock === 0 || data.isDeleted || data.isListed === false;
      const isLow   = !isOOS && data.stock > 0 && data.stock <= 5;
      let overlay   = imgWrap.querySelector('.oos-overlay');
      if (isOOS) {
        if (!overlay) {
          overlay = document.createElement('div');
          overlay.className = 'oos-overlay';
          overlay.innerHTML = '<span>Out of Stock</span>';
          imgWrap.appendChild(overlay);
        }
      } else { if (overlay) overlay.remove(); }
      if (addBtn) { addBtn.disabled = isOOS; addBtn.textContent = isOOS ? 'Out of Stock' : 'Add to Cart'; }
      const badge = card.querySelector('.stock-badge');
      if (badge) {
        badge.className = 'stock-badge ' + (isOOS ? 'out-stock' : isLow ? 'low-stock' : 'in-stock');
        const dot = document.createElement('span'); dot.className = 'stock-dot';
        badge.innerHTML = ''; badge.appendChild(dot);
        badge.appendChild(document.createTextNode(' ' + (isOOS ? 'Out of Stock' : isLow ? `Only ${data.stock} left` : `In Stock · ${data.stock} available`)));
      }
    });
    es.onerror = function () {};
  })();
</script>
</body>
</html>
