      <span id="heroCount" style="font-family:'Jost',sans-serif;font-size:.42rem;letter-spacing:.32em;text-transform:uppercase;color:rgba(201,169,110,.38)"><%= wishlistItems.length %> item<%= wishlistItems.length !== 1 ? 's' : '' %> saved</span>
