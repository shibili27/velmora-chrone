<!-- MAIN -->
<div class="wishlist-wrap">
  <% if (wishlistItems.length > 0) { %>

  <div class="wishlist-header reveal">
    <span class="wishlist-label">Saved Timepieces</span>
    <button class="clear-all-btn" onclick="openClearModal()">Remove All</button>
  </div>

  <div class="wishlist-list reveal" id="wishlistGrid">
    <% wishlistItems.forEach(item => {
      const p         = item.product;
      const isOOS     = p.stock === 0;
      const isLow     = p.stock > 0 && p.stock <= 5;
      const inCart    = cartProductIds.includes(p._id.toString());
      const mainImg   = p.images?.[0] || (p.colorVariants?.[0]?.images?.[0]) || null;
      const brandName = p.brand?.name || null;
    %>
    <div class="wish-card" id="wishCard-<%= item._id %>" data-product-id="<%= p._id %>">

      <!-- IMAGE SIDE -->
      <div class="card-img-wrap">
        <% if (inCart) { %><div class="in-cart-badge">In Cart</div><% } %>
        <% if (isOOS) { %><div class="oos-overlay"><span>Out of Stock</span></div><% } %>
        <button class="card-remove" onclick="removeItem('<%= item._id %>')" title="Remove from wishlist">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <% if (mainImg) { %>
          <a href="/products/<%= p._id %>" style="display:block;width:100%;height:100%">
            <img class="card-img" src="<%= mainImg %>" alt="<%= p.name %>" onerror="this.parentElement.style.background='#222220'"/>
          </a>
        <% } else { %>
          <a href="/products/<%= p._id %>" style="display:flex;align-items:center;justify-content:center;width:100%;height:100%;background:#1a1a18">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.06)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg>
          </a>
        <% } %>
      </div>

      <!-- INFO SIDE -->
      <div class="card-info">
        <div>
          <div class="card-eyebrow">
            <% if (brandName) { %><span class="card-brand"><%= brandName %></span><% } %>
            <% if (p.category?.name) { %><span class="card-cat-tag"><%= p.category.name %></span><% } %>
          </div>
          <a href="/products/<%= p._id %>" class="card-name"><%= p.name %></a>
          <div class="gold-rule"></div>
          <div class="card-price">₹<%= p.price.toLocaleString('en-IN') %></div>
          <div class="card-price-note">Inclusive of all taxes</div>
          <div class="stock-badge <%= isOOS ? 'out-stock' : isLow ? 'low-stock' : 'in-stock' %>">
            <span class="stock-dot"></span>
            <% if (isOOS) { %>Out of Stock
            <% } else if (isLow) { %>Only <%= p.stock %> left
            <% } else { %>In Stock · <%= p.stock %> available<% } %>
          </div>
        </div>
        <div>
          <div class="card-actions">
            <% if (inCart) { %>
              <div class="btn-in-cart">Already in Cart</div>
            <% } else { %>
              <button class="btn-add-cart" <%= isOOS ? 'disabled' : '' %> onclick="moveToCart('<%= item._id %>')">
                <%= isOOS ? 'Out of Stock' : 'Add to Cart' %>
              </button>
            <% } %>
            <a href="/products/<%= p._id %>" class="btn-view" title="View Details">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
          <div class="service-row">
            <span class="service-pill">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              Free Shipping
            </span>
            <span class="service-pill">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Authenticity Cert.
            </span>
            <span class="service-pill">
              <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.75"/></svg>
              30-Day Returns
            </span>
          </div>
        </div>
      </div>

    </div>
    <% }) %>
  </div>

  <% } else { %>
  <div style="text-align:center;padding:5rem 1rem" class="reveal">
    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.07)" stroke-width="0.6" style="margin:0 auto 1.5rem;display:block">
      <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
    </svg>
    <p style="font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:400;color:rgba(245,242,235,.18);margin-bottom:.5rem">Your wishlist is empty</p>
    <p style="font-family:'Jost',sans-serif;font-size:.55rem;color:rgba(245,242,235,.12);margin-bottom:2rem;letter-spacing:.12em">Save timepieces you love and revisit them anytime</p>
    <a href="/products" style="font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.25em;text-transform:uppercase;color:#c9a96e;text-decoration:none;border:1px solid rgba(201,169,110,.2);border-radius:100px;padding:.7rem 2.5rem;transition:all .2s;display:inline-block">Explore Collection</a>
  </div>
  <% } %>
</div>

