<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Wishlist — Velmora Chroné</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'Jost',sans-serif;background:#111110;color:#f5f2eb;overflow-x:hidden;min-height:100vh}
    ::-webkit-scrollbar{width:2px}::-webkit-scrollbar-track{background:#111110}::-webkit-scrollbar-thumb{background:#c9a96e}
    body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");opacity:.016}
    .nav-root{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(17,17,16,.92);backdrop-filter:blur(18px) saturate(1.4);-webkit-backdrop-filter:blur(18px) saturate(1.4);border-bottom:1px solid rgba(245,242,235,.06);transition:box-shadow .3s}
    .nav-root.scrolled{box-shadow:0 2px 24px rgba(0,0,0,.5)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem}
    @media(min-width:768px){.nav-inner{padding:1rem 3rem}}
    .nav-logo{font-family:'Cormorant Garamond',serif;font-size:.85rem;font-weight:300;letter-spacing:.25em;text-transform:uppercase;color:#f5f2eb;text-decoration:none}
    .nav-link{font-family:'Jost',sans-serif;font-size:.53rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,242,235,.45);text-decoration:none;transition:color .2s;position:relative;padding-bottom:2px}
    .nav-link::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:#c9a96e;transition:width .3s}
    .nav-link:hover{color:rgba(245,242,235,.9)}.nav-link:hover::after{width:100%}
    .nav-link.active{color:#c9a96e}.nav-link.active::after{width:100%}
    .nav-icon-btn{position:relative;width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:rgba(245,242,235,.5);background:rgba(255,255,255,.03);border:1px solid rgba(201,169,110,.12);border-radius:10px;cursor:pointer;text-decoration:none;transition:color .22s,background .22s,border-color .22s,transform .18s cubic-bezier(.34,1.56,.64,1),box-shadow .22s;box-shadow:0 1px 0 rgba(255,255,255,.04) inset,0 2px 6px rgba(0,0,0,.35)}
    .nav-icon-btn::before{content:'';position:absolute;inset:0;border-radius:10px;background:linear-gradient(135deg,rgba(255,255,255,.08) 0%,transparent 55%);pointer-events:none}
    .nav-icon-btn:hover{color:#c9a96e;background:rgba(201,169,110,.08);border-color:rgba(201,169,110,.35);transform:translateY(-2px) scale(1.06);box-shadow:0 1px 0 rgba(255,255,255,.06) inset,0 6px 20px rgba(0,0,0,.5),0 0 14px rgba(201,169,110,.15)}
    .nav-icon-btn:active{transform:translateY(0) scale(.97)}
    .nav-icon-btn.wish-active{color:#c9a96e;border-color:rgba(201,169,110,.3);background:rgba(201,169,110,.06)}
    .cart-badge{position:absolute;top:-5px;right:-5px;width:14px;height:14px;border-radius:50%;background:linear-gradient(135deg,#d4b97e,#c9a96e);font-size:.38rem;font-weight:600;color:#111110;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(201,169,110,.4)}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:3px}
    .hamburger span{display:block;width:20px;height:1px;background:rgba(245,242,235,.6);transition:transform .3s,opacity .3s}
    .hamburger.open span:nth-child(1){transform:translateY(6px) rotate(45deg)}
    .hamburger.open span:nth-child(2){opacity:0}
    .hamburger.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}
    .mobile-menu{display:none;flex-direction:column;background:#0d0d0c;padding:1.5rem 2rem;gap:1rem;border-top:1px solid rgba(245,242,235,.05)}
    .mobile-menu.open{display:flex}
    .mobile-menu .nav-link{font-size:.68rem;padding:.45rem 0;border-bottom:1px solid rgba(245,242,235,.04);color:rgba(245,242,235,.5)}
    .page-hero{padding:5.5rem 2rem 1.5rem;background:linear-gradient(180deg,#080807 0%,#111110 100%);border-bottom:1px solid rgba(201,169,110,.08);position:relative;overflow:hidden;text-align:center}
    @media(min-width:768px){.page-hero{padding:5.5rem 3rem 1.5rem}}
    .page-hero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:600px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(201,169,110,.06) 0%,transparent 70%);pointer-events:none}
    .page-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.25),transparent)}
    .page-hero-scan{position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(201,169,110,.022),transparent);animation:heroScan 7s ease-in-out infinite;pointer-events:none;z-index:0}
    @keyframes heroScan{0%{left:-60%}100%{left:140%}}
    .page-hero-inner{max-width:900px;margin:0 auto;position:relative;z-index:1;display:flex;flex-direction:column;align-items:center}
    .page-hero-tag{font-family:'Jost',sans-serif;font-size:.4rem;letter-spacing:.35em;text-transform:uppercase;color:rgba(201,169,110,.55);margin-bottom:.5rem;display:flex;align-items:center;gap:.65rem}
    .page-hero-tag::before{content:'';width:20px;height:1px;background:#c9a96e;opacity:.45}
    .page-hero-tag::after{content:'';width:20px;height:1px;background:#c9a96e;opacity:.45}
    .page-hero-title{font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.1rem,2.2vw,1.7rem);line-height:1;color:#f5f2eb;letter-spacing:-.01em}
    .page-hero-title em{font-style:italic;display:block;background:linear-gradient(125deg,#edd99e 0%,#c9a96e 45%,#a8873d 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative}
    .page-hero-title em::after{content:'';position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);width:0;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.6),transparent);animation:drawUnderline 1.4s cubic-bezier(.22,1,.36,1) .7s forwards}
    @keyframes drawUnderline{to{width:70%}}
    .breadcrumb{max-width:1200px;margin:0 auto;padding:.75rem 2rem 0;display:flex;align-items:center;gap:6px;flex-wrap:wrap;position:relative;z-index:1}
    @media(min-width:768px){.breadcrumb{padding:.75rem 3rem 0}}
    .bc-item{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.25);text-decoration:none;transition:color .2s}
    .bc-item:hover{color:rgba(245,242,235,.55)}
    .bc-sep{color:rgba(245,242,235,.12);font-size:.46rem}
    .bc-current{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.6)}
    .wishlist-wrap{max-width:1200px;margin:0 auto;padding:2rem 2rem 5rem;position:relative;z-index:1}
    @media(min-width:768px){.wishlist-wrap{padding:2rem 3rem 5rem}}
    .wishlist-header{display:flex;align-items:center;justify-content:space-between;padding-bottom:.75rem;border-bottom:1px solid rgba(245,242,235,.06);margin-bottom:1.5rem}
    .wishlist-label{font-family:'Jost',sans-serif;font-size:.42rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,169,110,.5);display:flex;align-items:center;gap:.5rem}
    .wishlist-label::before{content:'';width:10px;height:1px;background:rgba(201,169,110,.3)}
    .clear-all-btn{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(248,113,113,.4);background:none;border:none;cursor:pointer;transition:color .2s}
    .clear-all-btn:hover{color:#f87171}
    .wishlist-list{display:flex;flex-direction:column;gap:1rem}
    .wish-card{display:grid;grid-template-columns:200px 1fr;background:#1c1c1a;border:1px solid rgba(245,242,235,.06);border-radius:16px;overflow:hidden;position:relative;box-shadow:0 2px 8px rgba(0,0,0,.35);transition:transform .3s cubic-bezier(.34,1.56,.64,1),box-shadow .3s,border-color .25s}
    .wish-card::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(255,255,255,.06),transparent);z-index:2;pointer-events:none}
    .wish-card:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.55),0 0 0 1px rgba(201,169,110,.18),0 0 30px rgba(201,169,110,.06);border-color:rgba(201,169,110,.12)}
    .wish-card:hover .card-img{transform:scale(1.05)}
    .wish-card.removing{opacity:0;transform:scale(.97);transition:opacity .3s,transform .3s;pointer-events:none}
    @media(max-width:600px){.wish-card{grid-template-columns:110px 1fr}}
    .card-img-wrap{position:relative;overflow:hidden;background:#1a1a18}
    .card-img-wrap::after{content:'';position:absolute;inset:0;background:linear-gradient(90deg,transparent 55%,rgba(10,10,9,.6) 100%);pointer-events:none;z-index:1}
    .card-img{width:100%;height:100%;object-fit:cover;filter:brightness(.88) contrast(1.04) saturate(.8);transition:transform .6s cubic-bezier(.25,.46,.45,.94);display:block}
    .in-cart-badge{position:absolute;top:10px;left:10px;font-family:'Jost',sans-serif;font-size:.35rem;letter-spacing:.14em;text-transform:uppercase;background:rgba(201,169,110,.15);border:1px solid rgba(201,169,110,.4);color:#c9a96e;padding:3px 9px;border-radius:100px;z-index:3}
    .oos-overlay{position:absolute;inset:0;background:rgba(17,17,16,.65);display:flex;align-items:center;justify-content:center;z-index:2}
    .oos-overlay span{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,242,235,.5);border:1px solid rgba(245,242,235,.15);border-radius:100px;padding:4px 12px}
    .card-remove{position:absolute;top:9px;right:9px;width:26px;height:26px;background:rgba(17,17,16,.75);border:1px solid rgba(245,242,235,.1);border-radius:8px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:rgba(245,242,235,.35);transition:color .2s,background .2s,border-color .2s;z-index:4}
    .card-remove:hover{color:#f87171;background:rgba(248,113,113,.1);border-color:rgba(248,113,113,.25)}
    .card-info{padding:1.5rem 1.75rem;display:flex;flex-direction:column;justify-content:space-between;gap:.8rem;border-left:1px solid rgba(201,169,110,.06)}
    @media(max-width:600px){.card-info{padding:1rem}}
    .card-eyebrow{display:flex;align-items:center;gap:.5rem;flex-wrap:wrap;margin-bottom:.45rem}
    .card-brand{font-family:'Jost',sans-serif;font-size:.38rem;letter-spacing:.24em;text-transform:uppercase;color:rgba(201,169,110,.55)}
    .card-cat-tag{font-family:'Jost',sans-serif;font-size:.36rem;letter-spacing:.16em;text-transform:uppercase;color:rgba(201,169,110,.38);border:1px solid rgba(201,169,110,.15);padding:2px 8px;border-radius:100px;background:rgba(201,169,110,.04)}
    .card-name{font-family:'Playfair Display',serif;font-size:clamp(1rem,1.8vw,1.4rem);font-weight:400;color:#f5f2eb;line-height:1.15;text-decoration:none;display:block;transition:color .2s}
    .card-name:hover{color:rgba(201,169,110,.9)}
    .gold-rule{width:32px;height:1px;background:linear-gradient(90deg,#c9a96e,rgba(201,169,110,.2));margin:.6rem 0}
    .card-price{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:300;color:#f5f2eb;letter-spacing:.04em}
    .card-price-note{font-family:'Jost',sans-serif;font-size:.4rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,242,235,.18);margin-top:2px}
    .stock-badge{display:inline-flex;align-items:center;gap:6px;font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.14em;text-transform:uppercase;margin-top:.5rem}
    .stock-dot{width:5px;height:5px;border-radius:50%;flex-shrink:0}
    .in-stock{color:rgba(74,222,128,.75)}.in-stock .stock-dot{background:#4ade80;box-shadow:0 0 5px rgba(74,222,128,.5)}
    .low-stock{color:rgba(251,191,36,.75)}.low-stock .stock-dot{background:#fbbf24;box-shadow:0 0 5px rgba(251,191,36,.4)}
    .out-stock{color:rgba(248,113,113,.7)}.out-stock .stock-dot{background:#f87171}
    .card-actions{display:flex;gap:.6rem;align-items:center;flex-wrap:wrap;margin-top:.15rem}
    .btn-add-cart{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.22em;text-transform:uppercase;color:#0d0b08;border:none;cursor:pointer;height:42px;padding:0 1.35rem;border-radius:100px;position:relative;overflow:hidden;background:linear-gradient(135deg,#e0c47e 0%,#c9a96e 50%,#b8913d 100%);transition:transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .22s;box-shadow:0 1px 0 rgba(255,255,255,.35) inset,0 4px 14px rgba(185,140,55,.3);white-space:nowrap}
    .btn-add-cart::after{content:'';position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);transform:skewX(-18deg);transition:left .55s ease}
    .btn-add-cart:hover:not(:disabled)::after{left:130%}
    .btn-add-cart:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 1px 0 rgba(255,255,255,.4) inset,0 6px 20px rgba(185,140,55,.4)}
    .btn-add-cart:active{transform:translateY(1px)}
    .btn-add-cart:disabled{background:rgba(201,169,110,.12);color:rgba(245,242,235,.2);cursor:not-allowed;transform:none;box-shadow:none}
    .btn-add-cart:disabled::after{display:none}
    .btn-in-cart{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(201,169,110,.6);background:none;border:1px solid rgba(201,169,110,.22);border-radius:100px;height:42px;padding:0 1.2rem;cursor:default;white-space:nowrap;display:flex;align-items:center}
    .btn-view{width:42px;height:42px;border:1px solid rgba(245,242,235,.1);border-radius:10px;background:rgba(255,255,255,.02);color:rgba(245,242,235,.35);cursor:pointer;display:flex;align-items:center;justify-content:center;text-decoration:none;transition:color .22s,border-color .22s,background .22s,transform .18s cubic-bezier(.34,1.56,.64,1);flex-shrink:0}
    .btn-view:hover{color:#c9a96e;border-color:rgba(201,169,110,.35);background:rgba(201,169,110,.06);transform:translateY(-2px)}
    .service-row{display:flex;flex-wrap:wrap;gap:6px;padding-top:.85rem;border-top:1px solid rgba(245,242,235,.04);margin-top:.25rem}
    .service-pill{display:flex;align-items:center;gap:4px;font-family:'Jost',sans-serif;font-size:.4rem;letter-spacing:.1em;color:rgba(245,242,235,.22);border:1px solid rgba(245,242,235,.05);padding:4px 9px;border-radius:100px;background:rgba(245,242,235,.015)}
    .service-pill svg{color:rgba(201,169,110,.4);flex-shrink:0}
    .modal-backdrop{position:fixed;inset:0;z-index:500;background:rgba(8,8,7,.75);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);display:flex;align-items:center;justify-content:center;padding:1.5rem;opacity:0;pointer-events:none;transition:opacity .28s ease}
    .modal-backdrop.open{opacity:1;pointer-events:all}
    .modal{background:#1a1a18;border:1px solid rgba(245,242,235,.07);border-radius:20px;padding:2.25rem 2rem 1.75rem;max-width:380px;width:100%;position:relative;box-shadow:0 32px 80px rgba(0,0,0,.7),0 0 0 1px rgba(255,255,255,.03) inset;transform:translateY(18px) scale(.97);transition:transform .32s cubic-bezier(.34,1.56,.64,1),opacity .28s ease;opacity:0}
    .modal-backdrop.open .modal{transform:translateY(0) scale(1);opacity:1}
    .modal::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;border-radius:20px 20px 0 0;background:linear-gradient(90deg,transparent,rgba(255,255,255,.07),transparent)}
    .modal-icon{width:44px;height:44px;border-radius:12px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.18);display:flex;align-items:center;justify-content:center;margin:0 auto 1.25rem;color:rgba(248,113,113,.7)}
    .modal-title{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:400;color:#f5f2eb;text-align:center;margin-bottom:.5rem}
    .modal-body{font-family:'Jost',sans-serif;font-size:.58rem;font-weight:300;color:rgba(245,242,235,.3);text-align:center;line-height:1.75;letter-spacing:.04em;margin-bottom:1.75rem}
    .modal-actions{display:flex;gap:.65rem}
    .modal-cancel{flex:1;font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.4);background:rgba(255,255,255,.03);border:1px solid rgba(245,242,235,.08);border-radius:100px;height:42px;cursor:pointer;transition:color .2s,border-color .2s,background .2s}
    .modal-cancel:hover{color:rgba(245,242,235,.7);border-color:rgba(245,242,235,.18);background:rgba(255,255,255,.05)}
    .modal-confirm{flex:1;font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;color:#fff;background:linear-gradient(135deg,#f87171,#ef4444);border:none;border-radius:100px;height:42px;cursor:pointer;box-shadow:0 4px 14px rgba(239,68,68,.25);transition:transform .18s cubic-bezier(.34,1.56,.64,1),box-shadow .2s}
    .modal-confirm:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(239,68,68,.35)}
    .modal-confirm:active{transform:translateY(1px)}
    .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(8px);background:#1c1c1a;border:1px solid rgba(245,242,235,.08);border-radius:100px;font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.08em;color:rgba(245,242,235,.65);padding:.6rem 1.5rem;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:999;opacity:0;pointer-events:none;transition:opacity .3s,transform .3s;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .toast.gold{border-color:rgba(201,169,110,.3);color:#c9a96e}.toast.err{border-color:rgba(248,113,113,.3);color:#f87171}
    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
    .fade-up{animation:fadeUp .75s ease both}
    .d1{animation-delay:.1s}.d2{animation-delay:.22s}.d3{animation-delay:.35s}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}
    .rule{height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.18),transparent);position:relative;z-index:1}
    .footer{background:#0a0a09;padding:4rem 2rem 1.5rem;border-top:1px solid rgba(245,242,235,.05);position:relative;z-index:1}
    @media(min-width:768px){.footer{padding:4rem 3rem 1.5rem}}
    .footer-top{display:grid;grid-template-columns:1fr;gap:2.5rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(245,242,235,.05)}
    @media(min-width:768px){.footer-top{grid-template-columns:1.2fr 1fr 1fr 1.2fr;gap:3rem}}
    .footer-logo{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;letter-spacing:.2em;text-transform:uppercase;color:#f5f2eb;margin-bottom:.75rem}
    .footer-desc{font-family:'Jost',sans-serif;font-size:.6rem;font-weight:300;color:rgba(245,242,235,.22);line-height:1.85}
    .footer-socials{display:flex;gap:.9rem;margin-top:1.25rem}
    .footer-social-btn{width:32px;height:32px;border:1px solid rgba(201,169,110,.15);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(245,242,235,.3);text-decoration:none;transition:border-color .25s,color .25s,transform .18s}
    .footer-social-btn:hover{border-color:rgba(201,169,110,.4);color:#c9a96e;transform:scale(1.1)}
    .footer-col-title{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.28em;text-transform:uppercase;color:rgba(201,169,110,.35);margin-bottom:1rem;display:block}
    .footer-col-link{display:block;font-family:'Jost',sans-serif;font-size:.58rem;letter-spacing:.08em;color:rgba(245,242,235,.25);text-decoration:none;transition:color .2s;margin-bottom:.5rem}
    .footer-col-link:hover{color:rgba(245,242,235,.6)}
    .footer-bottom{display:flex;flex-direction:column;gap:.75rem;padding-top:1.5rem;align-items:center;text-align:center}
    @media(min-width:768px){.footer-bottom{flex-direction:row;justify-content:space-between}}
    .footer-copy{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,242,235,.12)}
    .footer-legal{display:flex;gap:1.25rem}
    .footer-legal a{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,242,235,.18);text-decoration:none;transition:color .2s}
    .footer-legal a:hover{color:rgba(245,242,235,.5)}
  </style>
</head>
