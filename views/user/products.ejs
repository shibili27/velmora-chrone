<!-- ══ PAGE HERO BAND ══ -->
<div class="page-hero">
  <div class="page-hero-scan"></div>
  <div class="page-hero-inner">
    <p class="page-hero-tag fade-up d1">Curated Selection</p>
    <h1 class="page-hero-title fade-up d2">The <em>Collection</em></h1>
    <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;margin-top:1.25rem;" class="fade-up d3">
      <div style="width:36px;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,0.4));flex-shrink:0;"></div>
      <span style="font-family:'Jost',sans-serif;font-size:0.42rem;letter-spacing:0.32em;text-transform:uppercase;color:rgba(201,169,110,0.38);">Swiss Made · Est. 1882</span>
      <div style="width:36px;height:1px;background:linear-gradient(270deg,transparent,rgba(201,169,110,0.4));flex-shrink:0;"></div>
    </div>
  </div>
</div>

<!-- ══ MAIN LAYOUT ══ -->
<div class="collection-wrap">

  <!-- ══ SIDEBAR FILTERS ══ -->
  <aside class="filters-sidebar reveal">
    <form method="GET" action="/products" id="filterForm">

      <!-- Search -->
      <div class="filter-block">
        <div class="filter-block-title">Search</div>
        <input class="vc-input" type="text" name="search" placeholder="Search timepieces…" value="<%= search %>"/>
      </div>

      <!-- Category -->
      <div class="filter-block">
        <div class="filter-block-title">Category</div>
        <select class="vc-input" name="category">
          <option value="">All Categories</option>
          <% categories.forEach(c => { %>
            <option value="<%= c._id %>" <%= category === c._id.toString() ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>

      <!-- Brand -->
      <% if (brands && brands.length > 0) { %>
      <div class="filter-block">
        <div class="filter-block-title">Brand</div>
        <div class="brand-list">
          <label class="brand-item">
            <input type="radio" name="brand" value="" <%= !brand ? 'checked' : '' %>/>
            All Brands
          </label>
          <% brands.forEach(b => { %>
            <label class="brand-item">
              <input type="radio" name="brand" value="<%= b %>" <%= brand === b ? 'checked' : '' %>/>
              <%= b %>
            </label>
          <% }) %>
        </div>
      </div>
      <% } %>

      <!-- Price -->
      <div class="filter-block">
        <div class="filter-block-title">Price Range (₹)</div>
        <div class="price-row">
          <input class="vc-input" type="number" name="minPrice" placeholder="Min" value="<%= minPrice %>"/>
          <input class="vc-input" type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice %>"/>
        </div>
      </div>

      <input type="hidden" name="sort" id="sortInput" value="<%= sort %>"/>

      <button type="submit" class="btn-apply">Apply Filters</button>
      <a href="/products" class="btn-clear">Clear all filters</a>

    </form>
  </aside>

  <!-- ══ PRODUCTS AREA ══ -->
  <div class="products-area">

    <!-- Topbar -->
    <div class="products-topbar reveal">
      <span class="products-count"><strong><%= total %></strong> timepiece<%= total !== 1 ? 's' : '' %> found</span>
      <select class="sort-select" onchange="applySort(this.value)">
        <option value="newest"    <%= sort==='newest'    ? 'selected':'' %>>Newest First</option>
        <option value="oldest"    <%= sort==='oldest'    ? 'selected':'' %>>Oldest First</option>
        <option value="priceLow"  <%= sort==='priceLow'  ? 'selected':'' %>>Price: Low to High</option>
        <option value="priceHigh" <%= sort==='priceHigh' ? 'selected':'' %>>Price: High to Low</option>
        <option value="nameAZ"    <%= sort==='nameAZ'    ? 'selected':'' %>>Name: A–Z</option>
        <option value="nameZA"    <%= sort==='nameZA'    ? 'selected':'' %>>Name: Z–A</option>
      </select>
    </div>

    <!-- Active filter tags -->
    <% const hasFilters = search || category || brand || minPrice || maxPrice; %>
    <% if (hasFilters) { %>
    <div class="active-filters reveal">
      <% if (search) { %>
        <a href="/products?<%= new URLSearchParams({...(category&&{category}), ...(brand&&{brand}), ...(minPrice&&{minPrice}), ...(maxPrice&&{maxPrice}), sort}).toString() %>" class="filter-tag">
          "<%= search %>"
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </a>
      <% } %>
      <% if (category) { %>
        <% const catName = categories.find(c => c._id.toString() === category); %>
        <a href="/products?<%= new URLSearchParams({...(search&&{search}), ...(brand&&{brand}), ...(minPrice&&{minPrice}), ...(maxPrice&&{maxPrice}), sort}).toString() %>" class="filter-tag">
          <%= catName ? catName.name : 'Category' %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </a>
      <% } %>
      <% if (brand) { %>
        <a href="/products?<%= new URLSearchParams({...(search&&{search}), ...(category&&{category}), ...(minPrice&&{minPrice}), ...(maxPrice&&{maxPrice}), sort}).toString() %>" class="filter-tag">
          <%= brand %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </a>
      <% } %>
      <% if (minPrice || maxPrice) { %>
        <a href="/products?<%= new URLSearchParams({...(search&&{search}), ...(category&&{category}), ...(brand&&{brand}), sort}).toString() %>" class="filter-tag">
          ₹<%= minPrice || '0' %> – ₹<%= maxPrice || '∞' %>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </a>
      <% } %>
    </div>
    <% } %>

    <!-- Product grid -->
    <% if (products.length > 0) { %>
    <div class="product-grid reveal">
      <% products.forEach(p => { %>
      <a href="/products/<%= p._id %>" class="prod-card">
        <div class="prod-img-wrap">
          <% if (p.images && p.images.length > 0) { %>
            <img class="prod-img" src="<%= p.images[0] %>" alt="<%= p.name %>" loading="lazy" onerror="this.style.opacity='0'"/>
          <% } else { %>
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#1a1a18;">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.06)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg>
            </div>
          <% } %>
        </div>
        <div class="prod-body">
          <% if (p.brand && p.brand.name) { %>
            <div class="prod-brand"><%= p.brand.name %></div>
          <% } %>
          <% if (p.category) { %>
            <div class="prod-cat"><%= p.category.name %></div>
          <% } %>
          <div class="prod-name"><%= p.name %></div>
          <div class="prod-price">₹<%= p.price.toLocaleString('en-IN') %></div>
        </div>
      </a>
      <% }) %>
    </div>

    <% } else { %>
    <div class="empty-state reveal">
      <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
      <h3>No timepieces found</h3>
      <p>Try adjusting your filters or <a href="/products">clear all</a></p>
    </div>
    <% } %>

    <!-- Pagination -->
    <% if (totalPages > 1) { %>
    <div class="pagination reveal">
      <a href="?page=<%= page-1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= category %>&brand=<%= brand %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
         class="page-btn <%= page===1?'disabled':'' %>">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
      </a>
      <% for(let p=1; p<=totalPages; p++) { %>
        <a href="?page=<%= p %>&search=<%= search %>&sort=<%= sort %>&category=<%= category %>&brand=<%= brand %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
           class="page-btn <%= p===page?'active':'' %>"><%= p %></a>
      <% } %>
      <a href="?page=<%= page+1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= category %>&brand=<%= brand %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>"
         class="page-btn <%= page===totalPages?'disabled':'' %>">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <% } %>

  </div><!-- /products-area -->
</div><!-- /collection-wrap -->

<div class="rule"></div>

