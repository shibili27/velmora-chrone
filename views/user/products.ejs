<!-- ════ PAGE HERO ════ -->
<div class="page-hero">
  <div class="page-hero-scan"></div>
  <div class="page-hero-inner">
    <p class="page-hero-tag fade-up d1">Curated Selection</p>
    <h1 class="page-hero-title fade-up d2">The <em>Collection</em></h1>
    <div style="display:flex;align-items:center;justify-content:center;gap:0.75rem;margin-top:0.9rem;" class="fade-up d3">
      <div style="width:28px;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,0.4));flex-shrink:0;"></div>
      <span style="font-family:'Jost',sans-serif;font-size:0.42rem;letter-spacing:0.32em;text-transform:uppercase;color:rgba(201,169,110,0.38);">Swiss Made · Est. 1882</span>
      <div style="width:28px;height:1px;background:linear-gradient(270deg,transparent,rgba(201,169,110,0.4));flex-shrink:0;"></div>
    </div>
  </div>
</div>

<!-- ════ TOPBAR ════ -->
<div class="topbar-wrap">
  <form method="GET" action="/products" id="filterFormTop">
    <div class="topbar-inner">
      <div class="search-input-wrap">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="search-input" type="text" name="search" placeholder="Search timepieces…" value="<%= search %>" autocomplete="off"/>
      </div>
      <button type="button" class="mob-filter-btn" id="mobFilterBtn">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
        Filters
        <% if(category||brand||minPrice||maxPrice){ %><span class="mob-filter-active-dot"></span><% } %>
      </button>
      <select class="sort-select" onchange="applySort(this.value)">
        <option value="newest"    <%= sort==='newest'    ?'selected':'' %>>Newest</option>
        <option value="oldest"    <%= sort==='oldest'    ?'selected':'' %>>Oldest</option>
        <option value="priceLow"  <%= sort==='priceLow'  ?'selected':'' %>>Price ↑</option>
        <option value="priceHigh" <%= sort==='priceHigh' ?'selected':'' %>>Price ↓</option>
        <option value="nameAZ"    <%= sort==='nameAZ'    ?'selected':'' %>>A–Z</option>
        <option value="nameZA"    <%= sort==='nameZA'    ?'selected':'' %>>Z–A</option>
      </select>
    </div>
    <input type="hidden" name="sort" id="sortInput" value="<%= sort %>"/>
  </form>
</div>

<!-- ════ MAIN LAYOUT ════ -->
<div class="collection-wrap">

  <!-- Desktop sidebar -->
  <aside class="filters-sidebar reveal">
    <form method="GET" action="/products" id="filterFormSidebar">
      <button type="button" class="filter-toggle-btn" id="filterToggleDesktop">
        <span class="filter-toggle-label">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="11" y1="18" x2="13" y2="18"/></svg>
          Filters
          <span class="filter-dot <%= (category||brand||minPrice||maxPrice)?'show':'' %>"></span>
        </span>
        <svg class="filter-toggle-chevron" id="filterChevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      <div class="filter-content" id="filterContent">
        <div class="filter-block">
          <div class="filter-block-title">Category</div>
          <select class="vc-input" name="category">
            <option value="">All Categories</option>
            <% categories.forEach(c => { %>
              <option value="<%= c._id %>" <%= category===c._id.toString()?'selected':'' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <% if (brands && brands.length > 0) { %>
        <div class="filter-block">
          <div class="filter-block-title">Brand</div>
          <div class="brand-list">
            <label class="brand-item"><input type="radio" name="brand" value="" <%= !brand?'checked':'' %>/>All Brands</label>
            <% brands.forEach(b => { %>
              <label class="brand-item"><input type="radio" name="brand" value="<%= b %>" <%= brand===b?'checked':'' %>/><%= b %></label>
            <% }) %>
          </div>
        </div>
        <% } %>
        <div class="filter-block">
          <div class="filter-block-title">Price Range (₹)</div>
          <div class="price-row">
            <input class="vc-input" type="number" name="minPrice" placeholder="Min" value="<%= minPrice %>"/>
            <input class="vc-input" type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice %>"/>
          </div>
        </div>
        <input type="hidden" name="search" value="<%= search %>"/>
        <input type="hidden" name="sort" value="<%= sort %>"/>
        <button type="submit" class="btn-apply">Apply Filters</button>
        <a href="/products" class="btn-clear">Clear all</a>
      </div>
    </form>
  </aside>

  <!-- Products -->
  <div class="products-area">
    <div class="products-topbar reveal">
      <span class="products-count"><strong><%= total %></strong> timepiece<%= total!==1?'s':'' %> found</span>
    </div>

    <% const hasFilters = search || category || brand || minPrice || maxPrice; %>
    <% if (hasFilters) { %>
    <div class="active-filters reveal">
      <% if (search) { %><a href="/products?<%= new URLSearchParams({...(category&&{category}), ...(brand&&{brand}), ...(minPrice&&{minPrice}), ...(maxPrice&&{maxPrice}), sort}).toString() %>" class="filter-tag">"<%= search %>"<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></a><% } %>
      <% if (category) { %><% const catName = categories.find(c=>c._id.toString()===category); %><a href="/products?<%= new URLSearchParams({...(search&&{search}), ...(brand&&{brand}), ...(minPrice&&{minPrice}), ...(maxPrice&&{maxPrice}), sort}).toString() %>" class="filter-tag"><%= catName?catName.name:'Category' %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></a><% } %>
      <% if (brand) { %><a href="/products?<%= new URLSearchParams({...(search&&{search}), ...(category&&{category}), ...(minPrice&&{minPrice}), ...(maxPrice&&{maxPrice}), sort}).toString() %>" class="filter-tag"><%= brand %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></a><% } %>
      <% if (minPrice||maxPrice) { %><a href="/products?<%= new URLSearchParams({...(search&&{search}), ...(category&&{category}), ...(brand&&{brand}), sort}).toString() %>" class="filter-tag">₹<%= minPrice||'0' %> – ₹<%= maxPrice||'∞' %><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></a><% } %>
    </div>
    <% } %>

    <% if (products.length > 0) { %>
    <div class="product-grid reveal">
      <% products.forEach(p => {
         const isOos      = p.stock === 0;
         const isUnavail  = p.isDeleted || p.isListed === false;
         const showBadge  = isOos || isUnavail;
         const badgeText  = isUnavail ? 'Unavailable' : 'Out of Stock';
         const badgeClass = isUnavail ? 'oos-badge unavailable' : 'oos-badge';
         const cardClass  = showBadge ? 'prod-card is-oos' : 'prod-card';
         const hasOffer   = p.hasOffer && !isOos && !isUnavail;
         const saveAmount = hasOffer ? (p.price - p.effectivePrice) : 0;
      %>
      <a href="/products/<%= p._id %>" class="<%= cardClass %>" data-pid="<%= p._id %>">
        <div class="prod-img-wrap">
          <% if (p.images && p.images.length > 0) { %>
            <img class="prod-img" src="<%= p.images[0] %>" alt="<%= p.name %>" loading="lazy" onerror="this.style.opacity='0'"/>
          <% } else { %>
            <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#1a1a18;">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.06)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg>
            </div>
          <% } %>
          <% if (showBadge) { %><span class="<%= badgeClass %>"><%= badgeText %></span><% } %>
          <% if (hasOffer) { %><span class="offer-badge">−<%= p.discountPct %>%</span><% } %>
        </div>
        <div class="prod-body">
          <% if (p.brand && p.brand.name) { %><div class="prod-brand"><%= p.brand.name %></div><% } %>
          <% if (p.category) { %><div class="prod-cat"><%= p.category.name %></div><% } %>
          <div class="prod-name"><%= p.name %></div>

          <% if (hasOffer) { %>
          <div class="prod-price-wrap">
            <span class="prod-price-effective">₹<%= p.effectivePrice.toLocaleString('en-IN') %></span>
            <div class="prod-price-meta">
              <span class="prod-price-original">₹<%= p.price.toLocaleString('en-IN') %></span>
              <span class="prod-save-tag">Save ₹<%= saveAmount.toLocaleString('en-IN') %></span>
            </div>
          </div>
          <% } else { %>
          <div class="prod-price">₹<%= p.price.toLocaleString('en-IN') %></div>
          <% } %>

        </div>
      </a>
      <% }) %>
    </div>
    <% } else { %>
    <div class="empty-state reveal">
      <svg class="empty-state-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="0.8"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <h3>No timepieces found</h3>
      <p>Try adjusting your filters or <a href="/products">clear all</a></p>
    </div>
    <% } %>

    <% if (totalPages > 1) { %>
    <div class="pagination reveal">
      <a href="?page=<%= page-1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= category %>&brand=<%= brand %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" class="page-btn <%= page===1?'disabled':'' %>"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></a>
      <% for(let i=1;i<=totalPages;i++){ %><a href="?page=<%= i %>&search=<%= search %>&sort=<%= sort %>&category=<%= category %>&brand=<%= brand %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" class="page-btn <%= i===page?'active':'' %>"><%= i %></a><% } %>
      <a href="?page=<%= page+1 %>&search=<%= search %>&sort=<%= sort %>&category=<%= category %>&brand=<%= brand %>&minPrice=<%= minPrice %>&maxPrice=<%= maxPrice %>" class="page-btn <%= page===totalPages?'disabled':'' %>"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg></a>
    </div>
    <% } %>
  </div>
</div>

<!-- ════ MOBILE FILTER DRAWER ════ -->
<div class="filter-overlay" id="filterOverlay"></div>
<div class="filter-drawer" id="filterDrawer">
  <div class="filter-drawer-header">
    <span class="filter-drawer-title">Filters</span>
    <button class="drawer-close-btn" id="drawerClose"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
  </div>
  <form method="GET" action="/products">
    <div class="filter-block">
      <div class="filter-block-title">Category</div>
      <select class="vc-input" name="category">
        <option value="">All Categories</option>
        <% categories.forEach(c=>{ %><option value="<%= c._id %>" <%= category===c._id.toString()?'selected':'' %>><%= c.name %></option><% }) %>
      </select>
    </div>
    <% if (brands && brands.length > 0) { %>
    <div class="filter-block">
      <div class="filter-block-title">Brand</div>
      <div class="brand-list">
        <label class="brand-item"><input type="radio" name="brand" value="" <%= !brand?'checked':'' %>/>All Brands</label>
        <% brands.forEach(b=>{ %><label class="brand-item"><input type="radio" name="brand" value="<%= b %>" <%= brand===b?'checked':'' %>/><%= b %></label><% }) %>
      </div>
    </div>
    <% } %>
    <div class="filter-block">
      <div class="filter-block-title">Price Range (₹)</div>
      <div class="price-row">
        <input class="vc-input" type="number" name="minPrice" placeholder="Min" value="<%= minPrice %>"/>
        <input class="vc-input" type="number" name="maxPrice" placeholder="Max" value="<%= maxPrice %>"/>
      </div>
    </div>
    <input type="hidden" name="search" value="<%= search %>"/>
    <input type="hidden" name="sort" value="<%= sort %>"/>
    <button type="submit" class="btn-apply">Apply Filters</button>
    <a href="/products" class="btn-clear">Clear all</a>
  </form>
</div>

<div class="rule"></div>

<!-- ════ FOOTER ════ -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <p class="footer-logo">Velmora<br/>Chroné</p>
        <p class="footer-desc">Geneva-made timepieces for those who understand that true luxury is measured not in price, but in permanence.</p>
        <div class="footer-socials">
          <a href="#" class="footer-social-btn" aria-label="Instagram"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg></a>
          <a href="#" class="footer-social-btn" aria-label="Facebook"><svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg></a>
        </div>
      </div>
      <div>
        <span class="footer-col-title">Customer Service</span>
        <a href="#" class="footer-col-link">Our Story</a>
        <a href="#" class="footer-col-link">Shipping &amp; Returns</a>
        <a href="#" class="footer-col-link">Watch Care Guide</a>
        <a href="#" class="footer-col-link">Contact Us</a>
      </div>
      <div>
        <span class="footer-col-title">About Us</span>
        <a href="#" class="footer-col-link">Craftsmanship</a>
        <a href="#" class="footer-col-link">Sustainability</a>
        <a href="#" class="footer-col-link">Store Blog</a>
        <a href="#" class="footer-col-link">Warranty</a>
      </div>
      <div>
        <span class="footer-col-title">Newsletter</span>
        <p style="font-family:'Jost',sans-serif;font-size:.58rem;color:rgba(245,242,235,.2);line-height:1.8;margin-bottom:.7rem;font-weight:300">Subscribe for exclusive deals &amp; new arrivals.</p>
        <div style="display:flex;align-items:center;border-bottom:1px solid rgba(201,169,110,0.2);padding-bottom:.25rem">
          <input type="email" placeholder="Enter your email address" style="flex:1;background:transparent;border:none;outline:none;font-family:'Jost',sans-serif;font-size:.6rem;color:#f5f2eb;min-width:0"/>
          <button style="background:none;border:none;cursor:pointer;color:rgba(201,169,110,0.45);transition:color .2s" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='rgba(201,169,110,0.45)'"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></button>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">&copy; <%= new Date().getFullYear() %> Velmora Chroné. All rights reserved.</span>
      <div class="footer-legal"><a href="#">Privacy Policy</a><a href="#">Terms of Service</a><a href="#">Accessibility</a></div>
    </div>
  </div>
</footer>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive:true });

  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    const open = hamburger.classList.toggle('open');
    mobileMenu.style.display = 'flex';
    requestAnimationFrame(() => mobileMenu.classList.toggle('open', open));
  });
  mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    hamburger.classList.remove('open'); mobileMenu.classList.remove('open');
  }));

  const filterToggleDesktop = document.getElementById('filterToggleDesktop');
  const filterContent       = document.getElementById('filterContent');
  const filterChevron       = document.getElementById('filterChevron');
  let sidebarOpen = false;
  if (document.querySelectorAll('.filter-tag').length > 0) {
    sidebarOpen = true;
    filterContent.classList.add('open');
    filterToggleDesktop.classList.add('active');
    filterChevron.classList.add('open');
  }
  filterToggleDesktop.addEventListener('click', () => {
    sidebarOpen = !sidebarOpen;
    filterContent.classList.toggle('open', sidebarOpen);
    filterToggleDesktop.classList.toggle('active', sidebarOpen);
    filterChevron.classList.toggle('open', sidebarOpen);
  });

  const mobFilterBtn  = document.getElementById('mobFilterBtn');
  const filterOverlay = document.getElementById('filterOverlay');
  const filterDrawer  = document.getElementById('filterDrawer');
  const drawerClose   = document.getElementById('drawerClose');
  function openDrawer()  { filterOverlay.classList.add('open'); filterDrawer.classList.add('open'); document.body.style.overflow='hidden'; }
  function closeDrawer() { filterOverlay.classList.remove('open'); filterDrawer.classList.remove('open'); document.body.style.overflow=''; }
  mobFilterBtn.addEventListener('click', openDrawer);
  filterOverlay.addEventListener('click', closeDrawer);
  drawerClose.addEventListener('click', closeDrawer);

  const obs = new IntersectionObserver(entries => {
    entries.forEach((e,i) => { if (e.isIntersecting) { setTimeout(()=>e.target.classList.add('visible'), i*55); obs.unobserve(e.target); } });
  }, { threshold:0.05 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));

  function updateWishBadge(count) {
    ['wishBadgeDesktop','wishBadgeMobile'].forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = count > 99 ? '99+' : count;
      el.style.display = count > 0 ? 'flex' : 'none';
    });
  }
  function updateCartBadge(count) {
    ['cartCountDesktop','cartCountMobile'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = count > 99 ? '99+' : count;
    });
  }

  fetch('/api/cart/count', { headers:{ 'Accept':'application/json' } })
    .then(r => r.json()).then(d => { if (d.count !== undefined) updateCartBadge(d.count); }).catch(() => {});
  fetch('/api/wishlist/count', { headers:{ 'Accept':'application/json' } })
    .then(r => r.json()).then(d => updateWishBadge(d.count || 0)).catch(() => {});

  function applySort(val) {
    document.getElementById('sortInput').value = val;
    document.getElementById('filterFormTop').submit();
  }

  (function () {
    const es = new EventSource('/sse/products');
    es.addEventListener('productUpdate', function (e) {
      const data = JSON.parse(e.data);
      const card = document.querySelector(`.prod-card[data-pid="${data.productId}"]`);
      if (!card) return;
      const isUnavail = data.isDeleted || data.isListed === false;
      const isOos     = data.stock === 0;
      const showBadge = isOos || isUnavail;
      const existing  = card.querySelector('.oos-badge');
      if (existing) existing.remove();
      if (showBadge) {
        card.classList.add('is-oos');
        const imgWrap = card.querySelector('.prod-img-wrap');
        const badge   = document.createElement('span');
        badge.className   = isUnavail ? 'oos-badge unavailable' : 'oos-badge';
        badge.textContent = isUnavail ? 'Unavailable' : 'Out of Stock';
        imgWrap.appendChild(badge);
      } else {
        card.classList.remove('is-oos');
      }
    });
    es.onerror = () => {};
  })();

  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
</script>
</body>
</html>
