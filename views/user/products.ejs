<script>
  /* ── NAV SCROLL ── */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive: true });

  /* ── HAMBURGER ── */
  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });
  mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    hamburger.classList.remove('open');
    mobileMenu.classList.remove('open');
  }));

  /* ── REVEAL ON SCROLL ── */
  const revealEls = document.querySelectorAll('.reveal');
  const observer  = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 60);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.06 });
  revealEls.forEach(el => observer.observe(el));

  /* ── CART COUNT ── */
  fetch('/api/cart/count', { headers: { 'Accept': 'application/json' } })
    .then(r => r.json())
    .then(d => { if (d.count !== undefined) document.getElementById('cartCount').textContent = d.count; })
    .catch(() => {});

  /* ── SORT ── */
  function applySort(val) {
    document.getElementById('sortInput').value = val;
    document.getElementById('filterForm').submit();
  }

  /* ── SSE: live stock/availability updates ── */
  (function () {
    const es = new EventSource('/sse/products');
    es.addEventListener('productUpdate', function (e) {
      const data = JSON.parse(e.data);
      if (data.stock !== 0 && !data.isDeleted && data.isListed !== false) return;
      const card = document.querySelector(`.prod-card[href="/products/${data.productId}"]`);
      if (!card) return;
      const imgWrap = card.querySelector('.prod-img-wrap');
      if (!imgWrap || imgWrap.querySelector('.oos-label')) return;
      imgWrap.style.position = 'relative';
      const label = document.createElement('div');
      label.className = 'oos-label';
      label.style.cssText = 'position:absolute;inset:0;background:rgba(17,17,16,.65);display:flex;align-items:center;justify-content:center;font-family:Jost,sans-serif;font-size:.46rem;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,242,235,.5);pointer-events:none;z-index:3;';
      label.textContent = data.isDeleted || data.isListed === false ? 'Unavailable' : 'Out of Stock';
      imgWrap.appendChild(label);
    });
    es.onerror = function () {};
  })();

  /* ── BACK BUTTON LOCK ── */
  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
</script>
</body>
