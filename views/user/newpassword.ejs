<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password | Velmora Chroné</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      background: #111110;
      color: #f5f2eb;
      min-height: 100vh;
      overflow-x: hidden;
      display: flex;
      flex-direction: column;
    }
    main { flex: 1 0 auto; width: 100%; }
    footer { flex-shrink: 0; }

    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: .016;
    }

    .brand-mark {
      font-family: 'Cormorant Garamond', Garamond, Georgia, 'Times New Roman', serif; font-size: 0.85rem; font-weight: 300;
      letter-spacing: 0.25em; text-transform: uppercase; color: #f5f2eb; text-decoration: none;
    }

    .access-badge {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 0.4rem 0.95rem; border-radius: 100px;
      border: 1px solid rgba(201,169,110,0.22); background: rgba(201,169,110,0.05);
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif;
      font-size: 0.44rem; letter-spacing: 0.32em; text-transform: uppercase; color: #c9a96e;
    }
    .access-badge svg { width: 9px; height: 9px; flex-shrink: 0; }

    .welcome-glow { position: relative; }
    .welcome-glow::before {
      content: ''; position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%);
      width: 260px; height: 90px; border-radius: 50%;
      background: radial-gradient(ellipse, rgba(201,169,110,0.13), transparent 72%);
      pointer-events: none; z-index: -1;
    }

    .crest-wrap { display: flex; justify-content: center; margin-bottom: 1.1rem; }
    .crest {
      position: relative; width: 54px; height: 54px;
      display: flex; align-items: center; justify-content: center;
    }
    .crest-ring {
      position: absolute; inset: 0; border-radius: 50%;
      border: 1px solid rgba(201,169,110,0.28);
    }
    .crest-ring-dashed {
      position: absolute; inset: -7px; border-radius: 50%;
      border: 1px dashed rgba(201,169,110,0.16);
      animation: crestSpin 26s linear infinite;
    }
    @keyframes crestSpin { to { transform: rotate(360deg); } }
    .crest-hand {
      position: absolute; left: 50%; bottom: 50%; width: 1px; height: 14px;
      background: linear-gradient(180deg, #c9a96e, transparent);
      transform-origin: bottom center; transform: rotate(0deg);
      animation: crestTick 8s linear infinite;
    }
    @keyframes crestTick { 100% { transform: rotate(360deg); } }
    .crest-monogram {
      font-family: 'Cormorant Garamond', Garamond, Georgia, 'Times New Roman', serif;
      font-style: italic; font-weight: 400; font-size: 1.1rem; letter-spacing: 0.02em;
      background: linear-gradient(135deg, #e8d49a 0%, #c9a96e 55%, #a8873d 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }

    .field-label {
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 0.6rem; font-weight: 500;
      letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.35); margin-bottom: 0.55rem;
      display: block;
    }

    .input-group { position: relative; margin-bottom: 1.8rem; }

    .input-group input {
      background: transparent; border: none; border-bottom: 1px solid rgba(245,242,235,0.16);
      border-radius: 0; outline: none; color: #f5f2eb;
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 300; font-size: 0.82rem;
      width: 100%; padding: 0.4rem 0; transition: border-color 0.3s;
    }
    .input-group input::placeholder { color: rgba(245,242,235,0.22); }
    .input-group input:focus        { border-bottom-color: #c9a96e; }
    .input-group input.input-error  { border-bottom-color: #f87171; }

    /* ══ Show-passwords checkbox — single luxury toggle for both fields ══ */
    .checkbox-vault { display: flex; align-items: center; gap: 10px; cursor: pointer; margin-bottom: 2rem; }
    .checkbox-vault input[type="checkbox"] {
      appearance: none; -webkit-appearance: none; flex-shrink: 0;
      width: 15px; height: 15px; border-radius: 3px; border: 1px solid rgba(245,242,235,0.25);
      background: rgba(255,255,255,0.02); cursor: pointer; position: relative; transition: border-color 0.2s, background 0.2s;
    }
    .checkbox-vault input[type="checkbox"]:checked {
      background: linear-gradient(135deg, #e0c47e 0%, #c9a96e 100%); border-color: #c9a96e;
    }
    .checkbox-vault input[type="checkbox"]:checked::after {
      content: ''; position: absolute; left: 4px; top: 1px; width: 4px; height: 8px;
      border: solid #0d0b08; border-width: 0 1.5px 1.5px 0; transform: rotate(45deg);
    }
    .checkbox-vault span {
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 0.6rem; font-weight: 500;
      letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.4);
    }

    .error-msg {
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 0.57rem; letter-spacing: 0.08em;
      color: #f87171; margin-top: 6px; display: none;
    }

    /* ══ Gold vault button — matches signup/otp/forgot-password treatment ══ */
    .save-btn {
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 0.62rem; letter-spacing: 0.24em; text-transform: uppercase; color: #0d0b08 !important;
      display: flex; align-items: center; justify-content: center; gap: 0.6rem; padding: 0.95rem 2rem; border-radius: 100px;
      position: relative; overflow: hidden; width: 100%; cursor: pointer; border: none;
      background: linear-gradient(135deg, #e0c47e 0%, #c9a96e 50%, #b8913d 100%) !important;
      transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s !important;
      box-shadow: 0 1px 0 rgba(255,255,255,0.35) inset, 0 4px 18px rgba(185,140,55,0.3), 0 1px 4px rgba(0,0,0,0.4);
    }
    .save-btn::after { content: ''; position: absolute; top: 0; left: -75%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent); transform: skewX(-18deg); transition: left 0.55s ease; }
    .save-btn:hover::after { left: 130%; }
    .save-btn:hover { background: linear-gradient(135deg, #e0c47e 0%, #c9a96e 50%, #b8913d 100%) !important; color: #0d0b08 !important; transform: translateY(-2px) scale(1.02); box-shadow: 0 1px 0 rgba(255,255,255,0.4) inset, 0 8px 28px rgba(185,140,55,0.4), 0 2px 8px rgba(0,0,0,0.45); }
    .save-btn:active { transform: translateY(1px) scale(0.99); }
    .save-btn:disabled { cursor: not-allowed; opacity: 0.7; transform: none !important; }
    .save-btn:disabled::after { display: none; }

    .back-link {
      display: block; text-align: center; margin-top: 1.8rem;
      font-family: 'Jost', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 0.62rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: rgba(245,242,235,0.4); text-decoration: none; transition: color 0.2s;
    }
    .back-link:hover { color: #c9a96e; }

    .tagline {
      text-align: center; margin-top: 1.6rem;
      font-family: 'Cormorant Garamond', Garamond, Georgia, 'Times New Roman', serif;
      font-style: italic; font-weight: 300; font-size: 0.85rem;
      color: rgba(245,242,235,0.28); line-height: 1.5;
    }

    .footer-link { color: rgba(245,242,235,0.28); transition: color 0.2s; text-decoration: none; }
    .footer-link:hover { color: #c9a96e; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp 0.8s ease both; }
    .delay-1 { animation-delay: 0.10s; }
    .delay-2 { animation-delay: 0.22s; }
    .delay-3 { animation-delay: 0.34s; }
    .delay-4 { animation-delay: 0.46s; }
    .delay-5 { animation-delay: 0.58s; }
  </style>
</head>

<body>

  <main class="reset-container flex flex-1 items-center justify-center p-4 md:p-8" style="position:relative;z-index:1;">
    <div class="reset-card w-full max-w-md fade-up px-6 py-10 md:px-12 md:py-12" style="background:#161614; border-radius:18px; border:1px solid rgba(245,242,235,0.07); box-shadow:0 24px 60px rgba(0,0,0,0.45);">

      <div class="text-center mb-9">
        <div class="crest-wrap">
          <div class="crest">
            <div class="crest-ring-dashed"></div>
            <div class="crest-ring"></div>
            <div class="crest-hand"></div>
            <span class="crest-monogram">VC</span>
          </div>
        </div>
        <a href="/home" class="brand-mark">Velmora Chroné</a>
        <div class="mt-4">
          <span class="access-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            Legacy &amp; Restoration
          </span>
        </div>
      </div>

      <h2 class="text-center fade-up delay-1 welcome-glow" style="font-family:'Cormorant Garamond',Garamond,Georgia,'Times New Roman',serif; font-weight:300; font-size:2rem; line-height:1.1; color:#f5f2eb; margin-bottom:0.6rem;">
        Reset Your <em style="font-style:italic; background:linear-gradient(125deg,#e8d49a 0%,#c9a96e 45%,#a8873d 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Password</em>
      </h2>
      <p class="instruction text-center mb-9 fade-up delay-2" style="font-family:'Jost','Helvetica Neue',Helvetica,Arial,sans-serif; font-weight:300; font-size:0.68rem; letter-spacing:0.02em; color:rgba(245,242,235,0.3);">
        Create a new, secure password for your account.
      </p>

      <form id="resetForm" action="/reset-password" method="POST" class="fade-up delay-3">

        <!-- NEW PASSWORD -->
        <div class="input-group">
          <label class="field-label">New Password</label>
          <input type="password" id="new-password" name="password" placeholder="············">
          <p class="error-msg" id="passError"></p>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="input-group">
          <label class="field-label">Confirm New Password</label>
          <input type="password" id="confirm-password" name="confirmPassword" placeholder="············">
          <p class="error-msg" id="confirmError"></p>
        </div>

        <label class="checkbox-vault">
          <input type="checkbox" id="show-passwords" onchange="toggleAllPasswords(this)">
          <span>Show Passwords</span>
        </label>

        <div class="pt-2 fade-up delay-4">
          <button type="submit" class="save-btn">Save New Password</button>
        </div>

      </form>

      <a href="/login" class="back-link fade-up delay-5">← Back to Login</a>
      <p class="tagline fade-up delay-5">Authenticating the timeless excellence of your horological pursuit.</p>

    </div>
  </main>

  <!-- FOOTER -->
  <footer class="footer w-full px-8 py-4 flex items-center justify-between" style="position:relative;z-index:1;">
    <div class="footer-left" style="font-family:'Jost','Helvetica Neue',Helvetica,Arial,sans-serif; font-size:0.46rem; letter-spacing:0.15em; text-transform:uppercase; color:rgba(245,242,235,0.15);">
      &copy; <%= new Date().getFullYear() %> Velmora Chroné. All Rights Reserved.
    </div>
    <div class="footer-right flex gap-6">
      <a href="#" class="footer-link" style="font-size:0.46rem; letter-spacing:0.1em; text-transform:uppercase;">Legal</a>
      <a href="#" class="footer-link" style="font-size:0.46rem; letter-spacing:0.1em; text-transform:uppercase;">Privacy</a>
    </div>
  </footer>

  <script>
    const form            = document.getElementById("resetForm");
    const password        = document.getElementById("new-password");
    const confirmPassword = document.getElementById("confirm-password");
    const passError       = document.getElementById("passError");
    const confirmError    = document.getElementById("confirmError");

    const strongPassword = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&]).{8,}$/;

    function toggleAllPasswords(checkbox) {
      const type = checkbox.checked ? "text" : "password";
      password.type = type;
      confirmPassword.type = type;
    }

    password.addEventListener("input", () => {
      password.classList.remove("input-error");
      passError.style.display = "none";
      if (!strongPassword.test(password.value)) {
        passError.style.display = "block";
        passError.textContent = "Min 8 chars, include A-Z, a-z, number & symbol.";
      }
    });

    confirmPassword.addEventListener("input", () => {
      confirmPassword.classList.remove("input-error");
      confirmError.style.display = "none";
      if (confirmPassword.value !== password.value) {
        confirmError.style.display = "block";
        confirmError.textContent = "Passwords do not match.";
      }
    });

    form.addEventListener("submit", function(e) {
      let valid = true;

      if (!strongPassword.test(password.value)) {
        passError.style.display = "block";
        passError.textContent = "Enter a strong password.";
        password.classList.add("input-error");
        valid = false;
      }

      if (confirmPassword.value !== password.value || confirmPassword.value === "") {
        confirmError.style.display = "block";
        confirmError.textContent = "Passwords do not match.";
        confirmPassword.classList.add("input-error");
        valid = false;
      }

      if (!valid) e.preventDefault();
    });
  </script>

</body>
</html>