<script>
document.getElementById('year').textContent = new Date().getFullYear();

const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive: true });

const hamburger  = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', () => { hamburger.classList.toggle('open'); mobileMenu.classList.toggle('open'); });
mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { hamburger.classList.remove('open'); mobileMenu.classList.remove('open'); }));

const revealEls = document.querySelectorAll('.reveal');
const observer  = new IntersectionObserver(entries => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) { setTimeout(() => entry.target.classList.add('visible'), i * 80); observer.unobserve(entry.target); }
  });
}, { threshold: 0.08 });
revealEls.forEach(el => observer.observe(el));

// FAQ accordion
document.querySelectorAll('.faq-item').forEach(item => {
  item.querySelector('.faq-q').addEventListener('click', () => {
    const wasOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
    if (!wasOpen) item.classList.add('open');
  });
});

/* ══════════════════════ CONTACT FORM VALIDATION ══════════════════════ */
const contactForm  = document.getElementById('contactForm');
const submitBtn     = document.getElementById('submitBtn');
const submitLabel   = document.getElementById('submitLabel');
const formStatus    = document.getElementById('formStatus');

// Letters + spaces + common name characters (accents, hyphen, apostrophe). No digits/symbols.
const NAME_REGEX    = /^[A-Za-zÀ-ÖØ-öø-ÿ]+(?:[\s'-][A-Za-zÀ-ÖØ-öø-ÿ]+)*$/;
const EMAIL_REGEX   = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

const validators = {
  fullName: (val) => {
    const v = val.trim();
    if (!v) return 'Please enter your full name.';
    if (!NAME_REGEX.test(v)) return 'Name can only contain letters and spaces.';
    if (v.length < 2) return 'Name must be at least 2 characters.';
    return null;
  },
  email: (val) => {
    const v = val.trim();
    if (!v) return 'Please enter your email address.';
    if (!EMAIL_REGEX.test(v)) return 'Please enter a valid email address.';
    return null;
  },
  subject: (val) => {
    if (!val) return 'Please select a subject.';
    return null;
  },
  message: (val) => {
    const v = val.trim();
    if (!v) return 'Please enter a message.';
    if (v.length < 10) return 'Message must be at least 10 characters.';
    return null;
  }
};

const fieldMap = {
  fullName: document.getElementById('fullNameField'),
  email:    document.getElementById('emailField'),
  subject:  document.getElementById('subjectField'),
  message:  document.getElementById('messageField'),
};

function showError(name, message) {
  const fieldEl = fieldMap[name];
  fieldEl.classList.add('error');
  fieldEl.classList.remove('valid');
  const msgEl = fieldEl.querySelector('.field-error-msg span:last-child');
  if (msgEl && message) msgEl.textContent = message;

  // trigger shake (retriggerable)
  fieldEl.classList.remove('shake');
  void fieldEl.offsetWidth; // force reflow so animation restarts
  fieldEl.classList.add('shake');
  fieldEl.addEventListener('animationend', () => fieldEl.classList.remove('shake'), { once: true });
}

function clearError(name) {
  const fieldEl = fieldMap[name];
  fieldEl.classList.remove('error');
  fieldEl.classList.add('valid');
}

function validateField(name, value) {
  const error = validators[name](value);
  if (error) {
    showError(name, error);
    return false;
  }
  clearError(name);
  return true;
}

// Live validation as the user types / selects
document.getElementById('fullName').addEventListener('input', (e) => {
  // Block digits/symbols from ever registering as valid typing feedback in real time
  validateField('fullName', e.target.value);
});
document.getElementById('email').addEventListener('input', (e) => validateField('email', e.target.value));
document.getElementById('subject').addEventListener('change', (e) => validateField('subject', e.target.value));
document.getElementById('message').addEventListener('input', (e) => validateField('message', e.target.value));

// Re-validate on blur too, so leaving a field empty still shows the error
['fullName', 'email', 'subject', 'message'].forEach((name) => {
  const el = document.getElementById(name);
  el.addEventListener('blur', () => validateField(name, el.value));
});

function validateAll() {
  const values = {
    fullName: document.getElementById('fullName').value,
    email: document.getElementById('email').value,
    subject: document.getElementById('subject').value,
    message: document.getElementById('message').value,
  };
  let firstInvalid = null;
  let allValid = true;

  Object.keys(validators).forEach((name) => {
    const ok = validateField(name, values[name]);
    if (!ok) {
      allValid = false;
      if (!firstInvalid) firstInvalid = name;
    }
  });

  if (firstInvalid) {
    fieldMap[firstInvalid].scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  return { allValid, values };
}

contactForm.addEventListener('submit', async (e) => {
  e.preventDefault();
  formStatus.className = 'form-status';
  formStatus.textContent = '';

  const { allValid, values } = validateAll();
  if (!allValid) return;

  submitBtn.disabled = true;
  submitLabel.textContent = 'Sending...';

  try {
    const res = await fetch('/api/contact', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(values)
    });
    const data = await res.json().catch(() => ({}));

    if (res.ok) {
      formStatus.textContent = "Thank you — your message has been sent. We'll be in touch within one business day.";
      formStatus.classList.add('success');
      contactForm.reset();
      Object.keys(fieldMap).forEach((name) => fieldMap[name].classList.remove('valid', 'error'));
    } else {
      formStatus.textContent = data.message || 'Something went wrong. Please try again.';
      formStatus.classList.add('error');
    }
  } catch (err) {
    formStatus.textContent = 'Unable to send message right now. Please try again shortly.';
    formStatus.classList.add('error');
  } finally {
    submitBtn.disabled = false;
    submitLabel.textContent = 'Send Message';
  }
});

fetch('/api/cart/count', { headers: { 'Accept': 'application/json' } })
  .then(r => r.json())
  .then(d => { if (d.count !== undefined) document.getElementById('cartBadge').textContent = d.count; })
  .catch(() => {});
</script>
