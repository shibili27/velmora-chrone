    <a href="/products" class="nav-link">Collection</a>
    <a href="/cart"     class="nav-link">Cart</a>
    <a href="/profile"  class="nav-link">My Profile</a>
    <a href="/logout"   class="nav-link" style="color:rgba(201,169,110,.55)">Logout</a>
  </div>
</nav>

<!-- ══ PAGE HERO — STEP TRAIL ══ -->
<div class="page-hero">
  <div class="page-hero-scan"></div>
  <div class="page-hero-inner">

    <!-- eyebrow -->
    <p class="page-hero-tag fade-up d1">Secure Checkout</p>

    <!-- ── STEP TRAIL ── -->
    <div class="hero-steps fade-up d2">

      <!-- Step 1: Cart (done) -->
      <div class="hero-step done">
        <div class="hero-step-circle">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </div>
        <span class="hero-step-label">Cart</span>
      </div>

      <!-- Connector -->
      <div class="hero-step-line done"></div>

      <!-- Step 2: Checkout (active) -->
      <div class="hero-step active">
        <div class="hero-step-circle">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
        </div>
        <span class="hero-step-label">Checkout</span>
      </div>

      <!-- Connector -->
      <div class="hero-step-line"></div>

      <!-- Step 3: Confirm Order (pending) -->
      <div class="hero-step">
        <div class="hero-step-circle">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <span class="hero-step-label">Confirm Order</span>
      </div>

    </div><!-- /hero-steps -->

    <!-- security line -->
    <div class="hero-secure-line fade-up d3">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      Cash on Delivery · 256-bit SSL Encrypted
    </div>

  </div>
</div>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="/home"     class="bc-item">Home</a>
  <span class="bc-sep">·</span>
  <a href="/products" class="bc-item">Collection</a>
  <span class="bc-sep">·</span>
  <a href="/cart"     class="bc-item">Cart</a>
  <span class="bc-sep">·</span>
  <span class="bc-current">Checkout</span>
</div>

<!-- ══ MAIN LAYOUT ══ -->
<div class="checkout-wrap">

  <!-- ══ LEFT COLUMN ══ -->
  <div>

    <!-- DELIVERY ADDRESS -->
    <div class="section-block reveal">
      <div class="section-label">Delivery Address</div>

      <% if (addresses && addresses.length > 0) { %>
        <div class="addr-grid" id="addrGrid">
          <% addresses.forEach((addr, idx) => { %>
          <div class="addr-card <%= addr.isDefault || idx === 0 ? 'selected' : '' %>"
               onclick="selectAddr(this, '<%= addr._id %>')"
               data-addr-id="<%= addr._id %>">
            <div class="addr-radio"><div class="addr-radio-dot"></div></div>
            <div class="addr-info">
              <div class="addr-name">
                <%= addr.fullName || addr.name || user.name %>
                <% if (addr.isDefault) { %><span class="addr-badge">Default</span><% } %>
              </div>
              <div class="addr-text">
                <%= addr.line1 || addr.addressLine || '' %><% if (addr.line2) { %>, <%= addr.line2 %><% } %><br/>
                <%= addr.city %><% if (addr.state) { %>, <%= addr.state %><% } %> — <%= addr.pincode || addr.pin || '' %><br/>
                <%= addr.phone || user.phone || '' %>
              </div>
              <div class="addr-actions">
                <button class="addr-btn"
                  onclick="openEditModal(event,
                    '<%= addr._id %>',
                    `<%= (addr.fullName || addr.name || '').replace(/`/g, '') %>`,
                    `<%= (addr.line1 || addr.addressLine || '').replace(/`/g, '') %>`,
                    `<%= (addr.city || '').replace(/`/g, '') %>`,
                    '<%= addr.state || '' %>',
                    '<%= addr.pincode || addr.pin || '' %>',
                    '<%= addr.phone || '' %>'
                  )">Edit</button>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="no-addr">
          <p>No saved addresses. Add one to continue.</p>
        </div>
      <% } %>

      <button class="btn-add-addr" onclick="openAddModal()">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Add New Address
      </button>
    </div>

    <!-- ORDER ITEMS -->
    <div class="section-block reveal">
      <div class="section-label">Your Timepieces</div>
      <div class="item-list">
        <% items.forEach(item => { %>
        <div class="item-card">
          <% if (item.image) { %>
            <img class="item-img" src="<%= item.image %>" alt="<%= item.name %>" onerror="this.style.display='none'"/>
          <% } else { %>
            <div class="item-img-placeholder">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.07)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg>
            </div>
          <% } %>
          <div>
            <% if (item.brand) { %><div class="item-brand"><%= item.brand %></div><% } %>
            <div class="item-name"><%= item.name %></div>
            <div class="item-qty-row">
              <span class="item-qty-label">Qty</span>
              <span class="item-qty-val"><%= item.quantity %></span>
            </div>
          </div>
          <div class="item-pricing">
            <% if (item.discountPercent > 0) { %>
              <div class="item-mrp">₹<%= item.mrp.toLocaleString('en-IN') %></div>
              <div class="item-disc-badge">−<%= item.discountPercent %>%</div>
            <% } %>
            <div class="item-subtotal">₹<%= item.itemTotal.toLocaleString('en-IN') %></div>
            <div class="item-tax-note">+ ₹<%= item.taxAmount.toLocaleString('en-IN') %> GST</div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- PAYMENT METHOD -->
    <div class="section-block reveal">
      <div class="section-label">Payment Method</div>
      <div class="payment-box">
        <div class="payment-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="5" width="20" height="14" rx="2"/>
            <path d="M2 10h20M6 15h4"/>
          </svg>
        </div>
        <div>
          <div class="payment-title">Cash on Delivery</div>
          <div class="payment-desc">Pay in cash when your timepiece arrives at your door. No advance payment needed — our courier will collect upon delivery. Signature required.</div>
        </div>
      </div>
    </div>

  </div><!-- /left col -->

  <!-- ══ RIGHT COLUMN: SUMMARY ══ -->
  <div>
    <div class="summary-card reveal">
      <div class="summary-title">Order Summary</div>

      <div class="summary-row">
        <span class="summary-key">Subtotal (<%= items.length %> item<%= items.length !== 1 ? 's' : '' %>)</span>
        <span class="summary-val">₹<%= pricing.subtotal.toLocaleString('en-IN') %></span>
      </div>

      <% if (pricing.itemDiscount > 0) { %>
      <div class="summary-row">
        <span class="summary-key">Item Discount</span>
        <span class="summary-val green">− ₹<%= pricing.itemDiscount.toLocaleString('en-IN') %></span>
      </div>
      <% } %>

      <% if (pricing.couponDiscount > 0) { %>
      <div class="summary-row">
        <span class="summary-key">Coupon (<%= couponCode %>)</span>
        <span class="summary-val green">− ₹<%= pricing.couponDiscount.toLocaleString('en-IN') %></span>
      </div>
      <% } %>

      <div class="summary-row">
        <span class="summary-key">GST (<%= pricing.taxRate %>%)</span>
        <span class="summary-val">₹<%= pricing.tax.toLocaleString('en-IN') %></span>
      </div>

      <div class="summary-row">
        <span class="summary-key">Shipping</span>
        <% if (pricing.isFreeShipping) { %>
          <span class="summary-val gold">Complimentary</span>
        <% } else { %>
          <span class="summary-val">₹<%= pricing.shipping %></span>
        <% } %>
      </div>

      <!-- Coupon field -->
      <div class="coupon-row">
        <input class="coupon-input" type="text" id="couponInput" placeholder="Promo / coupon code"/>
        <button class="coupon-apply-btn" onclick="applyCoupon()">Apply</button>
      </div>
      <div class="coupon-msg" id="couponMsg"></div>

      <div class="summary-divider"></div>

      <div class="summary-total-row">
        <span class="summary-total-key">Total Payable</span>
        <span class="summary-total-val">₹<%= pricing.grandTotal.toLocaleString('en-IN') %></span>
      </div>
      <div class="tax-note">Inclusive of all taxes &amp; duties</div>

      <input type="hidden" id="selectedAddressId"
        value="<%= addresses && addresses.length > 0 ? (addresses.find(a => a.isDefault) || addresses[0])._id : '' %>"/>

      <button class="btn-place" id="placeOrderBtn"
        <%= (!addresses || addresses.length === 0) ? 'disabled' : '' %>
        onclick="placeOrder()">
        Place Order · COD
      </button>

      <a href="/cart" class="btn-continue">← Back to Cart</a>

      <div class="secure-note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Secured by 256-bit SSL Encryption
      </div>
    </div>
  </div>

</div><!-- /checkout-wrap -->

<div class="rule"></div>

<!-- ══ FOOTER ══ -->
<footer class="footer">
  <div style="max-width:1200px;margin:0 auto">
    <div class="footer-top">
      <div>
        <p class="footer-logo">Velmora<br/>Chroné</p>
        <p class="footer-desc">Geneva-made timepieces for those who understand that true luxury is measured not in price, but in permanence.</p>
        <div class="footer-socials">
          <a href="#" class="footer-social-btn" aria-label="Instagram">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
          </a>
          <a href="#" class="footer-social-btn" aria-label="Facebook">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>
      <div>
        <span class="footer-col-title">Customer Service</span>
        <a href="#" class="footer-col-link">Shipping &amp; Returns</a>
        <a href="#" class="footer-col-link">Watch Care Guide</a>
        <a href="#" class="footer-col-link">Warranty Registration</a>
        <a href="#" class="footer-col-link">Track Order</a>
      </div>
      <div>
        <span class="footer-col-title">About Us</span>
        <a href="#" class="footer-col-link">Our Story</a>
        <a href="#" class="footer-col-link">Craftsmanship</a>
        <a href="#" class="footer-col-link">Sustainability</a>
        <a href="#" class="footer-col-link">Retail Partners</a>
      </div>
      <div>
        <span class="footer-col-title">Newsletter</span>
        <p style="font-family:'Jost',sans-serif;font-size:.6rem;color:rgba(245,242,235,.2);line-height:1.75;margin-bottom:.75rem;font-weight:300">Subscribe for exclusive deals &amp; new arrivals.</p>
        <div style="display:flex;align-items:center;border-bottom:1px solid rgba(201,169,110,.2);padding-bottom:.3rem">
          <input type="email" placeholder="Enter your email address" style="flex:1;background:transparent;border:none;outline:none;font-family:'Jost',sans-serif;font-size:.63rem;color:#f5f2eb;min-width:0"/>
          <button style="background:none;border:none;cursor:pointer;color:rgba(201,169,110,.45);transition:color .2s" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='rgba(201,169,110,0.45)'">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">&copy; <%= new Date().getFullYear() %> Velmora Chroné. All rights reserved.</span>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Accessibility</a>
      </div>
    </div>
  </div>
</footer>

<!-- ══ ADDRESS MODAL ══ -->
<div class="modal-overlay" id="addrModal" onclick="if(event.target===this)closeModal()">
  <div class="modal-box">
    <div class="modal-title-row">
      <span class="modal-title" id="modalTitleText">Add New Address</span>
      <button class="modal-close" onclick="closeModal()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <input type="hidden" id="editAddressId"/>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Full Name *</label>
        <input class="vc-input" id="mName" type="text" placeholder="Your full name"/>
      </div>
      <div class="form-group">
        <label class="form-label">Phone *</label>
        <input class="vc-input" id="mPhone" type="tel" placeholder="+91 98xxx xxxxx" maxlength="10"/>
      </div>
    </div>
    <div class="form-row full">
      <div class="form-group">
        <label class="form-label">Address Line *</label>
        <input class="vc-input" id="mLine1" type="text" placeholder="House / Flat, Street, Area"/>
      </div>
    </div>
    <div class="form-row full">
      <div class="form-group">
        <label class="form-label">Address Line 2</label>
        <input class="vc-input" id="mLine2" type="text" placeholder="Landmark (optional)"/>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">City *</label>
        <input class="vc-input" id="mCity" type="text" placeholder="City"/>
      </div>
      <div class="form-group">
        <label class="form-label">State *</label>
        <select class="vc-input" id="mState">
          <option value="">Select State</option>
          <option>Andhra Pradesh</option><option>Arunachal Pradesh</option>
          <option>Assam</option><option>Bihar</option><option>Chhattisgarh</option>
          <option>Delhi</option><option>Goa</option><option>Gujarat</option>
          <option>Haryana</option><option>Himachal Pradesh</option>
          <option>Jharkhand</option><option>Karnataka</option><option>Kerala</option>
          <option>Madhya Pradesh</option><option>Maharashtra</option>
          <option>Manipur</option><option>Meghalaya</option><option>Mizoram</option>
          <option>Nagaland</option><option>Odisha</option><option>Punjab</option>
          <option>Rajasthan</option><option>Sikkim</option><option>Tamil Nadu</option>
          <option>Telangana</option><option>Tripura</option><option>Uttar Pradesh</option>
          <option>Uttarakhand</option><option>West Bengal</option>
        </select>
      </div>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">PIN Code *</label>
        <input class="vc-input" id="mPin" type="text" placeholder="6-digit PIN" maxlength="6"/>
      </div>
      <div class="form-group">
        <label class="form-label">Address Type</label>
        <select class="vc-input" id="mType">
          <option value="Home">Home</option>
          <option value="Office">Office</option>
          <option value="Other">Other</option>
        </select>
      </div>
    </div>

    <div id="modalError" style="font-family:'Jost',sans-serif;font-size:.5rem;color:rgba(248,113,113,.8);margin-top:.75rem;display:none"></div>

    <div style="display:flex;gap:.75rem;margin-top:1.25rem">
      <button class="btn-place" style="flex:1;margin-top:0" id="modalSaveBtn" onclick="saveAddress()">Save Address</button>
      <button onclick="closeModal()" style="background:none;border:1px solid rgba(245,242,235,.1);border-radius:100px;color:rgba(245,242,235,.3);font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.16em;text-transform:uppercase;cursor:pointer;padding:0 1.25rem;transition:all .2s;flex-shrink:0">Cancel</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
  /* ── NAV ── */
  const navbar     = document.getElementById('navbar');
  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');

  window.addEventListener('scroll', () => {
    navbar.classList.toggle('scrolled', window.scrollY > 30);
  }, { passive: true });

  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });

  /* ── REVEAL ON SCROLL ── */
  const revealEls = document.querySelectorAll('.reveal');
  const observer  = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 80);
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.06 });
  revealEls.forEach(el => observer.observe(el));

  /* ── TOAST ── */
  let toastTimer;
  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast show' + (type ? ' ' + type : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3500);
  }

  /* ── ADDRESS SELECTION ── */
  function selectAddr(card, addrId) {
    document.querySelectorAll('.addr-card').forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');
    document.getElementById('selectedAddressId').value = addrId;
  }

  /* ── MODAL ── */
  let modalMode = 'add';

  function openAddModal() {
    modalMode = 'add';
    document.getElementById('modalTitleText').textContent = 'Add New Address';
    document.getElementById('editAddressId').value = '';
    ['mName','mPhone','mLine1','mLine2','mCity','mPin'].forEach(id => {
      document.getElementById(id).value = '';
      document.getElementById(id).classList.remove('error');
    });
    document.getElementById('mState').value = '';
    document.getElementById('mType').value  = 'Home';
    document.getElementById('modalError').style.display = 'none';
    document.getElementById('addrModal').classList.add('open');
  }

  function openEditModal(e, addrId, name, line1, city, state, pin, phone) {
    e.stopPropagation();
    modalMode = 'edit';
    document.getElementById('modalTitleText').textContent = 'Edit Address';
    document.getElementById('editAddressId').value = addrId;
    document.getElementById('mName').value  = name  || '';
    document.getElementById('mPhone').value = phone || '';
    document.getElementById('mLine1').value = line1 || '';
    document.getElementById('mLine2').value = '';
    document.getElementById('mCity').value  = city  || '';
    document.getElementById('mPin').value   = pin   || '';
    const sel = document.getElementById('mState');
    for (const opt of sel.options) {
      if (opt.value === state || opt.text === state) { sel.value = opt.value; break; }
    }
    document.getElementById('modalError').style.display = 'none';
    document.getElementById('addrModal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('addrModal').classList.remove('open');
  }

  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });

  /* ── SAVE ADDRESS ── */
  async function saveAddress() {
    const name  = document.getElementById('mName').value.trim();
    const phone = document.getElementById('mPhone').value.trim();
    const line1 = document.getElementById('mLine1').value.trim();
    const city  = document.getElementById('mCity').value.trim();
    const state = document.getElementById('mState').value;
    const pin   = document.getElementById('mPin').value.trim();
    const type  = document.getElementById('mType').value;

    const errors = [];
    if (!name)  errors.push('Full name is required.');
    if (!phone || !/^\d{10}$/.test(phone)) errors.push('Enter a valid 10-digit phone number.');
    if (!line1) errors.push('Address line is required.');
    if (!city)  errors.push('City is required.');
    if (!state) errors.push('Please select a state.');
    if (!pin || !/^\d{6}$/.test(pin)) errors.push('Enter a valid 6-digit PIN code.');

    const errEl = document.getElementById('modalError');
    if (errors.length) { errEl.textContent = errors[0]; errEl.style.display = 'block'; return; }
    errEl.style.display = 'none';

    const payload = { fullName: name, phone, line1, city, state, pincode: pin, addressType: type };
    const btn = document.getElementById('modalSaveBtn');
    btn.disabled = true; btn.textContent = 'Saving…';

    try {
      const addrId = document.getElementById('editAddressId').value;
      const url    = addrId ? `/profile/address/${addrId}` : '/profile/address';
      const method = addrId ? 'PUT' : 'POST';
      const res    = await fetch(url, {
        method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (!res.ok || data.success === false) {
        errEl.textContent = data.message || 'Failed to save address.'; errEl.style.display = 'block'; return;
      }
      showToast(addrId ? 'Address updated.' : 'Address saved.', 'gold');
      closeModal();
      setTimeout(() => window.location.reload(), 600);
    } catch (_) {
      errEl.textContent = 'Something went wrong. Please try again.'; errEl.style.display = 'block';
    } finally {
      btn.disabled = false; btn.textContent = 'Save Address';
    }
  }

  /* ── COUPON ── */
  async function applyCoupon() {
    const code = document.getElementById('couponInput').value.trim().toUpperCase();
    const msg  = document.getElementById('couponMsg');
    if (!code) { msg.textContent = 'Please enter a coupon code.'; msg.className = 'coupon-msg err'; return; }
    try {
      const res  = await fetch('/checkout/apply-coupon', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        msg.textContent = data.message || 'Invalid coupon.'; msg.className = 'coupon-msg err'; return;
      }
      msg.textContent = data.message || 'Coupon applied!'; msg.className = 'coupon-msg ok';
      if (data.newTotal !== undefined) {
        document.querySelector('.summary-total-val').textContent =
          '₹' + Number(data.newTotal).toLocaleString('en-IN');
      }
    } catch (_) { msg.textContent = 'Could not apply coupon.'; msg.className = 'coupon-msg err'; }
  }

  /* ── PLACE ORDER ── */
  async function placeOrder() {
    const addressId = document.getElementById('selectedAddressId').value;
    if (!addressId) { showToast('Please select a delivery address.', 'err'); return; }

    const btn = document.getElementById('placeOrderBtn');
    btn.disabled = true; btn.textContent = 'Processing…';

    try {
      const res  = await fetch('/checkout/place-order', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ addressId }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        showToast(data.message || 'Failed to place order.', 'err');
        btn.disabled = false; btn.textContent = 'Place Order · COD'; return;
      }
      window.location.href = `/checkout/success?orderId=${data.orderId}`;
    } catch (_) {
      showToast('Something went wrong. Please try again.', 'err');
      btn.disabled = false; btn.textContent = 'Place Order · COD';
    }
  }

  /* ── PREVENT BACK NAV ── */
  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
</script>
</body>
</html>
