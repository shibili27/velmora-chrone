<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title || 'Unavailable — Velmora Chroné' %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    :root {
      --gold:        #c9a96e;
      --gold-dim:    rgba(201,169,110,0.18);
      --gold-faint:  rgba(201,169,110,0.06);
      --bg:          #111110;
      --text:        #f5f2eb;
      --text-mid:    rgba(245,242,235,0.42);
      --text-light:  rgba(245,242,235,0.18);
      --border:      rgba(245,242,235,0.06);
      --border-gold: rgba(201,169,110,0.22);
    }

    body {
      font-family: 'Jost', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      overflow-x: hidden;
    }

    /* grain */
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: .018;
    }

    ::-webkit-scrollbar { width: 2px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--gold); }

    /* ═══ NAV ═══ */
    .nav-root {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(17,17,16,0.92);
      backdrop-filter: blur(18px) saturate(1.4);
      -webkit-backdrop-filter: blur(18px) saturate(1.4);
      border-bottom: 1px solid var(--border);
      transition: box-shadow 0.3s;
    }
    .nav-root.scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.5); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; }
    @media(min-width:768px) { .nav-inner { padding: 1rem 3rem; } }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 0.85rem; font-weight: 300; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--text); text-decoration: none;
    }
    .nav-link {
      font-family: 'Jost', sans-serif; font-size: 0.53rem; font-weight: 400;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(245,242,235,0.45); text-decoration: none;
      transition: color 0.2s; position: relative; padding-bottom: 2px;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -2px; left: 0;
      width: 0; height: 1px; background: var(--gold); transition: width 0.3s;
    }
    .nav-link:hover { color: rgba(245,242,235,0.9); }
    .nav-link:hover::after { width: 100%; }

    .nav-icon-btn {
      position: relative; width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(245,242,235,0.5);
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(201,169,110,0.12); border-radius: 10px;
      cursor: pointer; text-decoration: none;
      transition: color 0.22s, background 0.22s, border-color 0.22s,
                  transform 0.18s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s;
      box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 2px 6px rgba(0,0,0,0.35);
    }
    .nav-icon-btn::before {
      content: ''; position: absolute; inset: 0; border-radius: 10px;
      background: linear-gradient(135deg,rgba(255,255,255,0.08) 0%,transparent 55%);
      pointer-events: none;
    }
    .nav-icon-btn:hover {
      color: var(--gold); background: rgba(201,169,110,0.08);
      border-color: rgba(201,169,110,0.35);
      transform: translateY(-2px) scale(1.06);
      box-shadow: 0 1px 0 rgba(255,255,255,0.06) inset, 0 6px 20px rgba(0,0,0,0.5), 0 0 14px rgba(201,169,110,0.15);
    }
    .nav-icon-btn:active { transform: translateY(0px) scale(0.97); }

    .cart-badge {
      position: absolute; top: -5px; right: -5px; width: 14px; height: 14px;
      border-radius: 50%;
      background: linear-gradient(135deg,#d4b97e,#c9a96e);
      font-size: 0.38rem; font-weight: 600; color: #111110;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 6px rgba(201,169,110,0.4);
    }

    .hamburger { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 3px; }
    .hamburger span { display: block; width: 20px; height: 1px; background: rgba(245,242,235,0.6); transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

    .mobile-menu { display: none; flex-direction: column; background: #0d0d0c; padding: 1.5rem 2rem; gap: 1rem; border-top: 1px solid rgba(245,242,235,0.05); }
    .mobile-menu.open { display: flex; }
    .mobile-menu .nav-link { font-size: 0.68rem; padding: 0.45rem 0; border-bottom: 1px solid rgba(245,242,235,0.04); color: rgba(245,242,235,0.5); }

    /* ═══ BREADCRUMB ═══ */
    .breadcrumb {
      padding: 5.5rem 2rem 0; max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
      position: relative; z-index: 1;
    }
    @media(min-width:768px) { .breadcrumb { padding: 5.5rem 3rem 0; } }
    .breadcrumb a { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.25); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: rgba(201,169,110,0.6); }
    .breadcrumb .sep { font-size: 0.46rem; color: rgba(245,242,235,0.12); }
    .breadcrumb-current { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(201,169,110,0.55); }

    /* ═══ MAIN CONTENT ═══ */
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 72px 24px 96px;
      text-align: center;
      position: relative; z-index: 1;
    }

    /* ── GEOMETRIC VISUAL ── */
    .geo-wrap {
      position: relative;
      width: 180px; height: 180px;
      margin: 0 auto 52px;
      animation: geo-appear 1s cubic-bezier(0.22,1,0.36,1) both;
    }
    @keyframes geo-appear {
      from { opacity: 0; transform: scale(0.7) rotate(-8deg); }
      to   { opacity: 1; transform: scale(1) rotate(0deg); }
    }

    /* Slow rotation wrapper */
    .geo-spin {
      position: absolute; inset: 0;
      animation: slow-spin 28s linear infinite;
    }
    .geo-spin-rev {
      position: absolute; inset: 16px;
      animation: slow-spin 18s linear infinite reverse;
    }
    @keyframes slow-spin { to { transform: rotate(360deg); } }

    /* Outer diamond */
    .diamond-outer {
      position: absolute; inset: 0;
      border: 1px solid rgba(201,169,110,0.22);
      transform: rotate(45deg);
      border-radius: 4px;
    }
    .diamond-outer::before {
      content: '';
      position: absolute; inset: 10px;
      border: 1px solid rgba(201,169,110,0.10);
      border-radius: 2px;
    }

    /* Inner diamond */
    .diamond-inner {
      position: absolute; inset: 32px;
      border: 1px solid rgba(201,169,110,0.35);
      transform: rotate(45deg);
      border-radius: 3px;
      background: rgba(201,169,110,0.03);
    }

    /* Corner accent dots on outer diamond */
    .geo-dot {
      position: absolute;
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--gold);
      box-shadow: 0 0 10px 3px rgba(201,169,110,0.5);
    }
    .geo-dot.tl { top: -2.5px; left: -2.5px; }
    .geo-dot.tr { top: -2.5px; right: -2.5px; }
    .geo-dot.bl { bottom: -2.5px; left: -2.5px; }
    .geo-dot.br { bottom: -2.5px; right: -2.5px; }

    /* Cross-hair lines */
    .geo-crosshair {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
    }
    .geo-crosshair::before,
    .geo-crosshair::after {
      content: '';
      position: absolute;
      background: rgba(201,169,110,0.14);
    }
    .geo-crosshair::before { width: 1px; height: 100%; }
    .geo-crosshair::after  { width: 100%; height: 1px; }

    /* Centre mark */
    .geo-center {
      position: absolute;
      top: 50%; left: 50%;
      transform: translate(-50%,-50%);
      width: 10px; height: 10px;
      border-radius: 50%;
      border: 1px solid rgba(201,169,110,0.5);
      background: rgba(201,169,110,0.08);
    }
    .geo-center::after {
      content: '';
      position: absolute; inset: 2px;
      border-radius: 50%;
      background: var(--gold);
      opacity: 0.7;
      animation: pip-pulse 2.8s ease-in-out infinite;
    }
    @keyframes pip-pulse {
      0%,100% { opacity: 0.4; transform: scale(1); }
      50%      { opacity: 1;   transform: scale(1.3); }
    }

    /* Outer glow ring */
    .geo-glow {
      position: absolute; inset: -18px;
      border-radius: 50%;
      pointer-events: none;
      animation: geo-glow-pulse 4s ease-in-out infinite;
    }
    @keyframes geo-glow-pulse {
      0%,100% { box-shadow: 0 0 0 0 rgba(201,169,110,0); }
      50%      { box-shadow: 0 0 48px 12px rgba(201,169,110,0.08); }
    }
    .geo-glow.restored {
      animation: geo-glow-bright 1s ease-in-out infinite;
    }
    @keyframes geo-glow-bright {
      0%,100% { box-shadow: 0 0 0 0 rgba(201,169,110,0.2); }
      50%      { box-shadow: 0 0 80px 24px rgba(201,169,110,0.28); }
    }

    /* Rotating accent ring */
    .geo-ring {
      position: absolute; inset: -10px;
      border-radius: 50%;
      border: 1px dashed rgba(201,169,110,0.12);
      animation: slow-spin 36s linear infinite;
    }

    /* ── STATUS ── */
    .status-bar {
      display: flex; align-items: center; gap: 9px;
      margin-bottom: 40px;
      animation: fade-up 0.6s ease both 0.85s;
    }
    .status-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: rgba(201,169,110,0.25); flex-shrink: 0;
      transition: all 0.5s;
    }
    .status-dot.active  { background: var(--gold); animation: sdot-pulse 1.6s ease-in-out infinite; }
    .status-dot.success { background: #6fcf97; box-shadow: 0 0 8px rgba(111,207,151,0.5); animation: none; }
    @keyframes sdot-pulse {
      0%,100% { opacity: 0.5; transform: scale(1); }
      50%      { opacity: 1;   transform: scale(1.5); box-shadow: 0 0 8px rgba(201,169,110,0.6); }
    }
    .status-label {
      font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.25em;
      text-transform: uppercase; color: var(--text-light); transition: color 0.5s;
    }
    .status-label.active  { color: rgba(201,169,110,0.5); }
    .status-label.success { color: rgba(111,207,151,0.8); }

    /* ── REDIRECT BAR ── */
    .redirect-wrap {
      width: 120px; height: 1px;
      background: rgba(201,169,110,0.1);
      margin: 0 auto 40px; overflow: hidden;
      display: none;
    }
    .redirect-wrap.visible { display: block; }
    .redirect-bar {
      height: 100%; width: 0%;
      background: linear-gradient(90deg, rgba(201,169,110,0.4), var(--gold));
      transition: width 1.4s ease;
    }
    .redirect-bar.go { width: 100%; }

    /* ── COPY ── */
    @keyframes fade-up {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .label-line {
      display: flex; align-items: center; justify-content: center;
      gap: 14px; margin-bottom: 22px;
      animation: fade-up 0.6s ease both 0.1s;
    }
    .label-rule { width: 32px; height: 1px; background: rgba(201,169,110,0.25); }
    .label-text {
      font-family: 'Jost', sans-serif; font-size: 0.42rem;
      letter-spacing: 0.38em; text-transform: uppercase;
      color: rgba(201,169,110,0.55);
    }

    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.4rem, 6vw, 4rem);
      font-weight: 300;
      color: var(--text);
      line-height: 1.1;
      letter-spacing: -0.01em;
      margin-bottom: 24px;
      max-width: 520px;
      animation: fade-up 0.7s ease both 0.22s;
      transition: opacity 0.5s;
    }
    h1 em {
      font-style: italic;
      color: rgba(245,242,235,0.38);
    }

    .divider-mark {
      display: flex; align-items: center; justify-content: center;
      gap: 8px; margin-bottom: 22px;
      animation: fade-up 0.6s ease both 0.32s;
    }
    .divider-mark span { width: 3px; height: 3px; border-radius: 50%; background: rgba(201,169,110,0.3); }
    .divider-mark span:nth-child(2) { background: rgba(201,169,110,0.6); }

    .message {
      font-family: 'Jost', sans-serif;
      font-size: 0.68rem; font-weight: 300;
      letter-spacing: 0.05em;
      color: var(--text-mid);
      line-height: 1.95;
      max-width: 340px;
      margin: 0 auto 44px;
      animation: fade-up 0.7s ease both 0.42s;
      transition: opacity 0.5s;
    }

    /* ── ACTIONS ── */
    .actions {
      display: flex; gap: 10px; flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 0;
      animation: fade-up 0.7s ease both 0.54s;
      transition: opacity 0.5s;
    }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      height: 46px; padding: 0 28px; border-radius: 100px;
      font-family: 'Jost', sans-serif; font-size: 0.48rem;
      letter-spacing: 0.24em; text-transform: uppercase;
      color: #0d0b08; border: none; cursor: pointer; text-decoration: none;
      background: linear-gradient(135deg, #e0c47e 0%, #c9a96e 50%, #b8913d 100%);
      position: relative; overflow: hidden;
      transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s;
      box-shadow: 0 1px 0 rgba(255,255,255,0.35) inset, 0 4px 18px rgba(185,140,55,0.28), 0 1px 4px rgba(0,0,0,0.4);
    }
    .btn-primary::after {
      content: ''; position: absolute; top: 0; left: -75%;
      width: 50%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
      transform: skewX(-18deg); transition: left 0.55s ease;
    }
    .btn-primary:hover::after { left: 130%; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 1px 0 rgba(255,255,255,0.4) inset, 0 8px 24px rgba(185,140,55,0.38); }
    .btn-primary:active { transform: translateY(1px); }
    .btn-primary svg { width: 12px; height: 12px; flex-shrink: 0; }

    .btn-outline {
      display: inline-flex; align-items: center; gap: 8px;
      height: 46px; padding: 0 22px; border-radius: 100px;
      font-family: 'Jost', sans-serif; font-size: 0.48rem;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(245,242,235,0.35);
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(245,242,235,0.09);
      cursor: pointer; text-decoration: none;
      transition: color 0.22s, border-color 0.22s, background 0.22s,
                  transform 0.18s cubic-bezier(.34,1.56,.64,1);
    }
    .btn-outline:hover {
      color: var(--gold); border-color: rgba(201,169,110,0.32);
      background: rgba(201,169,110,0.05); transform: translateY(-2px);
    }
    .btn-outline svg { width: 12px; height: 12px; }

    /* ── BOTTOM RULE ── */
    .bottom-rule {
      width: 1px; height: 52px;
      background: linear-gradient(180deg, transparent, rgba(201,169,110,0.15), transparent);
      margin: 52px auto 28px;
      animation: fade-up 0.6s ease both 0.66s;
    }
    .support-text {
      font-family: 'Jost', sans-serif; font-size: 0.44rem;
      letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--text-light);
      animation: fade-up 0.6s ease both 0.72s;
    }
    .support-text a {
      color: rgba(201,169,110,0.4); text-decoration: none; transition: color 0.2s;
    }
    .support-text a:hover { color: var(--gold); }

    /* ═══ FOOTER ═══ */
    .rule { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.15), transparent); }

    .footer { background: #0a0a09; padding: 4rem 2rem 1.5rem; border-top: 1px solid var(--border); position: relative; z-index: 1; }
    @media(min-width:768px) { .footer { padding: 4rem 3rem 1.5rem; } }
    .footer-top { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid rgba(245,242,235,0.05); max-width: 1200px; margin: 0 auto; }
    @media(min-width:768px) { .footer-top { grid-template-columns: 1.2fr 1fr 1fr 1.2fr; gap: 3rem; } }
    .footer-bottom { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 1.5rem; align-items: center; text-align: center; max-width: 1200px; margin: 0 auto; }
    @media(min-width:768px) { .footer-bottom { flex-direction: row; justify-content: space-between; } }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text); margin-bottom: 0.75rem; }
    .footer-desc { font-family: 'Jost', sans-serif; font-size: 0.6rem; font-weight: 300; color: rgba(245,242,235,0.22); line-height: 1.85; }
    .footer-socials { display: flex; gap: 0.9rem; margin-top: 1.25rem; }
    .footer-social-btn { width: 32px; height: 32px; border: 1px solid rgba(201,169,110,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(245,242,235,0.3); text-decoration: none; transition: border-color 0.25s, color 0.25s, transform 0.18s; }
    .footer-social-btn:hover { border-color: rgba(201,169,110,0.4); color: var(--gold); transform: scale(1.1); }
    .footer-col-title { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(201,169,110,0.35); margin-bottom: 1rem; display: block; }
    .footer-col-link { display: block; font-family: 'Jost', sans-serif; font-size: 0.58rem; letter-spacing: 0.08em; color: rgba(245,242,235,0.25); text-decoration: none; transition: color 0.2s; margin-bottom: 0.5rem; }
    .footer-col-link:hover { color: rgba(245,242,235,0.6); }
    .footer-copy { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,242,235,0.12); }
    .footer-legal { display: flex; gap: 1.25rem; }
    .footer-legal a { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(245,242,235,0.18); text-decoration: none; transition: color 0.2s; }
    .footer-legal a:hover { color: rgba(245,242,235,0.5); }
  </style>
</head>
<body>

<%
  var pollId     = (locals.product && product && product._id) ? product._id.toString() : '';
  var shouldPoll = (reason === 'blocked' || reason === 'category') && pollId !== '';
%>

<!-- NAV -->
<nav class="nav-root" id="navbar">
  <div class="nav-inner">
    <div class="hidden md:flex items-center gap-8">
      <a href="/home"     class="nav-link">Home</a>
      <a href="/products" class="nav-link">Collection</a>
      <a href="/about"    class="nav-link">About</a>
      <a href="/contact"  class="nav-link">Contact</a>
    </div>
    <a href="/home" class="nav-logo md:absolute md:left-1/2 md:-translate-x-1/2">Velmora Chroné</a>
    <div class="flex items-center gap-2 md:gap-3 ml-auto md:ml-0">
      <a href="/wishlist" class="nav-icon-btn" aria-label="Wishlist">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>
      <a href="/cart" class="nav-icon-btn" aria-label="Cart" style="position:relative">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-badge" id="cartCount">0</span>
      </a>
      <a href="/profile" class="nav-icon-btn" aria-label="Account">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/logout" class="nav-link hidden md:inline" style="margin-left:4px;">Logout</a>
      <button class="hamburger md:hidden" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/home"     class="nav-link">Home</a>
    <a href="/products" class="nav-link">Collection</a>
    <a href="/about"    class="nav-link">About</a>
    <a href="/contact"  class="nav-link">Contact</a>
    <a href="/wishlist" class="nav-link">Wishlist</a>
    <a href="/cart"     class="nav-link">Cart</a>
    <a href="/profile"  class="nav-link">My Account</a>
    <a href="/logout"   class="nav-link" style="color:rgba(201,169,110,0.55)">Logout</a>
  </div>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="/home">Home</a><span class="sep">›</span>
  <a href="/products">Collection</a><span class="sep">›</span>
  <span class="breadcrumb-current">
    <% if (reason === 'notfound') { %>Not Found
    <% } else if (reason === 'blocked') { %>Withdrawn
    <% } else if (reason === 'category') { %>Discontinued
    <% } else { %>Unavailable<% } %>
  </span>
</div>

<!-- MAIN -->
<div class="container"
  id="page-root"
  data-product-id="<%= pollId %>"
  data-should-poll="<%= shouldPoll %>">

  <!-- Geometric visual -->
  <div class="geo-wrap">
    <div class="geo-glow" id="geoGlow"></div>
    <div class="geo-ring"></div>
    <div class="geo-spin">
      <div class="diamond-outer">
        <div class="geo-dot tl"></div>
        <div class="geo-dot tr"></div>
        <div class="geo-dot bl"></div>
        <div class="geo-dot br"></div>
      </div>
    </div>
    <div class="geo-spin-rev">
      <div class="diamond-inner"></div>
    </div>
    <div class="geo-crosshair"></div>
    <div class="geo-center"></div>
  </div>

  <!-- Status bar (polling only) -->
  <% if (shouldPoll) { %>
  <div class="status-bar" id="statusBar">
    <div class="status-dot"    id="statusDot"></div>
    <span class="status-label" id="statusLabel">Monitoring availability</span>
  </div>
  <% } %>

  <!-- Redirect progress bar -->
  <div class="redirect-wrap" id="redirectWrap">
    <div class="redirect-bar" id="redirectBar"></div>
  </div>

  <!-- Label -->
  <div class="label-line">
    <div class="label-rule"></div>
    <% if (reason === 'notfound') { %>
      <span class="label-text" id="labelText">Reference not found</span>
    <% } else if (reason === 'blocked') { %>
      <span class="label-text" id="labelText">Withdrawn from sale</span>
    <% } else if (reason === 'category') { %>
      <span class="label-text" id="labelText">Line discontinued</span>
    <% } else { %>
      <span class="label-text" id="labelText">Not available</span>
    <% } %>
    <div class="label-rule"></div>
  </div>

  <!-- Heading -->
  <% if (reason === 'notfound') { %>
    <h1 id="heading">This reference<br/><em>does not exist.</em></h1>
  <% } else if (reason === 'blocked') { %>
    <h1 id="heading">
      <% if (locals.product && product.name) { %><em><%= product.name %></em><br/>has been withdrawn.<% } else { %>This piece has<br/><em>been withdrawn.</em><% } %>
    </h1>
  <% } else if (reason === 'category') { %>
    <h1 id="heading">This line is<br/><em>no longer active.</em></h1>
  <% } else { %>
    <h1 id="heading">Acquisition is<br/><em>not possible.</em></h1>
  <% } %>

  <!-- Three dots -->
  <div class="divider-mark">
    <span></span><span></span><span></span>
  </div>

  <!-- Message -->
  <% if (reason === 'notfound') { %>
    <p class="message" id="msg">The link you followed leads nowhere. Our active collection is available below.</p>
  <% } else if (reason === 'blocked') { %>
    <p class="message" id="msg">This piece has been removed from the current catalogue. Explore what remains.</p>
  <% } else if (reason === 'category') { %>
    <p class="message" id="msg">The line this piece belonged to is no longer offered. Other collections remain active.</p>
  <% } else { %>
    <p class="message" id="msg">This piece is not currently available for acquisition. Browse our active catalogue.</p>
  <% } %>

  <!-- Actions -->
  <div class="actions" id="actions">
    <a href="/products" class="btn-primary">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
      Browse Collection
    </a>
    <a href="javascript:history.back()" class="btn-outline">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Go Back
    </a>
  </div>

  <div class="bottom-rule"></div>
  <p class="support-text">Enquiries — <a href="mailto:support@velmorachrone.com">support@velmorachrone.com</a></p>

</div>

<!-- FOOTER -->
<div class="rule"></div>
<footer class="footer">
  <div class="footer-top">
    <div>
      <p class="footer-logo">Velmora<br/>Chroné</p>
      <p class="footer-desc">Geneva-made timepieces for those who understand that true luxury is measured not in price, but in permanence.</p>
      <div class="footer-socials">
        <a href="#" class="footer-social-btn" aria-label="Instagram">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
        </a>
        <a href="#" class="footer-social-btn" aria-label="Facebook">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>
    <div>
      <span class="footer-col-title">Customer Service</span>
      <a href="#" class="footer-col-link">Our Story</a>
      <a href="#" class="footer-col-link">Shipping &amp; Returns</a>
      <a href="#" class="footer-col-link">Watch Care Guide</a>
      <a href="#" class="footer-col-link">Contact Us</a>
    </div>
    <div>
      <span class="footer-col-title">About Us</span>
      <a href="#" class="footer-col-link">Craftsmanship</a>
      <a href="#" class="footer-col-link">Sustainability</a>
      <a href="#" class="footer-col-link">Store Blog</a>
      <a href="#" class="footer-col-link">Warranty</a>
    </div>
    <div>
      <span class="footer-col-title">Newsletter</span>
      <p style="font-family:'Jost',sans-serif;font-size:.6rem;color:rgba(245,242,235,.2);line-height:1.75;margin-bottom:.75rem;font-weight:300">Subscribe for exclusive deals &amp; new arrivals.</p>
      <div style="display:flex;align-items:center;border-bottom:1px solid rgba(201,169,110,0.2);padding-bottom:.3rem">
        <input type="email" placeholder="Enter your email address" style="flex:1;background:transparent;border:none;outline:none;font-family:'Jost',sans-serif;font-size:.63rem;color:#f5f2eb;min-width:0"/>
        <button style="background:none;border:none;cursor:pointer;color:rgba(201,169,110,0.45);" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='rgba(201,169,110,0.45)'">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <span class="footer-copy">&copy; <%= new Date().getFullYear() %> Velmora Chroné. All rights reserved.</span>
    <div class="footer-legal">
      <a href="#">Privacy Policy</a><a href="#">Terms of Service</a><a href="#">Accessibility</a>
    </div>
  </div>
</footer>

<script>
  /* ── Hamburger ── */
  document.getElementById('hamburger').addEventListener('click', function () {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });
  document.querySelectorAll('#mobileMenu a').forEach(a =>
    a.addEventListener('click', () => {
      document.getElementById('hamburger').classList.remove('open');
      document.getElementById('mobileMenu').classList.remove('open');
    })
  );

  /* ── Nav scroll shadow ── */
  window.addEventListener('scroll', () => {
    document.getElementById('navbar').classList.toggle('scrolled', scrollY > 20);
  }, { passive: true });


  (function () {
    const root       = document.getElementById('page-root');
    const shouldPoll = root.dataset.shouldPoll === 'true';
    const productId  = root.dataset.productId;
    if (!shouldPoll || !productId) return;

    const statusDot   = document.getElementById('statusDot');
    const statusLabel = document.getElementById('statusLabel');
    const geoGlow     = document.getElementById('geoGlow');
    const labelText   = document.getElementById('labelText');
    const heading     = document.getElementById('heading');
    const msg         = document.getElementById('msg');
    const actions     = document.getElementById('actions');
    const redirectWrap = document.getElementById('redirectWrap');
    const redirectBar  = document.getElementById('redirectBar');

    let redirected = false;
    let attempts   = 0;
    const MAX      = 600;

    function setChecking() {
      if (statusDot)   statusDot.className   = 'status-dot active';
      if (statusLabel) { statusLabel.className = 'status-label active'; statusLabel.textContent = 'Checking availability…'; }
    }
    function setWaiting() {
      if (statusDot)   statusDot.className   = 'status-dot';
      if (statusLabel) { statusLabel.className = 'status-label'; statusLabel.textContent = 'Monitoring availability'; }
    }

    function triggerRestore() {
      if (redirected) return;
      redirected = true;

      if (statusDot)   statusDot.className   = 'status-dot success';
      if (statusLabel) { statusLabel.className = 'status-label success'; statusLabel.textContent = 'Now available — redirecting'; }
      if (geoGlow)     geoGlow.classList.add('restored');
      if (labelText)   labelText.textContent = 'Now available';
      if (heading)     heading.innerHTML     = 'This piece has<br/><em>been restored.</em>';
      if (msg)         msg.textContent       = 'The piece has returned to our catalogue. Taking you there now.';
      if (actions)     { actions.style.opacity = '0.3'; actions.style.pointerEvents = 'none'; }

      if (redirectWrap) {
        redirectWrap.classList.add('visible');
        void redirectWrap.offsetWidth;
        requestAnimationFrame(() => requestAnimationFrame(() => {
          if (redirectBar) redirectBar.classList.add('go');
        }));
      }

      setTimeout(() => { window.location.href = '/products/' + productId; }, 1500);
    }

    function poll() {
      if (redirected || attempts++ >= MAX) return;
      setChecking();
      fetch('/products/' + productId + '/status', { cache: 'no-store' })
        .then(r => { if (!r.ok) throw new Error(); return r.json(); })
        .then(data => {
          if (data.status === 'available') { triggerRestore(); }
          else { setWaiting(); setTimeout(poll, 3000); }
        })
        .catch(() => { setWaiting(); setTimeout(poll, 5000); });
    }

    setTimeout(poll, 2000);
  })();
</script>
</body>
</html>
