<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title || 'Product Unavailable — Velmora Chroné' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --gold: #c9a96e; --gold-dark: #b8954f;
      --bg: #111110; --border: rgba(245,242,235,0.08); --border-gold: rgba(201,169,110,0.25);
      --text: #f5f2eb; --text-mid: rgba(245,242,235,0.55); --text-light: rgba(245,242,235,0.28);
    }
    html, body { font-family: 'Jost', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; display: flex; flex-direction: column; }
    ::-webkit-scrollbar { width: 2px; } ::-webkit-scrollbar-track { background: var(--bg); } ::-webkit-scrollbar-thumb { background: var(--gold); }

    /* ── Navbar ── */
    .nav-root { position: sticky; top: 0; z-index: 200; background: rgba(10,10,9,0.96); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; height: 60px; position: relative; }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text); text-decoration: none; position: absolute; left: 50%; transform: translateX(-50%); white-space: nowrap; }
    .nav-left { display: flex; align-items: center; gap: 28px; }
    .nav-left a { font-size: 10px; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-mid); text-decoration: none; transition: color 0.2s; }
    .nav-left a:hover { color: var(--text); }
    .nav-right { display: flex; align-items: center; gap: 12px; margin-left: auto; }
    .nav-icon { display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; border: 1px solid var(--border); color: var(--text-mid); text-decoration: none; transition: all 0.2s; background: none; cursor: pointer; }
    .nav-icon:hover { border-color: var(--border-gold); color: var(--gold); }
    .nav-icon svg { width: 14px; height: 14px; }
    .nav-logout { font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-mid); text-decoration: none; transition: color 0.2s; }
    .nav-logout:hover { color: var(--text); }
    .cart-badge { position: relative; }
    .cart-badge-dot { position: absolute; top: -3px; right: -3px; width: 13px; height: 13px; border-radius: 50%; background: var(--gold); font-size: 8px; font-weight: 600; color: #111110; display: flex; align-items: center; justify-content: center; }
    .hamburger { display: none; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 3px; }
    .hamburger span { display: block; width: 20px; height: 1px; background: rgba(245,242,235,0.7); transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
    .mobile-menu { display: none; flex-direction: column; background: rgba(10,10,9,0.99); padding: 1.25rem 2rem; gap: 0.9rem; border-top: 1px solid rgba(201,169,110,0.08); }
    .mobile-menu.open { display: flex; }
    .mobile-menu a { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-mid); text-decoration: none; padding: 0.35rem 0; border-bottom: 1px solid var(--border); transition: color 0.2s; }
    .mobile-menu a:hover { color: var(--text); }
    .rule { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.15), transparent); }

    /* ── Main ── */
    .container { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 24px; text-align: center; }

    /* ── Watch ── */
    .watch-svg-wrap { position: relative; width: 160px; height: 160px; margin: 0 auto 40px; animation: watch-appear 0.9s cubic-bezier(0.22,1,0.36,1) both; }
    @keyframes watch-appear { from { opacity:0; transform:scale(0.75) translateY(12px); } to { opacity:1; transform:scale(1) translateY(0); } }
    .glow-ring { position: absolute; inset: -12px; border-radius: 50%; animation: glow-pulse 3s ease-in-out infinite; pointer-events: none; }
    @keyframes glow-pulse { 0%,100% { box-shadow: 0 0 0 0 rgba(201,169,110,0); } 50% { box-shadow: 0 0 32px 8px rgba(201,169,110,0.1); } }
    .glow-ring.restored { animation: glow-bright 0.8s ease-in-out infinite; }
    @keyframes glow-bright { 0%,100% { box-shadow: 0 0 0 0 rgba(201,169,110,0.2); } 50% { box-shadow: 0 0 48px 16px rgba(201,169,110,0.35); } }
    .orbit-ring { position: absolute; inset: 0; border-radius: 50%; border: 1px dashed rgba(201,169,110,0.2); animation: spin-slow 20s linear infinite; }
    .orbit-ring-inner { position: absolute; inset: 18px; border-radius: 50%; border: 1px dashed rgba(201,169,110,0.1); animation: spin-slow 13s linear infinite reverse; }
    @keyframes spin-slow { to { transform: rotate(360deg); } }
    .orbit-dot { position: absolute; width: 5px; height: 5px; border-radius: 50%; background: var(--gold); top: -2.5px; left: calc(50% - 2.5px); transform-origin: 50% 82.5px; animation: spin-slow 20s linear infinite; box-shadow: 0 0 8px 2px rgba(201,169,110,0.7); }
    .orbit-dot-inner { position: absolute; width: 3px; height: 3px; border-radius: 50%; background: rgba(201,169,110,0.6); top: -1.5px; left: calc(50% - 1.5px); transform-origin: 50% 61.5px; animation: spin-slow 13s linear infinite reverse; }
    .watch-body { position: absolute; inset: 28px; background: #161614; border-radius: 50%; border: 1.5px solid rgba(201,169,110,0.38); display: flex; align-items: center; justify-content: center; overflow: hidden; box-shadow: inset 0 0 22px 0 rgba(0,0,0,0.7), inset 0 1px 0 0 rgba(201,169,110,0.1); transition: border-color 0.6s ease, box-shadow 0.6s ease; }
    .watch-body.restored { border-color: rgba(201,169,110,0.9); box-shadow: inset 0 0 22px 0 rgba(0,0,0,0.5), inset 0 1px 0 0 rgba(201,169,110,0.3), 0 0 40px 8px rgba(201,169,110,0.18); }
    .watch-face { width: 100%; height: 100%; border-radius: 50%; position: relative; display: flex; align-items: center; justify-content: center; }
    .tick { position: absolute; width: 1px; height: 6px; background: rgba(201,169,110,0.28); top: 8px; left: calc(50% - 0.5px); transform-origin: 50% 33px; }
    .tick.major { width: 1.5px; height: 9px; background: rgba(201,169,110,0.55); }
    .hand-hr  { position: absolute; width: 2px;   height: 19px; background: linear-gradient(to top, transparent, var(--gold)); border-radius: 1px; bottom: 50%; left: calc(50% - 1px);    transform-origin: 50% 100%; }
    .hand-min { position: absolute; width: 1.5px; height: 24px; background: linear-gradient(to top, transparent, rgba(245,242,235,0.9)); border-radius: 1px; bottom: 50%; left: calc(50% - 0.75px); transform-origin: 50% 100%; }
    .hand-sec { position: absolute; width: 1px;   height: 28px; background: var(--gold); border-radius: 1px 1px 0 0; bottom: 50%; left: calc(50% - 0.5px); transform-origin: 50% 110%; }
    .hand-sec::after { content: ''; position: absolute; width: 1px; height: 8px; background: var(--gold); top: 100%; left: 0; }
    .center-dot { position: absolute; width: 7px; height: 7px; border-radius: 50%; background: var(--gold); top: 50%; left: 50%; transform: translate(-50%,-50%); z-index: 10; box-shadow: 0 0 6px 1px rgba(201,169,110,0.5); }
    .scan-light { position: absolute; inset: 0; border-radius: 50%; background: linear-gradient(180deg, transparent 20%, rgba(201,169,110,0.055) 50%, transparent 80%); animation: scan-sweep 4s ease-in-out infinite; pointer-events: none; }
    @keyframes scan-sweep { 0% { transform:translateY(-55%); opacity:0; } 25% { opacity:1; } 75% { opacity:1; } 100% { transform:translateY(55%); opacity:0; } }
    .lug { position: absolute; left: 50%; transform: translateX(-50%); width: 16px; height: 8px; background: #1e1e1c; border: 1px solid rgba(201,169,110,0.18); border-radius: 2px; }
    .lug.top { top: 18px; } .lug.bottom { bottom: 18px; }
    .crown { position: absolute; right: -8px; top: 50%; transform: translateY(-50%); width: 8px; height: 16px; background: #222220; border: 1px solid rgba(201,169,110,0.22); border-left: none; border-radius: 0 3px 3px 0; }
    .crown::before, .crown::after { content: ''; position: absolute; left: 2px; right: 1px; height: 1px; background: rgba(201,169,110,0.2); }
    .crown::before { top: 4px; } .crown::after { top: 9px; }

    /* ── Status bar ── */
    .status-bar { display: flex; align-items: center; gap: 8px; margin-bottom: 28px; animation: fade-up 0.6s ease both 0.9s; }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: rgba(201,169,110,0.35); animation: dot-blink 2s ease-in-out infinite; flex-shrink: 0; }
    .status-dot.active  { background: var(--gold); animation: dot-active 1.4s ease-in-out infinite; }
    .status-dot.success { background: #6fcf97; animation: none; box-shadow: 0 0 8px 2px rgba(111,207,151,0.4); }
    @keyframes dot-blink  { 0%,100% { opacity:0.3; transform:scale(1); }   50% { opacity:0.7; transform:scale(1.2); } }
    @keyframes dot-active { 0%,100% { opacity:0.6; transform:scale(1); }   50% { opacity:1;   transform:scale(1.3); box-shadow:0 0 8px 2px rgba(201,169,110,0.5); } }
    .status-label { font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-light); transition: color 0.4s; }
    .status-label.active  { color: rgba(201,169,110,0.5); }
    .status-label.success { color: #6fcf97; }

    /* ── Redirect bar ── */
    .redirect-bar-wrap { width: 160px; height: 1px; background: rgba(201,169,110,0.12); margin: 0 auto 28px; overflow: hidden; display: none; }
    .redirect-bar-wrap.visible { display: block; }
    .redirect-bar { height: 100%; width: 0%; background: linear-gradient(90deg, var(--gold-dark), var(--gold)); transition: width 1.3s ease; }
    .redirect-bar.go { width: 100%; }

    /* ── Copy ── */
    @keyframes fade-up { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
    .ornament { display: flex; align-items: center; gap: 12px; margin-bottom: 20px; justify-content: center; animation: fade-up 0.7s ease both 0.15s; }
    .ornament-line { width: 40px; height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.4)); }
    .ornament-line.rev { background: linear-gradient(90deg, rgba(201,169,110,0.4), transparent); }
    .ornament-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--gold); opacity: 0.6; }
    .eyebrow { font-size: 9px; font-weight: 500; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gold); opacity: 0.75; margin-bottom: 16px; animation: fade-up 0.7s ease both 0.25s; transition: color 0.4s, opacity 0.4s; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(28px,5vw,46px); font-weight: 500; color: var(--text); line-height: 1.2; margin-bottom: 18px; max-width: 540px; animation: fade-up 0.7s ease both 0.38s; transition: opacity 0.4s; }
    .message { font-size: 13px; font-weight: 300; letter-spacing: 0.06em; color: var(--text-mid); line-height: 1.8; max-width: 400px; margin: 0 auto 40px; animation: fade-up 0.7s ease both 0.5s; }
    .actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; animation: fade-up 0.7s ease both 0.62s; transition: opacity 0.4s; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; height: 42px; padding: 0 28px; background: var(--gold); color: #111110; border: none; font-family: 'Jost', sans-serif; font-size: 10px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: background 0.2s; }
    .btn-primary:hover { background: var(--gold-dark); }
    .btn-primary svg { width: 13px; height: 13px; }
    .btn-outline { display: inline-flex; align-items: center; gap: 8px; height: 42px; padding: 0 24px; background: transparent; color: var(--text-mid); border: 1px solid var(--border); font-family: 'Jost', sans-serif; font-size: 10px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; text-decoration: none; cursor: pointer; transition: all 0.2s; }
    .btn-outline:hover { border-color: var(--border-gold); color: var(--gold); }
    .btn-outline svg { width: 13px; height: 13px; }
    .divider { width: 1px; height: 48px; background: linear-gradient(180deg, transparent, rgba(201,169,110,0.2), transparent); margin: 44px auto; animation: fade-up 0.7s ease both 0.72s; }
    .support-text { font-size: 10px; font-weight: 300; letter-spacing: 0.12em; color: var(--text-light); text-transform: uppercase; animation: fade-up 0.7s ease both 0.78s; }
    .support-text a { color: rgba(201,169,110,0.55); text-decoration: none; transition: color 0.2s; }
    .support-text a:hover { color: var(--gold); }
    .footer { text-align: center; padding: 28px; font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--text-light); border-top: 1px solid var(--border); }
    @media (max-width: 768px) {
      .nav-left, .nav-logout { display: none; }
      .hamburger { display: flex; }
      .nav-logo { position: static; transform: none; }
      .nav-inner { justify-content: space-between; }
    }
  </style>
</head>
<body>

<nav class="nav-root">
  <div class="nav-inner">
    <div class="nav-left">
      <a href="/home">Home</a>
      <a href="/products">Collection</a>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>
    <a href="/home" class="nav-logo">Velmora Chroné</a>
    <div class="nav-right">
      <a href="/wishlist" class="nav-icon" title="Wishlist">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
      </a>
      <a href="/cart" class="nav-icon cart-badge" title="Cart">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        <span class="cart-badge-dot">0</span>
      </a>
      <a href="/profile" class="nav-icon" title="Account">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/logout" class="nav-logout">Logout</a>
      <button class="hamburger" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/home">Home</a>
    <a href="/products">Collection</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
    <a href="/wishlist">Wishlist</a>
    <a href="/cart">Cart</a>
    <a href="/profile">My Account</a>
    <a href="/logout" style="color:rgba(201,169,110,0.6);">Logout</a>
  </div>
</nav>

<div class="rule"></div>

<%
  /*
   * FIX: product is now the FULL doc from the controller (not just {name}).
   * So product._id is always present for blocked/category reasons.
   */
  var pollId     = (locals.product && product && product._id) ? product._id.toString() : '';
  var shouldPoll = (reason === 'blocked' || reason === 'category') && pollId !== '';
%>

<div class="container" id="page-root"
  data-product-id="<%= pollId %>"
  data-should-poll="<%= shouldPoll %>">

  <div class="watch-svg-wrap">
    <div class="glow-ring"       id="glowRing"></div>
    <div class="orbit-ring">     <div class="orbit-dot"></div></div>
    <div class="orbit-ring-inner"><div class="orbit-dot-inner"></div></div>
    <div class="lug top"></div>
    <div class="lug bottom"></div>
    <div class="crown"></div>
    <div class="watch-body" id="watchBody">
      <div class="watch-face">
        <div class="tick major" style="transform:rotate(0deg)"></div>
        <div class="tick"       style="transform:rotate(30deg)"></div>
        <div class="tick"       style="transform:rotate(60deg)"></div>
        <div class="tick major" style="transform:rotate(90deg)"></div>
        <div class="tick"       style="transform:rotate(120deg)"></div>
        <div class="tick"       style="transform:rotate(150deg)"></div>
        <div class="tick major" style="transform:rotate(180deg)"></div>
        <div class="tick"       style="transform:rotate(210deg)"></div>
        <div class="tick"       style="transform:rotate(240deg)"></div>
        <div class="tick major" style="transform:rotate(270deg)"></div>
        <div class="tick"       style="transform:rotate(300deg)"></div>
        <div class="tick"       style="transform:rotate(330deg)"></div>
        <div class="hand-hr"  id="handHr"></div>
        <div class="hand-min" id="handMin"></div>
        <div class="hand-sec" id="handSec"></div>
        <div class="center-dot"></div>
        <div class="scan-light"></div>
      </div>
    </div>
  </div>

  <% if (shouldPoll) { %>
  <div class="status-bar" id="statusBar">
    <div class="status-dot"   id="statusDot"></div>
    <span class="status-label" id="statusLabel">Monitoring availability</span>
  </div>
  <% } %>

  <div class="redirect-bar-wrap" id="redirectBarWrap">
    <div class="redirect-bar" id="redirectBar"></div>
  </div>

  <div class="ornament">
    <div class="ornament-line"></div>
    <div class="ornament-dot"></div>
    <div class="ornament-line rev"></div>
  </div>

  <% if (reason === 'notfound') { %>
    <p class="eyebrow" id="eyebrow">404 — Not Found</p>
    <h1 id="heading">This timepiece doesn't exist</h1>
    <p class="message" id="msg">The page you're looking for may have been moved or the link might be incorrect. Browse our collection to find the perfect timepiece.</p>

  <% } else if (reason === 'blocked') { %>
    <p class="eyebrow" id="eyebrow">Temporarily Unavailable</p>
    <h1 id="heading"><% if (locals.product && product.name) { %>"<%= product.name %>" is currently unavailable<% } else { %>This timepiece is currently unavailable<% } %></h1>
    <p class="message" id="msg">This piece has been temporarily removed from our catalogue. It may return — explore the rest of our collection in the meantime.</p>

  <% } else if (reason === 'category') { %>
    <p class="eyebrow" id="eyebrow">Category Unavailable</p>
    <h1 id="heading">This product's category is no longer active</h1>
    <p class="message" id="msg">The category this timepiece belongs to has been removed or is temporarily unavailable. Discover other pieces in our active collections.</p>

  <% } else { %>
    <p class="eyebrow" id="eyebrow">Unavailable</p>
    <h1 id="heading">This timepiece is not available right now</h1>
    <p class="message" id="msg">We apologise for the inconvenience. Please explore our other pieces or check back later.</p>
  <% } %>

  <div class="actions" id="actions">
    <a href="/products" class="btn-primary">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
      Browse Collection
    </a>
    <a href="javascript:history.back()" class="btn-outline">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Go Back
    </a>
  </div>

  <div class="divider"></div>
  <p class="support-text">Need help? <a href="mailto:support@velmorachrone.com">support@velmorachrone.com</a></p>
</div>

<footer class="footer">© <%= new Date().getFullYear() %> Velmora Chroné. All rights reserved.</footer>

<script>
  /* ── Hamburger ── */
  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });
  mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    hamburger.classList.remove('open');
    mobileMenu.classList.remove('open');
  }));

  /* ── Live clock ── */
  (function () {
    function tick() {
      const now = new Date();
      const s   = now.getSeconds() + now.getMilliseconds() / 1000;
      const m   = now.getMinutes() + s / 60;
      const h   = (now.getHours() % 12) + m / 60;
      const sec = document.getElementById('handSec');
      const min = document.getElementById('handMin');
      const hr  = document.getElementById('handHr');
      if (sec) sec.style.transform = `rotate(${s * 6}deg)`;
      if (min) min.style.transform = `rotate(${m * 6}deg)`;
      if (hr)  hr.style.transform  = `rotate(${h * 30}deg)`;
    }
    tick();
    setInterval(tick, 1000);
  })();

  /* ══════════════════════════════════════════════
     POLLING — hits GET /products/:id/status
     Returns { status: 'available' | 'blocked' | 'category' | 'notfound' }
  ══════════════════════════════════════════════ */
  (function () {
    const root       = document.getElementById('page-root');
    const shouldPoll = root.dataset.shouldPoll === 'true';
    const productId  = root.dataset.productId;

    if (!shouldPoll || !productId) return;

    const statusDot       = document.getElementById('statusDot');
    const statusLabel     = document.getElementById('statusLabel');
    const glowRing        = document.getElementById('glowRing');
    const watchBody       = document.getElementById('watchBody');
    const redirectBarWrap = document.getElementById('redirectBarWrap');
    const redirectBar     = document.getElementById('redirectBar');
    const eyebrow         = document.getElementById('eyebrow');
    const heading         = document.getElementById('heading');
    const msg             = document.getElementById('msg');
    const actions         = document.getElementById('actions');

    let redirected = false;
    let attempts   = 0;
    const MAX      = 600; // stop after 30 min

    function setChecking() {
      if (statusDot)   statusDot.className   = 'status-dot active';
      if (statusLabel) { statusLabel.className = 'status-label active'; statusLabel.textContent = 'Checking availability…'; }
    }

    function setWaiting() {
      if (statusDot)   statusDot.className   = 'status-dot';
      if (statusLabel) { statusLabel.className = 'status-label'; statusLabel.textContent = 'Monitoring availability'; }
    }

    function triggerRestore() {
      if (redirected) return;
      redirected = true;

      // Green pill
      if (statusDot)   statusDot.className   = 'status-dot success';
      if (statusLabel) { statusLabel.className = 'status-label success'; statusLabel.textContent = 'Product restored — redirecting'; }

      // Flash watch gold
      if (glowRing)  glowRing.classList.add('restored');
      if (watchBody) watchBody.classList.add('restored');

      // Update page copy
      if (eyebrow) { eyebrow.textContent = 'Now Available'; eyebrow.style.opacity = '1'; }
      if (heading) heading.textContent = 'This timepiece is now available';
      if (msg)     msg.textContent     = 'This piece has been restored to our catalogue. Taking you there now…';
      if (actions) { actions.style.opacity = '0.3'; actions.style.pointerEvents = 'none'; }

      // Progress bar
      if (redirectBarWrap) {
        redirectBarWrap.classList.add('visible');
        void redirectBarWrap.offsetWidth; // force reflow so CSS transition fires
        requestAnimationFrame(() => requestAnimationFrame(() => {
          if (redirectBar) redirectBar.classList.add('go');
        }));
      }

      // Redirect after bar finishes
      setTimeout(() => { window.location.href = '/products/' + productId; }, 1500);
    }

    function poll() {
      if (redirected || attempts++ >= MAX) return;

      setChecking();

      fetch('/products/' + productId + '/status', { cache: 'no-store' })
        .then(r => {
          if (!r.ok) throw new Error('bad response');
          return r.json();
        })
        .then(data => {
          if (data.status === 'available') {
            triggerRestore();
          } else {
            setWaiting();
            setTimeout(poll, 3000);
          }
        })
        .catch(() => {
          setWaiting();
          setTimeout(poll, 5000); // back off on network error
        });
    }

    setTimeout(poll, 2000); // first poll after page settles
  })();
</script>

</body>
</html>
