<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Your Cart — Velmora Chroné</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'Jost',sans-serif;background:#111110;color:#f5f2eb;overflow-x:hidden;min-height:100vh}
    ::-webkit-scrollbar{width:2px}::-webkit-scrollbar-track{background:#111110}::-webkit-scrollbar-thumb{background:#c9a96e}

    body::before{content:'';position:fixed;inset:0;pointer-events:none;z-index:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");opacity:.016}

    .nav-root{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(17,17,16,0.92);backdrop-filter:blur(18px) saturate(1.4);-webkit-backdrop-filter:blur(18px) saturate(1.4);border-bottom:1px solid rgba(245,242,235,0.06);transition:box-shadow .3s}
    .nav-root.scrolled{box-shadow:0 2px 24px rgba(0,0,0,.5)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem}
    @media(min-width:768px){.nav-inner{padding:1rem 3rem}}
    .nav-logo{font-family:'Cormorant Garamond',serif;font-size:.85rem;font-weight:300;letter-spacing:.25em;text-transform:uppercase;color:#f5f2eb;text-decoration:none}
    .nav-link{font-family:'Jost',sans-serif;font-size:.53rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,242,235,.45);text-decoration:none;transition:color .2s;position:relative;padding-bottom:2px}
    .nav-link::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:1px;background:#c9a96e;transition:width .3s}
    .nav-link:hover{color:rgba(245,242,235,.9)}.nav-link:hover::after{width:100%}
    .nav-link.active{color:#c9a96e}.nav-link.active::after{width:100%}
    .nav-icon-btn{position:relative;width:36px;height:36px;display:flex;align-items:center;justify-content:center;color:rgba(245,242,235,.5);background:rgba(255,255,255,.03);border:1px solid rgba(201,169,110,.12);border-radius:10px;cursor:pointer;text-decoration:none;transition:color .22s,background .22s,border-color .22s,transform .18s cubic-bezier(.34,1.56,.64,1),box-shadow .22s;box-shadow:0 1px 0 rgba(255,255,255,.04) inset,0 2px 6px rgba(0,0,0,.35)}
    .nav-icon-btn::before{content:'';position:absolute;inset:0;border-radius:10px;background:linear-gradient(135deg,rgba(255,255,255,.08) 0%,transparent 55%);pointer-events:none}
    .nav-icon-btn:hover{color:#c9a96e;background:rgba(201,169,110,.08);border-color:rgba(201,169,110,.35);transform:translateY(-2px) scale(1.06);box-shadow:0 1px 0 rgba(255,255,255,.06) inset,0 6px 20px rgba(0,0,0,.5),0 0 14px rgba(201,169,110,.15)}
    .nav-icon-btn:active{transform:translateY(0px) scale(.97)}
    .cart-badge{position:absolute;top:-5px;right:-5px;width:14px;height:14px;border-radius:50%;background:linear-gradient(135deg,#d4b97e,#c9a96e);font-size:.38rem;font-weight:600;color:#111110;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(201,169,110,.4)}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:3px}
    .hamburger span{display:block;width:20px;height:1px;background:rgba(245,242,235,.6);transition:transform .3s,opacity .3s}
    .hamburger.open span:nth-child(1){transform:translateY(6px) rotate(45deg)}
    .hamburger.open span:nth-child(2){opacity:0}
    .hamburger.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}
    .mobile-menu{display:none;flex-direction:column;background:#0d0d0c;padding:1.5rem 2rem;gap:1rem;border-top:1px solid rgba(245,242,235,.05)}
    .mobile-menu.open{display:flex}
    .mobile-menu .nav-link{font-size:.68rem;padding:.45rem 0;border-bottom:1px solid rgba(245,242,235,.04);color:rgba(245,242,235,.5)}

    .page-hero{padding:5.5rem 2rem 1.5rem;background:linear-gradient(180deg,#080807 0%,#111110 100%);border-bottom:1px solid rgba(201,169,110,.08);position:relative;overflow:hidden;text-align:center}
    @media(min-width:768px){.page-hero{padding:5.5rem 3rem 1.5rem}}
    .page-hero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:600px;height:400px;border-radius:50%;background:radial-gradient(ellipse,rgba(201,169,110,.06) 0%,transparent 70%);pointer-events:none}
    .page-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.25),transparent)}
    .page-hero-scan{position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(201,169,110,.022),transparent);animation:heroScan 7s ease-in-out infinite;pointer-events:none;z-index:0}
    @keyframes heroScan{0%{left:-60%}100%{left:140%}}
    .page-hero-inner{max-width:900px;margin:0 auto;position:relative;z-index:1;display:flex;flex-direction:column;align-items:center}
    .page-hero-tag{font-family:'Jost',sans-serif;font-size:.4rem;letter-spacing:.35em;text-transform:uppercase;color:rgba(201,169,110,.55);margin-bottom:.5rem;display:flex;align-items:center;gap:.65rem}
    .page-hero-tag::before{content:'';width:20px;height:1px;background:#c9a96e;opacity:.45}
    .page-hero-tag::after{content:'';width:20px;height:1px;background:#c9a96e;opacity:.45}
    .page-hero-title{font-family:'Playfair Display',serif;font-weight:400;font-size:clamp(1.1rem,2.2vw,1.7rem);line-height:1;color:#f5f2eb;letter-spacing:-.01em}
    .page-hero-title em{font-style:italic;display:block;background:linear-gradient(125deg,#edd99e 0%,#c9a96e 45%,#a8873d 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative}
    .page-hero-title em::after{content:'';position:absolute;bottom:-5px;left:50%;transform:translateX(-50%);width:0;height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.6),transparent);animation:drawUnderline 1.4s cubic-bezier(.22,1,.36,1) .7s forwards}
    @keyframes drawUnderline{to{width:70%}}

    .breadcrumb{max-width:1200px;margin:0 auto;padding:.75rem 2rem 0;display:flex;align-items:center;gap:6px;flex-wrap:wrap;position:relative;z-index:1}
    @media(min-width:768px){.breadcrumb{padding:.75rem 3rem 0}}
    .bc-item{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.25);text-decoration:none;transition:color .2s}
    .bc-item:hover{color:rgba(245,242,235,.55)}
    .bc-sep{color:rgba(245,242,235,.12);font-size:.46rem}
    .bc-current{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.6)}

    .cart-wrap{max-width:1200px;margin:0 auto;padding:2rem 2rem 5rem;position:relative;z-index:1}
    @media(min-width:768px){.cart-wrap{padding:2rem 3rem 5rem}}

    .cart-grid{display:grid;grid-template-columns:1fr;gap:2rem}
    @media(min-width:960px){.cart-grid{grid-template-columns:1fr 360px;gap:2.5rem;align-items:start}}

    .cart-items-header{display:flex;align-items:center;justify-content:space-between;padding-bottom:.75rem;border-bottom:1px solid rgba(245,242,235,.06);margin-bottom:1rem}
    .cart-items-label{font-family:'Jost',sans-serif;font-size:.42rem;letter-spacing:.3em;text-transform:uppercase;color:rgba(201,169,110,.5);display:flex;align-items:center;gap:.5rem}
    .cart-items-label::before{content:'';width:10px;height:1px;background:rgba(201,169,110,.3)}
    .clear-all-btn{font-family:'Jost',sans-serif;font-size:.46rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(248,113,113,.4);background:none;border:none;cursor:pointer;transition:color .2s}
    .clear-all-btn:hover{color:#f87171}

    .cart-item{display:grid;grid-template-columns:100px 1fr;gap:1.25rem;padding:1.25rem;margin-bottom:10px;background:rgba(245,242,235,.02);border:1px solid rgba(245,242,235,.06);border-radius:16px;transition:opacity .3s,border-color .25s;align-items:start}
    @media(min-width:480px){.cart-item{grid-template-columns:110px 1fr}}
    .cart-item:hover{border-color:rgba(201,169,110,.1)}
    .cart-item.removing{opacity:.3;pointer-events:none}
    .item-img-wrap{width:100px;height:100px;background:#1a1a18;overflow:hidden;border-radius:12px;flex-shrink:0}
    @media(min-width:480px){.item-img-wrap{width:110px;height:110px}}
    .item-img{width:100%;height:100%;object-fit:cover;filter:brightness(.88) contrast(1.04) saturate(.8);transition:transform .5s cubic-bezier(.25,.46,.45,.94)}
    .cart-item:hover .item-img{transform:scale(1.05)}
    .item-details{display:flex;flex-direction:column;gap:.5rem}
    .item-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem}
    .item-brand{font-family:'Jost',sans-serif;font-size:.38rem;letter-spacing:.24em;text-transform:uppercase;color:rgba(201,169,110,.55);margin-bottom:2px}
    .item-name{font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,2vw,1.2rem);font-weight:300;color:#f5f2eb;line-height:1.2;text-decoration:none}
    .item-category{font-family:'Jost',sans-serif;font-size:.4rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.38);margin-bottom:2px}
    .item-price-unit{font-family:'Jost',sans-serif;font-size:.55rem;color:rgba(245,242,235,.3);margin-top:3px}
    .item-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem;margin-top:.25rem}
    .remove-btn{background:none;border:none;cursor:pointer;color:rgba(245,242,235,.18);padding:4px;transition:color .2s;display:flex;align-items:center;flex-shrink:0}
    .remove-btn:hover{color:#f87171}
    .item-warning{font-family:'Jost',sans-serif;font-size:.42rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(248,113,113,.8);border:1px solid rgba(248,113,113,.2);padding:3px 10px;border-radius:100px;display:inline-block;background:rgba(248,113,113,.05)}
    .item-low{font-family:'Jost',sans-serif;font-size:.42rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(251,191,36,.8);border:1px solid rgba(251,191,36,.2);padding:3px 10px;border-radius:100px;display:inline-block;background:rgba(251,191,36,.04)}

    .qty-ctrl{display:flex;align-items:center;border:1px solid rgba(245,242,235,.1);border-radius:100px;overflow:hidden}
    .qty-btn{width:30px;height:30px;background:none;border:none;cursor:pointer;color:rgba(245,242,235,.45);font-size:.9rem;display:flex;align-items:center;justify-content:center;transition:color .2s,background .2s;line-height:1}
    .qty-btn:hover:not(:disabled){color:#c9a96e;background:rgba(201,169,110,.07)}
    .qty-btn:disabled{opacity:.2;cursor:not-allowed}
    .qty-val{min-width:32px;text-align:center;font-family:'Jost',sans-serif;font-size:.65rem;color:#f5f2eb;padding:0 4px}
    .item-total{font-family:'Cormorant Garamond',serif;font-size:1.15rem;font-weight:300;color:rgba(201,169,110,.9)}

    .oos-banner{background:rgba(248,113,113,.04);border:1px solid rgba(248,113,113,.15);border-radius:12px;padding:.85rem 1.1rem;margin-bottom:1.25rem;display:flex;gap:10px;align-items:flex-start}
    .oos-banner-text{font-family:'Jost',sans-serif;font-size:.5rem;color:rgba(245,242,235,.4);line-height:1.7}

    .summary-box{background:rgba(245,242,235,.02);border:1px solid rgba(245,242,235,.06);border-radius:16px;padding:1.5rem;position:sticky;top:84px;transition:border-color .25s}
    .summary-box:hover{border-color:rgba(201,169,110,.1)}
    .summary-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:300;color:#f5f2eb;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:1px solid rgba(245,242,235,.06)}
    .summary-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:.7rem}
    .summary-label{font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(245,242,235,.28)}
    .summary-val{font-family:'Jost',sans-serif;font-size:.65rem;color:rgba(245,242,235,.65)}
    .summary-divider{height:1px;background:rgba(245,242,235,.05);margin:.85rem 0}
    .summary-total-row{display:flex;align-items:baseline;justify-content:space-between}
    .summary-total-label{font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.35)}
    .summary-total-val{font-family:'Cormorant Garamond',serif;font-size:1.65rem;font-weight:300;color:#f5f2eb}
    .tax-note{font-family:'Jost',sans-serif;font-size:.42rem;color:rgba(245,242,235,.18);margin-top:.3rem;text-align:right}

    .coupon-row{display:flex;gap:6px;margin:1rem 0}
    .coupon-input{flex:1;background:rgba(245,242,235,.03);border:none;border-bottom:1px solid rgba(245,242,235,.1);font-family:'Jost',sans-serif;font-size:.62rem;color:#f5f2eb;padding:.35rem 0;outline:none;transition:border-color .2s}
    .coupon-input::placeholder{color:rgba(245,242,235,.18)}
    .coupon-input:focus{border-color:rgba(201,169,110,.4)}
    .coupon-apply-btn{font-family:'Jost',sans-serif;font-size:.45rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.7);background:none;border:1px solid rgba(201,169,110,.2);border-radius:100px;padding:0 12px;cursor:pointer;transition:all .2s;flex-shrink:0}
    .coupon-apply-btn:hover{background:rgba(201,169,110,.08);color:#c9a96e;border-color:rgba(201,169,110,.4)}
    .coupon-msg{font-family:'Jost',sans-serif;font-size:.48rem;margin-top:.3rem;letter-spacing:.05em}
    .coupon-msg.ok{color:rgba(74,222,128,.7)}.coupon-msg.err{color:rgba(248,113,113,.7)}

    .checkout-btn{display:block;width:100%;padding:.9rem;border:none;border-radius:100px;cursor:pointer;font-family:'Jost',sans-serif;font-size:.52rem;letter-spacing:.25em;text-transform:uppercase;color:#0d0b08;background:linear-gradient(135deg,#e0c47e 0%,#c9a96e 50%,#b8913d 100%);position:relative;overflow:hidden;transition:transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .22s;box-shadow:0 1px 0 rgba(255,255,255,.35) inset,0 4px 18px rgba(185,140,55,.3),0 1px 4px rgba(0,0,0,.4);margin-top:1.25rem;text-align:center;text-decoration:none}
    .checkout-btn::after{content:'';position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.25),transparent);transform:skewX(-18deg);transition:left .55s ease}
    .checkout-btn:hover::after{left:130%}
    .checkout-btn:hover:not(.disabled){transform:translateY(-2px);box-shadow:0 1px 0 rgba(255,255,255,.4) inset,0 8px 24px rgba(185,140,55,.4)}
    .checkout-btn:active{transform:translateY(1px)}
    .checkout-btn.disabled{background:rgba(201,169,110,.15);color:rgba(245,242,235,.2);cursor:not-allowed;transform:none;pointer-events:none;box-shadow:none}

    .continue-btn{display:block;width:100%;background:none;color:rgba(245,242,235,.3);font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.2em;text-transform:uppercase;padding:.65rem;border:1px solid rgba(245,242,235,.07);border-radius:100px;margin-top:.65rem;cursor:pointer;transition:all .2s;text-align:center;text-decoration:none}
    .continue-btn:hover{border-color:rgba(245,242,235,.18);color:rgba(245,242,235,.6)}

    .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(8px);background:#1c1c1a;border:1px solid rgba(245,242,235,.08);border-radius:100px;font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.08em;color:rgba(245,242,235,.65);padding:.6rem 1.5rem;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:999;opacity:0;pointer-events:none;transition:opacity .3s,transform .3s;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .toast.gold{border-color:rgba(201,169,110,.3);color:#c9a96e}.toast.err{border-color:rgba(248,113,113,.3);color:#f87171}

    @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
    .fade-up{animation:fadeUp .75s ease both}
    .d1{animation-delay:.1s}.d2{animation-delay:.22s}.d3{animation-delay:.35s}
    .reveal{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease}
    .reveal.visible{opacity:1;transform:translateY(0)}

    .rule{height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.18),transparent);position:relative;z-index:1}

    .footer{background:#0a0a09;padding:4rem 2rem 1.5rem;border-top:1px solid rgba(245,242,235,.05);position:relative;z-index:1}
    @media(min-width:768px){.footer{padding:4rem 3rem 1.5rem}}
    .footer-top{display:grid;grid-template-columns:1fr;gap:2.5rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(245,242,235,.05)}
    @media(min-width:768px){.footer-top{grid-template-columns:1.2fr 1fr 1fr 1.2fr;gap:3rem}}
    .footer-logo{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;letter-spacing:.2em;text-transform:uppercase;color:#f5f2eb;margin-bottom:.75rem}
    .footer-desc{font-family:'Jost',sans-serif;font-size:.6rem;font-weight:300;color:rgba(245,242,235,.22);line-height:1.85}
    .footer-socials{display:flex;gap:.9rem;margin-top:1.25rem}
    .footer-social-btn{width:32px;height:32px;border:1px solid rgba(201,169,110,.15);border-radius:8px;display:flex;align-items:center;justify-content:center;color:rgba(245,242,235,.3);text-decoration:none;transition:border-color .25s,color .25s,transform .18s}
    .footer-social-btn:hover{border-color:rgba(201,169,110,.4);color:#c9a96e;transform:scale(1.1)}
    .footer-col-title{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.28em;text-transform:uppercase;color:rgba(201,169,110,.35);margin-bottom:1rem;display:block}
    .footer-col-link{display:block;font-family:'Jost',sans-serif;font-size:.58rem;letter-spacing:.08em;color:rgba(245,242,235,.25);text-decoration:none;transition:color .2s;margin-bottom:.5rem}
    .footer-col-link:hover{color:rgba(245,242,235,.6)}
    .footer-bottom{display:flex;flex-direction:column;gap:.75rem;padding-top:1.5rem;align-items:center;text-align:center}
    @media(min-width:768px){.footer-bottom{flex-direction:row;justify-content:space-between}}
    .footer-copy{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,242,235,.12)}
    .footer-legal{display:flex;gap:1.25rem}
    .footer-legal a{font-family:'Jost',sans-serif;font-size:.44rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,242,235,.18);text-decoration:none;transition:color .2s}
    .footer-legal a:hover{color:rgba(245,242,235,.5)}

    /* ── CLEAR CART DIALOG ── */
    .vc-overlay{position:fixed;inset:0;z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem;background:rgba(0,0,0,0.72);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);opacity:0;pointer-events:none;transition:opacity .28s ease}
    .vc-overlay.open{opacity:1;pointer-events:all}
    .vc-dialog{background:#111110;border:1px solid rgba(201,169,110,.18);border-radius:20px;padding:2rem 1.75rem;max-width:360px;width:100%;transform:translateY(18px) scale(.97);transition:transform .32s cubic-bezier(.22,1,.36,1),opacity .28s ease;opacity:0;position:relative;overflow:hidden}
    .vc-overlay.open .vc-dialog{transform:translateY(0) scale(1);opacity:1}
    .vc-dialog::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:280px;height:180px;border-radius:50%;background:radial-gradient(ellipse,rgba(201,169,110,.07) 0%,transparent 70%);pointer-events:none}
    .vc-icon{width:48px;height:48px;border-radius:14px;border:1px solid rgba(248,113,113,.18);background:rgba(248,113,113,.05);display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem}
    .vc-tag{font-family:'Jost',sans-serif;font-size:.38rem;letter-spacing:.32em;text-transform:uppercase;color:rgba(201,169,110,.45);text-align:center;margin-bottom:.35rem;display:flex;align-items:center;justify-content:center;gap:.5rem}
    .vc-tag::before,.vc-tag::after{content:'';width:14px;height:1px;background:rgba(201,169,110,.25)}
    .vc-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:400;color:#f5f2eb;text-align:center;margin-bottom:.5rem}
    .vc-sub{font-family:'Jost',sans-serif;font-size:.56rem;color:rgba(245,242,235,.3);text-align:center;line-height:1.7;margin-bottom:1.5rem;letter-spacing:.04em}
    .vc-actions{display:flex;gap:.65rem;flex-direction:column;margin-top:1rem}
    .vc-confirm{display:block;width:100%;padding:.8rem;border:none;border-radius:100px;cursor:pointer;font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.22em;text-transform:uppercase;color:#0d0b08;background:linear-gradient(135deg,#e0c47e 0%,#c9a96e 50%,#b8913d 100%);box-shadow:0 1px 0 rgba(255,255,255,.3) inset,0 4px 18px rgba(185,140,55,.25);transition:transform .2s cubic-bezier(.34,1.56,.64,1),box-shadow .2s;position:relative;overflow:hidden}
    .vc-confirm::after{content:'';position:absolute;top:0;left:-75%;width:50%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.22),transparent);transform:skewX(-18deg);transition:left .5s ease}
    .vc-confirm:hover::after{left:130%}
    .vc-confirm:hover{transform:translateY(-1px);box-shadow:0 1px 0 rgba(255,255,255,.35) inset,0 7px 22px rgba(185,140,55,.35)}
    .vc-confirm:active{transform:scale(.97)}
    .vc-cancel{display:block;width:100%;background:none;color:rgba(245,242,235,.3);font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.2em;text-transform:uppercase;padding:.65rem;border:1px solid rgba(245,242,235,.07);border-radius:100px;cursor:pointer;transition:all .2s;text-align:center}
    .vc-cancel:hover{border-color:rgba(245,242,235,.18);color:rgba(245,242,235,.6)}
    .vc-divider{height:1px;background:linear-gradient(90deg,transparent,rgba(201,169,110,.12),transparent);margin:.35rem 0}
    .vc-item-count{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:300;color:rgba(201,169,110,.6);text-align:center;display:block;margin-bottom:.2rem}
  </style>
</head>
