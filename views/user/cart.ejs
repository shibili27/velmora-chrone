<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Your Cart — Velmora Chroné</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { display: ['Cormorant Garamond','serif'], body: ['Jost','sans-serif'] },
          colors: { cream:'#f5f2eb', vault:'#1a1a18', pine:'#0e1f18', gold:'#c9a96e' },
        }
      }
    };
  </script>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'Jost',sans-serif;background:#111110;color:#f5f2eb;overflow-x:hidden}
    ::-webkit-scrollbar{width:2px}
    ::-webkit-scrollbar-track{background:#111110}
    ::-webkit-scrollbar-thumb{background:#c9a96e}

    /* NAV */
    .nav-root{position:fixed;top:0;left:0;right:0;z-index:200;background:#111110;border-bottom:1px solid rgba(245,242,235,0.06);transition:box-shadow .3s}
    .nav-root.scrolled{box-shadow:0 2px 20px rgba(0,0,0,.3)}
    .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:1rem 2rem}
    @media(min-width:768px){.nav-inner{padding:1rem 3rem}}
    .nav-logo{font-family:'Cormorant Garamond',serif;font-size:.85rem;font-weight:300;letter-spacing:.25em;text-transform:uppercase;color:#f5f2eb;text-decoration:none}
    .nav-link{font-family:'Jost',sans-serif;font-size:.55rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:rgba(245,242,235,.55);text-decoration:none;transition:color .2s}
    .nav-link:hover{color:#f5f2eb}
    .nav-icon{color:rgba(245,242,235,.6);background:none;border:none;cursor:pointer;transition:color .2s;text-decoration:none;display:flex;align-items:center}
    .nav-icon:hover{color:#c9a96e}
    .cart-badge{position:absolute;top:-4px;right:-5px;width:13px;height:13px;border-radius:50%;background:#c9a96e;font-size:.4rem;font-weight:600;color:#111110;display:flex;align-items:center;justify-content:center}
    .hamburger{display:flex;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:3px}
    .hamburger span{display:block;width:20px;height:1px;background:rgba(245,242,235,.7);transition:transform .3s,opacity .3s}
    .hamburger.open span:nth-child(1){transform:translateY(6px) rotate(45deg)}
    .hamburger.open span:nth-child(2){opacity:0}
    .hamburger.open span:nth-child(3){transform:translateY(-6px) rotate(-45deg)}
    .mobile-menu{display:none;flex-direction:column;background:#0d0d0c;padding:1.5rem 2rem;gap:1rem;border-top:1px solid rgba(245,242,235,.05)}
    .mobile-menu.open{display:flex}
    .mobile-menu .nav-link{font-size:.7rem;padding:.4rem 0;border-bottom:1px solid rgba(245,242,235,.04);color:rgba(245,242,235,.5)}

    /* BREADCRUMB */
    .breadcrumb{padding:5.5rem 3rem 0;max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
    .bc-item{font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.28);text-decoration:none;transition:color .2s}
    .bc-item:hover{color:rgba(245,242,235,.6)}
    .bc-sep{color:rgba(245,242,235,.15);font-size:.5rem}
    .bc-current{font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.7)}

    /* PAGE HEADER */
    .page-head{max-width:1200px;margin:0 auto;padding:1.5rem 3rem 0}
    .page-title{font-family:'Cormorant Garamond',serif;font-size:clamp(1.8rem,3vw,2.4rem);font-weight:300;color:#f5f2eb}
    .page-subtitle{font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.25);margin-top:.3rem}

    /* CART LAYOUT */
    .cart-wrap{max-width:1200px;margin:0 auto;padding:2rem 2rem 5rem}
    @media(min-width:768px){.cart-wrap{padding:2rem 3rem 5rem}}
    .cart-grid{display:grid;grid-template-columns:1fr;gap:2rem}
    @media(min-width:900px){.cart-grid{grid-template-columns:1fr 360px;gap:2.5rem;align-items:start}}

    /* CART ITEMS */
    .cart-items-header{display:flex;align-items:center;justify-content:space-between;padding-bottom:.75rem;border-bottom:1px solid rgba(245,242,235,.06);margin-bottom:1rem}
    .cart-items-label{font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.25em;text-transform:uppercase;color:rgba(245,242,235,.25)}
    .clear-all-btn{font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(248,113,113,.5);background:none;border:none;cursor:pointer;transition:color .2s}
    .clear-all-btn:hover{color:#f87171}

    .cart-item{display:grid;grid-template-columns:80px 1fr;gap:1rem;padding:1.25rem 0;border-bottom:1px solid rgba(245,242,235,.04);transition:opacity .3s;align-items:start}
    @media(min-width:480px){.cart-item{grid-template-columns:100px 1fr}}
    .cart-item.removing{opacity:.3;pointer-events:none}

    .item-img-wrap{width:80px;height:80px;background:#1a1a18;overflow:hidden;flex-shrink:0}
    @media(min-width:480px){.item-img-wrap{width:100px;height:100px}}
    .item-img{width:100%;height:100%;object-fit:cover}

    .item-details{display:flex;flex-direction:column;gap:.5rem}
    .item-top{display:flex;align-items:flex-start;justify-content:space-between;gap:.5rem}
    .item-brand{font-family:'Jost',sans-serif;font-size:.42rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.6)}
    .item-name{font-family:'Cormorant Garamond',serif;font-size:clamp(1rem,2vw,1.2rem);font-weight:300;color:#f5f2eb;line-height:1.2}
    .item-category{font-family:'Jost',sans-serif;font-size:.45rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(245,242,235,.25)}
    .item-price-unit{font-family:'Jost',sans-serif;font-size:.58rem;color:rgba(245,242,235,.4)}

    .item-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:.5rem}
    .qty-ctrl{display:flex;align-items:center;border:1px solid rgba(245,242,235,.1)}
    .qty-btn{width:30px;height:30px;background:none;border:none;cursor:pointer;color:rgba(245,242,235,.5);font-size:.9rem;display:flex;align-items:center;justify-content:center;transition:color .2s,background .2s;line-height:1}
    .qty-btn:hover:not(:disabled){color:#f5f2eb;background:rgba(245,242,235,.04)}
    .qty-btn:disabled{opacity:.2;cursor:not-allowed}
    .qty-val{min-width:32px;text-align:center;font-family:'Jost',sans-serif;font-size:.65rem;color:#f5f2eb;padding:0 4px}

    .item-total{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;color:#f5f2eb}
    .remove-btn{background:none;border:none;cursor:pointer;color:rgba(245,242,235,.2);padding:4px;transition:color .2s;display:flex;align-items:center}
    .remove-btn:hover{color:#f87171}

    /* OOS / unavailable badges on item */
    .item-warning{font-family:'Jost',sans-serif;font-size:.45rem;letter-spacing:.12em;text-transform:uppercase;color:#f87171;border:1px solid rgba(248,113,113,.2);padding:2px 8px;display:inline-block}
    .item-low{font-family:'Jost',sans-serif;font-size:.45rem;letter-spacing:.12em;text-transform:uppercase;color:#fbbf24;border:1px solid rgba(251,191,36,.2);padding:2px 8px;display:inline-block}

    /* EMPTY STATE */
    .empty-cart{text-align:center;padding:5rem 1rem}

    /* ORDER SUMMARY */
    .summary-box{background:#1a1a18;padding:1.5rem;border:1px solid rgba(245,242,235,.05);position:sticky;top:80px}
    .summary-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:300;color:#f5f2eb;margin-bottom:1.25rem;padding-bottom:.75rem;border-bottom:1px solid rgba(245,242,235,.06)}
    .summary-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:.7rem}
    .summary-label{font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,242,235,.3)}
    .summary-val{font-family:'Jost',sans-serif;font-size:.65rem;color:rgba(245,242,235,.7)}
    .summary-divider{height:1px;background:rgba(245,242,235,.06);margin:.75rem 0}
    .summary-total-row{display:flex;align-items:baseline;justify-content:space-between}
    .summary-total-label{font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(245,242,235,.4)}
    .summary-total-val{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:300;color:#f5f2eb}
    .tax-note{font-family:'Jost',sans-serif;font-size:.42rem;color:rgba(245,242,235,.2);margin-top:.25rem;text-align:right}

    /* Coupon */
    .coupon-row{display:flex;gap:6px;margin:1rem 0}
    .coupon-input{flex:1;background:transparent;border:none;border-bottom:1px solid rgba(245,242,235,.12);font-family:'Jost',sans-serif;font-size:.62rem;color:#f5f2eb;padding:.3rem 0;outline:none;transition:border-color .2s}
    .coupon-input::placeholder{color:rgba(245,242,235,.2)}
    .coupon-input:focus{border-color:rgba(201,169,110,.4)}
    .coupon-apply-btn{font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.18em;text-transform:uppercase;color:rgba(201,169,110,.7);background:none;border:1px solid rgba(201,169,110,.2);padding:0 10px;cursor:pointer;transition:all .2s;flex-shrink:0}
    .coupon-apply-btn:hover{background:rgba(201,169,110,.08);color:#c9a96e}
    .coupon-msg{font-family:'Jost',sans-serif;font-size:.5rem;margin-top:.3rem;letter-spacing:.05em}
    .coupon-msg.ok{color:rgba(74,222,128,.7)}
    .coupon-msg.err{color:rgba(248,113,113,.7)}

    /* Checkout btn */
    .checkout-btn{display:block;width:100%;background:#c9a96e;color:#111110;font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.25em;text-transform:uppercase;padding:.95rem;border:none;cursor:pointer;margin-top:1.25rem;transition:background .2s,transform .15s;text-align:center;text-decoration:none}
    .checkout-btn:hover:not(.disabled){background:#d4b97e;transform:translateY(-1px)}
    .checkout-btn.disabled{background:rgba(201,169,110,.2);color:rgba(245,242,235,.2);cursor:not-allowed;transform:none;pointer-events:none}
    .continue-btn{display:block;width:100%;background:none;color:rgba(245,242,235,.35);font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.2em;text-transform:uppercase;padding:.65rem;border:1px solid rgba(245,242,235,.08);margin-top:.6rem;cursor:pointer;transition:all .2s;text-align:center;text-decoration:none}
    .continue-btn:hover{border-color:rgba(245,242,235,.2);color:rgba(245,242,235,.6)}

    /* OOS checkout warning */
    .oos-warning{background:rgba(248,113,113,.05);border:1px solid rgba(248,113,113,.15);padding:.75rem 1rem;margin-bottom:1rem;display:flex;gap:8px;align-items:flex-start}
    .oos-warning-text{font-family:'Jost',sans-serif;font-size:.5rem;color:rgba(245,242,235,.4);line-height:1.6}

    /* TOAST */
    .toast{position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(8px);background:#1a1a18;border:1px solid rgba(245,242,235,.08);font-family:'Jost',sans-serif;font-size:.58rem;letter-spacing:.08em;color:rgba(245,242,235,.7);padding:.65rem 1.5rem;box-shadow:0 8px 32px rgba(0,0,0,.5);z-index:999;opacity:0;pointer-events:none;transition:opacity .3s,transform .3s;white-space:nowrap}
    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
    .toast.gold{border-color:rgba(201,169,110,.3);color:#c9a96e}
    .toast.err{border-color:rgba(248,113,113,.3);color:#f87171}

    /* FOOTER */
    .footer{background:#0a0a09;padding:4rem 2rem 1.5rem;border-top:1px solid rgba(245,242,235,.05)}
    @media(min-width:768px){.footer{padding:4rem 3rem 1.5rem}}
    .footer-inner{max-width:1200px;margin:0 auto}
    .footer-top{display:grid;grid-template-columns:1fr;gap:2.5rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(245,242,235,.05)}
    @media(min-width:768px){.footer-top{grid-template-columns:1.2fr 1fr 1fr 1.2fr;gap:3rem}}
    .footer-logo{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;letter-spacing:.2em;text-transform:uppercase;color:#f5f2eb;line-height:1.4;margin-bottom:.75rem}
    .footer-desc{font-family:'Jost',sans-serif;font-size:.6rem;font-weight:300;color:rgba(245,242,235,.25);line-height:1.85;margin-bottom:1rem}
    .footer-col-title{font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.28em;text-transform:uppercase;color:rgba(245,242,235,.35);margin-bottom:1rem;display:block}
    .footer-link{display:block;font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.1em;color:rgba(245,242,235,.25);text-decoration:none;transition:color .2s;margin-bottom:.5rem}
    .footer-link:hover{color:rgba(245,242,235,.6)}
    .footer-bottom{display:flex;flex-direction:column;gap:.75rem;padding-top:1.5rem;align-items:center;text-align:center}
    @media(min-width:768px){.footer-bottom{flex-direction:row;justify-content:space-between;text-align:left}}
    .footer-copy{font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(245,242,235,.15)}
    .footer-legal{display:flex;gap:1.25rem}
    .footer-legal a{font-family:'Jost',sans-serif;font-size:.48rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(245,242,235,.2);text-decoration:none;transition:color .2s}
    .footer-legal a:hover{color:rgba(245,242,235,.5)}
  </style>
</head>
<body>

<!-- NAV -->
<nav class="nav-root" id="navbar">
  <div class="nav-inner">
    <div class="hidden md:flex items-center gap-8">
      <a href="/products" class="nav-link">Collection</a>
      <a href="/home"     class="nav-link">Watches</a>
      <a href="/home"     class="nav-link">About</a>
      <a href="/home"     class="nav-link">Contact</a>
    </div>
    <a href="/home" class="nav-logo md:absolute md:left-1/2 md:-translate-x-1/2">Velmora Chroné</a>
    <div class="flex items-center gap-4 md:gap-5 ml-auto md:ml-0">
      <a href="/profile" class="nav-icon" aria-label="Profile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/cart" class="nav-icon relative" aria-label="Cart">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-badge" id="cartBadge"><%= cart.totalItems || 0 %></span>
      </a>
      <a href="/logout" class="nav-link hidden md:inline">Logout</a>
      <button class="hamburger md:hidden" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/products" class="nav-link">Collection</a>
    <a href="/home"     class="nav-link">Watches</a>
    <a href="/profile"  class="nav-link">My Profile</a>
    <a href="/cart"     class="nav-link">Cart</a>
    <a href="/logout"   class="nav-link" style="color:rgba(201,169,110,.6)">Logout</a>
  </div>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="/home"     class="bc-item">Home</a>
  <span class="bc-sep">·</span>
  <a href="/products" class="bc-item">Collection</a>
  <span class="bc-sep">·</span>
  <span class="bc-current">Cart</span>
</div>

<!-- PAGE HEAD -->
<div class="page-head">
  <h1 class="page-title">Your Cart</h1>
  <p class="page-subtitle"><%= cart.totalItems || 0 %> item<%= (cart.totalItems||0)!==1?'s':'' %></p>
</div>

<!-- CART CONTENT -->
<div class="cart-wrap">
  <% if (cart.items && cart.items.length > 0) { %>
  <div class="cart-grid">

    <!-- LEFT: Items -->
    <div>
      <div class="cart-items-header">
        <span class="cart-items-label">Timepieces</span>
        <button class="clear-all-btn" onclick="clearCart()">Remove All</button>
      </div>

      <div id="cartItemsList">
        <% cart.items.forEach(item => {
          const p = item.product;

          // ✅ FIXED: use isDeleted & isListed (matching your Product schema)
          // Old (broken): const isBlocked = p.isBlocked || p.status !== 'active';
          const isBlocked = p.isDeleted || !p.isListed || p.category?.isBlocked;

          const isOOS = p.stock === 0;
          const isLow = p.stock > 0 && p.stock <= 5;
        %>
        <div class="cart-item" id="cartItem-<%= item._id %>">

          <!-- Image -->
          <a href="/products/<%= p._id %>">
            <div class="item-img-wrap">
              <% if (p.images && p.images.length > 0) { %>
                <img class="item-img" src="<%= p.images[0] %>" alt="<%= p.name %>"
                  onerror="this.parentElement.style.background='#222220'"/>
              <% } else { %>
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#222220;">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.08)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg>
                </div>
              <% } %>
            </div>
          </a>

          <!-- Details -->
          <div class="item-details">
            <div class="item-top">
              <div>
                <% if (p.brand) { %><div class="item-brand"><%= p.brand %></div><% } %>
                <a href="/products/<%= p._id %>" style="text-decoration:none">
                  <div class="item-name"><%= p.name %></div>
                </a>
                <div class="item-category"><%= p.category?.name || '' %></div>
                <div class="item-price-unit">₹<%= item.price.toLocaleString('en-IN') %> each</div>
              </div>
              <button class="remove-btn" onclick="removeItem('<%= item._id %>')" title="Remove">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>

            <!-- ✅ FIXED: Status badges now correctly reflect product schema fields -->
            <% if (isBlocked) { %>
              <span class="item-warning">No Longer Available</span>
            <% } else if (isOOS) { %>
              <span class="item-warning">Out of Stock</span>
            <% } else if (isLow) { %>
              <span class="item-low">Only <%= p.stock %> left</span>
            <% } %>

            <div class="item-bottom">
              <!-- Qty controls -->
              <div class="qty-ctrl">
                <button class="qty-btn"
                  <%= (isOOS || isBlocked || item.quantity <= 1) ? 'disabled' : '' %>
                  onclick="updateQty('<%= item._id %>', 'dec')">−</button>
                <span class="qty-val" id="qty-<%= item._id %>"><%= item.quantity %></span>
                <button class="qty-btn"
                  <%= (isOOS || isBlocked || item.quantity >= Math.min(p.stock, MAX_QTY)) ? 'disabled' : '' %>
                  onclick="updateQty('<%= item._id %>', 'inc')">+</button>
              </div>
              <!-- Item total -->
              <span class="item-total" id="total-<%= item._id %>">
                ₹<%= (item.price * item.quantity).toLocaleString('en-IN') %>
              </span>
            </div>
          </div>

        </div>
        <% }) %>
      </div>
    </div>

    <!-- RIGHT: Summary -->
    <div>
      <!-- OOS checkout block warning -->
      <% if (!canCheckout) { %>
      <div class="oos-warning">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="1.5" stroke-linecap="round" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div class="oos-warning-text">Some items in your cart are out of stock or unavailable. Please remove them before proceeding to checkout.</div>
      </div>
      <% } %>

      <div class="summary-box">
        <div class="summary-title">Order Summary</div>

        <div class="summary-row">
          <span class="summary-label">Subtotal (<%= cart.totalItems %> items)</span>
          <span class="summary-val" id="summarySubtotal">₹<%= cart.subtotal?.toLocaleString('en-IN') || '0' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">Shipping</span>
          <span class="summary-val" style="color:rgba(74,222,128,.7)">Free</span>
        </div>

        <!-- Coupon -->
        <div class="coupon-row">
          <input class="coupon-input" type="text" id="couponInput" placeholder="Coupon code"/>
          <button class="coupon-apply-btn" onclick="applyCoupon()">Apply</button>
        </div>
        <div class="coupon-msg" id="couponMsg"></div>

        <div class="summary-divider"></div>
        <div class="summary-total-row">
          <span class="summary-total-label">Total</span>
          <span class="summary-total-val" id="summaryTotal">₹<%= cart.subtotal?.toLocaleString('en-IN') || '0' %></span>
        </div>
        <div class="tax-note">Inclusive of all taxes</div>

        <% if (canCheckout) { %>
          <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
        <% } else { %>
          <button class="checkout-btn disabled" disabled>Proceed to Checkout</button>
        <% } %>
        <a href="/products" class="continue-btn">Continue Shopping</a>
      </div>
    </div>

  </div>

  <% } else { %>
  <!-- EMPTY CART -->
  <div class="empty-cart">
    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.08)" stroke-width="0.6" style="margin:0 auto 1.5rem;display:block"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    <p style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:300;color:rgba(245,242,235,.2);margin-bottom:.5rem">Your cart is empty</p>
    <p style="font-family:'Jost',sans-serif;font-size:.58rem;color:rgba(245,242,235,.15);margin-bottom:2rem;letter-spacing:.1em">Discover our collection of luxury timepieces</p>
    <a href="/products" style="font-family:'Jost',sans-serif;font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:#c9a96e;text-decoration:none;border:1px solid rgba(201,169,110,.2);padding:.7rem 2rem;transition:all .2s">Explore Collection</a>
  </div>
  <% } %>
</div>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div>
        <div class="footer-logo">Velmora<br/>Chroné</div>
        <p class="footer-desc">Velmora Chroné represents the pinnacle of luxury horology. Each timepiece is a testament to centuries of watchmaking tradition.</p>
      </div>
      <div>
        <span class="footer-col-title">Customer Service</span>
        <a href="#" class="footer-link">Shipping & Returns</a>
        <a href="#" class="footer-link">Watch Care Guide</a>
        <a href="#" class="footer-link">Warranty Registration</a>
        <a href="#" class="footer-link">Track Order</a>
      </div>
      <div>
        <span class="footer-col-title">About Us</span>
        <a href="#" class="footer-link">Our Story</a>
        <a href="#" class="footer-link">Craftsmanship</a>
        <a href="#" class="footer-link">Sustainability</a>
        <a href="#" class="footer-link">Retail Partners</a>
      </div>
      <div>
        <span class="footer-col-title">Newsletter</span>
        <p style="font-family:'Jost',sans-serif;font-size:.58rem;font-weight:300;color:rgba(245,242,235,.25);line-height:1.7;margin-bottom:.75rem">Join our inner circle for exclusive previews.</p>
        <div style="display:flex;align-items:center;border-bottom:1px solid rgba(245,242,235,.12);padding-bottom:.3rem">
          <input style="flex:1;background:transparent;border:none;outline:none;font-family:'Jost',sans-serif;font-size:.62rem;color:#f5f2eb;font-weight:300;min-width:0" type="email" placeholder="Your address"/>
          <button style="background:none;border:none;cursor:pointer;color:rgba(245,242,235,.4);padding:0 .2rem;flex-shrink:0">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">&copy; <%= new Date().getFullYear() %> Velmora Chroné. All rights reserved.</span>
      <div class="footer-legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Terms of Service</a>
        <a href="#">Cookie Policy</a>
      </div>
    </div>
  </div>
</footer>

<div class="toast" id="toast"></div>

<script>
  const MAX_QTY = <%= MAX_QTY %>;

  /* NAV */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 20), { passive: true });
  document.getElementById('hamburger').addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });

  /* ── TOAST ── */
  let toastTimer;
  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast show' + (type ? ' ' + type : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
  }

  /* ── FORMAT currency ── */
  function fmt(n) {
    return '₹' + Number(n).toLocaleString('en-IN');
  }

  /* ── UPDATE QTY (inc / dec) ── */
  async function updateQty(itemId, action) {
    const decBtn  = document.querySelector(`#cartItem-${itemId} .qty-btn:first-child`);
    const incBtn  = document.querySelector(`#cartItem-${itemId} .qty-btn:last-child`);
    if (decBtn) decBtn.disabled = true;
    if (incBtn) incBtn.disabled = true;

    try {
      const res  = await fetch(`/cart/update/${itemId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action }),
      });
      const data = await res.json();

      if (!res.ok) {
        showToast(data.message || 'Could not update quantity', 'err');
        return;
      }

      if (data.removed) {
        const row = document.getElementById(`cartItem-${itemId}`);
        if (row) { row.classList.add('removing'); setTimeout(() => row.remove(), 300); }
        updateSummary(data.subtotal, data.cartCount);
        checkEmptyState();
        showToast('Item removed from cart');
        return;
      }

      const qtyEl = document.getElementById(`qty-${itemId}`);
      if (qtyEl) qtyEl.textContent = data.quantity;

      const totalEl = document.getElementById(`total-${itemId}`);
      if (totalEl) totalEl.textContent = fmt(data.itemTotal);

      updateSummary(data.subtotal, data.cartCount);

      if (decBtn) decBtn.disabled = data.quantity <= 1;
      if (incBtn) incBtn.disabled = data.quantity >= MAX_QTY || (data.maxStock !== undefined && data.quantity >= data.maxStock);

    } catch (err) {
      showToast('Something went wrong', 'err');
    } finally {
      const q = parseInt(document.getElementById(`qty-${itemId}`)?.textContent || '1');
      if (decBtn && decBtn.disabled === true && q > 1) decBtn.disabled = false;
    }
  }

  /* ── REMOVE ITEM ── */
  async function removeItem(itemId) {
    const row = document.getElementById(`cartItem-${itemId}`);
    if (row) row.classList.add('removing');

    try {
      const res  = await fetch(`/cart/remove/${itemId}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok) {
        if (row) row.classList.remove('removing');
        showToast(data.message || 'Failed to remove item', 'err');
        return;
      }
      if (row) setTimeout(() => row.remove(), 300);
      updateSummary(data.subtotal, data.cartCount);
      checkEmptyState();
      showToast('Item removed from cart');
    } catch (_) {
      if (row) row.classList.remove('removing');
      showToast('Something went wrong', 'err');
    }
  }

  /* ── CLEAR CART ── */
  async function clearCart() {
    if (!confirm('Remove all items from your cart?')) return;
    try {
      const res = await fetch('/cart/clear', { method: 'DELETE' });
      if (res.ok) {
        document.querySelectorAll('.cart-item').forEach(r => {
          r.classList.add('removing');
          setTimeout(() => r.remove(), 300);
        });
        setTimeout(() => {
          updateSummary(0, 0);
          checkEmptyState();
        }, 350);
        showToast('Cart cleared');
      }
    } catch (_) { showToast('Something went wrong', 'err'); }
  }

  /* ── APPLY COUPON ── */
  async function applyCoupon() {
    const code = document.getElementById('couponInput').value.trim().toUpperCase();
    const msg  = document.getElementById('couponMsg');
    if (!code) { msg.textContent = 'Please enter a coupon code'; msg.className = 'coupon-msg err'; return; }
    try {
      const res  = await fetch('/cart/coupon', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      const data = await res.json();
      if (!res.ok || !data.success) {
        msg.textContent = data.message || 'Invalid coupon code';
        msg.className   = 'coupon-msg err';
        return;
      }
      msg.textContent = data.message || 'Coupon applied!';
      msg.className   = 'coupon-msg ok';
      if (data.newTotal !== undefined) {
        document.getElementById('summaryTotal').textContent = fmt(data.newTotal);
      }
    } catch (_) {
      msg.textContent = 'Could not apply coupon'; msg.className = 'coupon-msg err';
    }
  }

  /* ── HELPERS ── */
  function updateSummary(subtotal, cartCount) {
    const subEl   = document.getElementById('summarySubtotal');
    const totEl   = document.getElementById('summaryTotal');
    const badgeEl = document.getElementById('cartBadge');
    if (subEl)   subEl.textContent   = fmt(subtotal);
    if (totEl)   totEl.textContent   = fmt(subtotal);
    if (badgeEl) badgeEl.textContent = cartCount;

    const sub = document.querySelector('.page-subtitle');
    if (sub) sub.textContent = `${cartCount} item${cartCount !== 1 ? 's' : ''}`;
  }

  function checkEmptyState() {
    const items = document.querySelectorAll('.cart-item');
    if (items.length === 0) {
      window.location.reload();
    }
  }

  /* ── Back-button guard ── */
  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
</script>
</body>
</html>
