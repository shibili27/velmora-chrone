<!-- CLEAR CART DIALOG -->
<div class="vc-overlay" id="vcOverlay" onclick="if(event.target===this)closeClearDialog()">
  <div class="vc-dialog" role="dialog" aria-modal="true" aria-labelledby="vcDialogTitle">
    <div class="vc-icon" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="3 6 5 6 21 6"/>
        <path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/>
        <path d="M10 11v6M14 11v6"/>
        <path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/>
      </svg>
    </div>
    <p class="vc-tag">Confirm action</p>
    <span class="vc-item-count" id="vcCount"></span>
    <h2 class="vc-title" id="vcDialogTitle">Clear your cart?</h2>
    <p class="vc-sub">All selected timepieces will be removed.<br/>This action cannot be undone.</p>
    <div class="vc-divider"></div>
    <div class="vc-actions">
      <button class="vc-confirm" id="vcConfirmBtn">Remove all items</button>
      <button class="vc-cancel" onclick="closeClearDialog()">Keep shopping</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  const MAX_QTY = <%= MAX_QTY %>;

  /* ── NAV ── */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive: true });

  const hamburger  = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('open');
  });

  /* ── REVEAL ── */
  const revealEls = document.querySelectorAll('.reveal');
  const observer  = new IntersectionObserver(entries => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.06 });
  revealEls.forEach(el => observer.observe(el));

  /* ── TOAST ── */
  let toastTimer;
  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast show' + (type ? ' ' + type : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3000);
  }

  function fmt(n) { return '₹' + Number(n).toLocaleString('en-IN'); }

  /* ── CLEAR CART DIALOG ── */
  let _pendingClearCallback = null;

  function openClearDialog(itemCount, onConfirm) {
    const count = itemCount || 0;
    document.getElementById('vcCount').textContent = count + ' timepiece' + (count !== 1 ? 's' : '');
    _pendingClearCallback = onConfirm || null;
    document.getElementById('vcOverlay').classList.add('open');
    setTimeout(() => document.getElementById('vcConfirmBtn').focus(), 60);
  }

  function closeClearDialog() {
    document.getElementById('vcOverlay').classList.remove('open');
    /* NOTE: do NOT null out _pendingClearCallback here —
       the confirm button saves it before calling this */
  }

  document.getElementById('vcConfirmBtn').addEventListener('click', async () => {
    const cb = _pendingClearCallback;   /* save BEFORE closing */
    _pendingClearCallback = null;
    closeClearDialog();
    if (cb) await cb();                 /* then run it */
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      _pendingClearCallback = null;
      closeClearDialog();
    }
  });

  /* ── CLEAR ALL ── */
  function clearCart() {
    const itemCount = document.querySelectorAll('.cart-item').length;
    openClearDialog(itemCount, async () => {
      try {
        const res = await fetch('/cart/clear', { method: 'DELETE' });
        if (res.ok) {
          document.querySelectorAll('.cart-item').forEach(r => {
            r.classList.add('removing');
            setTimeout(() => r.remove(), 300);
          });
          setTimeout(() => { updateSummary(0, 0); checkEmptyState(); }, 350);
          showToast('Cart cleared');
        } else {
          showToast('Could not clear cart', 'err');
        }
      } catch (_) {
        showToast('Something went wrong', 'err');
      }
    });
  }

  /* ── QTY UPDATE ── */
  async function updateQty(itemId, action) {
    const decBtn = document.querySelector(`#cartItem-${itemId} .qty-btn:first-child`);
    const incBtn = document.querySelector(`#cartItem-${itemId} .qty-btn:last-child`);
    if (decBtn) decBtn.disabled = true;
    if (incBtn) incBtn.disabled = true;
    try {
      const res  = await fetch(`/cart/update/${itemId}`, { method: 'PATCH', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action }) });
      const data = await res.json();
      if (!res.ok) { showToast(data.message || 'Could not update quantity', 'err'); return; }
      if (data.removed) {
        const row = document.getElementById(`cartItem-${itemId}`);
        if (row) { row.classList.add('removing'); setTimeout(() => row.remove(), 300); }
        updateSummary(data.subtotal, data.cartCount);
        checkEmptyState();
        showToast('Item removed from cart');
        return;
      }
      const qtyEl = document.getElementById(`qty-${itemId}`);
      if (qtyEl) qtyEl.textContent = data.quantity;
      const totalEl = document.getElementById(`total-${itemId}`);
      if (totalEl) totalEl.textContent = fmt(data.itemTotal);
      updateSummary(data.subtotal, data.cartCount);
      if (decBtn) decBtn.disabled = data.quantity <= 1;
      if (incBtn) incBtn.disabled = data.quantity >= MAX_QTY || (data.maxStock !== undefined && data.quantity >= data.maxStock);
    } catch (err) { showToast('Something went wrong', 'err'); }
    finally {
      const q = parseInt(document.getElementById(`qty-${itemId}`)?.textContent || '1');
      if (decBtn && decBtn.disabled === true && q > 1) decBtn.disabled = false;
    }
  }

  /* ── REMOVE SINGLE ITEM ── */
  async function removeItem(itemId) {
    const row = document.getElementById(`cartItem-${itemId}`);
    if (row) row.classList.add('removing');
    try {
      const res  = await fetch(`/cart/remove/${itemId}`, { method: 'DELETE' });
      const data = await res.json();
      if (!res.ok) { if (row) row.classList.remove('removing'); showToast(data.message || 'Failed to remove item', 'err'); return; }
      if (row) setTimeout(() => row.remove(), 300);
      updateSummary(data.subtotal, data.cartCount);
      checkEmptyState();
      showToast('Item removed from cart');
    } catch (_) { if (row) row.classList.remove('removing'); showToast('Something went wrong', 'err'); }
  }

  /* ── COUPON ── */
  async function applyCoupon() {
    const code = document.getElementById('couponInput').value.trim().toUpperCase();
    const msg  = document.getElementById('couponMsg');
    if (!code) { msg.textContent = 'Please enter a coupon code'; msg.className = 'coupon-msg err'; return; }
    try {
      const res  = await fetch('/cart/coupon', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ code }) });
      const data = await res.json();
      if (!res.ok || !data.success) { msg.textContent = data.message || 'Invalid coupon code'; msg.className = 'coupon-msg err'; return; }
      msg.textContent = data.message || 'Coupon applied!'; msg.className = 'coupon-msg ok';
      if (data.newTotal !== undefined) document.getElementById('summaryTotal').textContent = fmt(data.newTotal);
    } catch (_) { msg.textContent = 'Could not apply coupon'; msg.className = 'coupon-msg err'; }
  }

  /* ── SUMMARY UPDATE ── */
  function updateSummary(subtotal, cartCount) {
    const subEl   = document.getElementById('summarySubtotal');
    const totEl   = document.getElementById('summaryTotal');
    const badgeEl = document.getElementById('cartBadge');
    const heroEl  = document.getElementById('heroItemCount');
    if (subEl)   subEl.textContent   = fmt(subtotal);
    if (totEl)   totEl.textContent   = fmt(subtotal);
    if (badgeEl) badgeEl.textContent = cartCount;
    if (heroEl)  heroEl.textContent  = `${cartCount} item${cartCount !== 1 ? 's' : ''} selected`;
  }

  /* ── EMPTY STATE CHECK ── */
  function checkEmptyState() {
    const items = document.querySelectorAll('.cart-item');
    if (items.length === 0) window.location.reload();
  }

  /* ── PREVENT BACK NAV ── */
  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));

  /* ── SSE: REAL-TIME PRODUCT UPDATES ── */
  (function () {
    const es = new EventSource('/sse/products');
    es.addEventListener('productUpdate', function (e) {
      const data  = JSON.parse(e.data);
      const item  = document.querySelector(`.cart-item[data-product-id="${data.productId}"]`);
      if (!item) return;
      const itemId  = item.dataset.itemId;
      const unavail = data.isDeleted || data.isListed === false;
      const isOOS   = data.stock === 0 || unavail;
      const isLow   = !isOOS && data.stock > 0 && data.stock <= 5;
      const old = item.querySelector('.item-warning, .item-low');
      if (old) old.remove();
      const details = item.querySelector('.item-details');
      const bottom  = item.querySelector('.item-bottom');
      if (unavail || isOOS) {
        const badge = document.createElement('span');
        badge.className = 'item-warning';
        badge.textContent = unavail ? 'No Longer Available' : 'Out of Stock';
        details.insertBefore(badge, bottom);
        item.querySelectorAll('.qty-btn').forEach(b => b.disabled = true);
      } else if (isLow) {
        const badge = document.createElement('span');
        badge.className = 'item-low';
        badge.textContent = `Only ${data.stock} left`;
        details.insertBefore(badge, bottom);
        const currentQty = parseInt(document.getElementById(`qty-${itemId}`)?.textContent || '1');
        const incBtn = item.querySelector('.qty-btn:last-child');
        if (incBtn) incBtn.disabled = currentQty >= data.stock;
      } else {
        const currentQty = parseInt(document.getElementById(`qty-${itemId}`)?.textContent || '1');
        const decBtn = item.querySelector('.qty-btn:first-child');
        const incBtn = item.querySelector('.qty-btn:last-child');
        if (decBtn) decBtn.disabled = currentQty <= 1;
        if (incBtn) incBtn.disabled = currentQty >= Math.min(data.stock, MAX_QTY);
      }
    });
    es.onerror = function () {};
  })();
</script>
</body>
</html>