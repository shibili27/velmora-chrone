<!-- MAIN -->
<div class="cart-wrap">
  <% if (cart.items && cart.items.length > 0) { %>
  <div class="cart-grid">

    <!-- LEFT: ITEMS -->
    <div class="reveal">
      <div class="cart-items-header">
        <span class="cart-items-label">Timepieces</span>
        <button class="clear-all-btn" onclick="clearCart()">Remove All</button>
      </div>

      <div id="cartItemsList">
        <% cart.items.forEach(item => {
          const p = item.product;
          const brandName = p.brand ? (typeof p.brand === 'object' ? p.brand.name : p.brand) : null;
          const isBlocked = p.isDeleted || !p.isListed || p.category?.isBlocked;
          const isOOS     = p.stock === 0;
          const isLow     = p.stock > 0 && p.stock <= 5;
        %>
        <div class="cart-item" id="cartItem-<%= item._id %>"
             data-product-id="<%= p._id %>"
             data-item-id="<%= item._id %>">

          <a href="/products/<%= p._id %>">
            <div class="item-img-wrap">
              <% if (p.images && p.images.length > 0) { %>
                <img class="item-img" src="<%= p.images[0] %>" alt="<%= p.name %>" onerror="this.parentElement.style.background='#222220'"/>
              <% } else { %>
                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:#1a1a18">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.06)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg>
                </div>
              <% } %>
            </div>
          </a>

          <div class="item-details">
            <div class="item-top">
              <div>
                <% if (brandName) { %><div class="item-brand"><%= brandName %></div><% } %>
                <a href="/products/<%= p._id %>" class="item-name"><%= p.name %></a>
                <div class="item-category"><%= p.category?.name || '' %></div>
                <div class="item-price-unit">₹<%= item.price.toLocaleString('en-IN') %> each</div>
              </div>
              <button class="remove-btn" onclick="removeItem('<%= item._id %>')" title="Remove">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </button>
            </div>

            <% if (isBlocked) { %>
              <span class="item-warning">No Longer Available</span>
            <% } else if (isOOS) { %>
              <span class="item-warning">Out of Stock</span>
            <% } else if (isLow) { %>
              <span class="item-low">Only <%= p.stock %> left</span>
            <% } %>

            <div class="item-bottom">
              <div class="qty-ctrl">
                <button class="qty-btn"
                  <%= (isOOS || isBlocked || item.quantity <= 1) ? 'disabled' : '' %>
                  onclick="updateQty('<%= item._id %>', 'dec')">−</button>
                <span class="qty-val" id="qty-<%= item._id %>"><%= item.quantity %></span>
                <button class="qty-btn"
                  <%= (isOOS || isBlocked || item.quantity >= Math.min(p.stock, MAX_QTY)) ? 'disabled' : '' %>
                  onclick="updateQty('<%= item._id %>', 'inc')">+</button>
              </div>
              <span class="item-total" id="total-<%= item._id %>">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></span>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- RIGHT: SUMMARY -->
    <div class="reveal">
      <% if (!canCheckout) { %>
      <div class="oos-banner">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="1.5" stroke-linecap="round" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <div class="oos-banner-text">Some items are out of stock or unavailable. Please remove them before proceeding to checkout.</div>
      </div>
      <% } %>

      <div class="summary-box">
        <div class="summary-title">Order Summary</div>

        <div class="summary-row">
          <span class="summary-label">Subtotal (<%= cart.totalItems %> items)</span>
          <span class="summary-val" id="summarySubtotal">₹<%= cart.subtotal?.toLocaleString('en-IN') || '0' %></span>
        </div>
        <div class="summary-row">
          <span class="summary-label">Shipping</span>
          <span class="summary-val" style="color:rgba(74,222,128,.7)">Complimentary</span>
        </div>

        <div class="coupon-row">
          <input class="coupon-input" type="text" id="couponInput" placeholder="Coupon code"/>
          <button class="coupon-apply-btn" onclick="applyCoupon()">Apply</button>
        </div>
        <div class="coupon-msg" id="couponMsg"></div>

        <div class="summary-divider"></div>

        <div class="summary-total-row">
          <span class="summary-total-label">Total</span>
          <span class="summary-total-val" id="summaryTotal">₹<%= cart.subtotal?.toLocaleString('en-IN') || '0' %></span>
        </div>
        <div class="tax-note">Inclusive of all taxes</div>

        <% if (canCheckout) { %>
          <a href="/checkout" class="checkout-btn">Proceed to Checkout</a>
        <% } else { %>
          <button class="checkout-btn disabled" disabled>Proceed to Checkout</button>
        <% } %>
        <a href="/products" class="continue-btn">Continue Shopping</a>
      </div>
    </div>

  </div><!-- /cart-grid -->

  <% } else { %>
  <!-- EMPTY STATE -->
  <div style="text-align:center;padding:5rem 1rem" class="reveal">
    <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.07)" stroke-width="0.6" style="margin:0 auto 1.5rem;display:block"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
    <p style="font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:400;color:rgba(245,242,235,.18);margin-bottom:.5rem">Your cart is empty</p>
    <p style="font-family:'Jost',sans-serif;font-size:.55rem;color:rgba(245,242,235,.12);margin-bottom:2rem;letter-spacing:.12em">Discover our collection of luxury timepieces</p>
    <a href="/products" style="font-family:'Jost',sans-serif;font-size:.5rem;letter-spacing:.25em;text-transform:uppercase;color:#c9a96e;text-decoration:none;border:1px solid rgba(201,169,110,.2);border-radius:100px;padding:.7rem 2.5rem;transition:all .2s;display:inline-block">Explore Collection</a>
  </div>
  <% } %>
</div>

