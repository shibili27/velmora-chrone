<div class="toast" id="toast">
  <span class="toast-dot"></span>
  <span id="toastMsg">Added to cart</span>
</div>

<script>
  const PRODUCT_ID = '<%= product._id %>';
  const MAX_QTY    = 5;

  const COLOR_VARIANTS = <%- JSON.stringify(variants) %>;
  let activeVariantIndex = 0;

  /* ── Nav scroll ── */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 20), { passive: true });
  document.getElementById('hamburger').addEventListener('click', function () {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });

  /* ── Zoom ── */
  let zoomed = false;
  const mainWrap = document.getElementById('mainImgWrap');
  const mainImg  = document.getElementById('mainImg');
  function toggleZoom(e) {
    if (!mainImg) return;
    zoomed = !zoomed;
    mainWrap.classList.toggle('zoomed', zoomed);
    mainImg.classList.toggle('zoomed', zoomed);
    if (zoomed) updateZoomOrigin(e);
  }
  mainWrap && mainWrap.addEventListener('mousemove', function (e) {
    if (zoomed && mainImg) updateZoomOrigin(e);
  });
  function updateZoomOrigin(e) {
    const r = mainWrap.getBoundingClientRect();
    if (mainImg) mainImg.style.transformOrigin = `${((e.clientX-r.left)/r.width)*100}% ${((e.clientY-r.top)/r.height)*100}%`;
  }

  /* ── Thumbnail click ── */
  function switchImg(thumb, src) {
    if (mainImg) {
      mainImg.src = src;
      zoomed = false;
      mainWrap && mainWrap.classList.remove('zoomed');
      mainImg.classList.remove('zoomed');
    }
    document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
  }

  /* ── Select colour variant ── */
  function selectVariant(idx) {
    const v = COLOR_VARIANTS[idx];
    if (!v) return;
    activeVariantIndex = idx;

    document.querySelectorAll('.color-swatch').forEach((s, i) => {
      s.classList.toggle('active', i === idx);
    });

    const nameEl = document.getElementById('selectedColorName');
    if (nameEl) nameEl.textContent = v.name;

    const wrap = document.getElementById('mainImgWrap');
    if (wrap) {
      wrap.classList.remove('visible');
      setTimeout(() => {
        if (mainImg && v.images.length > 0) mainImg.src = v.images[0];
        const thumbRow = document.getElementById('thumbRow');
        if (thumbRow) {
          thumbRow.innerHTML = v.images.map((src, i) => `
            <div class="thumb ${i === 0 ? 'active' : ''}" onclick="switchImg(this,'${src}')">
              <img src="${src}" alt="View ${i+1}"/>
            </div>
          `).join('');
        }
        zoomed = false;
        wrap.classList.remove('zoomed');
        if (mainImg) mainImg.classList.remove('zoomed');
        wrap.classList.add('visible');
      }, 250);
    }
    updateStockUI(v.stock);
  }

  function selectFlatColor(el, name) {
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    const nameEl = document.getElementById('selectedColorName');
    if (nameEl) nameEl.textContent = name;
  }

  /* ── Stock UI ── */
  function updateStockUI(stock) {
    const badge    = document.getElementById('stockBadge');
    const dot      = document.getElementById('stockDot');
    const text     = document.getElementById('stockText');
    const qtyInput = document.getElementById('qtyInput');
    const qtyMinus = document.getElementById('qtyMinus');
    const qtyPlus  = document.getElementById('qtyPlus');
    const addBtn   = document.getElementById('addCartBtn');
    const specsStk = document.getElementById('specsStock');

    const isOOS = stock === 0;
    const isLow = stock > 0 && stock <= 5;

    if (badge)   badge.className = 'stock-badge ' + (isOOS ? 'out' : isLow ? 'low' : 'in');
    if (dot)     dot.className   = 'stock-dot '   + (isOOS ? 'out' : isLow ? 'low' : 'in');
    if (text) {
      if (isOOS)      text.textContent = 'Out of Stock';
      else if (isLow) text.textContent = `Low Stock — Only ${stock} left`;
      else            text.textContent = `In Stock · ${stock} available`;
    }
    if (qtyInput) { qtyInput.max = stock; qtyInput.value = Math.min(parseInt(qtyInput.value)||1, Math.min(stock, MAX_QTY)); qtyInput.disabled = isOOS; }
    if (qtyMinus) qtyMinus.disabled = isOOS;
    if (qtyPlus)  qtyPlus.disabled  = isOOS;
    if (addBtn)   { addBtn.disabled = isOOS; addBtn.textContent = isOOS ? 'Out of Stock' : 'Add to Cart'; }
    if (specsStk) specsStk.textContent = isOOS ? 'Sold Out' : stock + ' units';
  }

  /* ── Quantity ── */
  function changeQty(delta) {
    const input = document.getElementById('qtyInput');
    const stock = COLOR_VARIANTS.length > 0 ? COLOR_VARIANTS[activeVariantIndex].stock : <%= initialStock %>;
    const cap   = Math.min(stock, MAX_QTY);
    const val   = Math.min(cap, Math.max(1, parseInt(input.value || 1) + delta));
    input.value = val;
    document.getElementById('qtyMinus').disabled = val <= 1;
    document.getElementById('qtyPlus').disabled  = val >= cap;
  }

  /* ── Add to Cart ── */
  async function addToCart(productId) {
    const qty = parseInt(document.getElementById('qtyInput').value) || 1;
    const btn = document.getElementById('addCartBtn');
    btn.disabled = true;
    btn.textContent = 'Adding…';
    try {
      const body = { productId, quantity: qty };
      if (COLOR_VARIANTS.length > 0) {
        body.variantIndex = activeVariantIndex;
        body.variantName  = COLOR_VARIANTS[activeVariantIndex].name;
      }
      const res  = await fetch('/cart/add', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
      const data = await res.json();
      if (!res.ok) { showToast(data.message || 'Could not add to cart', true); return; }
      showToast('Added to cart ✓');
      if (data.cartCount !== undefined) document.getElementById('cartCount').textContent = data.cartCount;
    } catch (err) {
      showToast('Something went wrong', true);
    } finally {
      btn.disabled    = false;
      btn.textContent = COLOR_VARIANTS.length > 0 && COLOR_VARIANTS[activeVariantIndex].stock === 0 ? 'Out of Stock' : 'Add to Cart';
    }
  }


  let wishlisted = false;

  
  function applyWishlistUI(state) {
    // Product page heart button
    const btn      = document.getElementById('wishlistBtn');
    const heartSvg = document.getElementById('heartSvg');
    if (btn)      btn.classList.toggle('active', state);
    if (heartSvg) {
      heartSvg.setAttribute('fill',   state ? '#f87171' : 'none');
      heartSvg.setAttribute('stroke', state ? '#f87171' : 'currentColor');
    }
    
    const navIcon    = document.getElementById('navWishlistIcon');
    const navHeart   = document.getElementById('navHeartSvg');
    if (navIcon)  navIcon.classList.toggle('wishlisted', state);
    if (navHeart) {
      navHeart.setAttribute('fill',   state ? '#f87171' : 'none');
      navHeart.setAttribute('stroke', state ? '#f87171' : 'currentColor');
    }
  }

  
  function updateWishlistNavBadge(count) {
    const badge = document.getElementById('wishlistNavCount');
    if (!badge) return;
    if (count > 0) {
      badge.textContent  = count > 9 ? '9+' : count;
      badge.style.display = 'flex';
    } else {
      badge.style.display = 'none';
    }
  }

  
  async function checkWishlistStatus() {
    try {
      const res  = await fetch(`/wishlist/status/${PRODUCT_ID}`);
      if (!res.ok) return;
      const data = await res.json();
      wishlisted = !!data.wishlisted;
      applyWishlistUI(wishlisted);
      if (data.count !== undefined) updateWishlistNavBadge(data.count);
    } catch (e) { /* silent user may not be logged in */ }
  }

  async function toggleWishlist() {
    const btn = document.getElementById('wishlistBtn');
    if (btn) btn.disabled = true;
    try {
      const res  = await fetch('/wishlist/toggle', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ productId: PRODUCT_ID }),
      });
      const data = await res.json();
      if (!res.ok) {

        if (res.status === 401) { window.location.href = '/login'; return; }
        showToast(data.message || 'Could not update wishlist', true);
        return;
      }
      wishlisted = !!data.wishlisted;
      applyWishlistUI(wishlisted);
      if (data.count !== undefined) updateWishlistNavBadge(data.count);
      showToast(wishlisted ? 'Added to wishlist ♥' : 'Removed from wishlist');
    } catch (e) {
      showToast('Something went wrong', true);
    } finally {
      if (btn) btn.disabled = false;
    }
  }

  
  checkWishlistStatus();

  // Tabs 
  function openTab(id) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('tab-'   + id).classList.add('active');
    document.getElementById('panel-' + id).classList.add('active');
    document.querySelector('.tabs-root').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  let toastTimer;
  function showToast(msg, isErr = false) {
    const toast = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    toast.className = 'toast show' + (isErr ? ' err' : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
  }
</script>
</body>
</html>
