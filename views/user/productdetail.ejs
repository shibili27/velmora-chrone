<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= product.name %> — Velmora Chroné</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&family=Playfair+Display:ital,wght@0,400;1,400&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: #111110; color: #f5f2eb; overflow-x: hidden; }
    ::-webkit-scrollbar { width: 2px; }
    ::-webkit-scrollbar-track { background: #111110; }
    ::-webkit-scrollbar-thumb { background: #c9a96e; }

    /* ── GRAIN ── */
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: .016;
    }

    /* ═══ NAV ═══ */
    .nav-root { position: fixed; top: 0; left: 0; right: 0; z-index: 200; background: rgba(17,17,16,0.92); backdrop-filter: blur(18px) saturate(1.4); -webkit-backdrop-filter: blur(18px) saturate(1.4); border-bottom: 1px solid rgba(245,242,235,0.06); transition: box-shadow 0.3s; }
    .nav-root.scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.5); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; }
    @media(min-width:768px) { .nav-inner { padding: 1rem 3rem; } }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; font-weight: 300; letter-spacing: 0.25em; text-transform: uppercase; color: #f5f2eb; text-decoration: none; }
    .nav-link { font-family: 'Jost', sans-serif; font-size: 0.53rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.45); text-decoration: none; transition: color 0.2s; position: relative; padding-bottom: 2px; }
    .nav-link::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px; background: #c9a96e; transition: width 0.3s; }
    .nav-link:hover { color: rgba(245,242,235,0.9); }
    .nav-link:hover::after { width: 100%; }
    .nav-link.active { color: #c9a96e; }
    .nav-link.active::after { width: 100%; }
    .nav-icon-btn { position: relative; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; color: rgba(245,242,235,0.5); background: rgba(255,255,255,0.03); border: 1px solid rgba(201,169,110,0.12); border-radius: 10px; cursor: pointer; text-decoration: none; transition: color 0.22s, background 0.22s, border-color 0.22s, transform 0.18s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s; box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 2px 6px rgba(0,0,0,0.35); }
    .nav-icon-btn::before { content: ''; position: absolute; inset: 0; border-radius: 10px; background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 55%); pointer-events: none; }
    .nav-icon-btn:hover { color: #c9a96e; background: rgba(201,169,110,0.08); border-color: rgba(201,169,110,0.35); transform: translateY(-2px) scale(1.06); box-shadow: 0 1px 0 rgba(255,255,255,0.06) inset, 0 6px 20px rgba(0,0,0,0.5), 0 0 14px rgba(201,169,110,0.15); }
    .nav-icon-btn:active { transform: translateY(0px) scale(0.97); }
    .nav-icon-btn.wishlisted { color: #f87171; border-color: rgba(248,113,113,0.3); }
    .cart-badge { position: absolute; top: -5px; right: -5px; width: 14px; height: 14px; border-radius: 50%; background: linear-gradient(135deg, #d4b97e, #c9a96e); font-size: 0.38rem; font-weight: 600; color: #111110; display: flex; align-items: center; justify-content: center; box-shadow: 0 2px 6px rgba(201,169,110,0.4); }
    .hamburger { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 3px; }
    .hamburger span { display: block; width: 20px; height: 1px; background: rgba(245,242,235,0.6); transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
    .mobile-menu { display: none; flex-direction: column; background: #0d0d0c; padding: 1.5rem 2rem; gap: 1rem; border-top: 1px solid rgba(245,242,235,0.05); }
    .mobile-menu.open { display: flex; }
    .mobile-menu .nav-link { font-size: 0.68rem; padding: 0.45rem 0; border-bottom: 1px solid rgba(245,242,235,0.04); color: rgba(245,242,235,0.5); }

    /* ═══ BREADCRUMB ═══ */
    .breadcrumb { padding: 5.5rem 2rem 0; max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; position: relative; z-index: 1; }
    @media(min-width:768px) { .breadcrumb { padding: 5.5rem 3rem 0; } }
    .breadcrumb a { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.25); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: rgba(201,169,110,0.6); }
    .breadcrumb .sep { font-size: 0.46rem; color: rgba(245,242,235,0.12); }
    .breadcrumb-current { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(201,169,110,0.6); }

    /* ═══ DETAIL GRID ═══ */
    .detail-wrap { max-width: 1200px; margin: 0 auto; padding: 2rem 2rem 4rem; position: relative; z-index: 1; }
    @media(min-width:768px) { .detail-wrap { padding: 2rem 3rem 4rem; } }
    .detail-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
    @media(min-width:900px) { .detail-grid { grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; } }

    /* ═══ GALLERY ═══ */
    .gallery { display: flex; flex-direction: column; gap: 0.75rem; }

    .main-img-wrap {
      width: 100%; aspect-ratio: 4/3; overflow: hidden;
      background: #1a1a18; position: relative; cursor: zoom-in;
      border: 1px solid rgba(245,242,235,0.06); border-radius: 16px;
    }
    .main-img-wrap.zoomed { cursor: zoom-out; }
    .main-img-wrap::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent); z-index: 2; pointer-events: none; border-radius: 16px 16px 0 0; }

    .slide-overlay {
      position: absolute; inset: 0; z-index: 1;
      background-size: cover; background-position: center;
      opacity: 0; transition: opacity 0.55s ease; pointer-events: none;
      border-radius: 16px;
    }
    .slide-overlay.fading { opacity: 1; }

    .main-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94); transform-origin: center; pointer-events: none; user-select: none; filter: brightness(.92) contrast(1.04) saturate(.85); display: block; }
    .main-img.zoomed { transform: scale(2.4); filter: brightness(1) contrast(1.04) saturate(.85); }

    .slide-counter {
      position: absolute; bottom: 12px; left: 14px; z-index: 4;
      font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.15em;
      color: rgba(245,242,235,0.4); background: rgba(17,17,16,0.55);
      backdrop-filter: blur(6px); padding: 3px 9px; border-radius: 100px;
      pointer-events: none;
    }

    .slide-arrow {
      position: absolute; top: 50%; z-index: 4; transform: translateY(-50%);
      width: 32px; height: 32px; background: rgba(17,17,16,0.6);
      border: 1px solid rgba(245,242,235,0.12); border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(245,242,235,0.45); cursor: pointer;
      transition: color 0.2s, background 0.2s, border-color 0.2s, opacity 0.2s;
      opacity: 0; backdrop-filter: blur(6px);
    }
    .main-img-wrap:hover .slide-arrow { opacity: 1; }
    .slide-arrow:hover { color: #c9a96e; background: rgba(17,17,16,0.85); border-color: rgba(201,169,110,0.35); }
    .slide-arrow.prev { left: 10px; }
    .slide-arrow.next { right: 10px; }

    .slide-dots {
      position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
      display: flex; gap: 5px; z-index: 4; pointer-events: none;
    }
    .slide-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: rgba(245,242,235,0.25); transition: background 0.3s, transform 0.3s;
      pointer-events: all; cursor: pointer;
    }
    .slide-dot.active { background: #c9a96e; transform: scale(1.3); }

    .zoom-hint { position: absolute; bottom: 12px; right: 14px; font-family: 'Jost', sans-serif; font-size: 0.4rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,242,235,0.18); display: flex; align-items: center; gap: 4px; pointer-events: none; transition: opacity 0.3s; z-index: 4; }
    .main-img-wrap.zoomed .zoom-hint { opacity: 0; }

    .img-badge { position: absolute; top: 12px; left: 12px; z-index: 5; font-family: 'Jost', sans-serif; font-size: 0.4rem; letter-spacing: 0.18em; text-transform: uppercase; padding: 3px 10px; border-radius: 100px; }
    .badge-oos { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.28); color: #f87171; }
    .badge-low { background: rgba(251,191,36,0.1); border: 1px solid rgba(251,191,36,0.28); color: #fbbf24; }
    .badge-discount { background: rgba(201,169,110,0.1); border: 1px solid rgba(201,169,110,0.28); color: #c9a96e; }

    .thumb-row { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 4px; }
    .thumb-row::-webkit-scrollbar { height: 2px; }
    .thumb-row::-webkit-scrollbar-thumb { background: rgba(201,169,110,0.3); }
    .thumb { width: 68px; height: 54px; overflow: hidden; background: #1a1a18; cursor: pointer; border: 1px solid rgba(245,242,235,0.06); border-radius: 8px; transition: border-color 0.2s; flex-shrink: 0; }
    .thumb.active { border-color: rgba(201,169,110,0.5); }
    .thumb img { width: 100%; height: 100%; object-fit: cover; opacity: 0.5; transition: opacity 0.2s; filter: brightness(.9) saturate(.8); }
    .thumb.active img, .thumb:hover img { opacity: 1; }
    .watch-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #1a1a18; }
    .gallery-fade { opacity: 0; transition: opacity 0.25s; }
    .gallery-fade.visible { opacity: 1; }

    /* ═══ INFO COLUMN ═══ */
    .info-col { display: flex; flex-direction: column; }
    .prod-eyebrow { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.6rem; flex-wrap: wrap; }
    .prod-category { font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(245,242,235,0.28); }
    .prod-brand-tag { font-family: 'Jost', sans-serif; font-size: 0.4rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(201,169,110,0.7); border: 1px solid rgba(201,169,110,0.2); padding: 2px 9px; border-radius: 100px; background: rgba(201,169,110,0.05); }
    .prod-name { font-family: 'Playfair Display', serif; font-size: clamp(1.7rem, 3.2vw, 2.4rem); font-weight: 400; color: #f5f2eb; line-height: 1.15; margin-bottom: 0.8rem; }
    .gold-rule { width: 40px; height: 1px; background: linear-gradient(90deg, #c9a96e, rgba(201,169,110,0.2)); margin-bottom: 1.1rem; }

    .rating-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .stars { display: flex; gap: 3px; }
    .star { width: 11px; height: 11px; }
    .star polygon.filled { fill: #c9a96e; }
    .star polygon.half { fill: url(#halfGrad); }
    .star polygon.empty { fill: none; stroke: rgba(201,169,110,0.3); stroke-width: 1.5; }
    .rating-num { font-family: 'Jost', sans-serif; font-size: 0.58rem; color: rgba(245,242,235,0.4); }
    .review-link { font-family: 'Jost', sans-serif; font-size: 0.5rem; color: rgba(245,242,235,0.25); text-decoration: underline; text-underline-offset: 3px; cursor: pointer; transition: color 0.2s; }
    .review-link:hover { color: rgba(201,169,110,0.6); }

    .price-block { margin-bottom: 0.4rem; }
    .prod-price { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 300; color: #f5f2eb; letter-spacing: 0.04em; }
    .prod-price-label { font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.18); margin-top: 3px; margin-bottom: 1.1rem; }

    .stock-badge { display: inline-flex; align-items: center; gap: 7px; font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem; }
    .stock-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .stock-dot.in  { background: #4ade80; box-shadow: 0 0 6px rgba(74,222,128,0.5); }
    .stock-dot.low { background: #fbbf24; box-shadow: 0 0 6px rgba(251,191,36,0.4); }
    .stock-dot.out { background: #f87171; }
    .stock-badge.in  { color: rgba(74,222,128,0.75); }
    .stock-badge.low { color: rgba(251,191,36,0.75); }
    .stock-badge.out { color: rgba(248,113,113,0.75); }

    .color-variants { margin-bottom: 1.5rem; }
    .color-block-title { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(245,242,235,0.3); margin-bottom: 0.75rem; padding-bottom: 0.45rem; border-bottom: 1px solid rgba(245,242,235,0.05); }
    .color-selected-name { font-family: 'Jost', sans-serif; font-size: 0.5rem; color: rgba(245,242,235,0.35); margin-bottom: 0.75rem; letter-spacing: 0.06em; }
    .color-selected-name span { color: rgba(245,242,235,0.75); }
    .color-swatches { display: flex; flex-wrap: wrap; gap: 10px; }
    .color-swatch { width: 30px; height: 30px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; position: relative; flex-shrink: 0; }
    .color-swatch:hover { transform: scale(1.12); }
    .color-swatch.active { border-color: rgba(245,242,235,0.55); box-shadow: 0 0 0 3px rgba(245,242,235,0.08); }
    .color-swatch[data-oos="true"] { opacity: 0.3; cursor: not-allowed; }
    .color-swatch[data-oos="true"]::after { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1.5px; background: rgba(248,113,113,0.7); transform: rotate(-45deg); }
    .color-swatch::before { content: attr(title); position: absolute; bottom: 115%; left: 50%; transform: translateX(-50%); background: #1a1a18; border: 1px solid rgba(245,242,235,0.08); color: rgba(245,242,235,0.6); font-family: 'Jost', sans-serif; font-size: 0.4rem; letter-spacing: 0.1em; white-space: nowrap; padding: 3px 8px; border-radius: 4px; pointer-events: none; opacity: 0; transition: opacity 0.2s; }
    .color-swatch:hover::before { opacity: 1; }

    .action-row { display: flex; gap: 0.65rem; align-items: stretch; margin-bottom: 1rem; }
    .qty-wrap { display: flex; align-items: center; border: 1px solid rgba(245,242,235,0.1); border-radius: 10px; overflow: hidden; }
    .qty-btn { width: 38px; height: 50px; background: none; border: none; color: rgba(245,242,235,0.45); font-size: 1rem; cursor: pointer; transition: color 0.2s, background 0.2s; display: flex; align-items: center; justify-content: center; }
    .qty-btn:hover:not(:disabled) { color: #f5f2eb; background: rgba(245,242,235,0.05); }
    .qty-btn:disabled { opacity: 0.2; cursor: not-allowed; }
    .qty-input { width: 42px; height: 50px; background: transparent; border: none; border-left: 1px solid rgba(245,242,235,0.08); border-right: 1px solid rgba(245,242,235,0.08); text-align: center; font-family: 'Jost', sans-serif; font-size: 0.75rem; color: #f5f2eb; outline: none; }
    .qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }

    .add-cart-btn { flex: 1; font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.24em; text-transform: uppercase; color: #0d0b08; border: none; cursor: pointer; height: 50px; padding: 0 1.5rem; border-radius: 100px; position: relative; overflow: hidden; background: linear-gradient(135deg, #e0c47e 0%, #c9a96e 50%, #b8913d 100%); transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s; box-shadow: 0 1px 0 rgba(255,255,255,0.35) inset, 0 4px 18px rgba(185,140,55,0.3), 0 1px 4px rgba(0,0,0,0.4); }
    .add-cart-btn::after { content: ''; position: absolute; top: 0; left: -75%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent); transform: skewX(-18deg); transition: left 0.55s ease; }
    .add-cart-btn:hover:not(:disabled)::after { left: 130%; }
    .add-cart-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 1px 0 rgba(255,255,255,0.4) inset, 0 8px 24px rgba(185,140,55,0.4); }
    .add-cart-btn:active { transform: translateY(1px); }
    .add-cart-btn:disabled { background: rgba(245,242,235,0.06); color: rgba(245,242,235,0.18); cursor: not-allowed; box-shadow: none; }

    .wishlist-btn { width: 50px; height: 50px; border: 1px solid rgba(245,242,235,0.1); border-radius: 10px; background: rgba(255,255,255,0.02); color: rgba(245,242,235,0.35); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: color 0.22s, border-color 0.22s, background 0.22s, transform 0.18s cubic-bezier(.34,1.56,.64,1); }
    .wishlist-btn:hover { color: #c9a96e; border-color: rgba(201,169,110,0.35); background: rgba(201,169,110,0.06); transform: translateY(-2px); }
    .wishlist-btn.active { color: #f87171; border-color: rgba(248,113,113,0.25); background: rgba(248,113,113,0.04); }
    .wishlist-btn:disabled { opacity: 0.4; cursor: not-allowed; }

    .service-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid rgba(245,242,235,0.05); }
    .service-pill { display: flex; align-items: center; gap: 5px; font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.1em; color: rgba(245,242,235,0.28); border: 1px solid rgba(245,242,235,0.06); padding: 5px 10px; border-radius: 100px; background: rgba(245,242,235,0.02); }
    .service-pill svg { color: rgba(201,169,110,0.45); flex-shrink: 0; }

    /* ═══ TABS ═══ */
    .tabs-root { max-width: 1200px; margin: 0 auto; padding: 0 2rem 3rem; position: relative; z-index: 1; }
    @media(min-width:768px) { .tabs-root { padding: 0 3rem 3rem; } }
    .tab-nav { display: flex; border-bottom: 1px solid rgba(245,242,235,0.07); overflow-x: auto; margin-bottom: 0; }
    .tab-btn { font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.28); background: none; border: none; padding: 0.85rem 1.5rem; cursor: pointer; position: relative; transition: color 0.2s; white-space: nowrap; flex-shrink: 0; }
    .tab-btn::after { content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 1px; background: #c9a96e; transform: scaleX(0); transition: transform 0.25s; }
    .tab-btn.active { color: rgba(245,242,235,0.8); }
    .tab-btn.active::after { transform: scaleX(1); }
    .tab-panel { display: none; padding: 2rem 0; animation: fadeUp 0.4s ease both; }
    .tab-panel.active { display: block; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
    .desc-text { font-family: 'Jost', sans-serif; font-size: 0.68rem; color: rgba(245,242,235,0.42); line-height: 1.95; font-weight: 300; max-width: 680px; }

    .specs-table { width: 100%; border-collapse: collapse; max-width: 540px; }
    .specs-table tr { border-bottom: 1px solid rgba(245,242,235,0.04); }
    .specs-table tr:hover { background: rgba(201,169,110,0.02); }
    .specs-table td { padding: 0.7rem 0.75rem; font-family: 'Jost', sans-serif; font-size: 0.58rem; }
    .specs-table td:first-child { color: rgba(245,242,235,0.28); letter-spacing: 0.14em; text-transform: uppercase; font-size: 0.44rem; width: 38%; }
    .specs-table td:last-child { color: rgba(245,242,235,0.62); }

    .review-item { padding: 1.25rem 0; border-bottom: 1px solid rgba(245,242,235,0.04); }
    .review-item:last-child { border-bottom: none; }
    .review-meta { display: flex; align-items: center; gap: 10px; margin-bottom: 0.5rem; flex-wrap: wrap; }
    .reviewer-name { font-family: 'Jost', sans-serif; font-size: 0.56rem; color: rgba(245,242,235,0.55); }
    .review-date { font-family: 'Jost', sans-serif; font-size: 0.44rem; color: rgba(245,242,235,0.18); margin-left: auto; }
    .review-body { font-family: 'Jost', sans-serif; font-size: 0.6rem; color: rgba(245,242,235,0.32); line-height: 1.85; font-weight: 300; }
    .no-reviews { text-align: center; padding: 3rem 0; font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 300; color: rgba(245,242,235,0.15); }

    /* ═══ RELATED ═══ */
    .related-section { max-width: 1200px; margin: 0 auto; padding: 0 2rem 5rem; position: relative; z-index: 1; }
    @media(min-width:768px) { .related-section { padding: 0 3rem 5rem; } }
    .related-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(245,242,235,0.06); }
    .related-eyebrow { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(201,169,110,0.5); display: flex; align-items: center; gap: 0.5rem; }
    .related-eyebrow::before { content: ''; width: 12px; height: 1px; background: rgba(201,169,110,0.3); }
    .related-all { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.25); text-decoration: none; display: flex; align-items: center; gap: 5px; transition: color 0.2s; }
    .related-all:hover { color: #c9a96e; }
    .related-grid { display: grid; gap: 14px; grid-template-columns: repeat(2,1fr); }
    @media(min-width:640px) { .related-grid { grid-template-columns: repeat(4,1fr); } }
    .prod-card { background: #1c1c1a; overflow: hidden; cursor: pointer; text-decoration: none; color: inherit; transition: transform 0.3s cubic-bezier(.34,1.56,.64,1), box-shadow 0.3s; position: relative; border: 1px solid rgba(245,242,235,0.06); border-radius: 16px; box-shadow: 0 2px 8px rgba(0,0,0,0.35); display: flex; flex-direction: column; }
    .prod-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent); z-index: 2; border-radius: 16px 16px 0 0; pointer-events: none; }
    .prod-card:hover { transform: translateY(-6px) scale(1.02); box-shadow: 0 16px 40px rgba(0,0,0,0.55), 0 0 0 1px rgba(201,169,110,0.18), 0 0 30px rgba(201,169,110,0.06); }
    .prod-card:hover .prod-img { transform: scale(1.06); }
    .prod-img-wrap { aspect-ratio: 1/1; overflow: hidden; background: #1a1a18; position: relative; border-radius: 16px 16px 0 0; }
    .prod-img-wrap::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 55%, rgba(10,10,9,.5) 100%); pointer-events: none; z-index: 1; }
    .prod-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s cubic-bezier(.25,.46,.45,.94); filter: brightness(.88) contrast(1.04) saturate(.8); display: block; }
    .prod-body { padding: 0.9rem 1rem 1.1rem; border-top: 1px solid rgba(201,169,110,0.07); }
    .prod-cat { font-family: 'Jost', sans-serif; font-size: 0.38rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(201,169,110,0.38); margin-bottom: 3px; }
    .prod-name-sm { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; color: #f5f2eb; line-height: 1.2; margin-bottom: 4px; }
    .prod-price-sm { font-family: 'Jost', sans-serif; font-size: 0.58rem; color: rgba(201,169,110,0.6); }

    .rule { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.18), transparent); }

    .toast { position: fixed; bottom: 2rem; right: 2rem; z-index: 999; background: #1a1a18; border: 1px solid rgba(201,169,110,0.25); border-radius: 10px; color: #f5f2eb; font-family: 'Jost', sans-serif; font-size: 0.58rem; letter-spacing: 0.08em; padding: 0.8rem 1.25rem; display: flex; align-items: center; gap: 10px; transform: translateY(80px); opacity: 0; transition: transform 0.35s, opacity 0.35s; pointer-events: none; min-width: 200px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.err { border-color: rgba(248,113,113,0.3); }
    .toast-dot { width: 5px; height: 5px; border-radius: 50%; background: #c9a96e; flex-shrink: 0; }
    .toast.err .toast-dot { background: #f87171; }

    .footer { background: #0a0a09; padding: 4rem 2rem 1.5rem; border-top: 1px solid rgba(245,242,235,0.05); position: relative; z-index: 1; }
    @media(min-width:768px) { .footer { padding: 4rem 3rem 1.5rem; } }
    .footer-top { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid rgba(245,242,235,0.05); max-width: 1200px; margin: 0 auto; }
    @media(min-width:768px) { .footer-top { grid-template-columns: 1.2fr 1fr 1fr 1.2fr; gap: 3rem; } }
    .footer-bottom { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 1.5rem; align-items: center; text-align: center; max-width: 1200px; margin: 0 auto; }
    @media(min-width:768px) { .footer-bottom { flex-direction: row; justify-content: space-between; } }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: #f5f2eb; margin-bottom: 0.75rem; }
    .footer-desc { font-family: 'Jost', sans-serif; font-size: 0.6rem; font-weight: 300; color: rgba(245,242,235,0.22); line-height: 1.85; }
    .footer-socials { display: flex; gap: 0.9rem; margin-top: 1.25rem; }
    .footer-social-btn { width: 32px; height: 32px; border: 1px solid rgba(201,169,110,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(245,242,235,0.3); text-decoration: none; transition: border-color 0.25s, color 0.25s, transform 0.18s; }
    .footer-social-btn:hover { border-color: rgba(201,169,110,0.4); color: #c9a96e; transform: scale(1.1); }
    .footer-col-title { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(201,169,110,0.35); margin-bottom: 1rem; display: block; }
    .footer-col-link { display: block; font-family: 'Jost', sans-serif; font-size: 0.58rem; letter-spacing: 0.08em; color: rgba(245,242,235,0.25); text-decoration: none; transition: color 0.2s; margin-bottom: 0.5rem; }
    .footer-col-link:hover { color: rgba(245,242,235,0.6); }
    .footer-copy { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,242,235,0.12); }
    .footer-legal { display: flex; gap: 1.25rem; }
    .footer-legal a { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(245,242,235,0.18); text-decoration: none; transition: color 0.2s; }
    .footer-legal a:hover { color: rgba(245,242,235,0.5); }
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }
  </style>
</head>
<body>

<%
  const hasVariants  = product.colorVariants && product.colorVariants.length > 0;
  const variants     = hasVariants ? product.colorVariants.map(v => ({ name: v.name, hex: v.hex, images: v.images || [], stock: v.stock || 0 })) : [];
  const initialImages = hasVariants ? (variants[0].images || []) : (product.images || []);
  const initialStock  = hasVariants ? variants[0].stock : product.stock;
  const isOOS         = initialStock === 0;
  const isLow         = initialStock > 0 && initialStock <= 5;
  const hasDiscount   = product.originalPrice && product.originalPrice > product.price;
  const discPct       = hasDiscount ? Math.round((1 - product.price / product.originalPrice) * 100) : 0;
  const avgRating     = product.avgRating || 0;
  const reviewCount   = product.reviewCount || (product.reviews ? product.reviews.length : 0);
  const reviews       = product.reviews || [];
  const brandName     = product.brand ? (typeof product.brand === 'object' ? product.brand.name : product.brand) : null;
  const isLoggedIn    = !!currentUser;
%>

<svg width="0" height="0" style="position:absolute">
  <defs>
    <linearGradient id="halfGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="50%" stop-color="#c9a96e"/>
      <stop offset="50%" stop-color="transparent"/>
    </linearGradient>
  </defs>
</svg>

<!-- NAV -->
<nav class="nav-root" id="navbar">
  <div class="nav-inner">
    <div class="hidden md:flex items-center gap-8">
      <a href="/home"     class="nav-link">Home</a>
      <a href="/products" class="nav-link active">Collection</a>
      <a href="/orders"   class="nav-link">Orders</a>
      <a href="/home"     class="nav-link">About</a>
      <a href="/home"     class="nav-link">Contact</a>
    </div>
    <a href="/home" class="nav-logo md:absolute md:left-1/2 md:-translate-x-1/2">Velmora Chroné</a>
    <div class="flex items-center gap-2 md:gap-3 ml-auto md:ml-0">
      <a href="<%= isLoggedIn ? '/profile' : '/login' %>" class="nav-icon-btn" aria-label="Profile">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="<%= isLoggedIn ? '/wishlist' : '/login' %>" class="nav-icon-btn" aria-label="Wishlist" id="navWishlistBtn">
        <svg id="navHeartSvg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </a>
      <a href="<%= isLoggedIn ? '/cart' : '/login' %>" class="nav-icon-btn" aria-label="Cart" style="position:relative">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-badge" id="cartCount">0</span>
      </a>
      <% if (isLoggedIn) { %>
        <a href="/logout" class="nav-link hidden md:inline" style="margin-left:4px;">Logout</a>
      <% } else { %>
        <a href="/login" class="nav-link hidden md:inline" style="margin-left:4px;">Login</a>
      <% } %>
      <button class="hamburger md:hidden" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/home"     class="nav-link">Home</a>
    <a href="/products" class="nav-link active">Collection</a>
    <a href="/orders"   class="nav-link">Orders</a>
    <% if (isLoggedIn) { %>
      <a href="/profile"  class="nav-link">My Profile</a>
      <a href="/wishlist" class="nav-link">Wishlist</a>
      <a href="/cart"     class="nav-link">Cart</a>
      <a href="/logout"   class="nav-link" style="color:rgba(201,169,110,0.55)">Logout</a>
    <% } else { %>
      <a href="/login"  class="nav-link" style="color:rgba(201,169,110,0.55)">Login</a>
      <a href="/signup" class="nav-link">Sign Up</a>
    <% } %>
  </div>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
  <a href="/home">Home</a><span class="sep">›</span>
  <a href="/products">Collection</a>
  <% if (product.category) { %><span class="sep">›</span><a href="/products?category=<%= product.category._id %>"><%= product.category.name %></a><% } %>
  <span class="sep">›</span>
  <span class="breadcrumb-current"><%= product.name %></span>
</div>

<!-- DETAIL GRID -->
<div class="detail-wrap">
  <div class="detail-grid">

    <!-- GALLERY -->
    <div class="gallery reveal">
      <div class="main-img-wrap gallery-fade visible" id="mainImgWrap" onclick="handleImgClick(event)">

        <% if (isOOS) { %><span class="img-badge badge-oos">Out of Stock</span>
        <% } else if (isLow) { %><span class="img-badge badge-low" id="lowBadge">Only <%= initialStock %> Left</span>
        <% } else if (hasDiscount) { %><span class="img-badge badge-discount">−<%= discPct %>%</span><% } %>

        <div class="slide-overlay" id="slideOverlay"></div>

        <% if (initialImages.length > 0) { %>
          <img class="main-img" id="mainImg" src="<%= initialImages[0] %>" alt="<%= product.name %>"/>
        <% } else { %>
          <div class="watch-ph"><svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.05)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg></div>
        <% } %>

        <button class="slide-arrow prev" id="arrowPrev" onclick="manualSlide(-1, event)" aria-label="Previous">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="slide-arrow next" id="arrowNext" onclick="manualSlide(1, event)" aria-label="Next">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>

        <div class="slide-dots" id="slideDots"></div>
        <div class="slide-counter" id="slideCounter" style="display:none">1 / 1</div>

        <div class="zoom-hint">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
          Click to zoom
        </div>
      </div>

      <div class="thumb-row" id="thumbRow">
        <% initialImages.forEach((img, i) => { %>
          <div class="thumb <%= i === 0 ? 'active' : '' %>" onclick="thumbClick(this, '<%= img %>', <%= i %>)">
            <img src="<%= img %>" alt="View <%= i+1 %>"/>
          </div>
        <% }) %>
      </div>
    </div>

    <!-- INFO COLUMN -->
    <div class="info-col reveal">
      <div class="prod-eyebrow">
        <% if (product.category) { %><span class="prod-category"><%= product.category.name %></span><% } %>
        <% if (brandName) { %><span class="prod-brand-tag"><%= brandName %></span><% } %>
      </div>
      <h1 class="prod-name"><%= product.name %></h1>
      <div class="gold-rule"></div>

      <div class="rating-row">
        <div class="stars">
          <% for (let s = 1; s <= 5; s++) { %>
            <svg class="star" viewBox="0 0 24 24">
              <% if (s <= Math.floor(avgRating)) { %>
                <polygon class="filled" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
              <% } else if (s - 0.5 <= avgRating) { %>
                <polygon class="half" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
              <% } else { %>
                <polygon class="empty" points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
              <% } %>
            </svg>
          <% } %>
        </div>
        <span class="rating-num"><%= avgRating.toFixed(1) %></span>
        <span class="review-link" onclick="openTab('reviews')">(<%= reviewCount %> review<%= reviewCount !== 1 ? 's' : '' %>)</span>
      </div>

      <div class="price-block">
        <div class="prod-price">₹<%= product.price.toLocaleString('en-IN') %></div>
        <div class="prod-price-label">Inclusive of all taxes</div>
      </div>

      <div class="stock-badge <%= isOOS ? 'out' : isLow ? 'low' : 'in' %>" id="stockBadge">
        <span class="stock-dot <%= isOOS ? 'out' : isLow ? 'low' : 'in' %>" id="stockDot"></span>
        <span id="stockText">
          <% if (isOOS) { %>Out of Stock
          <% } else if (isLow) { %>Low Stock — Only <%= initialStock %> left
          <% } else { %>In Stock · <%= initialStock %> available<% } %>
        </span>
      </div>

      <% if (hasVariants) { %>
      <div class="color-variants">
        <div class="color-block-title">Colour</div>
        <div class="color-selected-name">Selected: <span id="selectedColorName"><%= variants[0].name %></span></div>
        <div class="color-swatches">
          <% variants.forEach((v, i) => { %>
            <div class="color-swatch <%= i === 0 ? 'active' : '' %>"
              style="background:<%= v.hex %>;<%= v.hex === '#ffffff' || v.hex === '#fff' ? 'border:2px solid rgba(245,242,235,0.2);' : '' %>"
              title="<%= v.name %><%= v.stock === 0 ? ' — Out of Stock' : '' %>"
              data-index="<%= i %>" data-oos="<%= v.stock === 0 ? 'true' : 'false' %>"
              onclick="selectVariant(<%= i %>)"></div>
          <% }) %>
        </div>
      </div>
      <% } else if (product.colors && product.colors.length > 0) { %>
      <div class="color-variants">
        <div class="color-block-title">Colour</div>
        <div class="color-selected-name">Selected: <span id="selectedColorName"><%= product.colors[0].name %></span></div>
        <div class="color-swatches">
          <% product.colors.forEach((c, i) => { %>
            <div class="color-swatch <%= i === 0 ? 'active' : '' %>" style="background:<%= c.hex %>;" title="<%= c.name %>" onclick="selectFlatColor(this,'<%= c.name %>')"></div>
          <% }) %>
        </div>
      </div>
      <% } %>

      <div class="action-row">
        <div class="qty-wrap">
          <button class="qty-btn" id="qtyMinus" onclick="changeQty(-1)" <%= isOOS ? 'disabled' : '' %>>−</button>
          <input class="qty-input" type="number" id="qtyInput" value="1" min="1" max="<%= initialStock %>" <%= isOOS ? 'disabled' : '' %>/>
          <button class="qty-btn" id="qtyPlus" onclick="changeQty(1)" <%= isOOS ? 'disabled' : '' %>>+</button>
        </div>
        <button class="add-cart-btn" id="addCartBtn" onclick="handleAddToCart('<%= product._id %>')" <%= isOOS ? 'disabled' : '' %>>
          <%= isOOS ? 'Out of Stock' : 'Add to Cart' %>
        </button>
        <button class="wishlist-btn" id="wishlistBtn" onclick="handleWishlistToggle()" aria-label="Wishlist">
          <svg id="heartSvg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      </div>

      <div class="service-row">
        <span class="service-pill"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>Free Shipping</span>
        <span class="service-pill"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.75"/></svg>30-Day Returns</span>
        <span class="service-pill"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>Authenticity Cert.</span>
        <span class="service-pill"><svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7"/><path d="M9 12l2 2 4-4"/></svg>5-Year Warranty</span>
      </div>
    </div>

  </div>
</div>

<!-- TABS -->
<div class="tabs-root reveal">
  <div class="tab-nav">
    <button class="tab-btn active" id="tab-desc"    onclick="openTab('desc')">Description</button>
    <button class="tab-btn"        id="tab-specs"   onclick="openTab('specs')">Specifications</button>
    <button class="tab-btn"        id="tab-reviews" onclick="openTab('reviews')">Reviews (<%= reviewCount %>)</button>
  </div>
  <div class="tab-panel active" id="panel-desc">
    <p class="desc-text"><%= product.description || "A masterpiece of horology, this timepiece reflects the pinnacle of Velmora Chroné's craft." %></p>
  </div>
  <div class="tab-panel" id="panel-specs">
    <table class="specs-table">
      <% if (brandName) { %><tr><td>Brand</td><td><%= brandName %></td></tr><% } %>
      <% if (product.category) { %><tr><td>Category</td><td><%= product.category.name %></td></tr><% } %>
      <tr><td>Warranty</td><td><%= product.warranty || '2 Years' %></td></tr>
      <tr><td>Box Included</td><td><%= product.boxIncluded !== false ? 'Yes' : 'No' %></td></tr>
      <tr><td>Availability</td><td id="specsStock"><%= product.stock > 0 ? product.stock + ' units' : 'Sold Out' %></td></tr>
    </table>
  </div>
  <div class="tab-panel" id="panel-reviews">
    <% if (reviews.length === 0) { %>
      <div class="no-reviews">No reviews yet</div>
    <% } else { %>
      <% reviews.forEach(r => { %>
      <div class="review-item">
        <div class="review-meta">
          <span class="reviewer-name"><%= r.userName || 'Verified Buyer' %></span>
          <span class="review-date"><%= r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-IN') : '' %></span>
        </div>
        <div class="review-body"><%= r.body || r.comment || '' %></div>
      </div>
      <% }) %>
    <% } %>
  </div>
</div>

<div class="rule" style="max-width:1200px;margin:0 auto;padding:0 3rem;"></div>

<!-- RELATED -->
<% if (related && related.length > 0) { %>
<div class="related-section reveal">
  <div class="related-header">
    <p class="related-eyebrow">You Might Also Like</p>
    <a href="/products<%= product.category ? '?category='+product.category._id : '' %>" class="related-all">
      View All
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>
  </div>
  <div class="related-grid">
    <% related.forEach(p => { %>
    <a href="/products/<%= p._id %>" class="prod-card">
      <div class="prod-img-wrap">
        <% const rImg = (p.colorVariants && p.colorVariants.length > 0) ? p.colorVariants[0].images[0] : (p.images && p.images[0]); %>
        <% if (rImg) { %>
          <img class="prod-img" src="<%= rImg %>" alt="<%= p.name %>"/>
        <% } else { %>
          <div class="watch-ph"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.05)" stroke-width="0.5"><circle cx="12" cy="12" r="10"/></svg></div>
        <% } %>
      </div>
      <div class="prod-body">
        <div class="prod-cat"><%= p.category ? p.category.name : '' %></div>
        <div class="prod-name-sm"><%= p.name %></div>
        <div class="prod-price-sm">₹<%= p.price.toLocaleString('en-IN') %></div>
      </div>
    </a>
    <% }) %>
  </div>
</div>
<% } %>

