<div class="toast" id="toast"><span class="toast-dot"></span><span id="toastMsg"></span></div>


<script>
  const PRODUCT_ID     = '<%= product._id %>';
  const MAX_QTY        = 5;
  const IS_LOGGED_IN   = <%= !!currentUser %>;
  const COLOR_VARIANTS = JSON.parse('<%- JSON.stringify(variants).replace(/\\/g,"\\\\").replace(/'/g,"\\'") %>');
  let activeVariantIndex = 0;

  const SLIDE_INTERVAL = 3500;
  let slideImages   = <%- JSON.stringify(initialImages) %>;
  let slideIndex    = 0;
  let slideTimer    = null;
  let isPaused      = false;
  let isZoomed      = false;

  const mainImg      = document.getElementById('mainImg');
  const overlay      = document.getElementById('slideOverlay');
  const counterEl    = document.getElementById('slideCounter');
  const dotsEl       = document.getElementById('slideDots');
  const mainWrap     = document.getElementById('mainImgWrap');

  function buildDots() {
    dotsEl.innerHTML = '';
    if (slideImages.length <= 1) { dotsEl.style.display = 'none'; return; }
    dotsEl.style.display = 'flex';
    slideImages.forEach((_, i) => {
      const d = document.createElement('div');
      d.className = 'slide-dot' + (i === 0 ? ' active' : '');
      d.onclick = () => goToSlide(i, true);
      dotsEl.appendChild(d);
    });
  }

  function updateDots() {
    document.querySelectorAll('.slide-dot').forEach((d, i) => d.classList.toggle('active', i === slideIndex));
  }

  function updateCounter() {
    if (slideImages.length <= 1) { counterEl.style.display = 'none'; return; }
    counterEl.style.display = 'block';
    counterEl.textContent = (slideIndex + 1) + ' / ' + slideImages.length;
  }

  function updateThumbs() {
    document.querySelectorAll('.thumb').forEach((t, i) => t.classList.toggle('active', i === slideIndex));
  }

  function crossfadeTo(src, onDone) {
    if (!mainImg) { if (onDone) onDone(); return; }
    overlay.style.backgroundImage = `url('${src}')`;
    overlay.style.backgroundSize  = 'cover';
    overlay.style.backgroundPosition = 'center';
    overlay.offsetHeight;
    overlay.classList.add('fading');
    setTimeout(() => {
      mainImg.src = src;
      overlay.classList.remove('fading');
      overlay.style.backgroundImage = '';
      if (onDone) onDone();
    }, 560);
  }

  function goToSlide(idx, manual = false) {
    if (!slideImages.length) return;
    idx = ((idx % slideImages.length) + slideImages.length) % slideImages.length;
    if (idx === slideIndex && !manual) return;
    slideIndex = idx;
    crossfadeTo(slideImages[slideIndex]);
    updateDots();
    updateCounter();
    updateThumbs();
    if (manual) { restartSlideshow(); }
  }

  function startSlideshow() {
    if (slideImages.length <= 1) return;
    clearInterval(slideTimer);
    slideTimer = setInterval(() => {
      if (!isPaused && !isZoomed) goToSlide(slideIndex + 1);
    }, SLIDE_INTERVAL);
  }

  function stopSlideshow() { clearInterval(slideTimer); }
  function restartSlideshow() { stopSlideshow(); startSlideshow(); }

  mainWrap.addEventListener('mouseenter', () => { isPaused = true; });
  mainWrap.addEventListener('mouseleave', () => { if (!isZoomed) { isPaused = false; restartSlideshow(); } });

  let touchStartX = 0;
  mainWrap.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, { passive: true });
  mainWrap.addEventListener('touchend', e => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    if (Math.abs(dx) > 40) { manualSlide(dx < 0 ? 1 : -1); }
  }, { passive: true });

  function manualSlide(dir, e) {
    if (e) e.stopPropagation();
    goToSlide(slideIndex + dir, true);
  }

  function thumbClick(thumb, src, idx) {
    if (isZoomed) return;
    slideIndex = idx;
    crossfadeTo(src);
    updateDots();
    updateCounter();
    document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
    thumb.classList.add('active');
    restartSlideshow();
  }

  function loadImageSet(images) {
    slideImages = images;
    slideIndex  = 0;
    buildDots();
    updateCounter();
    stopSlideshow();
    if (mainImg && images.length > 0) {
      const thumbRow = document.getElementById('thumbRow');
      thumbRow.innerHTML = images.map((src, i) => `<div class="thumb ${i===0?'active':''}" onclick="thumbClick(this,'${src}',${i})"><img src="${src}" alt="View ${i+1}"/></div>`).join('');
      crossfadeTo(images[0], () => startSlideshow());
    }
  }

  buildDots();
  updateCounter();
  startSlideshow();

  function handleImgClick(e) {
    if (e.target.closest('.slide-arrow') || e.target.closest('.slide-dot')) return;
    isZoomed = !isZoomed;
    mainWrap.classList.toggle('zoomed', isZoomed);
    if (mainImg) mainImg.classList.toggle('zoomed', isZoomed);
    if (isZoomed) { isPaused = true; updateZoomOrigin(e); stopSlideshow(); }
    else { isPaused = false; startSlideshow(); }
  }
  mainWrap.addEventListener('mousemove', e => { if (isZoomed && mainImg) updateZoomOrigin(e); });
  function updateZoomOrigin(e) {
    const r = mainWrap.getBoundingClientRect();
    if (mainImg) mainImg.style.transformOrigin = `${((e.clientX-r.left)/r.width)*100}% ${((e.clientY-r.top)/r.height)*100}%`;
  }

  function selectVariant(idx) {
    const v = COLOR_VARIANTS[idx];
    if (!v) return;
    activeVariantIndex = idx;
    document.querySelectorAll('.color-swatch').forEach((s, i) => s.classList.toggle('active', i === idx));
    const nameEl = document.getElementById('selectedColorName');
    if (nameEl) nameEl.textContent = v.name;
    isZoomed = false;
    mainWrap.classList.remove('zoomed');
    if (mainImg) mainImg.classList.remove('zoomed');
    loadImageSet(v.images || []);
    updateStockUI(v.stock);
  }

  function selectFlatColor(el, name) {
    document.querySelectorAll('.color-swatch').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    const nameEl = document.getElementById('selectedColorName');
    if (nameEl) nameEl.textContent = name;
  }

  // Mutable flat stock — overwritten immediately by the live stock fetch on load
  let currentFlatStock = <%= initialStock %>;

  function updateStockUI(stock) {
    if (COLOR_VARIANTS.length === 0) currentFlatStock = stock;

    const badge    = document.getElementById('stockBadge');
    const dot      = document.getElementById('stockDot');
    const text     = document.getElementById('stockText');
    const qtyInput = document.getElementById('qtyInput');
    const qtyMinus = document.getElementById('qtyMinus');
    const qtyPlus  = document.getElementById('qtyPlus');
    const addBtn   = document.getElementById('addCartBtn');
    const specsStk = document.getElementById('specsStock');
    const isOOS = stock === 0, isLow = stock > 0 && stock <= 5;

    if (badge)   badge.className = 'stock-badge ' + (isOOS ? 'out' : isLow ? 'low' : 'in');
    if (dot)     dot.className   = 'stock-dot '   + (isOOS ? 'out' : isLow ? 'low' : 'in');
    if (text) {
      if (isOOS)      text.textContent = 'Out of Stock';
      else if (isLow) text.textContent = `Low Stock — Only ${stock} left`;
      else            text.textContent = `In Stock · ${stock} available`;
    }

    const mainImgWrap = document.getElementById('mainImgWrap');
    let imgBadge = mainImgWrap ? mainImgWrap.querySelector('.img-badge') : null;
    if (isOOS || isLow) {
      if (!imgBadge && mainImgWrap) {
        imgBadge = document.createElement('span');
        mainImgWrap.prepend(imgBadge);
      }
      if (imgBadge) {
        imgBadge.className   = 'img-badge ' + (isOOS ? 'badge-oos' : 'badge-low');
        imgBadge.textContent = isOOS ? 'Out of Stock' : `Only ${stock} Left`;
      }
    } else {
      if (imgBadge && (imgBadge.classList.contains('badge-oos') || imgBadge.classList.contains('badge-low'))) {
        imgBadge.remove();
      }
    }

    if (qtyInput) {
      qtyInput.max      = stock;
      qtyInput.value    = Math.min(parseInt(qtyInput.value) || 1, Math.min(stock, MAX_QTY));
      qtyInput.disabled = isOOS;
    }
    const qtyVal = parseInt(qtyInput ? qtyInput.value : 1);
    if (qtyMinus) qtyMinus.disabled = isOOS || qtyVal <= 1;
    if (qtyPlus)  qtyPlus.disabled  = isOOS || qtyVal >= Math.min(stock, MAX_QTY);
    if (addBtn)   { addBtn.disabled = isOOS; addBtn.textContent = isOOS ? 'Out of Stock' : 'Add to Cart'; }
    if (specsStk) specsStk.textContent = isOOS ? 'Sold Out' : stock + ' units';

    if (COLOR_VARIANTS.length > 0) {
      document.querySelectorAll('.color-swatch').forEach((sw, i) => {
        const v = COLOR_VARIANTS[i];
        if (!v) return;
        sw.dataset.oos = v.stock === 0 ? 'true' : 'false';
        sw.title = v.name + (v.stock === 0 ? ' — Out of Stock' : '');
      });
    }
  }

  function getCurrentStock() {
    if (COLOR_VARIANTS.length > 0) return COLOR_VARIANTS[activeVariantIndex].stock;
    return currentFlatStock;
  }

  function changeQty(delta) {
    const input = document.getElementById('qtyInput');
    const stock = getCurrentStock();
    const cap   = Math.min(stock, MAX_QTY);
    const val   = Math.min(cap, Math.max(1, parseInt(input.value || 1) + delta));
    input.value = val;
    document.getElementById('qtyMinus').disabled = val <= 1;
    document.getElementById('qtyPlus').disabled  = val >= cap;
  }

  // ✅ KEY FIX: fetch live stock from DB on every page load.
  // The EJS bakes initialStock into the HTML at render time, but if another
  // user purchased between renders, that value is stale. This call overwrites
  // the UI with the actual current DB value immediately after the page loads,
  // so the user always sees the correct stock before they can click anything.
  async function syncStockFromDB() {
    try {
      const res  = await fetch(`/products/${PRODUCT_ID}/stock`);
      if (!res.ok) return;
      const data = await res.json();
      if (!data.success) return;

      if (COLOR_VARIANTS.length > 0 && data.colorVariants?.length > 0) {
        // Patch each variant's stock from the live DB response
        data.colorVariants.forEach(updated => {
          const match = COLOR_VARIANTS.find(v => v.name === updated.name);
          if (match) match.stock = updated.stock;
        });
        // Update UI for the currently selected variant
        updateStockUI(COLOR_VARIANTS[activeVariantIndex].stock);
      } else {
        // Flat-stock product
        currentFlatStock = data.stock;
        updateStockUI(data.stock);
      }
    } catch (err) {
      console.warn('[syncStockFromDB] failed silently:', err);
      // Non-fatal — page still works, SSE will pick up changes
    }
  }

  // Run immediately on page load — before user can interact
  syncStockFromDB();

  async function handleAddToCart(productId) {
    if (!IS_LOGGED_IN) { window.location.href = '/login'; return; }

    const currentStock = getCurrentStock();
    if (currentStock === 0) {
      showToast('This item is currently out of stock', true);
      return;
    }

    const qty = parseInt(document.getElementById('qtyInput').value) || 1;
    const btn = document.getElementById('addCartBtn');
    btn.disabled = true;
    btn.textContent = 'Adding…';

    try {
      const body = { productId, quantity: qty };
      if (COLOR_VARIANTS.length > 0) {
        body.variantIndex = activeVariantIndex;
        body.variantName  = COLOR_VARIANTS[activeVariantIndex].name;
      }

      const res  = await fetch('/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(body)
      });

      let data = {};
      const contentType = res.headers.get('content-type') || '';
      if (contentType.includes('application/json')) {
        data = await res.json();
      }

      if (res.status === 401) {
        window.location.href = data.redirectUrl || '/login';
        return;
      }

      if (!res.ok) {
        showToast(data.message || 'Could not add to cart', true);
        // ✅ If server says out of stock, sync UI immediately
        if (res.status === 400) await syncStockFromDB();
        return;
      }

      showToast('Added to cart ✓');
      if (data.cartCount !== undefined) {
        document.getElementById('cartCount').textContent = data.cartCount;
      }

    } catch (err) {
      console.error('Cart error:', err);
      showToast('Something went wrong', true);
    } finally {
      const stockNow = getCurrentStock();
      const isNowOOS = stockNow === 0;
      btn.disabled    = isNowOOS;
      btn.textContent = isNowOOS ? 'Out of Stock' : 'Add to Cart';
    }
  }

  let wishlisted = false;
  function applyWishlistUI(state) {
    const btn = document.getElementById('wishlistBtn'), heartSvg = document.getElementById('heartSvg');
    if (btn) btn.classList.toggle('active', state);
    if (heartSvg) { heartSvg.setAttribute('fill', state ? '#f87171' : 'none'); heartSvg.setAttribute('stroke', state ? '#f87171' : 'currentColor'); }
    const navBtn = document.getElementById('navWishlistBtn'), navHeart = document.getElementById('navHeartSvg');
    if (navBtn)   navBtn.classList.toggle('wishlisted', state);
    if (navHeart) { navHeart.setAttribute('fill', state ? '#f87171' : 'none'); navHeart.setAttribute('stroke', state ? '#f87171' : 'currentColor'); }
  }
  async function checkWishlistStatus() {
    if (!IS_LOGGED_IN) return;
    try {
      const res = await fetch(`/wishlist/status/${PRODUCT_ID}`, { headers: { 'Accept': 'application/json' } });
      if (!res.ok) return;
      const data = await res.json();
      wishlisted = !!data.wishlisted;
      applyWishlistUI(wishlisted);
    } catch {}
  }
  async function handleWishlistToggle() {
    if (!IS_LOGGED_IN) { window.location.href = '/login'; return; }
    const btn = document.getElementById('wishlistBtn');
    if (btn) btn.disabled = true;
    try {
      const res  = await fetch('/wishlist/toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ productId: PRODUCT_ID })
      });
      const data = await res.json();
      if (res.status === 401) { window.location.href = data.redirectUrl || '/login'; return; }
      if (!res.ok) { showToast(data.message || 'Could not update wishlist', true); return; }
      wishlisted = !!data.wishlisted;
      applyWishlistUI(wishlisted);
      showToast(wishlisted ? 'Added to wishlist ♥' : 'Removed from wishlist');
    } catch { showToast('Something went wrong', true); }
    finally { if (btn) btn.disabled = false; }
  }
  checkWishlistStatus();

  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 20), { passive: true });
  document.getElementById('hamburger').addEventListener('click', function () {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });

  if (IS_LOGGED_IN) {
    fetch('/api/cart/count', { headers: { 'Accept': 'application/json' } })
      .then(r => r.json())
      .then(d => { if (d.count !== undefined) document.getElementById('cartCount').textContent = d.count; })
      .catch(() => {});
  }

  const revealEls = document.querySelectorAll('.reveal');
  const revealObs = new IntersectionObserver(entries => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        setTimeout(() => e.target.classList.add('visible'), i * 80);
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.06 });
  revealEls.forEach(el => revealObs.observe(el));

  function openTab(id) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.getElementById('tab-' + id).classList.add('active');
    document.getElementById('panel-' + id).classList.add('active');
    document.querySelector('.tabs-root').scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  let toastTimer;
  function showToast(msg, isErr = false) {
    const toast = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    toast.className = 'toast show' + (isErr ? ' err' : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // ── SSE: live stock/price updates with auto-reconnect ──
  (function () {
    let es = null;
    let reconnectDelay = 3000;

    function connectSSE() {
      if (es) { try { es.close(); } catch(e) {} }
      es = new EventSource('/sse/products');

      es.addEventListener('productUpdate', function (e) {
        let data;
        try { data = JSON.parse(e.data); } catch { return; }
        if (data.productId !== PRODUCT_ID) return;

        reconnectDelay = 3000;

        if (data.colorVariants && COLOR_VARIANTS.length > 0) {
          data.colorVariants.forEach(updated => {
            const match = COLOR_VARIANTS.find(v => v.name === updated.name);
            if (match) match.stock = updated.stock;
          });
          updateStockUI(COLOR_VARIANTS[activeVariantIndex].stock);
        } else if (data.stock !== undefined) {
          currentFlatStock = data.stock;
          updateStockUI(data.stock);
        }

        if (data.price !== undefined) {
          const el = document.querySelector('.prod-price');
          if (el) el.textContent = '₹' + Number(data.price).toLocaleString('en-IN');
        }

        if (data.isDeleted || data.isListed === false) {
          const btn = document.getElementById('addCartBtn');
          if (btn) { btn.disabled = true; btn.textContent = 'No Longer Available'; }
        }
      });

      es.onerror = function () {
        try { es.close(); } catch(e) {}
        setTimeout(() => {
          reconnectDelay = Math.min(reconnectDelay * 1.5, 30000);
          connectSSE();
        }, reconnectDelay);
      };
    }

    connectSSE();
  })();
</script>
</body>
</html>
