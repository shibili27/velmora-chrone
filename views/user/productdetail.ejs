<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= product.name %> — Velmora Chroné</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: #111110; color: #f5f2eb; overflow-x: hidden; }
    ::-webkit-scrollbar { width: 2px; }
    ::-webkit-scrollbar-track { background: #111110; }
    ::-webkit-scrollbar-thumb { background: #c9a96e; }

    .nav-root { position: fixed; top: 0; left: 0; right: 0; z-index: 200; background: #111110; border-bottom: 1px solid rgba(245,242,235,0.06); transition: box-shadow 0.3s; }
    .nav-root.scrolled { box-shadow: 0 2px 20px rgba(0,0,0,0.3); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; }
    @media(min-width:768px) { .nav-inner { padding: 1rem 3rem; } }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; font-weight: 300; letter-spacing: 0.25em; text-transform: uppercase; color: #f5f2eb; text-decoration: none; }
    .nav-link { font-family: 'Jost', sans-serif; font-size: 0.55rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.55); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover, .nav-link.active { color: #f5f2eb; }
    .nav-icon { color: rgba(245,242,235,0.6); background: none; border: none; cursor: pointer; transition: color 0.2s; text-decoration: none; display: flex; align-items: center; }
    .nav-icon:hover { color: #c9a96e; }
    .nav-icon.wishlisted { color: #f87171; }
    .cart-badge { position: absolute; top: -4px; right: -5px; width: 13px; height: 13px; border-radius: 50%; background: #c9a96e; font-size: 0.4rem; font-weight: 600; color: #111110; display: flex; align-items: center; justify-content: center; }
    .wishlist-nav-badge { position: absolute; top: -4px; right: -5px; width: 13px; height: 13px; border-radius: 50%; background: #f87171; font-size: 0.4rem; font-weight: 600; color: #fff; display: none; align-items: center; justify-content: center; }
    .hamburger { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 3px; }
    .hamburger span { display: block; width: 20px; height: 1px; background: rgba(245,242,235,0.7); transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
    .mobile-menu { display: none; flex-direction: column; background: #0d0d0c; padding: 1.5rem 2rem; gap: 1rem; border-top: 1px solid rgba(245,242,235,0.05); }
    .mobile-menu.open { display: flex; }
    .mobile-menu .nav-link { font-size: 0.7rem; padding: 0.4rem 0; border-bottom: 1px solid rgba(245,242,235,0.04); color: rgba(245,242,235,0.5); }

    .breadcrumb { padding: 5.5rem 3rem 0; max-width: 1200px; margin: 0 auto; display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; }
    .breadcrumb a { font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.3); text-decoration: none; transition: color 0.2s; }
    .breadcrumb a:hover { color: rgba(245,242,235,0.6); }
    .breadcrumb span.sep { font-size: 0.5rem; color: rgba(245,242,235,0.15); }
    .breadcrumb-current { font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(201,169,110,0.7); }

    .detail-wrap { max-width: 1200px; margin: 0 auto; padding: 2rem 2rem 5rem; }
    @media(min-width:768px) { .detail-wrap { padding: 2rem 3rem 5rem; } }
    .detail-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
    @media(min-width:900px) { .detail-grid { grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; } }

    .gallery { display: flex; flex-direction: column; gap: 0.75rem; }
    .main-img-wrap { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: #1a1a18; position: relative; cursor: zoom-in; border: 1px solid rgba(245,242,235,0.05); }
    .main-img-wrap.zoomed { cursor: zoom-out; }
    .main-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94); transform-origin: center center; pointer-events: none; user-select: none; }
    .main-img.zoomed { transform: scale(2.4); }
    .zoom-hint { position: absolute; bottom: 10px; right: 12px; font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,242,235,0.2); display: flex; align-items: center; gap: 4px; pointer-events: none; transition: opacity 0.3s; }
    .main-img-wrap.zoomed .zoom-hint { opacity: 0; }
    .img-badge { position: absolute; top: 12px; left: 12px; z-index: 2; font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.18em; text-transform: uppercase; padding: 3px 9px; }
    .badge-oos      { background: rgba(248,113,113,0.1); border: 1px solid rgba(248,113,113,0.3); color: #f87171; }
    .badge-low      { background: rgba(251,191,36,0.1);  border: 1px solid rgba(251,191,36,0.3);  color: #fbbf24; }
    .badge-discount { background: rgba(201,169,110,0.12);border: 1px solid rgba(201,169,110,0.3); color: #c9a96e; }

    .thumb-row { display: flex; gap: 0.5rem; overflow-x: auto; padding-bottom: 4px; }
    .thumb { width: 70px; height: 55px; overflow: hidden; background: #1a1a18; cursor: pointer; border: 1px solid transparent; transition: border-color 0.2s, opacity 0.2s; flex-shrink: 0; }
    .thumb.active { border-color: #c9a96e; }
    .thumb img { width: 100%; height: 100%; object-fit: cover; }
    .thumb:not(.active) img { opacity: 0.5; }
    .thumb:hover img { opacity: 1; }
    .watch-ph { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #1a1a18; }

    .info-col { display: flex; flex-direction: column; gap: 0; }
    .prod-category { font-family: 'Jost', sans-serif; font-size: 0.45rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(245,242,235,0.3); margin-bottom: 0.5rem; }
    .prod-brand-tag { font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(201,169,110,0.65); margin-bottom: 0.6rem; border: 1px solid rgba(201,169,110,0.15); padding: 2px 8px; display: inline-block; }
    .prod-name { font-family: 'Cormorant Garamond', serif; font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 300; color: #f5f2eb; line-height: 1.15; margin-bottom: 0.75rem; }
    .divider { width: 40px; height: 1px; background: rgba(201,169,110,0.4); margin-bottom: 1rem; }

    .rating-row { display: flex; align-items: center; gap: 10px; margin-bottom: 1.25rem; flex-wrap: wrap; }
    .stars { display: flex; gap: 2px; }
    .star { width: 11px; height: 11px; }
    .star polygon.filled  { fill: #c9a96e; }
    .star polygon.empty   { fill: none; stroke: rgba(201,169,110,0.3); stroke-width: 1.5; }
    .rating-num { font-family: 'Jost', sans-serif; font-size: 0.6rem; color: rgba(245,242,235,0.5); }
    .review-link { font-family: 'Jost', sans-serif; font-size: 0.52rem; color: rgba(245,242,235,0.3); text-decoration: underline; text-underline-offset: 3px; cursor: pointer; transition: color 0.2s; }
    .review-link:hover { color: rgba(245,242,235,0.6); }

    .price-block { margin-bottom: 0.35rem; }
    .price-row { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; }
    .prod-price { font-family: 'Jost', sans-serif; font-size: 1.4rem; font-weight: 300; color: #f5f2eb; letter-spacing: 0.05em; }
    .prod-price-label { font-family: 'Jost', sans-serif; font-size: 0.45rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.2); margin-bottom: 1rem; margin-top: 3px; }

    .stock-badge { display: inline-flex; align-items: center; gap: 6px; font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem; }
    .stock-dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; }
    .stock-dot.in  { background: #4ade80; box-shadow: 0 0 6px rgba(74,222,128,0.5); }
    .stock-dot.low { background: #fbbf24; box-shadow: 0 0 6px rgba(251,191,36,0.4); }
    .stock-dot.out { background: #f87171; }
    .stock-badge.in  { color: rgba(74,222,128,0.8); }
    .stock-badge.low { color: rgba(251,191,36,0.8); }
    .stock-badge.out { color: rgba(248,113,113,0.8); }

    .color-variants { margin-bottom: 1.5rem; }
    .color-variants-label { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(245,242,235,0.35); margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(245,242,235,0.06); }
    .color-selected-name { font-family: 'Jost', sans-serif; font-size: 0.52rem; color: rgba(245,242,235,0.5); margin-bottom: 0.75rem; letter-spacing: 0.08em; }
    .color-selected-name span { color: #f5f2eb; }
    .color-swatches { display: flex; flex-wrap: wrap; gap: 10px; }
    .color-swatch { width: 32px; height: 32px; border-radius: 50%; cursor: pointer; border: 2px solid transparent; transition: all 0.2s; position: relative; flex-shrink: 0; }
    .color-swatch:hover { transform: scale(1.1); }
    .color-swatch.active { border-color: rgba(245,242,235,0.6); box-shadow: 0 0 0 3px rgba(245,242,235,0.1); }
    .color-swatch[data-oos="true"] { opacity: 0.35; cursor: not-allowed; }
    .color-swatch[data-oos="true"]::after { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 1.5px; background: rgba(248,113,113,0.7); transform: rotate(-45deg); }
    .color-swatch[title]::before { content: attr(title); position: absolute; bottom: 110%; left: 50%; transform: translateX(-50%); background: #1a1a18; border: 1px solid rgba(245,242,235,0.08); color: rgba(245,242,235,0.7); font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.1em; white-space: nowrap; padding: 3px 8px; pointer-events: none; opacity: 0; transition: opacity 0.2s; }
    .color-swatch:hover::before { opacity: 1; }

    .gallery-fade { opacity: 0; transition: opacity 0.25s; }
    .gallery-fade.visible { opacity: 1; }

    .action-row { display: flex; gap: 0.75rem; align-items: stretch; margin-bottom: 1rem; }
    .qty-wrap { display: flex; align-items: center; border: 1px solid rgba(245,242,235,0.12); }
    .qty-btn { width: 36px; height: 48px; background: none; border: none; color: rgba(245,242,235,0.5); font-size: 1rem; cursor: pointer; transition: color 0.2s, background 0.2s; display: flex; align-items: center; justify-content: center; }
    .qty-btn:hover:not(:disabled) { color: #f5f2eb; background: rgba(245,242,235,0.05); }
    .qty-btn:disabled { opacity: 0.2; cursor: not-allowed; }
    .qty-input { width: 44px; height: 48px; background: transparent; border: none; border-left: 1px solid rgba(245,242,235,0.12); border-right: 1px solid rgba(245,242,235,0.12); text-align: center; font-family: 'Jost', sans-serif; font-size: 0.75rem; color: #f5f2eb; outline: none; }
    .qty-input::-webkit-outer-spin-button, .qty-input::-webkit-inner-spin-button { -webkit-appearance: none; }
    .add-cart-btn { flex: 1; background: #c9a96e; color: #111110; font-family: 'Jost', sans-serif; font-size: 0.55rem; letter-spacing: 0.25em; text-transform: uppercase; border: none; cursor: pointer; padding: 0 1.5rem; height: 48px; transition: background 0.2s; }
    .add-cart-btn:hover:not(:disabled) { background: #d4b97e; }
    .add-cart-btn:disabled { background: rgba(245,242,235,0.06); color: rgba(245,242,235,0.18); cursor: not-allowed; }
    .wishlist-btn { width: 48px; height: 48px; border: 1px solid rgba(245,242,235,0.12); background: none; color: rgba(245,242,235,0.4); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: color 0.2s, border-color 0.2s; }
    .wishlist-btn:hover { color: #c9a96e; border-color: rgba(201,169,110,0.4); }
    .wishlist-btn.active { color: #f87171; border-color: rgba(248,113,113,0.3); }
    .wishlist-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .section-title { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(245,242,235,0.35); margin-bottom: 0.75rem; margin-top: 2rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(245,242,235,0.06); }
    .prod-desc { font-family: 'Jost', sans-serif; font-size: 0.7rem; font-weight: 300; color: rgba(245,242,235,0.45); line-height: 1.9; letter-spacing: 0.03em; }

    .service-row { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 1.25rem; padding-top: 1rem; border-top: 1px solid rgba(245,242,235,0.05); }
    .service-pill { display: flex; align-items: center; gap: 5px; font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.1em; color: rgba(245,242,235,0.3); }
    .service-pill svg { color: rgba(201,169,110,0.5); }

    .tabs-root { max-width: 1200px; margin: 0 auto; padding: 0 2rem 3rem; }
    @media(min-width:768px) { .tabs-root { padding: 0 3rem 3rem; } }
    .tab-nav { display: flex; border-bottom: 1px solid rgba(245,242,235,0.07); overflow-x: auto; }
    .tab-btn { font-family: 'Jost', sans-serif; font-size: 0.52rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.3); background: none; border: none; padding: 0.75rem 1.5rem; cursor: pointer; position: relative; transition: color 0.2s; white-space: nowrap; flex-shrink: 0; }
    .tab-btn::after { content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 1px; background: #c9a96e; transform: scaleX(0); transition: transform 0.2s; }
    .tab-btn.active { color: #f5f2eb; }
    .tab-btn.active::after { transform: scaleX(1); }
    .tab-panel { display: none; padding: 2rem 0; }
    .tab-panel.active { display: block; }
    .desc-text { font-family: 'Jost', sans-serif; font-size: 0.65rem; color: rgba(245,242,235,0.45); line-height: 1.9; }
    .specs-table { width: 100%; border-collapse: collapse; }
    .specs-table tr { border-bottom: 1px solid rgba(245,242,235,0.04); }
    .specs-table td { padding: 0.65rem 0.5rem; font-family: 'Jost', sans-serif; font-size: 0.58rem; }
    .specs-table td:first-child { color: rgba(245,242,235,0.3); letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.48rem; width: 40%; }
    .specs-table td:last-child { color: rgba(245,242,235,0.65); }

    .related-section { max-width: 1200px; margin: 0 auto; padding: 0 2rem 5rem; }
    @media(min-width:768px) { .related-section { padding: 0 3rem 5rem; } }
    .related-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(245,242,235,0.06); }
    .related-title { font-family: 'Cormorant Garamond', serif; font-size: 1.4rem; font-weight: 300; color: rgba(245,242,235,0.7); }
    .related-all { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.28); text-decoration: none; transition: color 0.2s; }
    .related-all:hover { color: #c9a96e; }
    .related-grid { display: grid; gap: 1.5rem; grid-template-columns: repeat(2,1fr); }
    @media(min-width:640px) { .related-grid { grid-template-columns: repeat(4,1fr); } }
    .prod-card { background: #1a1a18; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s; }
    .prod-card:hover { transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0,0,0,0.4); }
    .prod-card:hover .prod-img { transform: scale(1.04); }
    .prod-img-wrap { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: #222220; }
    .prod-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .prod-body { padding: 1rem 1rem 0; text-align: center; }
    .prod-cat { font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.25); margin-bottom: 3px; }
    .prod-name-sm { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; color: #f5f2eb; line-height: 1.2; margin-bottom: 4px; }
    .prod-price-sm { font-family: 'Jost', sans-serif; font-size: 0.6rem; color: rgba(245,242,235,0.45); }
    .view-btn { display: block; width: 100%; margin-top: 0.75rem; background: #111110; color: rgba(245,242,235,0.5); font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.65rem; border: none; cursor: pointer; text-align: center; text-decoration: none; border-top: 1px solid rgba(245,242,235,0.06); transition: background 0.2s, color 0.2s; }
    .view-btn:hover { background: #c9a96e; color: #111110; }

    .toast { position: fixed; bottom: 2rem; right: 2rem; z-index: 999; background: #1a1a18; border: 1px solid rgba(201,169,110,0.25); color: #f5f2eb; font-family: 'Jost', sans-serif; font-size: 0.58rem; letter-spacing: 0.08em; padding: 0.8rem 1.25rem; display: flex; align-items: center; gap: 10px; transform: translateY(80px); opacity: 0; transition: transform 0.35s, opacity 0.35s; pointer-events: none; min-width: 220px; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.err { border-color: rgba(248,113,113,0.3); }
    .toast-dot { width: 5px; height: 5px; border-radius: 50%; background: #c9a96e; flex-shrink: 0; }
    .toast.err .toast-dot { background: #f87171; }

    .footer { background: #0a0a09; padding: 4rem 2rem 1.5rem; border-top: 1px solid rgba(245,242,235,0.05); }
    @media(min-width:768px) { .footer { padding: 4rem 3rem 1.5rem; } }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-top { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid rgba(245,242,235,0.05); }
    @media(min-width:768px) { .footer-top { grid-template-columns: 1.2fr 1fr 1fr 1.2fr; gap: 3rem; } }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: #f5f2eb; line-height: 1.4; margin-bottom: 0.75rem; }
    .footer-desc { font-family: 'Jost', sans-serif; font-size: 0.6rem; font-weight: 300; color: rgba(245,242,235,0.25); line-height: 1.85; margin-bottom: 1rem; }
    .footer-col-title { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(245,242,235,0.35); margin-bottom: 1rem; display: block; }
    .footer-link { display: block; font-family: 'Jost', sans-serif; font-size: 0.55rem; letter-spacing: 0.1em; color: rgba(245,242,235,0.25); text-decoration: none; transition: color 0.2s; margin-bottom: 0.5rem; }
    .footer-link:hover { color: rgba(245,242,235,0.6); }
    .footer-bottom { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 1.5rem; align-items: center; text-align: center; }
    @media(min-width:768px) { .footer-bottom { flex-direction: row; justify-content: space-between; } }
    .footer-copy { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,242,235,0.15); }
    .footer-legal { display: flex; gap: 1.25rem; }
    .footer-legal a { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(245,242,235,0.2); text-decoration: none; transition: color 0.2s; }
    .footer-legal a:hover { color: rgba(245,242,235,0.5); }
  </style>
</head>
<body>

<%
  const hasVariants = product.colorVariants && product.colorVariants.length > 0;
  const variants = hasVariants
    ? product.colorVariants.map(v => ({
        name:   v.name,
        hex:    v.hex,
        images: v.images || [],
        stock:  v.stock  || 0,
      }))
    : [];

  const initialImages = hasVariants ? (variants[0].images || []) : (product.images || []);
  const initialStock  = hasVariants ? variants[0].stock : product.stock;

  const isOOS       = initialStock === 0;
  const isLow       = initialStock > 0 && initialStock <= 5;
  const hasDiscount = product.originalPrice && product.originalPrice > product.price;
  const discPct     = hasDiscount ? Math.round((1 - product.price / product.originalPrice) * 100) : 0;

  const avgRating   = product.avgRating  || 0;
  const reviewCount = product.reviewCount || (product.reviews ? product.reviews.length : 0);
  const reviews     = product.reviews    || [];
  const rc = {5:0, 4:0, 3:0, 2:0, 1:0};
  let rSum = 0;
  reviews.forEach(r => { rc[r.rating] = (rc[r.rating]||0)+1; rSum += r.rating; });

  const brandName = product.brand
    ? (typeof product.brand === 'object' ? product.brand.name : product.brand)
    : null;
%>

<svg width="0" height="0" style="position:absolute">
  <defs>
    <linearGradient id="halfGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="50%" stop-color="#c9a96e"/>
