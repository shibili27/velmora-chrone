<script>
/* ── NAV SCROLL ── */
const navbar = document.getElementById('navbar');
window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive: true });

/* ── HAMBURGER ── */
const hamburger  = document.getElementById('hamburger');
const mobileMenu = document.getElementById('mobileMenu');
hamburger.addEventListener('click', () => { hamburger.classList.toggle('open'); mobileMenu.classList.toggle('open'); });
mobileMenu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => { hamburger.classList.remove('open'); mobileMenu.classList.remove('open'); }));

/* ── REVEAL ON SCROLL ── */
const revealEls = document.querySelectorAll('.reveal');
const observer  = new IntersectionObserver(entries => {
  entries.forEach((entry, i) => {
    if (entry.isIntersecting) { setTimeout(() => entry.target.classList.add('visible'), i * 80); observer.unobserve(entry.target); }
  });
}, { threshold: 0.08 });
revealEls.forEach(el => observer.observe(el));

/* ── TOAST ── */
let toastTimer;
function showToast(msg, isErr = false) {
  const toast = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = msg;
  toast.className = 'toast show' + (isErr ? ' err' : '');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
}

/* ── HERO VIDEO ── */
(function () {
  const video  = document.getElementById('heroVideo');
  const poster = document.getElementById('heroPoster');
  if (!video) return;
  video.addEventListener('error', () => {
    video.style.display = 'none';
    if (poster) { poster.style.opacity = '1'; poster.style.pointerEvents = 'auto'; }
  });
  video.play().catch(() => {});
})();

function toggleHeroSound() {
  const video    = document.getElementById('heroVideo');
  const iconMute = document.getElementById('iconMuted');
  const iconSnd  = document.getElementById('iconSound');
  if (!video) return;
  video.muted = !video.muted;
  iconMute.style.display = video.muted ? '' : 'none';
  iconSnd.style.display  = video.muted ? 'none' : '';
}

/* ── WISHLIST ── */
function toggleWishlist(e, btn) {
  e.preventDefault(); e.stopPropagation();
  const active = btn.classList.toggle('active');
  const svg    = btn.querySelector('svg');
  svg.setAttribute('fill',   active ? '#f87171' : 'none');
  svg.setAttribute('stroke', active ? '#f87171' : 'currentColor');
  showToast(active ? 'Saved to wishlist ♥' : 'Removed from wishlist');
}

/* ── CART COUNT ── */
fetch('/api/cart/count', { headers: { 'Accept': 'application/json' } })
  .then(r => r.json())
  .then(d => { if (d.count !== undefined) document.getElementById('cartBadge').textContent = d.count; })
  .catch(() => {});

/* ── CAROUSEL ── */
(function () {
  const track    = document.getElementById('carouselTrack');
  const dotsWrap = document.getElementById('carouselDots');
  const outer    = document.getElementById('carouselOuter');
  if (!track) return;
  const cards = track.querySelectorAll('.prod-card');
  const total = cards.length;
  if (total === 0) return;
  const GAP = 14;

  function cardWidth() {
    const vis = window.innerWidth < 640 ? 2 : 4;
    return (outer.offsetWidth - GAP * (vis - 1)) / vis;
  }
  function setCardWidths() {
    const w = cardWidth();
    cards.forEach(c => { c.style.width = w + 'px'; c.style.flex = '0 0 ' + w + 'px'; });
  }
  setCardWidths();
  window.addEventListener('resize', () => { setCardWidths(); buildDots(); goTo(0); });

  let current = 0;
  let autoTimer;
  function visible() { return window.innerWidth < 640 ? 2 : 4; }

  function buildDots() {
    dotsWrap.innerHTML = '';
    const numDots = Math.ceil(total / visible());
    for (let i = 0; i < numDots; i++) {
      const dot = document.createElement('button');
      dot.className = 'carousel-dot';
      dot.style.width = i === 0 ? '18px' : '6px';
      dot.style.background = i === 0 ? '#c9a96e' : 'rgba(245,242,235,0.08)';
      dot.addEventListener('click', () => goTo(i * visible()));
      dotsWrap.appendChild(dot);
    }
  }
  function updateDots() {
    const activeDot = Math.floor(current / visible());
    dotsWrap.querySelectorAll('.carousel-dot').forEach((d, i) => {
      d.style.background = i === activeDot ? '#c9a96e' : 'rgba(245,242,235,0.08)';
      d.style.width      = i === activeDot ? '18px' : '6px';
    });
  }
  function goTo(index) {
    const maxSlide = Math.max(0, total - visible());
    current = Math.min(Math.max(0, index), maxSlide);
    track.style.transform = `translateX(-${current * (cardWidth() + GAP)}px)`;
    updateDots();
  }
  function next() {
    const vis = visible();
    const maxSlide = Math.max(0, total - vis);
    goTo(current + vis > maxSlide ? 0 : current + vis);
  }
  function startAuto() { autoTimer = setInterval(next, 3200); }
  function stopAuto()  { clearInterval(autoTimer); }

  outer.addEventListener('mouseenter', stopAuto);
  outer.addEventListener('mouseleave', startAuto);

  let touchStartX = 0;
  track.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; stopAuto(); }, { passive: true });
  track.addEventListener('touchend', e => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) diff > 0 ? next() : goTo(Math.max(0, current - visible()));
    startAuto();
  });

  buildDots();
  startAuto();
})();

/* ── BACK BUTTON LOCK ── */
history.pushState(null, null, window.location.href);
window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
</script>
