<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate"/>
  <meta http-equiv="Pragma" content="no-cache"/>
  <meta http-equiv="Expires" content="0"/>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Velmora Chroné — My Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: #111110; color: #f5f2eb; overflow-x: hidden; min-height: 100vh; }
    ::-webkit-scrollbar { width: 2px; }
    ::-webkit-scrollbar-track { background: #111110; }
    ::-webkit-scrollbar-thumb { background: #c9a96e; }

    /* ── GRAIN OVERLAY ── */
    body::before {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: .016;
    }

    /* ═══════════════════════════════════════
       NAV
    ═══════════════════════════════════════ */
    .nav-root {
      position: fixed; top: 0; left: 0; right: 0; z-index: 200;
      background: rgba(17,17,16,0.92);
      backdrop-filter: blur(18px) saturate(1.4);
      -webkit-backdrop-filter: blur(18px) saturate(1.4);
      border-bottom: 1px solid rgba(245,242,235,0.06);
      transition: box-shadow 0.3s;
    }
    .nav-root.scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.5); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 1rem 2rem; }
    @media(min-width:768px) { .nav-inner { padding: 1rem 3rem; } }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; font-weight: 300;
      letter-spacing: 0.25em; text-transform: uppercase; color: #f5f2eb; text-decoration: none;
    }
    .nav-link {
      font-family: 'Jost', sans-serif; font-size: 0.53rem; font-weight: 400;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: rgba(245,242,235,0.45); text-decoration: none;
      transition: color 0.2s; position: relative; padding-bottom: 2px;
    }
    .nav-link::after {
      content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 1px;
      background: #c9a96e; transition: width 0.3s;
    }
    .nav-link:hover { color: rgba(245,242,235,0.9); }
    .nav-link:hover::after { width: 100%; }
    .nav-link.active { color: #c9a96e; }
    .nav-link.active::after { width: 100%; }

    .nav-icon-btn {
      position: relative; width: 36px; height: 36px;
      display: flex; align-items: center; justify-content: center;
      color: rgba(245,242,235,0.5);
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(201,169,110,0.12);
      border-radius: 10px; cursor: pointer; text-decoration: none;
      transition: color 0.22s, background 0.22s, border-color 0.22s,
        transform 0.18s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s;
      transform-style: preserve-3d;
      box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 2px 6px rgba(0,0,0,0.35), 0 0 0 0 rgba(201,169,110,0);
    }
    .nav-icon-btn::before {
      content: ''; position: absolute; inset: 0; border-radius: 10px;
      background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 55%);
      pointer-events: none;
    }
    .nav-icon-btn:hover {
      color: #c9a96e; background: rgba(201,169,110,0.08); border-color: rgba(201,169,110,0.35);
      transform: translateY(-2px) scale(1.06);
      box-shadow: 0 1px 0 rgba(255,255,255,0.06) inset, 0 6px 20px rgba(0,0,0,0.5), 0 0 14px rgba(201,169,110,0.15);
    }
    .nav-icon-btn:active { transform: translateY(0px) scale(0.97); box-shadow: 0 1px 4px rgba(0,0,0,0.4); }
    .nav-icon-btn.active-icon { color: #c9a96e; border-color: rgba(201,169,110,0.3); background: rgba(201,169,110,0.06); }
    .cart-badge {
      position: absolute; top: -5px; right: -5px; width: 14px; height: 14px; border-radius: 50%;
      background: linear-gradient(135deg, #d4b97e, #c9a96e);
      font-size: 0.38rem; font-weight: 600; color: #111110;
      display: flex; align-items: center; justify-content: center;
      box-shadow: 0 2px 6px rgba(201,169,110,0.4);
    }
    .hamburger { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 3px; }
    .hamburger span { display: block; width: 20px; height: 1px; background: rgba(245,242,235,0.6); transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
    .mobile-menu { display: none; flex-direction: column; background: #0d0d0c; padding: 1.5rem 2rem; gap: 1rem; border-top: 1px solid rgba(245,242,235,0.05); }
    .mobile-menu.open { display: flex; }
    .mobile-menu .nav-link { font-size: 0.68rem; padding: 0.45rem 0; border-bottom: 1px solid rgba(245,242,235,0.04); color: rgba(245,242,235,0.5); }

    /* ═══════════════════════════════════════
       PAGE HERO — CENTERED
    ═══════════════════════════════════════ */
    .page-hero {
      padding: 5.5rem 2rem 2.5rem;
      background: linear-gradient(180deg, #080807 0%, #111110 100%);
      border-bottom: 1px solid rgba(201,169,110,0.08);
      position: relative; overflow: hidden;
      text-align: center;
    }
    @media(min-width:768px) { .page-hero { padding: 5.5rem 3rem 2.5rem; } }

    /* Radial glow — centered now */
    .page-hero::before {
      content: ''; position: absolute; top: -60px; left: 50%; transform: translateX(-50%);
      width: 600px; height: 400px; border-radius: 50%;
      background: radial-gradient(ellipse, rgba(201,169,110,0.07) 0%, transparent 70%);
      pointer-events: none;
    }
    .page-hero::after {
      content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,169,110,0.25), transparent);
    }

    .page-hero-inner {
      max-width: 900px; margin: 0 auto; position: relative; z-index: 1;
      display: flex; flex-direction: column; align-items: center;
    }

    .page-hero-tag {
      font-family: 'Jost', sans-serif; font-size: 0.42rem;
      letter-spacing: 0.38em; text-transform: uppercase;
      color: rgba(201,169,110,0.55); margin-bottom: 0.65rem;
      display: flex; align-items: center; gap: 0.65rem;
    }
    .page-hero-tag::before { content: ''; width: 24px; height: 1px; background: #c9a96e; opacity: 0.45; }
    .page-hero-tag::after  { content: ''; width: 24px; height: 1px; background: #c9a96e; opacity: 0.45; }

    /* NEW: Playfair Display for the hero title */
    .page-hero-title {
      font-family: 'Playfair Display', serif; font-weight: 400;
      font-size: clamp(1.6rem, 3.5vw, 2.6rem); line-height: 1;
      color: #f5f2eb; letter-spacing: -0.01em;
    }
    .page-hero-title em {
      font-style: italic; display: block;
      background: linear-gradient(125deg, #edd99e 0%, #c9a96e 45%, #a8873d 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      position: relative;
    }

    /* ── SIGNATURE DRAW UNDERLINE ── */
    .page-hero-title em::after {
      content: '';
      position: absolute; bottom: -6px; left: 50%; transform: translateX(-50%);
      width: 0; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,169,110,0.6), transparent);
      animation: drawUnderline 1.4s cubic-bezier(.22,1,.36,1) 0.7s forwards;
    }
    @keyframes drawUnderline { to { width: 80%; } }

    /* Live clock under heading — centered */
    .hero-clock-row {
      display: flex; align-items: center; justify-content: center;
      gap: 0.75rem; margin-top: 0.9rem; height: 16px;
    }
    .hero-clock-row .clock-line {
      width: 36px; height: 1px;
      background: linear-gradient(90deg, transparent, rgba(201,169,110,0.4));
    }
    .hero-clock-row .clock-line.right {
      background: linear-gradient(270deg, transparent, rgba(201,169,110,0.4));
    }

    /* ── FLOATING DUST PARTICLES ── */
    .hero-particles {
      position: absolute; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
    }
    .particle {
      position: absolute; border-radius: 50%;
      background: rgba(201,169,110,0.55);
      animation: particleDrift linear infinite;
    }

    @keyframes particleDrift {
      0%   { transform: translateY(0px) translateX(0px); opacity: 0; }
      10%  { opacity: 1; }
      90%  { opacity: 0.6; }
      100% { transform: translateY(-120px) translateX(var(--drift-x)); opacity: 0; }
    }

    /* ambient orbs (kept from original, repositioned for center) */
    .hero-orb {
      position: absolute; border-radius: 50%;
      background: radial-gradient(circle, rgba(201,169,110,0.06) 0%, transparent 65%);
      animation: orbFloat 8s ease-in-out infinite; pointer-events: none;
    }
    .hero-orb.orb1 { width: 380px; height: 380px; top: -100px; left: 50%; transform: translateX(-50%); animation-delay: 0s; }
    .hero-orb.orb2 { width: 200px; height: 200px; bottom: -20px; left: 30%; animation-delay: 3.5s; animation-duration: 11s; }
    @keyframes orbFloat {
      0%, 100% { transform: translateY(0) scale(1); }
      50%       { transform: translateY(-20px) scale(1.05); }
    }

    /* Gold scan line */
    .page-hero-scan {
      position: absolute; top: 0; left: -100%; width: 60%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(201,169,110,0.025), transparent);
      animation: heroScan 6s ease-in-out infinite; pointer-events: none; z-index: 0;
    }
    @keyframes heroScan { 0% { left: -60%; } 100% { left: 140%; } }

    /* ── ACCENT RULE ── */
    .rule { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.2), transparent); }

    /* ── WATCH-FACE DIVIDER ── */
    .watch-divider {
      background: #0a0a09;
      border-top: 1px solid rgba(201,169,110,0.07);
      border-bottom: 1px solid rgba(201,169,110,0.07);
      padding: 1.1rem 2rem;
      display: flex; align-items: center; justify-content: center; gap: 2.5rem;
      position: relative; overflow: hidden;
    }
    .watch-divider::before {
      content: ''; position: absolute; inset: 0;
      background: radial-gradient(ellipse at center, rgba(201,169,110,0.04) 0%, transparent 65%);
      pointer-events: none;
    }
    .wd-line { flex: 1; max-width: 200px; height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.2), transparent); }
    .wd-line.right { background: linear-gradient(270deg, transparent, rgba(201,169,110,0.2), transparent); }
    .wd-items { display: flex; align-items: center; gap: 2rem; flex-shrink: 0; }
    .wd-item {
      display: flex; align-items: center; gap: 0.65rem;
      font-family: 'Jost', sans-serif; font-size: 0.42rem;
      letter-spacing: 0.28em; text-transform: uppercase; color: rgba(201,169,110,0.38);
      opacity: 0; animation: wdFadeIn 0.6s ease forwards;
    }
    .wd-item:nth-child(1) { animation-delay: 0.15s; }
    .wd-item:nth-child(2) { animation-delay: 0.3s; }
    .wd-item:nth-child(3) { animation-delay: 0.45s; }
    @keyframes wdFadeIn { to { opacity: 1; } }
    .wd-sep { width: 3px; height: 3px; border-radius: 50%; background: rgba(201,169,110,0.2); flex-shrink: 0; }
    .wd-clock { position: relative; width: 28px; height: 28px; flex-shrink: 0; }
    .wd-clock-face { width: 28px; height: 28px; border-radius: 50%; border: 1px solid rgba(201,169,110,0.3); background: rgba(201,169,110,0.04); position: relative; overflow: visible; }
    .wd-hand-seconds { transform-origin: 50% 80%; animation: sweepSeconds 60s linear infinite; }
    .wd-hand-minutes { transform-origin: 50% 75%; animation: sweepMinutes 3600s linear infinite; }
    @keyframes sweepSeconds { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
    @keyframes sweepMinutes { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

    /* ═══════════════════════════════════════
       LAYOUT — fix dark shading on right
    ═══════════════════════════════════════ */
    .profile-wrap {
      max-width: 1200px; margin: 0 auto;
      padding: 3rem 2rem 5rem;
      display: flex; gap: 0; position: relative; z-index: 1;
      background: transparent; /* was causing shade on right */
    }
    @media(min-width:768px) { .profile-wrap { padding: 3rem 3rem 5rem; } }
    @media(max-width:767px) { .profile-wrap { flex-direction: column; padding: 2rem 1.25rem 4rem; } }

    /* ── SIDEBAR ── */
    .profile-sidebar { width: 210px; flex-shrink: 0; border-right: 1px solid rgba(201,169,110,0.1); padding-top: 0.5rem; }
    @media(max-width:767px) { .profile-sidebar { width: 100%; border-right: none; border-bottom: 1px solid rgba(201,169,110,0.1); padding-bottom: 1rem; margin-bottom: 2rem; } }
    .sidebar-inner { display: flex; flex-direction: column; gap: 2px; }
    @media(max-width:767px) { .sidebar-inner { flex-direction: row; overflow-x: auto; gap: 0; } }

    /* NEW: DM Serif Display font on sidebar tabs */
    .sidebar-tab {
      display: flex; align-items: center; gap: 10px;
      padding: 0.75rem 1.1rem;
      font-family: 'Jost', sans-serif; font-size: 0.52rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(245,242,235,0.35);
      cursor: pointer; background: none; width: 100%; text-align: left;
      border-left: 2px solid transparent;
      border-top: none; border-right: none; border-bottom: none;
      transition: color 0.22s, border-color 0.22s, background 0.22s, transform 0.15s;
      white-space: nowrap; border-radius: 0 6px 6px 0;
      opacity: 0; animation: sidebarSlide 0.5s cubic-bezier(.25,.46,.45,.94) forwards;
    }
    @media(max-width:767px) { .sidebar-tab { border-left: none; border-bottom: 2px solid transparent; padding: 0.6rem 0.9rem; border-radius: 0; } }
    .sidebar-tab:nth-child(1) { animation-delay: 0.1s; }
    .sidebar-tab:nth-child(2) { animation-delay: 0.18s; }
    .sidebar-tab:nth-child(3) { animation-delay: 0.26s; }
    .sidebar-tab:nth-child(4) { animation-delay: 0.34s; }
    .sidebar-tab:nth-child(5) { animation-delay: 0.42s; }
    @keyframes sidebarSlide { from { opacity:0; transform:translateX(-12px); } to { opacity:1; transform:translateX(0); } }
    .sidebar-tab svg { width: 13px; height: 13px; flex-shrink: 0; transition: color 0.2s; }
    .sidebar-tab:hover { color: rgba(245,242,235,0.8); border-left-color: rgba(201,169,110,0.35); background: rgba(201,169,110,0.04); }
    @media(max-width:767px) { .sidebar-tab:hover { border-left-color: transparent; border-bottom-color: rgba(201,169,110,0.35); } }
    .sidebar-tab.active { color: #c9a96e; border-left-color: #c9a96e; background: rgba(201,169,110,0.06); }
    @media(max-width:767px) { .sidebar-tab.active { border-left-color: transparent; border-bottom-color: #c9a96e; } }

    .sidebar-logout {
      display: flex; align-items: center; gap: 8px;
      font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(201,169,110,0.3); text-decoration: none;
      padding: 0.7rem 1.1rem; margin-top: 1.5rem;
      transition: color 0.2s; border-radius: 0 6px 6px 0;
      opacity: 0; animation: sidebarSlide 0.5s cubic-bezier(.25,.46,.45,.94) 0.52s forwards;
    }
    .sidebar-logout:hover { color: rgba(201,169,110,0.65); }
    .sidebar-logout svg { width: 12px; height: 12px; }
    @media(max-width:767px) { .sidebar-logout { display: none; } }

    /* ── MAIN PANEL ── */
    .profile-main { flex: 1; padding: 0.5rem 0 0 2.5rem; min-width: 0; }
    @media(max-width:767px) { .profile-main { padding: 0; } }

    /* ── PANEL TRANSITIONS ── */
    .panel { display: none; }
    .panel.active {
      display: block;
      animation: panelReveal 0.55s cubic-bezier(.22,1,.36,1) both;
    }
    @keyframes panelReveal {
      from { opacity: 0; transform: translateY(18px) scale(0.995); filter: blur(2px); }
      to   { opacity: 1; transform: translateY(0)    scale(1);     filter: blur(0); }
    }

    /* NEW: panel title uses DM Serif Display */
    .panel-title {
      font-family: 'DM Serif Display', serif; font-size: 1.1rem; font-style: italic;
      letter-spacing: 0.01em; color: rgba(201,169,110,0.7);
      margin-bottom: 1.75rem;
      display: flex; align-items: center; gap: 0.65rem;
    }
    .panel-title::before { content: ''; width: 18px; height: 1px; background: rgba(201,169,110,0.35); flex-shrink: 0; }

    /* ── INPUTS ── */
    .vc-label { display: block; font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.3); margin-bottom: 7px; }
    .vc-input {
      width: 100%; background: rgba(245,242,235,0.03);
      border: 1px solid rgba(245,242,235,0.08);
      padding: 0.8rem 1rem;
      font-family: 'Jost', sans-serif; font-size: 0.82rem; font-weight: 300;
      color: #f5f2eb; outline: none;
      transition: border-color 0.25s, background 0.25s, box-shadow 0.25s;
      border-radius: 6px;
    }
    .vc-input::placeholder { color: rgba(245,242,235,0.18); }
    .vc-input:focus { border-color: rgba(201,169,110,0.4); background: rgba(201,169,110,0.03); box-shadow: 0 0 0 3px rgba(201,169,110,0.06); }
    .vc-input:disabled { opacity: 0.3; cursor: not-allowed; }

    /* ── BUTTONS ── */
    .btn-gold {
      font-family: 'Jost', sans-serif; font-size: 0.5rem;
      letter-spacing: 0.24em; text-transform: uppercase; color: #0d0b08;
      display: inline-flex; align-items: center; gap: 0.6rem;
      padding: 0.85rem 2rem; border-radius: 100px; text-decoration: none; cursor: pointer;
      position: relative; overflow: hidden;
      background: linear-gradient(135deg, #e0c47e 0%, #c9a96e 50%, #b8913d 100%);
      border: none;
      transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s;
      box-shadow: 0 1px 0 rgba(255,255,255,0.35) inset, 0 4px 18px rgba(185,140,55,0.35), 0 1px 4px rgba(0,0,0,0.4);
    }
    .btn-gold::after {
      content: ''; position: absolute; top: 0; left: -75%; width: 50%; height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.28), transparent);
      transform: skewX(-18deg); transition: left 0.55s ease;
    }
    .btn-gold:hover::after { left: 130%; }
    .btn-gold:hover { transform: translateY(-2px) scale(1.04); box-shadow: 0 1px 0 rgba(255,255,255,0.4) inset, 0 8px 28px rgba(185,140,55,0.45), 0 2px 8px rgba(0,0,0,0.45); }
    .btn-gold:active { transform: translateY(1px) scale(0.98); }
    .btn-gold:disabled { opacity: 0.45; cursor: not-allowed; pointer-events: none; }
    .btn-gold .btn-arrow { width: 16px; height: 16px; border-radius: 50%; background: rgba(0,0,0,0.15); display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: transform 0.2s; }
    .btn-gold:hover .btn-arrow { transform: translateX(3px); }

    .btn-dark {
      font-family: 'Jost', sans-serif; font-size: 0.5rem;
      letter-spacing: 0.24em; text-transform: uppercase; color: rgba(245,242,235,0.6);
      display: inline-flex; align-items: center; gap: 0.55rem;
      padding: 0.83rem 1.8rem; border-radius: 100px; text-decoration: none; cursor: pointer;
      background: transparent;
      border: 1px solid rgba(201,169,110,0.25);
      transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.22s, border-color 0.22s, color 0.22s;
      box-shadow: none;
    }
    .btn-dark:hover { color: #f5f2eb; border-color: rgba(201,169,110,0.5); transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,0.3), 0 0 14px rgba(201,169,110,0.08); }
    .btn-dark:active { transform: translateY(1px); box-shadow: none; }
    .btn-dark:disabled { opacity: 0.4; cursor: not-allowed; }

    .btn-danger-sm {
      display: inline-flex; align-items: center; gap: 5px;
      font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: rgba(248,113,113,0.65); background: transparent;
      border: 1px solid rgba(248,113,113,0.18); border-radius: 100px;
      padding: 0.55rem 1.1rem; cursor: pointer;
      transition: color 0.22s, border-color 0.22s, background 0.22s, transform 0.18s;
    }
    .btn-danger-sm:hover { color: #f87171; border-color: rgba(248,113,113,0.45); background: rgba(248,113,113,0.06); transform: translateY(-1px); }
    .btn-danger-sm:active { transform: translateY(0); }

    /* ── AVATAR ── */
    .avatar-wrap { position: relative; width: 90px; height: 90px; cursor: pointer; flex-shrink: 0; }
    .avatar-img { width: 90px; height: 90px; object-fit: cover; border: 1px solid rgba(201,169,110,0.2); display: block; border-radius: 12px; }
    .avatar-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; border-radius: 12px; }
    .avatar-wrap:hover .avatar-overlay { opacity: 1; }
    .avatar-wrap::after { content: ''; position: absolute; inset: -4px; border-radius: 16px; border: 1px solid rgba(201,169,110,0); transition: border-color 0.3s, box-shadow 0.3s; }
    .avatar-wrap:hover::after { border-color: rgba(201,169,110,0.35); box-shadow: 0 0 16px rgba(201,169,110,0.15); }

    /* ── STAT PILLS ── */
    .stat-pill {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
      padding: 0.9rem 1.4rem; border: 1px solid rgba(201,169,110,0.12);
      background: rgba(201,169,110,0.03); border-radius: 10px; position: relative; overflow: hidden;
      transition: border-color 0.25s, background 0.25s, box-shadow 0.25s, transform 0.18s cubic-bezier(.34,1.56,.64,1);
    }
    .stat-pill:hover { border-color: rgba(201,169,110,0.3); background: rgba(201,169,110,0.06); transform: translateY(-2px); box-shadow: 0 4px 18px rgba(0,0,0,0.3), 0 0 12px rgba(201,169,110,0.08); }
    .stat-num {
      font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; line-height: 1;
      background: linear-gradient(135deg, #d4b97e, #c9a96e);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
    }
    .stat-label { font-family: 'Jost', sans-serif; font-size: 0.42rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(245,242,235,0.25); }

    /* ── INFO GRID ── */
    .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem 2rem; }
    .info-item { padding: 1rem 1.1rem; border: 1px solid rgba(245,242,235,0.06); border-radius: 8px; background: rgba(245,242,235,0.02); transition: border-color 0.25s, box-shadow 0.25s; position: relative; overflow: hidden; }
    .info-item:hover { border-color: rgba(201,169,110,0.2); box-shadow: 0 2px 16px rgba(0,0,0,0.25); }
    .info-item::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 1px; background: linear-gradient(90deg, rgba(201,169,110,0.45), transparent); transition: width 0.4s ease; }
    .info-item:hover::after { width: 100%; }
    .info-item-label { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.25); margin-bottom: 6px; }
    .info-item-value { font-family: 'Jost', sans-serif; font-size: 0.82rem; font-weight: 300; color: rgba(245,242,235,0.7); }

    /* ── OTP CELLS ── */
    .otp-row { display: flex; gap: 8px; }
    .otp-cell { width: 44px; height: 52px; text-align: center; background: rgba(245,242,235,0.03); border: 1px solid rgba(245,242,235,0.1); border-radius: 8px; font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: #c9a96e; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
    .otp-cell:focus { border-color: rgba(201,169,110,0.5); box-shadow: 0 0 0 3px rgba(201,169,110,0.08); }

    /* ── PASSWORD STRENGTH ── */
    .pw-bar-wrap { display: flex; gap: 3px; margin-top: 8px; }
    .pw-bar { flex: 1; height: 2px; background: rgba(245,242,235,0.07); border-radius: 2px; transition: background 0.3s; }
    .pw-bar.weak   { background: #f87171; }
    .pw-bar.medium { background: #fbbf24; }
    .pw-bar.strong { background: #4ade80; }

    /* ── ADDRESS CARD ── */
    .addr-card { border: 1px solid rgba(245,242,235,0.06); border-radius: 12px; padding: 1.25rem 1.25rem 1.1rem; position: relative; background: rgba(245,242,235,0.02); transition: border-color 0.25s, background 0.25s, box-shadow 0.25s, transform 0.18s; }
    .addr-card:hover { border-color: rgba(201,169,110,0.22); background: rgba(201,169,110,0.03); box-shadow: 0 4px 20px rgba(0,0,0,0.3); transform: translateY(-2px); }
    .addr-card.default-addr { border-color: rgba(201,169,110,0.3); }

    /* ── FLASH ── */
    .flash-error   { background: rgba(248,113,113,0.06); border: 1px solid rgba(248,113,113,0.2); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.72rem; font-weight: 300; color: rgba(248,113,113,0.85); margin-bottom: 1.25rem; }
    .flash-success { background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.2); padding: 0.75rem 1rem; border-radius: 8px; font-size: 0.72rem; font-weight: 300; color: rgba(74,222,128,0.75); margin-bottom: 1.25rem; }

    /* ── MODAL ── */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.78); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); z-index: 300; display: flex; align-items: center; justify-content: center; padding: 1rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal-box { background: #1a1a18; border: 1px solid rgba(201,169,110,0.15); border-radius: 16px; padding: 2rem; width: 100%; max-width: 440px; transform: translateY(16px); transition: transform 0.3s; max-height: 90vh; overflow-y: auto; box-shadow: 0 24px 60px rgba(0,0,0,0.7), 0 0 0 1px rgba(255,255,255,0.03); }
    .modal-backdrop.open .modal-box { transform: translateY(0); }
    .modal-title { font-family: 'DM Serif Display', serif; font-size: 1rem; font-style: italic; letter-spacing: 0.01em; color: rgba(201,169,110,0.65); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem; }
    .modal-title::before { content: ''; width: 14px; height: 1px; background: rgba(201,169,110,0.3); }

    /* ── TOAST ── */
    .toast { position: fixed; bottom: 2rem; right: 2rem; z-index: 999; background: #1a1a18; border: 1px solid rgba(201,169,110,0.25); border-radius: 10px; color: #f5f2eb; font-family: 'Jost', sans-serif; font-size: 0.58rem; letter-spacing: 0.08em; padding: 0.8rem 1.25rem; display: flex; align-items: center; gap: 10px; transform: translateY(80px); opacity: 0; transition: transform 0.35s, opacity 0.35s; pointer-events: none; min-width: 200px; box-shadow: 0 8px 32px rgba(0,0,0,0.5); }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.err { border-color: rgba(248,113,113,0.3); }
    .toast-dot { width: 5px; height: 5px; border-radius: 50%; background: #c9a96e; flex-shrink: 0; }
    .toast.err .toast-dot { background: #f87171; }
    .toast.ok  .toast-dot { background: #4ade80; }

    /* ── GOOGLE BADGE ── */
    .google-badge { font-size: 0.48rem; letter-spacing: 0.15em; text-transform: uppercase; color: #4ade80; border: 1px solid rgba(74,222,128,0.25); padding: 3px 10px; display: inline-block; border-radius: 100px; background: rgba(74,222,128,0.05); }

    /* ═══════════════════════════════════════
       UNIQUE ANIMATION: GOLD INK REVEAL
       on overview profile card
    ═══════════════════════════════════════ */
    .ink-reveal {
      position: relative; overflow: hidden;
    }
    .ink-reveal::before {
      content: '';
      position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background: radial-gradient(ellipse at 30% 50%,
        #111110 0%,
        rgba(17,17,16,0.92) 30%,
        rgba(17,17,16,0.6) 55%,
        transparent 75%
      );
      animation: inkWipe 1.1s cubic-bezier(.77,0,.18,1) 0.2s forwards;
    }
    @keyframes inkWipe {
      0%   { clip-path: inset(0 0 0 0); opacity: 1; }
      100% { clip-path: inset(0 100% 0 0); opacity: 0; }
    }

    /* ═══════════════════════════════════════
       UNIQUE ANIMATION: ANIMATED GOLD LINE
       under the profile name
    ═══════════════════════════════════════ */
    .profile-name-wrap { position: relative; display: inline-block; }
    .profile-name-wrap::after {
      content: '';
      position: absolute; bottom: -3px; left: 0; width: 0; height: 1px;
      background: linear-gradient(90deg, #c9a96e, rgba(201,169,110,0.3));
      animation: nameUnderline 0.9s cubic-bezier(.22,1,.36,1) 0.6s forwards;
    }
    @keyframes nameUnderline { to { width: 100%; } }

    /* ═══════════════════════════════════════
       UNIQUE ANIMATION: GOLD COUNTER
       stat pills count up on load
    ═══════════════════════════════════════ */
    .stat-num[data-count] { transition: none; }

    /* ── REVEAL ── */
    @keyframes fadeUp { from { opacity: 0; transform: translateY(26px); } to { opacity: 1; transform: translateY(0); } }
    .fade-up { animation: fadeUp .75s ease both; }
    .d1 { animation-delay: .1s; } .d2 { animation-delay: .22s; } .d3 { animation-delay: .38s; }

    /* ── FOOTER ── */
    .footer { background: #0a0a09; padding: 4rem 2rem 1.5rem; border-top: 1px solid rgba(245,242,235,0.05); position: relative; z-index: 1; }
    @media(min-width:768px) { .footer { padding: 4rem 3rem 1.5rem; } }
    .footer-top { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid rgba(245,242,235,0.05); }
    @media(min-width:768px) { .footer-top { grid-template-columns: 1.2fr 1fr 1fr 1.2fr; gap: 3rem; } }
    .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 1rem; font-weight: 300; letter-spacing: 0.2em; text-transform: uppercase; color: #f5f2eb; margin-bottom: 0.75rem; }
    .footer-desc { font-family: 'Jost', sans-serif; font-size: 0.6rem; font-weight: 300; color: rgba(245,242,235,0.22); line-height: 1.85; }
    .footer-socials { display: flex; gap: 0.9rem; margin-top: 1.25rem; }
    .footer-social-btn { width: 32px; height: 32px; border: 1px solid rgba(201,169,110,0.15); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: rgba(245,242,235,0.3); text-decoration: none; transition: border-color 0.25s, color 0.25s, transform 0.18s; }
    .footer-social-btn:hover { border-color: rgba(201,169,110,0.4); color: #c9a96e; transform: scale(1.1); }
    .footer-col-title { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(201,169,110,0.35); margin-bottom: 1rem; display: block; }
    .footer-col-link { display: block; font-family: 'Jost', sans-serif; font-size: 0.58rem; letter-spacing: 0.08em; color: rgba(245,242,235,0.25); text-decoration: none; transition: color 0.2s; margin-bottom: 0.5rem; }
    .footer-col-link:hover { color: rgba(245,242,235,0.6); }
    .footer-bottom { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 1.5rem; align-items: center; text-align: center; }
    @media(min-width:768px) { .footer-bottom { flex-direction: row; justify-content: space-between; } }
    .footer-copy { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.15em; text-transform: uppercase; color: rgba(245,242,235,0.12); }
    .footer-legal { display: flex; gap: 1.25rem; }
    .footer-legal a { font-family: 'Jost', sans-serif; font-size: 0.44rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(245,242,235,0.18); text-decoration: none; transition: color 0.2s; }
    .footer-legal a:hover { color: rgba(245,242,235,0.5); }
  </style>
</head>
