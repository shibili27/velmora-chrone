        <button onclick="resetEmailForm()" style="margin-top:1rem;background:none;border:none;font-size:0.48rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(245,242,235,0.2);cursor:pointer;transition:color 0.2s;" onmouseover="this.style.color='rgba(245,242,235,0.5)'" onmouseout="this.style.color='rgba(245,242,235,0.2)'">← Use different email</button>
      </div>
    </div>

    <!-- ── CHANGE PASSWORD PANEL ── -->
    <% if (user.password) { %>
    <div class="panel" id="panel-password">
      <p class="panel-title">Change Password</p>
      <form action="/change-password" method="POST" style="max-width:400px;" id="pwForm">
        <div style="margin-bottom:1.25rem;">
          <label class="vc-label" for="pw-current">Current Password</label>
          <div style="position:relative;">
            <input class="vc-input" id="pw-current" name="oldPassword" type="password" placeholder="Current password" style="padding-right:2.75rem;" required/>
            <button type="button" onclick="togglePw('pw-current')" style="position:absolute;right:0.85rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.25);transition:color 0.2s;" onmouseover="this.style.color='rgba(245,242,235,0.6)'" onmouseout="this.style.color='rgba(245,242,235,0.25)'">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div style="margin-bottom:1.25rem;">
          <label class="vc-label" for="pw-new">New Password</label>
          <div style="position:relative;">
            <input class="vc-input" id="pw-new" name="newPassword" type="password" placeholder="Min. 8 characters" style="padding-right:2.75rem;" oninput="updateStrength(this.value)" required/>
            <button type="button" onclick="togglePw('pw-new')" style="position:absolute;right:0.85rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.25);transition:color 0.2s;" onmouseover="this.style.color='rgba(245,242,235,0.6)'" onmouseout="this.style.color='rgba(245,242,235,0.25)'">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-bar-wrap"><div class="pw-bar" id="bar1"></div><div class="pw-bar" id="bar2"></div><div class="pw-bar" id="bar3"></div></div>
          <p style="font-size:0.5rem;color:rgba(245,242,235,0.22);margin-top:5px;" id="pwStrengthLabel"></p>
        </div>
        <div style="margin-bottom:1.75rem;">
          <label class="vc-label" for="pw-confirm">Confirm New Password</label>
          <input class="vc-input" id="pw-confirm" name="confirmPassword" type="password" placeholder="Re-enter new password" required/>
        </div>
        <button type="button" class="btn-gold" onclick="submitPassword()">
          Update Password
          <span class="btn-arrow">
            <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </span>
        </button>
      </form>
    </div>
    <% } %>

    <!-- ── ADDRESSES PANEL ── -->
    <div class="panel" id="panel-addresses">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem;">
        <p class="panel-title" style="margin-bottom:0;">Saved Addresses</p>
        <button class="btn-gold" onclick="openAddressModal()" style="font-size:0.48rem;padding:0.72rem 1.4rem;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Address
        </button>
      </div>
      <script>
        const dbAddresses = <%- JSON.stringify(user.addresses || []) %>;
        let addresses = dbAddresses.map(a => ({ ...a, id: a._id ? a._id.toString() : String(Math.random()) }));
      </script>
      <div id="addressList" style="display:flex;flex-direction:column;gap:0.75rem;max-width:600px;"></div>
      <p id="noAddresses" style="font-size:0.75rem;font-weight:300;color:rgba(245,242,235,0.22);display:none;">No saved addresses. Add one above.</p>
    </div>

  </main>
</div>

