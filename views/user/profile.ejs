<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate"/>
  <meta http-equiv="Pragma" content="no-cache"/>
  <meta http-equiv="Expires" content="0"/>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Velmora Chroné — My Profile</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Jost', sans-serif; background: #111110; color: #f5f2eb; overflow-x: hidden; min-height: 100vh; }
    ::-webkit-scrollbar { width: 2px; }
    ::-webkit-scrollbar-track { background: #111110; }
    ::-webkit-scrollbar-thumb { background: #c9a96e; }

    /* ── NAV (exact from home.ejs) ── */
    .nav-root { position: fixed; top: 0; left: 0; right: 0; z-index: 200; transition: background 0.4s; }
    .nav-root.scrolled { background: rgba(10,10,9,0.96); backdrop-filter: blur(16px); }
    .nav-inner { display: flex; align-items: center; justify-content: space-between; padding: 1.1rem 2rem; }
    @media(min-width:768px) { .nav-inner { padding: 1.1rem 3rem; } }
    .nav-logo { font-family: 'Cormorant Garamond', serif; font-size: 0.85rem; font-weight: 300; letter-spacing: 0.25em; text-transform: uppercase; color: #f5f2eb; text-decoration: none; }
    .nav-link { font-family: 'Jost', sans-serif; font-size: 0.55rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.6); text-decoration: none; transition: color 0.2s; }
    .nav-link:hover, .nav-link.active { color: #f5f2eb; }
    .nav-icon { color: rgba(245,242,235,0.7); background: none; border: none; cursor: pointer; transition: color 0.2s; text-decoration: none; display: flex; align-items: center; }
    .nav-icon:hover { color: #c9a96e; }
    .cart-badge { position: absolute; top: -4px; right: -5px; width: 13px; height: 13px; border-radius: 50%; background: #c9a96e; font-size: 0.4rem; font-weight: 600; color: #111110; display: flex; align-items: center; justify-content: center; }
    .hamburger { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 3px; }
    .hamburger span { display: block; width: 20px; height: 1px; background: rgba(245,242,235,0.7); transition: transform 0.3s, opacity 0.3s; }
    .hamburger.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
    .mobile-menu { display: none; flex-direction: column; background: rgba(10,10,9,0.99); padding: 1.5rem 2rem; gap: 1rem; border-top: 1px solid rgba(201,169,110,0.1); }
    .mobile-menu.open { display: flex; }
    .mobile-menu .nav-link { font-size: 0.7rem; padding: 0.4rem 0; border-bottom: 1px solid rgba(245,242,235,0.04); color: rgba(245,242,235,0.6); }

    /* ── PAGE HERO BAND ── */
    .page-hero { padding: 7rem 2rem 3rem; background: linear-gradient(180deg, #0a0a09 0%, #111110 100%); border-bottom: 1px solid rgba(201,169,110,0.08); position: relative; overflow: hidden; }
    @media(min-width:768px) { .page-hero { padding: 7rem 3rem 3rem; } }
    .page-hero::before { content: ''; position: absolute; top: -80px; right: -80px; width: 360px; height: 360px; border-radius: 50%; background: radial-gradient(circle, rgba(201,169,110,0.04) 0%, transparent 70%); pointer-events: none; }
    .page-hero-inner { max-width: 1200px; margin: 0 auto; }
    .page-hero-tag { font-family: 'Jost', sans-serif; font-size: 0.52rem; letter-spacing: 0.35em; text-transform: uppercase; color: rgba(201,169,110,0.7); margin-bottom: 0.75rem; }
    .page-hero-title { font-family: 'Cormorant Garamond', serif; font-weight: 300; font-size: clamp(2.2rem, 5vw, 3.5rem); line-height: 1.1; color: #f5f2eb; }
    .page-hero-title em { font-style: italic; }

    /* ── RULE ── */
    .rule { height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.2), transparent); }

    /* ── LAYOUT ── */
    .profile-wrap { max-width: 1200px; margin: 0 auto; padding: 3rem 2rem 5rem; display: flex; gap: 0; }
    @media(min-width:768px) { .profile-wrap { padding: 3rem 3rem 5rem; } }
    @media(max-width:767px) { .profile-wrap { flex-direction: column; padding: 2rem 1.25rem 4rem; } }

    /* ── SIDEBAR ── */
    .profile-sidebar { width: 210px; flex-shrink: 0; border-right: 1px solid rgba(201,169,110,0.1); padding-right: 0; padding-top: 0.5rem; }
    @media(max-width:767px) { .profile-sidebar { width: 100%; border-right: none; border-bottom: 1px solid rgba(201,169,110,0.1); padding-bottom: 1rem; margin-bottom: 2rem; } }
    .sidebar-inner { display: flex; flex-direction: column; gap: 2px; }
    @media(max-width:767px) { .sidebar-inner { flex-direction: row; overflow-x: auto; gap: 0; } }

    .sidebar-tab { display: flex; align-items: center; gap: 10px; padding: 0.7rem 1.1rem; font-family: 'Jost', sans-serif; font-size: 0.55rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(245,242,235,0.4); cursor: pointer; border-left: 2px solid transparent; border-top: none; border-right: none; border-bottom: none; background: none; width: 100%; text-align: left; transition: color 0.2s, border-color 0.2s, background 0.2s; white-space: nowrap; }
    @media(max-width:767px) { .sidebar-tab { border-left: none; border-bottom: 2px solid transparent; padding: 0.6rem 0.9rem; } }
    .sidebar-tab svg { width: 13px; height: 13px; flex-shrink: 0; }
    .sidebar-tab:hover { color: rgba(245,242,235,0.75); border-left-color: rgba(201,169,110,0.3); background: rgba(201,169,110,0.03); }
    @media(max-width:767px) { .sidebar-tab:hover { border-left-color: transparent; border-bottom-color: rgba(201,169,110,0.3); } }
    .sidebar-tab.active { color: #c9a96e; border-left-color: #c9a96e; background: rgba(201,169,110,0.05); }
    @media(max-width:767px) { .sidebar-tab.active { border-left-color: transparent; border-bottom-color: #c9a96e; } }

    .sidebar-logout { display: flex; align-items: center; gap: 8px; font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(201,169,110,0.35); text-decoration: none; padding: 0.7rem 1.1rem; transition: color 0.2s; margin-top: 1.5rem; }
    .sidebar-logout:hover { color: rgba(201,169,110,0.7); }
    .sidebar-logout svg { width: 12px; height: 12px; }
    @media(max-width:767px) { .sidebar-logout { display: none; } }

    /* ── MAIN PANEL ── */
    .profile-main { flex: 1; padding: 0.5rem 0 0 2.5rem; min-width: 0; }
    @media(max-width:767px) { .profile-main { padding: 0; } }

    .panel { display: none; animation: fadeUp 0.4s ease both; }
    .panel.active { display: block; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:translateY(0); } }

    .panel-title { font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.32em; text-transform: uppercase; color: rgba(201,169,110,0.7); margin-bottom: 1.75rem; }

    /* ── INPUTS ── */
    .vc-label { display: block; font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.35); margin-bottom: 7px; }
    .vc-input { width: 100%; background: rgba(245,242,235,0.03); border: 1px solid rgba(245,242,235,0.1); padding: 0.75rem 1rem; font-family: 'Jost', sans-serif; font-size: 0.82rem; font-weight: 300; color: #f5f2eb; outline: none; transition: border-color 0.2s; }
    .vc-input::placeholder { color: rgba(245,242,235,0.2); }
    .vc-input:focus { border-color: rgba(201,169,110,0.4); }
    .vc-input:disabled { opacity: 0.35; cursor: not-allowed; }

    /* ── BUTTONS (exact home.ejs style) ── */
    .btn-gold { display: inline-flex; align-items: center; gap: 6px; font-family: 'Jost', sans-serif; font-size: 0.55rem; letter-spacing: 0.22em; text-transform: uppercase; color: #111110; background: #c9a96e; border: 1px solid #c9a96e; padding: 0.7rem 1.5rem; cursor: pointer; transition: background 0.25s, color 0.25s; text-decoration: none; }
    .btn-gold:hover { background: transparent; color: #c9a96e; }
    .btn-gold:disabled { opacity: 0.45; cursor: not-allowed; pointer-events: none; }
    .btn-dark { display: inline-flex; align-items: center; gap: 6px; font-family: 'Jost', sans-serif; font-size: 0.55rem; letter-spacing: 0.22em; text-transform: uppercase; color: #f5f2eb; background: rgba(245,242,235,0.08); border: 1px solid rgba(245,242,235,0.2); padding: 0.7rem 1.5rem; cursor: pointer; transition: background 0.25s, border-color 0.25s; text-decoration: none; backdrop-filter: blur(8px); }
    .btn-dark:hover { background: rgba(245,242,235,0.14); border-color: rgba(245,242,235,0.4); }
    .btn-dark:disabled { opacity: 0.4; cursor: not-allowed; }
    .btn-danger-sm { display: inline-flex; align-items: center; gap: 5px; font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(248,113,113,0.7); background: transparent; border: 1px solid rgba(248,113,113,0.2); padding: 0.55rem 1rem; cursor: pointer; transition: color 0.2s, border-color 0.2s; }
    .btn-danger-sm:hover { color: #f87171; border-color: rgba(248,113,113,0.5); }

    /* ── AVATAR ── */
    .avatar-wrap { position: relative; width: 90px; height: 90px; cursor: pointer; flex-shrink: 0; }
    .avatar-img { width: 90px; height: 90px; object-fit: cover; border: 1px solid rgba(201,169,110,0.2); display: block; }
    .avatar-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center; opacity: 0; transition: opacity 0.2s; }
    .avatar-wrap:hover .avatar-overlay { opacity: 1; }

    /* ── STAT PILLS ── */
    .stat-pill { display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 0.9rem 1.5rem; border: 1px solid rgba(201,169,110,0.1); background: rgba(201,169,110,0.02); }
    .stat-num { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 300; color: #c9a96e; line-height: 1; }
    .stat-label { font-family: 'Jost', sans-serif; font-size: 0.45rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.3); }

    /* ── INFO GRID ── */
    .info-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 1.5rem 2rem; }
    .info-item-label { font-family: 'Jost', sans-serif; font-size: 0.46rem; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(245,242,235,0.3); margin-bottom: 5px; }
    .info-item-value { font-family: 'Jost', sans-serif; font-size: 0.85rem; font-weight: 300; color: rgba(245,242,235,0.75); }

    /* ── OTP CELLS ── */
    .otp-row { display: flex; gap: 8px; }
    .otp-cell { width: 44px; height: 52px; text-align: center; background: rgba(245,242,235,0.03); border: 1px solid rgba(245,242,235,0.12); font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; font-weight: 300; color: #c9a96e; outline: none; transition: border-color 0.2s; }
    .otp-cell:focus { border-color: rgba(201,169,110,0.5); }

    /* ── PASSWORD STRENGTH ── */
    .pw-bar-wrap { display: flex; gap: 3px; margin-top: 6px; }
    .pw-bar { flex: 1; height: 2px; background: rgba(245,242,235,0.08); transition: background 0.3s; }
    .pw-bar.weak   { background: #f87171; }
    .pw-bar.medium { background: #fbbf24; }
    .pw-bar.strong { background: #4ade80; }

    /* ── ADDRESS CARD ── */
    .addr-card { border: 1px solid rgba(245,242,235,0.07); padding: 1.25rem 1.25rem 1.1rem; position: relative; transition: border-color 0.2s; background: rgba(245,242,235,0.02); }
    .addr-card:hover { border-color: rgba(201,169,110,0.2); }
    .addr-card.default-addr { border-color: rgba(201,169,110,0.3); }

    /* ── FLASH ── */
    .flash-error   { background: rgba(248,113,113,0.06); border: 1px solid rgba(248,113,113,0.2); padding: 0.75rem 1rem; font-size: 0.72rem; font-weight: 300; color: rgba(248,113,113,0.85); margin-bottom: 1.25rem; }
    .flash-success { background: rgba(74,222,128,0.05); border: 1px solid rgba(74,222,128,0.2); padding: 0.75rem 1rem; font-size: 0.72rem; font-weight: 300; color: rgba(74,222,128,0.75); margin-bottom: 1.25rem; }

    /* ── MODAL ── */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(8px); z-index: 300; display: flex; align-items: center; justify-content: center; padding: 1rem; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal-box { background: #1a1a18; border: 1px solid rgba(201,169,110,0.15); padding: 2rem; width: 100%; max-width: 440px; transform: translateY(16px); transition: transform 0.3s; max-height: 90vh; overflow-y: auto; }
    .modal-backdrop.open .modal-box { transform: translateY(0); }
    .modal-title { font-family: 'Jost', sans-serif; font-size: 0.5rem; letter-spacing: 0.3em; text-transform: uppercase; color: rgba(201,169,110,0.7); margin-bottom: 1.5rem; }

    /* ── TOAST ── */
    .toast { position: fixed; bottom: 2rem; right: 2rem; z-index: 999; background: #1a1a18; border: 1px solid rgba(201,169,110,0.2); color: #f5f2eb; font-family: 'Jost', sans-serif; font-size: 0.6rem; letter-spacing: 0.08em; padding: 0.85rem 1.25rem; display: flex; align-items: center; gap: 10px; transform: translateY(80px); opacity: 0; transition: transform 0.35s, opacity 0.35s; pointer-events: none; min-width: 220px; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.err { border-color: rgba(248,113,113,0.3); }
    .toast-dot { width: 5px; height: 5px; border-radius: 50%; background: #c9a96e; flex-shrink: 0; }
    .toast.err .toast-dot { background: #f87171; }
    .toast.ok  .toast-dot { background: #4ade80; }

    /* ── FOOTER (matches home) ── */
    .footer { background: #0a0a09; padding: 3rem 2rem 1.5rem; border-top: 1px solid rgba(245,242,235,0.05); }
    @media(min-width:768px) { .footer { padding: 3rem 3rem 1.5rem; } }
    .footer-inner { max-width: 1200px; margin: 0 auto; }
    .footer-bottom { display: flex; flex-direction: column; gap: 0.75rem; padding-top: 1.5rem; align-items: center; text-align: center; }
    @media(min-width:768px) { .footer-bottom { flex-direction: row; justify-content: space-between; } }
    .footer-copy { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(245,242,235,0.15); }
    .footer-link { font-family: 'Jost', sans-serif; font-size: 0.48rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(245,242,235,0.2); text-decoration: none; transition: color 0.2s; }
    .footer-link:hover { color: rgba(245,242,235,0.5); }

    /* Google badge */
    .google-badge { font-size: 0.5rem; letter-spacing: 0.15em; text-transform: uppercase; color: #4ade80; border: 1px solid rgba(74,222,128,0.25); padding: 3px 10px; display: inline-block; }
  </style>
</head>
<body>

<!-- ══ NAV (exact home.ejs) ══ -->
<nav class="nav-root" id="navbar">
  <div class="nav-inner">
    <div class="hidden md:flex items-center gap-8">
      <a href="/products" class="nav-link">Collection</a>
      <a href="/home"     class="nav-link">Watches</a>
      <a href="/home"     class="nav-link">About</a>
      <a href="/home"     class="nav-link">Contact</a>
    </div>
    <a href="/home" class="nav-logo md:absolute md:left-1/2 md:-translate-x-1/2">Velmora Chroné</a>
    <div class="flex items-center gap-4 md:gap-5 ml-auto md:ml-0">
      <a href="/profile" class="nav-icon active" aria-label="Profile" style="color:#c9a96e">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      <a href="/cart" class="nav-icon relative" aria-label="Cart">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        <span class="cart-badge" id="cartCount">0</span>
      </a>
      <a href="/logout" class="nav-link hidden md:inline">Logout</a>
      <button class="hamburger md:hidden" id="hamburger"><span></span><span></span><span></span></button>
    </div>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="/products" class="nav-link">Collection</a>
    <a href="/home"     class="nav-link">Watches</a>
    <a href="/profile"  class="nav-link" style="color:#c9a96e">My Profile</a>
    <a href="/cart"     class="nav-link">Cart</a>
    <a href="/logout"   class="nav-link" style="color:rgba(201,169,110,0.6)">Logout</a>
  </div>
</nav>

<!-- ══ PAGE HERO BAND ══ -->
<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-hero-tag">My Account</p>
    <h1 class="page-hero-title">My <em>Profile</em></h1>
  </div>
</div>

<!-- ══ PROFILE LAYOUT ══ -->
<div class="profile-wrap">

  <!-- SIDEBAR -->
  <aside class="profile-sidebar">
    <div class="sidebar-inner">
      <button class="sidebar-tab active" onclick="switchTab('details')" id="tab-details">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        Overview
      </button>
      <button class="sidebar-tab" onclick="switchTab('edit')" id="tab-edit">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Edit Profile
      </button>
      <button class="sidebar-tab" onclick="switchTab('email')" id="tab-email">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Change Email
      </button>
      <% if (user.password) { %>
      <button class="sidebar-tab" onclick="switchTab('password')" id="tab-password">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        Change Password
      </button>
      <% } %>
      <button class="sidebar-tab" onclick="switchTab('addresses')" id="tab-addresses">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        Addresses
      </button>
    </div>
    <a href="/logout" class="sidebar-logout">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Logout
    </a>
  </aside>

  <!-- MAIN -->
  <main class="profile-main">

    <!-- ── OVERVIEW PANEL ── -->
    <div class="panel active" id="panel-details">
      <p class="panel-title">Profile Overview</p>

      <!-- Avatar + name block -->
      <div style="display:flex;align-items:flex-start;gap:1.5rem;flex-wrap:wrap;margin-bottom:2.5rem;">
        <div>
          <div class="avatar-wrap" onclick="document.getElementById('avatarInput').click()">
            <img id="avatarPreview"
              src="<%= user.profileImage && user.profileImage !== '/images/default-avatar.png' ? user.profileImage : 'https://res.cloudinary.com/dwb0hd0m6/image/upload/v1774530220/velmora_chrone_logo_bgyhmw.svg' %>"
              onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 96 96%22%3E%3Crect fill=%22%231a1a18%22 width=%2296%22 height=%2296%22/%3E%3Ccircle cx=%2248%22 cy=%2238%22 r=%2216%22 fill=%22rgba(201,169,110,0.15)%22/%3E%3C/svg%3E'"
              alt="Profile" class="avatar-img"/>
            <div class="avatar-overlay">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
          </div>
          <input type="file" id="avatarInput" accept="image/*" style="display:none" onchange="uploadAvatar(event)"/>
          <p id="avatarStatus" style="font-size:0.44rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(245,242,235,0.2);margin-top:6px;text-align:center;">Click to change</p>
        </div>
        <div style="flex:1;min-width:160px;padding-top:4px;">
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:1.9rem;font-weight:300;color:#f5f2eb;line-height:1.1;margin-bottom:4px;"><%= user.name %></h2>
          <p id="displayEmail" style="font-size:0.72rem;font-weight:300;color:rgba(245,242,235,0.38);margin-bottom:12px;letter-spacing:0.04em;"><%= user.email %></p>
          <% if (user.googleId && !user.password) { %>
            <span class="google-badge">Google Account</span>
          <% } %>
          <!-- Stats row -->
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
            <div class="stat-pill">
              <span class="stat-num"><%= user.addresses ? user.addresses.length : 0 %></span>
              <span class="stat-label">Addresses</span>
            </div>
            <div class="stat-pill">
              <span class="stat-num" style="font-size:1rem;padding-top:4px;"><%= user.emailVerified ? '✓' : '—' %></span>
              <span class="stat-label">Verified</span>
            </div>
            <div class="stat-pill">
              <span class="stat-num" style="font-size:1.1rem;padding-top:4px;"><%= new Date(user.createdAt).getFullYear() %></span>
              <span class="stat-label">Since</span>
            </div>
          </div>
        </div>
      </div>

      <div class="rule" style="margin-bottom:2rem;"></div>

      <!-- Detail rows -->
      <div class="info-grid">
        <div>
          <p class="info-item-label">Full Name</p>
          <p class="info-item-value"><%= user.name %></p>
        </div>
        <div>
          <p class="info-item-label">Email Address</p>
          <p class="info-item-value"><%= user.email %></p>
        </div>
        <div>
          <p class="info-item-label">Account Type</p>
          <p class="info-item-value"><%= user.googleId ? 'Google OAuth' : 'Email & Password' %></p>
        </div>
        <div>
          <p class="info-item-label">Member Since</p>
          <p class="info-item-value"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) %></p>
        </div>
        <div>
          <p class="info-item-label">Last Login</p>
          <p class="info-item-value"><%= user.lastLogin ? new Date(user.lastLogin).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : '—' %></p>
        </div>
        <div>
          <p class="info-item-label">Role</p>
          <p class="info-item-value" style="text-transform:capitalize;"><%= user.role %></p>
        </div>
      </div>

      <div style="margin-top:2rem;">
        <button class="btn-gold" onclick="switchTab('edit')">Edit Profile</button>
      </div>
    </div>

    <!-- ── EDIT PROFILE PANEL ── -->
    <div class="panel" id="panel-edit">
      <p class="panel-title">Edit Profile</p>
      <% if (locals.editError) { %><div class="flash-error"><%= editError %></div><% } %>
      <% if (locals.editSuccess) { %><div class="flash-success"><%= editSuccess %></div><% } %>
      <form action="/profile/update" method="POST" style="max-width:440px;">
        <div style="display:grid;gap:1.25rem;">
          <div>
            <label class="vc-label" for="edit-name">Full Name</label>
            <input class="vc-input" id="edit-name" name="name" value="<%= user.name %>" placeholder="Your full name" required/>
          </div>
          <div>
            <label class="vc-label">Email Address</label>
            <input class="vc-input" value="<%= user.email %>" disabled/>
            <p style="font-size:0.48rem;color:rgba(245,242,235,0.2);margin-top:5px;letter-spacing:0.1em;">Use the Change Email tab to update your email.</p>
          </div>
        </div>
        <div style="margin-top:1.75rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
          <button type="submit" class="btn-gold">Save Changes</button>
          <button type="button" class="btn-dark" onclick="switchTab('details')">Cancel</button>
        </div>
      </form>
    </div>

    <!-- ── CHANGE EMAIL PANEL ── -->
    <div class="panel" id="panel-email">
      <p class="panel-title">Change Email Address</p>
      <div id="email-step1" style="max-width:420px;">
        <p style="font-size:0.75rem;font-weight:300;color:rgba(245,242,235,0.4);line-height:1.8;margin-bottom:1.5rem;">Enter your new email. We'll send a 6-digit code to confirm the change.</p>
        <div style="margin-bottom:1.25rem;">
          <label class="vc-label">Current Email</label>
          <input class="vc-input" value="<%= user.email %>" disabled/>
        </div>
        <div style="margin-bottom:1.5rem;">
          <label class="vc-label" for="new-email">New Email Address</label>
          <input class="vc-input" id="new-email" type="email" placeholder="new@email.com"/>
          <p id="emailInputError" style="display:none;font-size:0.6rem;color:#f87171;margin-top:6px;"></p>
        </div>
        <button class="btn-gold" id="sendOtpBtn" onclick="sendEmailOTP()">Send Verification Code</button>
      </div>

      <div id="email-step2" style="display:none;max-width:420px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;padding:1rem;border:1px solid rgba(74,222,128,0.15);background:rgba(74,222,128,0.04);">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div>
            <p style="font-size:0.7rem;color:rgba(245,242,235,0.75);">Verification code sent</p>
            <p style="font-size:0.6rem;color:rgba(245,242,235,0.3);" id="otp-sent-to">Check your inbox</p>
          </div>
        </div>
        <p style="font-size:0.7rem;color:rgba(245,242,235,0.4);margin-bottom:1.25rem;font-weight:300;">Enter the 6-digit code:</p>
        <div class="otp-row" style="margin-bottom:0.75rem;">
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,0)" onkeydown="otpBack(event,this,0)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,1)" onkeydown="otpBack(event,this,1)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,2)" onkeydown="otpBack(event,this,2)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,3)" onkeydown="otpBack(event,this,3)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,4)" onkeydown="otpBack(event,this,4)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,5)" onkeydown="otpBack(event,this,5)"/>
        </div>
        <p id="otpError" style="display:none;font-size:0.6rem;color:#f87171;margin-bottom:1rem;"></p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
          <button class="btn-gold" id="verifyOtpBtn" onclick="verifyEmailOTP()">Verify &amp; Update</button>
          <button class="btn-dark" id="resendOtpBtn" onclick="resendEmailOTP()" disabled style="font-size:0.52rem;">Resend <span id="resendTimer"></span></button>
        </div>
        <button onclick="resetEmailForm()" style="margin-top:1rem;background:none;border:none;font-size:0.5rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(245,242,235,0.25);cursor:pointer;">← Use different email</button>
      </div>
    </div>

    <!-- ── CHANGE PASSWORD PANEL ── -->
    <% if (user.password) { %>
    <div class="panel" id="panel-password">
      <p class="panel-title">Change Password</p>
      <form action="/change-password" method="POST" style="max-width:400px;" id="pwForm">
        <div style="margin-bottom:1.25rem;">
          <label class="vc-label" for="pw-current">Current Password</label>
          <div style="position:relative;">
            <input class="vc-input" id="pw-current" name="oldPassword" type="password" placeholder="Current password" style="padding-right:2.5rem;" required/>
            <button type="button" onclick="togglePw('pw-current')" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.3);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
        </div>
        <div style="margin-bottom:1.25rem;">
          <label class="vc-label" for="pw-new">New Password</label>
          <div style="position:relative;">
            <input class="vc-input" id="pw-new" name="newPassword" type="password" placeholder="Min. 8 characters" style="padding-right:2.5rem;" oninput="updateStrength(this.value)" required/>
            <button type="button" onclick="togglePw('pw-new')" style="position:absolute;right:0.75rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.3);">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-bar-wrap"><div class="pw-bar" id="bar1"></div><div class="pw-bar" id="bar2"></div><div class="pw-bar" id="bar3"></div></div>
          <p style="font-size:0.5rem;color:rgba(245,242,235,0.25);margin-top:4px;" id="pwStrengthLabel"></p>
        </div>
        <div style="margin-bottom:1.75rem;">
          <label class="vc-label" for="pw-confirm">Confirm New Password</label>
          <input class="vc-input" id="pw-confirm" name="confirmPassword" type="password" placeholder="Re-enter new password" required/>
        </div>
        <button type="button" class="btn-gold" onclick="submitPassword()">Update Password</button>
      </form>
    </div>
    <% } %>

    <!-- ── ADDRESSES PANEL ── -->
    <div class="panel" id="panel-addresses">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem;">
        <p class="panel-title" style="margin-bottom:0;">Saved Addresses</p>
        <button class="btn-gold" onclick="openAddressModal()" style="font-size:0.5rem;padding:0.6rem 1.2rem;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Address
        </button>
      </div>
      <script>
        const dbAddresses = <%- JSON.stringify(user.addresses || []) %>;
        let addresses = dbAddresses.map(a => ({ ...a, id: a._id ? a._id.toString() : String(Math.random()) }));
      </script>
      <div id="addressList" style="display:flex;flex-direction:column;gap:0.75rem;max-width:600px;"></div>
      <p id="noAddresses" style="font-size:0.75rem;font-weight:300;color:rgba(245,242,235,0.25);display:none;">No saved addresses. Add one above.</p>
    </div>

  </main>
</div>

<!-- ══ FOOTER ══ -->
<footer class="footer">
  <div class="footer-inner">
    <div class="rule" style="margin-bottom:1.5rem;"></div>
    <div class="footer-bottom">
      <span class="footer-copy">&copy; <%= new Date().getFullYear() %> Velmora Chroné. All rights reserved.</span>
      <div style="display:flex;gap:1.25rem;">
        <a href="#" class="footer-link">Privacy</a>
        <a href="#" class="footer-link">Terms</a>
      </div>
    </div>
  </div>
</footer>

<div class="modal-backdrop" id="addrModal">
  <div class="modal-box">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
      <p class="modal-title" id="addrModalTitle">Add New Address</p>
      <button onclick="closeAddressModal()" style="background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.3);">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
    <div style="display:grid;gap:1rem;">
      <div><label class="vc-label">Street / House No.</label><input class="vc-input" id="addr-street" placeholder="House No., Street, Area"/></div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
        <div><label class="vc-label">City</label><input class="vc-input" id="addr-city" placeholder="City"/></div>
        <div><label class="vc-label">PIN Code</label><input class="vc-input" id="addr-pincode" placeholder="6-digit PIN" maxlength="6"/></div>
      </div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:4px;">
        <input type="checkbox" id="addr-default" style="accent-color:#c9a96e;width:13px;height:13px;"/>
        <label for="addr-default" style="font-size:0.52rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(245,242,235,0.35);cursor:pointer;">Set as default address</label>
      </div>
    </div>
    <div style="margin-top:1.5rem;display:flex;gap:0.75rem;">
      <button class="btn-gold" onclick="saveAddress()" id="saveAddrBtn">Save Address</button>
      <button class="btn-dark" onclick="closeAddressModal()">Cancel</button>
    </div>
  </div>
</div>

<div class="modal-backdrop" id="deleteModal">
  <div class="modal-box" style="max-width:360px;text-align:center;">
    <div style="width:46px;height:46px;border:1px solid rgba(248,113,113,0.2);display:flex;align-items:center;justify-content:center;margin:0 auto 1.1rem;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="rgba(248,113,113,0.75)" stroke-width="1.5"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
    </div>
    <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:300;margin-bottom:8px;">Remove Address?</h3>
    <p style="font-size:0.7rem;font-weight:300;color:rgba(245,242,235,0.35);line-height:1.7;margin-bottom:1.5rem;">This address will be permanently removed from your account.</p>
    <div style="display:flex;gap:0.75rem;justify-content:center;">
      <button class="btn-danger-sm" onclick="confirmDelete()" style="padding:0.7rem 1.4rem;">Delete</button>
      <button class="btn-dark" onclick="closeDeleteModal()" style="font-size:0.52rem;padding:0.7rem 1.2rem;">Cancel</button>
    </div>
  </div>
</div>

<div class="toast" id="toast">
  <span class="toast-dot"></span>
  <span id="toastMsg"></span>
</div>

<script>
  
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 50), { passive: true });
  document.getElementById('hamburger').addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });

  
  function switchTab(tab) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.sidebar-tab').forEach(t => t.classList.remove('active'));
    const panel = document.getElementById('panel-' + tab);
    const tabEl = document.getElementById('tab-'   + tab);
    if (panel) panel.classList.add('active');
    if (tabEl) tabEl.classList.add('active');
    if (tab === 'addresses') renderAddresses();
  }

  
  let toastTimer;
  function showToast(msg, type = 'info') {
    const t = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    t.className = 'toast show' + (type === 'error' ? ' err' : type === 'success' ? ' ok' : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3200);
  }


  async function uploadAvatar(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => document.getElementById('avatarPreview').src = ev.target.result;
    reader.readAsDataURL(file);
    const statusEl = document.getElementById('avatarStatus');
    statusEl.textContent = 'Uploading…';
    const formData = new FormData();
    formData.append('profileImage', file);
    try {
      const res  = await fetch('/profile/upload-image', { method: 'POST', body: formData });
      const data = await res.json();
      if (data.success) {
        document.getElementById('avatarPreview').src = data.imageUrl;
        statusEl.textContent = 'Click to change';
        showToast('Profile photo updated!', 'success');
      } else {
        statusEl.textContent = 'Upload failed';
        showToast(data.message || 'Upload failed', 'error');
      }
    } catch {
      statusEl.textContent = 'Click to change';
      showToast('Network error. Try again.', 'error');
    }
  }

  
  let resendInterval = null;

  async function sendEmailOTP() {
    const email = document.getElementById('new-email').value.trim();
    const errEl = document.getElementById('emailInputError');
    const btn   = document.getElementById('sendOtpBtn');
    errEl.style.display = 'none';
    if (!email || !/^\S+@\S+\.\S+$/.test(email)) {
      errEl.textContent = 'Please enter a valid email address.';
      errEl.style.display = 'block'; return;
    }
    btn.disabled = true; btn.textContent = 'Sending…';
    try {
      const res  = await fetch('/profile/request-email-change', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ newEmail: email }) });
      const data = await res.json();
      if (data.success) {
        document.getElementById('otp-sent-to').textContent = 'Sent to ' + email;
        document.getElementById('email-step1').style.display = 'none';
        document.getElementById('email-step2').style.display = 'block';
        document.querySelectorAll('.otp-cell')[0].focus();
        startResendTimer();
        showToast('OTP sent! Check your inbox.', 'success');
      } else {
        errEl.textContent = data.message || 'Failed to send OTP.';
        errEl.style.display = 'block';
      }
    } catch { errEl.textContent = 'Network error. Please try again.'; errEl.style.display = 'block'; }
    btn.disabled = false; btn.textContent = 'Send Verification Code';
  }

  async function verifyEmailOTP() {
    const cells = document.querySelectorAll('.otp-cell');
    const otp   = Array.from(cells).map(c => c.value).join('');
    const errEl = document.getElementById('otpError');
    const btn   = document.getElementById('verifyOtpBtn');
    errEl.style.display = 'none';
    if (otp.length < 6) { errEl.textContent = 'Enter the complete 6-digit code.'; errEl.style.display = 'block'; return; }
    btn.disabled = true; btn.textContent = 'Verifying…';
    try {
      const res  = await fetch('/profile/verify-email-change', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ otp }) });
      const data = await res.json();
      if (data.success) {
        showToast('Email updated successfully!', 'success');
        clearInterval(resendInterval);
        const newEmail = document.getElementById('new-email').value.trim();
        const el = document.getElementById('displayEmail');
        if (el) el.textContent = newEmail;
        resetEmailForm();
      } else {
        errEl.textContent = data.message || 'Invalid OTP. Try again.';
        errEl.style.display = 'block';
        cells.forEach(c => { c.style.borderColor = 'rgba(248,113,113,0.5)'; });
        setTimeout(() => cells.forEach(c => { c.style.borderColor = ''; }), 1400);
      }
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = 'block'; }
    btn.disabled = false; btn.textContent = 'Verify & Update';
  }

  async function resendEmailOTP() {
    const btn = document.getElementById('resendOtpBtn');
    const errEl = document.getElementById('otpError');
    errEl.style.display = 'none'; btn.disabled = true;
    try {
      const email = document.getElementById('new-email').value.trim();
      const res   = await fetch('/profile/request-email-change', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ newEmail: email }) });
      const data  = await res.json();
      if (data.success) {
        document.querySelectorAll('.otp-cell').forEach(c => c.value = '');
        document.querySelectorAll('.otp-cell')[0].focus();
        startResendTimer();
        showToast('New OTP sent!', 'success');
      } else { errEl.textContent = data.message || 'Failed to resend.'; errEl.style.display = 'block'; btn.disabled = false; }
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = 'block'; btn.disabled = false; }
  }

  function otpNext(input, idx) {
    input.value = input.value.replace(/[^0-9]/g, '');
    const cells = document.querySelectorAll('.otp-cell');
    if (input.value.length === 1 && idx < 5) cells[idx + 1].focus();
    if (idx === 5 && input.value.length === 1) {
      const otp = Array.from(cells).map(c => c.value).join('');
      if (otp.length === 6) verifyEmailOTP();
    }
  }
  function otpBack(e, input, idx) {
    if (e.key === 'Backspace' && !input.value && idx > 0) document.querySelectorAll('.otp-cell')[idx - 1].focus();
  }
  document.querySelectorAll('.otp-cell').forEach(cell => {
    cell.addEventListener('paste', e => {
      e.preventDefault();
      const pasted = e.clipboardData.getData('text').replace(/[^0-9]/g, '').slice(0, 6);
      if (!pasted) return;
      const cells = document.querySelectorAll('.otp-cell');
      pasted.split('').forEach((char, i) => { if (cells[i]) cells[i].value = char; });
      cells[Math.min(pasted.length - 1, 5)].focus();
      if (pasted.length === 6) verifyEmailOTP();
    });
  });
  function startResendTimer() {
    const btn = document.getElementById('resendOtpBtn'), timerEl = document.getElementById('resendTimer');
    btn.disabled = true; let secs = 30; timerEl.textContent = '(' + secs + 's)';
    clearInterval(resendInterval);
    resendInterval = setInterval(() => {
      secs--; timerEl.textContent = '(' + secs + 's)';
      if (secs <= 0) { clearInterval(resendInterval); btn.disabled = false; timerEl.textContent = ''; }
    }, 1000);
  }
  function resetEmailForm() {
    document.getElementById('email-step1').style.display = 'block';
    document.getElementById('email-step2').style.display = 'none';
    document.getElementById('new-email').value = '';
    document.getElementById('emailInputError').style.display = 'none';
    document.getElementById('otpError').style.display = 'none';
    document.querySelectorAll('.otp-cell').forEach(c => c.value = '');
    clearInterval(resendInterval);
  }

  
  function togglePw(id) { const el = document.getElementById(id); el.type = el.type === 'password' ? 'text' : 'password'; }
  function updateStrength(val) {
    let score = 0;
    if (val.length >= 8) score++;
    if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const b1 = document.getElementById('bar1'), b2 = document.getElementById('bar2'), b3 = document.getElementById('bar3'), lb = document.getElementById('pwStrengthLabel');
    if (!b1) return;
    b1.className = b2.className = b3.className = 'pw-bar';
    if      (score === 1) { b1.classList.add('weak');   lb.textContent = 'Weak';   lb.style.color = '#f87171'; }
    else if (score === 2) { b1.classList.add('medium'); b2.classList.add('medium'); lb.textContent = 'Good'; lb.style.color = '#fbbf24'; }
    else if (score === 3) { b1.classList.add('strong'); b2.classList.add('strong'); b3.classList.add('strong'); lb.textContent = 'Strong'; lb.style.color = '#4ade80'; }
    else { lb.textContent = ''; }
  }
  function submitPassword() {
    const nw = document.getElementById('pw-new').value, conf = document.getElementById('pw-confirm').value;
    if (nw.length < 8)  { showToast('Password must be at least 8 characters', 'error'); return; }
    if (nw !== conf)    { showToast('Passwords do not match', 'error'); return; }
    document.getElementById('pwForm').submit();
  }

  let editingAddrId = null, deleteAddrId = null;

  function renderAddresses() {
    const list = document.getElementById('addressList'), empty = document.getElementById('noAddresses');
    list.innerHTML = '';
    if (!addresses.length) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';
    addresses.forEach(addr => {
      const card = document.createElement('div');
      card.className = 'addr-card' + (addr.isDefault ? ' default-addr' : '');
      card.innerHTML = `
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
          <div style="flex:1;min-width:140px;">
            ${addr.isDefault ? '<span style="font-size:0.46rem;letter-spacing:0.15em;text-transform:uppercase;color:#4ade80;border:1px solid rgba(74,222,128,0.25);padding:2px 8px;display:inline-block;margin-bottom:8px;">Default</span>' : ''}
            <p style="font-size:0.82rem;font-weight:300;line-height:1.8;color:rgba(245,242,235,0.65);">
              ${addr.street || '—'}<br/>${addr.city || ''}${addr.pincode ? ' — ' + addr.pincode : ''}
            </p>
          </div>
          <div style="display:flex;flex-direction:column;gap:5px;align-items:flex-end;">
            <button class="btn-dark" style="font-size:0.48rem;padding:0.5rem 1rem;" onclick="editAddress('${addr.id}')">Edit</button>
            ${!addr.isDefault ? `<button class="btn-dark" style="font-size:0.48rem;padding:0.5rem 1rem;" onclick="setDefaultAddr('${addr.id}')">Set Default</button>` : ''}
            <button class="btn-danger-sm" style="font-size:0.48rem;padding:0.5rem 1rem;" onclick="promptDelete('${addr.id}')">Delete</button>
          </div>
        </div>`;
      list.appendChild(card);
    });
  }

  function openAddressModal(id = null) {
    editingAddrId = id;
    document.getElementById('addr-street').value  = '';
    document.getElementById('addr-city').value    = '';
    document.getElementById('addr-pincode').value = '';
    document.getElementById('addr-default').checked = false;
    document.getElementById('addrModalTitle').textContent = id ? 'Edit Address' : 'Add New Address';
    document.getElementById('saveAddrBtn').textContent    = id ? 'Update Address' : 'Save Address';
    if (id) {
      const a = addresses.find(x => x.id === id);
      if (a) {
        document.getElementById('addr-street').value  = a.street  || '';
        document.getElementById('addr-city').value    = a.city    || '';
        document.getElementById('addr-pincode').value = a.pincode || '';
        document.getElementById('addr-default').checked = !!a.isDefault;
      }
    }
    document.getElementById('addrModal').classList.add('open');
  }
  function closeAddressModal() { document.getElementById('addrModal').classList.remove('open'); editingAddrId = null; }

  function saveAddress() {
    const street = document.getElementById('addr-street').value.trim();
    const city   = document.getElementById('addr-city').value.trim();
    const pincode = document.getElementById('addr-pincode').value.trim();
    const isDefault = document.getElementById('addr-default').checked;
    if (!street || !city || !pincode) { showToast('Please fill all address fields', 'error'); return; }
    if (!/^\d{6}$/.test(pincode))     { showToast('PIN code must be 6 digits', 'error'); return; }
    const payload = { street, city, pincode, isDefault };
    const url    = editingAddrId ? `/profile/address/${editingAddrId}` : '/profile/address';
    const method = editingAddrId ? 'PUT' : 'POST';
    fetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) })
      .then(r => r.json()).then(data => {
        if (data.success) {
          addresses = data.addresses.map(a => ({ ...a, id: a._id.toString() }));
          closeAddressModal(); renderAddresses();
          showToast(editingAddrId ? 'Address updated' : 'Address added', 'success');
        } else showToast(data.message || 'Failed', 'error');
      }).catch(() => showToast('Network error', 'error'));
  }
  function setDefaultAddr(id) {
    fetch(`/profile/address/${id}/default`, { method: 'PATCH' })
      .then(r => r.json()).then(data => {
        if (data.success) { addresses = data.addresses.map(a => ({ ...a, id: a._id.toString() })); renderAddresses(); showToast('Default address updated', 'success'); }
      }).catch(() => showToast('Network error', 'error'));
  }
  function editAddress(id) { openAddressModal(id); }
  function promptDelete(id) { deleteAddrId = id; document.getElementById('deleteModal').classList.add('open'); }
  function closeDeleteModal() { document.getElementById('deleteModal').classList.remove('open'); deleteAddrId = null; }
  function confirmDelete() {
    if (!deleteAddrId) return;
    fetch(`/profile/address/${deleteAddrId}`, { method: 'DELETE' })
      .then(r => r.json()).then(data => {
        if (data.success) { addresses = data.addresses.map(a => ({ ...a, id: a._id.toString() })); closeDeleteModal(); renderAddresses(); showToast('Address removed', 'info'); }
        else showToast(data.message || 'Delete failed', 'error');
      }).catch(() => showToast('Network error', 'error'));
  }

  document.getElementById('addrModal').addEventListener('click',   e => { if (e.target === document.getElementById('addrModal'))   closeAddressModal(); });
  document.getElementById('deleteModal').addEventListener('click',  e => { if (e.target === document.getElementById('deleteModal'))  closeDeleteModal(); });

  renderAddresses();
  const hash = window.location.hash.replace('#', '');
  if (['details','edit','email','password','addresses'].includes(hash)) switchTab(hash);

  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
</script>
</body>
</html>
