                <p style="font-size:0.55rem;color:rgba(245,242,235,0.22);margin-top:1px;letter-spacing:0.04em;">
                  Joined <%= ref.joinedAt ? new Date(ref.joinedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) : '—' %>
                </p>
