<!-- ══ TOAST ══ -->
<div class="toast" id="toast"><span class="toast-dot"></span><span id="toastMsg"></span></div>

<script>
  /* ── NAV ── */
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => navbar.classList.toggle('scrolled', scrollY > 30), { passive: true });
  document.getElementById('hamburger').addEventListener('click', function() {
    this.classList.toggle('open');
    document.getElementById('mobileMenu').classList.toggle('open');
  });

  /* ── PARTICLES ── */
  (function() {
    const container = document.getElementById('heroParticles');
    if (!container) return;
    for (let i = 0; i < 18; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 2.5 + 1;
      p.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100+20}%;--drift-x:${(Math.random()-0.5)*60}px;animation-duration:${Math.random()*12+8}s;animation-delay:-${Math.random()*10}s;opacity:${Math.random()*0.5+0.2};`;
      container.appendChild(p);
    }
  })();

  /* ── LIVE CLOCK ── */
  (function() {
    const el = document.getElementById('liveTime');
    function tick() {
      const now = new Date();
      el.textContent = String(now.getHours()).padStart(2,'0') + ' : ' + String(now.getMinutes()).padStart(2,'0') + ' : ' + String(now.getSeconds()).padStart(2,'0');
    }
    tick(); setInterval(tick, 1000);
  })();

  /* ── WATCH HANDS ── */
  (function() {
    const now = new Date(), sec = now.getSeconds(), min = now.getMinutes() + sec/60;
    document.querySelectorAll('.wd-hand-seconds').forEach(el => { el.style.transform = `rotate(${sec*6}deg)`; el.style.animationDelay = `-${sec}s`; });
    document.querySelectorAll('.wd-hand-minutes').forEach(el => { el.style.transform = `rotate(${min*6}deg)`; el.style.animationDelay = `-${min*60}s`; });
  })();

  /* ── CART COUNT ── */
  fetch('/api/cart/count', { headers: { 'Accept': 'application/json' } })
    .then(r => r.json()).then(d => { if (d.count !== undefined) document.getElementById('cartCount').textContent = d.count; }).catch(() => {});

  /* ── TAB SWITCHER ── */
  function switchTab(tab) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.sidebar-tab').forEach(t => t.classList.remove('active'));
    const panel = document.getElementById('panel-' + tab);
    const tabEl = document.getElementById('tab-' + tab);
    if (panel) panel.classList.add('active');
    if (tabEl) tabEl.classList.add('active');
    if (tab === 'addresses') renderAddresses();
  }

  /* ── TOAST ── */
  let toastTimer;
  function showToast(msg, type = 'info') {
    const t = document.getElementById('toast');
    document.getElementById('toastMsg').textContent = msg;
    t.className = 'toast show' + (type === 'error' ? ' err' : type === 'success' ? ' ok' : '');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => t.classList.remove('show'), 3200);
  }

  /* ════ VALIDATION ════ */
  const ERR_ICON = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;

  function setFieldError(inputEl, errId, msg) {
    inputEl.classList.add('input-error'); inputEl.classList.remove('input-valid');
    const errEl = document.getElementById(errId);
    if (errEl) { errEl.innerHTML = ERR_ICON + ' ' + msg; errEl.classList.remove('hidden'); inputEl.classList.remove('shake'); void inputEl.offsetWidth; inputEl.classList.add('shake'); }
    return false;
  }
  function setFieldValid(inputEl, errId) {
    inputEl.classList.remove('input-error'); inputEl.classList.add('input-valid');
    const errEl = document.getElementById(errId); if (errEl) errEl.classList.add('hidden'); return true;
  }
  function clearFieldError(inputEl) {
    inputEl.classList.remove('input-error','input-valid','shake');
    const parent = inputEl.closest('.form-group') || inputEl.parentElement;
    if (parent) { const err = parent.querySelector('.field-error-msg'); if (err) err.classList.add('hidden'); }
  }

  /* ════ ADDRESS FIELD VALIDATION ════ */

  /**
   * Generic "must contain real text" check — used for Full Name and City.
   * Rejects:
   *   - empty / whitespace-only
   *   - values with no letters at all (e.g. "____", "....", "1234", "!!!")
   *   - characters outside letters/marks/spaces/apostrophes/hyphens/periods
   *   - runs of 5+ identical characters (e.g. "aaaaaaa", "______")
   * Uses \p{L}/\p{M} so non-Latin scripts (Devanagari, Tamil, etc.) still work.
   */
  function isValidTextField(val) {
    if (!val) return { ok: false, msg: 'This field cannot be empty.' };
    if (!/\p{L}/u.test(val)) return { ok: false, msg: 'Must contain letters, not just symbols or numbers.' };
    if (!/^[\p{L}\p{M}\s.'-]+$/u.test(val)) return { ok: false, msg: 'Only letters, spaces, hyphens, periods, and apostrophes are allowed.' };
    if (val.replace(/\s/g, '').length < 2) return { ok: false, msg: 'Too short — please enter a valid value.' };
    if (/(.)\1{4,}/u.test(val)) return { ok: false, msg: 'Please enter a valid value.' };
    return { ok: true };
  }

  /**
   * Address line check — like isValidTextField but also allows digits,
   * commas, and slashes since street addresses legitimately contain
   * house/flat numbers (e.g. "12/4, MG Road"). Still rejects symbol-only
   * junk like "____", "....", "////".
   */
  function isValidAddressLine(val) {
    if (!val) return { ok: false, msg: 'This field cannot be empty.' };
    if (!/\p{L}/u.test(val) && !/\d/.test(val)) return { ok: false, msg: 'Must contain letters or numbers, not just symbols.' };
    if (!/\p{L}/u.test(val)) return { ok: false, msg: 'Please include a street/area name, not just numbers or symbols.' };
    if (!/^[\p{L}\p{M}\p{N}\s.,'\/-]+$/u.test(val)) return { ok: false, msg: "Contains characters that aren't allowed." };
    if (val.replace(/\s/g, '').length < 3) return { ok: false, msg: 'Too short — please enter a valid address.' };
    if (/(.)\1{4,}/u.test(val)) return { ok: false, msg: 'Please enter a valid address.' };
    return { ok: true };
  }

  function validateAddrField(inputId, errId, fallbackMsg) {
    const el = document.getElementById(inputId);
    if (!el) return true;
    const val = el.value.trim();
    const isAddressLine = inputId === 'addr-line1';
    const result = isAddressLine ? isValidAddressLine(val) : isValidTextField(val);
    if (!result.ok) return setFieldError(el, errId, result.msg || fallbackMsg);
    return setFieldValid(el, errId);
  }

  function validatePhone() {
    const el = document.getElementById('addr-phone');
    if (!/^\d{10}$/.test(el.value.trim())) return setFieldError(el, 'err-addr-phone', 'Enter a valid 10-digit number.');
    if (/^(\d)\1{9}$/.test(el.value.trim())) return setFieldError(el, 'err-addr-phone', 'Enter a valid 10-digit number.');
    return setFieldValid(el, 'err-addr-phone');
  }

  function validateState() {
    const el = document.getElementById('addr-state');
    if (!el.value) return setFieldError(el, 'err-addr-state', 'Please select a state.');
    return setFieldValid(el, 'err-addr-state');
  }

  function validatePincode() {
    const el = document.getElementById('addr-pincode');
    if (!/^\d{6}$/.test(el.value.trim())) return setFieldError(el, 'err-addr-pincode', 'Enter a valid 6-digit PIN code.');
    if (/^(\d)\1{5}$/.test(el.value.trim())) return setFieldError(el, 'err-addr-pincode', 'Enter a valid 6-digit PIN code.');
    return setFieldValid(el, 'err-addr-pincode');
  }

  /**
   * Full-name validation (Edit Profile tab).
   * Rejects:
   *   - empty / whitespace-only values
   *   - values with no letters at all (e.g. "____", "....", "1234", "!!!")
   *   - values containing characters outside letters/marks/spaces/apostrophes/hyphens/periods
   *   - single-character "names"
   *   - runs of 5+ identical characters (e.g. "aaaaaaa", "xxxxxxx")
   * Uses \p{L} (Unicode letter) + \p{M} (combining mark) rather than A-Z, so names
   * in Devanagari, Tamil, Arabic, etc. — including diacritics/matras — are accepted.
   * Change to /[A-Za-z]/ only if you want Latin-only names.
   */
  function validateEditName() {
    const el = document.getElementById('edit-name');
    const val = el.value.trim();

    if (!val) {
      return setFieldError(el, 'err-edit-name', 'Name cannot be empty.');
    }
    if (!/\p{L}/u.test(val)) {
      return setFieldError(el, 'err-edit-name', 'Name must contain letters.');
    }
    if (!/^[\p{L}\p{M}\s.'-]+$/u.test(val)) {
      return setFieldError(el, 'err-edit-name', "Name can only contain letters, spaces, hyphens, periods, and apostrophes.");
    }
    if (val.replace(/\s/g, '').length < 2) {
      return setFieldError(el, 'err-edit-name', 'Name is too short.');
    }
    if (/(.)\1{4,}/u.test(val)) {
      return setFieldError(el, 'err-edit-name', 'Please enter a valid name.');
    }

    return setFieldValid(el, 'err-edit-name');
  }

  /**
   * New-email validation (Change Email tab).
   * Beyond the basic shape check, also rejects local-parts (the bit before
   * the @) that contain no letters or digits at all — e.g. "____@gmail.com",
   * "....@gmail.com", "----@gmail.com" are syntactically "valid" emails per
   * RFC but are obviously junk/test input, not a real address.
   */
  function validateNewEmail() {
    const el = document.getElementById('new-email');
    const val = el.value.trim();

    if (!val) {
      return setFieldError(el, 'err-new-email', 'Enter your new email address.');
    }
    if (!/^\S+@\S+\.\S+$/.test(val)) {
      return setFieldError(el, 'err-new-email', 'Enter a valid email address.');
    }

    const atIndex = val.lastIndexOf('@');
    const localPart = val.slice(0, atIndex);
    const domainPart = val.slice(atIndex + 1);

    // Local part must contain at least one letter or digit — not just
    // underscores/dots/hyphens/plus signs strung together.
    if (!/[A-Za-z0-9]/.test(localPart)) {
      return setFieldError(el, 'err-new-email', 'Enter a real email address, not just symbols.');
    }
    // Reject local parts that are a single character repeated 4+ times
    // (e.g. "____", "....", "----") even if mixed with one stray letter.
    if (/^(.)\1{3,}$/.test(localPart)) {
      return setFieldError(el, 'err-new-email', 'Enter a real email address, not just symbols.');
    }
    // Domain part (before the dot) must also contain real letters/digits.
    const domainLabel = domainPart.split('.')[0];
    if (!domainLabel || !/[A-Za-z0-9]/.test(domainLabel)) {
      return setFieldError(el, 'err-new-email', 'Enter a valid email domain.');
    }

    return setFieldValid(el, 'err-new-email');
  }
  function validateCurrentPw() { const el = document.getElementById('pw-current'); return el.value ? setFieldValid(el,'err-pw-current') : setFieldError(el,'err-pw-current','Current password is required.'); }
  function validateNewPw() { const el = document.getElementById('pw-new'); return el.value.length >= 8 ? setFieldValid(el,'err-pw-new') : setFieldError(el,'err-pw-new','Password must be at least 8 characters.'); }
  function validateConfirmPw() { const el = document.getElementById('pw-confirm'); const nw = document.getElementById('pw-new').value; if (!el.value) return setFieldError(el,'err-pw-confirm','Please confirm your new password.'); return el.value === nw ? setFieldValid(el,'err-pw-confirm') : setFieldError(el,'err-pw-confirm','Passwords do not match.'); }

  function submitEditProfile() {
    if (!validateEditName()) return;
    const nameEl = document.getElementById('edit-name');
    nameEl.value = nameEl.value.trim().replace(/\s+/g, ' '); // collapse internal multiple spaces
    document.getElementById('editProfileForm').submit();
  }

  /* ── AVATAR ── */
  async function uploadAvatar(e) {
    const file = e.target.files[0]; if (!file) return;
    const statusEl = document.getElementById('avatarStatus'); statusEl.textContent = 'Uploading…';
    const formData = new FormData(); formData.append('profileImage', file);
    try {
      const res = await fetch('/profile/upload-image', { method: 'POST', body: formData });
      const data = await res.json();
      if (data.success) {
        const wrap = document.querySelector('.avatar-wrap'), old = document.getElementById('avatarPreview'), img = document.createElement('img');
        img.id = 'avatarPreview'; img.src = data.imageUrl; img.alt = 'Profile'; img.className = 'avatar-img';
        wrap.replaceChild(img, old); statusEl.textContent = 'Click to change'; showToast('Profile photo updated!','success');
      } else { statusEl.textContent = 'Upload failed'; showToast(data.message || 'Upload failed','error'); }
    } catch { statusEl.textContent = 'Click to change'; showToast('Network error. Try again.','error'); }
  }

  /* ── EMAIL OTP ── */
  let resendInterval = null;
  async function sendEmailOTP() {
    if (!validateNewEmail()) return;
    const email = document.getElementById('new-email').value.trim(), btn = document.getElementById('sendOtpBtn');
    btn.disabled = true; btn.textContent = 'Sending…';
    try {
      const res = await fetch('/profile/request-email-change', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ newEmail: email }) });
      const data = await res.json();
      if (data.success) {
        document.getElementById('otp-sent-to').textContent = 'Sent to ' + email;
        document.getElementById('email-step1').style.display = 'none';
        document.getElementById('email-step2').style.display = 'block';
        document.querySelectorAll('.otp-cell')[0].focus(); startResendTimer(); showToast('OTP sent! Check your inbox.','success');
      } else { setFieldError(document.getElementById('new-email'),'err-new-email', data.message || 'Failed to send OTP.'); }
    } catch { setFieldError(document.getElementById('new-email'),'err-new-email','Network error. Please try again.'); }
    btn.disabled = false; btn.textContent = 'Send Verification Code';
  }
  async function verifyEmailOTP() {
    const cells = document.querySelectorAll('.otp-cell'), otp = Array.from(cells).map(c => c.value).join('');
    const errEl = document.getElementById('otpError'), btn = document.getElementById('verifyOtpBtn');
    errEl.style.display = 'none';
    if (otp.length < 6) { errEl.textContent = 'Enter the complete 6-digit code.'; errEl.style.display = 'block'; return; }
    btn.disabled = true; btn.textContent = 'Verifying…';
    try {
      const res = await fetch('/profile/verify-email-change', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ otp }) });
      const data = await res.json();
      if (data.success) {
        showToast('Email updated successfully!','success'); clearInterval(resendInterval);
        const el = document.getElementById('displayEmail'); if (el) el.textContent = document.getElementById('new-email').value.trim();
        resetEmailForm();
      } else { errEl.textContent = data.message || 'Invalid OTP. Try again.'; errEl.style.display = 'block'; cells.forEach(c => { c.style.borderColor = 'rgba(248,113,113,0.5)'; }); setTimeout(() => cells.forEach(c => { c.style.borderColor = ''; }), 1400); }
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = 'block'; }
    btn.disabled = false; btn.textContent = 'Verify & Update';
  }
  async function resendEmailOTP() {
    const btn = document.getElementById('resendOtpBtn'), errEl = document.getElementById('otpError');
    errEl.style.display = 'none'; btn.disabled = true;
    try {
      const email = document.getElementById('new-email').value.trim();
      const res = await fetch('/profile/request-email-change', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ newEmail: email }) });
      const data = await res.json();
      if (data.success) { document.querySelectorAll('.otp-cell').forEach(c => c.value = ''); document.querySelectorAll('.otp-cell')[0].focus(); startResendTimer(); showToast('New OTP sent!','success'); }
      else { errEl.textContent = data.message || 'Failed to resend.'; errEl.style.display = 'block'; btn.disabled = false; }
    } catch { errEl.textContent = 'Network error.'; errEl.style.display = 'block'; btn.disabled = false; }
  }
  function otpNext(input, idx) { input.value = input.value.replace(/[^0-9]/g,''); const cells = document.querySelectorAll('.otp-cell'); if (input.value.length===1 && idx<5) cells[idx+1].focus(); if (idx===5 && input.value.length===1) { const otp = Array.from(cells).map(c=>c.value).join(''); if (otp.length===6) verifyEmailOTP(); } }
  function otpBack(e, input, idx) { if (e.key==='Backspace' && !input.value && idx>0) document.querySelectorAll('.otp-cell')[idx-1].focus(); }
  document.querySelectorAll('.otp-cell').forEach(cell => {
    cell.addEventListener('paste', e => {
      e.preventDefault(); const pasted = e.clipboardData.getData('text').replace(/[^0-9]/g,'').slice(0,6); if (!pasted) return;
      const cells = document.querySelectorAll('.otp-cell'); pasted.split('').forEach((char,i) => { if (cells[i]) cells[i].value = char; });
      cells[Math.min(pasted.length-1,5)].focus(); if (pasted.length===6) verifyEmailOTP();
    });
  });
  function startResendTimer() {
    const btn = document.getElementById('resendOtpBtn'), timerEl = document.getElementById('resendTimer');
    btn.disabled = true; let secs = 30; timerEl.textContent = '('+secs+'s)'; clearInterval(resendInterval);
    resendInterval = setInterval(() => { secs--; timerEl.textContent = '('+secs+'s)'; if (secs<=0) { clearInterval(resendInterval); btn.disabled = false; timerEl.textContent = ''; } }, 1000);
  }
  function resetEmailForm() {
    document.getElementById('email-step1').style.display = 'block'; document.getElementById('email-step2').style.display = 'none';
    document.getElementById('new-email').value = ''; document.getElementById('err-new-email').classList.add('hidden');
    document.getElementById('otpError').style.display = 'none'; document.querySelectorAll('.otp-cell').forEach(c => c.value = ''); clearInterval(resendInterval);
  }

  /* ── PASSWORD ── */
  function togglePw(id) {
  const el = document.getElementById(id);
  el.type = el.type === 'password' ? 'text' : 'password';
}

function updateStrength(val) {
  let score = 0;
  if (val.length >= 8) score++;
  if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
  if (/[^A-Za-z0-9]/.test(val)) score++;
  const b1 = document.getElementById('bar1');
  const b2 = document.getElementById('bar2');
  const b3 = document.getElementById('bar3');
  const lb = document.getElementById('pwStrengthLabel');
  if (!b1) return;
  b1.className = b2.className = b3.className = 'pw-bar';
  if (score === 1) {
    b1.classList.add('weak');
    lb.textContent = 'Weak';
    lb.style.color = '#f87171';
  } else if (score === 2) {
    b1.classList.add('medium');
    b2.classList.add('medium');
    lb.textContent = 'Good';
    lb.style.color = '#fbbf24';
  } else if (score === 3) {
    b1.classList.add('strong');
    b2.classList.add('strong');
    b3.classList.add('strong');
    lb.textContent = 'Strong';
    lb.style.color = '#4ade80';
  } else {
    lb.textContent = '';
  }
}

async function submitPassword() {
  if (!validateCurrentPw() || !validateNewPw() || !validateConfirmPw()) return;

  const form = document.getElementById('pwForm');
  const btn = form.querySelector('.btn-gold');
  const oldPassword = document.getElementById('pw-current').value;
  const newPassword = document.getElementById('pw-new').value;
  const confirmPassword = document.getElementById('pw-confirm').value;

  const originalHTML = btn.innerHTML;
  btn.disabled = true;
  btn.textContent = 'Updating…';

  try {
    const res = await fetch('/change-password', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ oldPassword, newPassword, confirmPassword })
    });
    const data = await res.json();

    if (data.success) {
      showToast(data.message || 'Password updated successfully.', 'success');
      form.reset();
      updateStrength('');
      ['pw-current', 'pw-new', 'pw-confirm'].forEach(id => {
        const el = document.getElementById(id);
        el.classList.remove('input-error', 'input-valid');
      });
    } else {
      showToast(data.message || 'Failed to update password.', 'error');
      if (res.status === 400 && /current password/i.test(data.message || '')) {
        setFieldError(document.getElementById('pw-current'), 'err-pw-current', data.message);
      }
    }
  } catch {
    showToast('Network error. Please try again.', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = originalHTML;
  }
}

document.getElementById('pwForm').addEventListener('submit', e => e.preventDefault());
  /* ════ ADDRESSES ════ */
  let editingAddrId = null, deleteAddrId = null;
  function renderAddresses() {
    const list = document.getElementById('addressList'), empty = document.getElementById('noAddresses');
    list.innerHTML = '';
    if (!addresses.length) { empty.style.display = 'block'; return; }
    empty.style.display = 'none';
    addresses.forEach(addr => {
      const card = document.createElement('div');
      card.className = 'addr-card' + (addr.isDefault ? ' default-addr' : '');
      const nameLine = addr.fullName||'—', phoneLine = addr.phone?`📞 ${addr.phone}`:'', line1 = addr.line1||addr.street||'', line2 = addr.line2?`, ${addr.line2}`:'', cityLine = [addr.city,addr.state].filter(Boolean).join(', '), pinLine = addr.pincode?` — ${addr.pincode}`:'', typeBadge = addr.addressType?`<span style="font-size:0.38rem;letter-spacing:0.14em;text-transform:uppercase;color:rgba(201,169,110,0.55);border:1px solid rgba(201,169,110,0.2);padding:2px 8px;border-radius:100px;margin-left:8px;">${addr.addressType}</span>`:'';
      card.innerHTML = `<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;"><div style="flex:1;min-width:160px;">${addr.isDefault?'<span style="font-size:0.44rem;letter-spacing:0.15em;text-transform:uppercase;color:#4ade80;border:1px solid rgba(74,222,128,0.22);padding:2px 10px;display:inline-block;margin-bottom:8px;border-radius:100px;background:rgba(74,222,128,0.05);">Default</span>':''}<p style="font-family:\'Cormorant Garamond\',serif;font-size:1rem;font-weight:400;color:#f5f2eb;margin-bottom:4px;">${nameLine}${typeBadge}</p><p style="font-size:0.72rem;font-weight:300;line-height:1.85;color:rgba(245,242,235,0.45);">${line1}${line2}<br/>${cityLine}${pinLine}<br/>${phoneLine}</p></div><div style="display:flex;flex-direction:column;gap:6px;align-items:flex-end;flex-shrink:0;"><button class="btn-dark" style="font-size:0.46rem;padding:0.5rem 1.1rem;" onclick="editAddress('${addr.id}')">Edit</button>${!addr.isDefault?`<button class="btn-dark" style="font-size:0.46rem;padding:0.5rem 1.1rem;" onclick="setDefaultAddr('${addr.id}')">Set Default</button>`:''}<button class="btn-danger-sm" style="font-size:0.46rem;padding:0.5rem 1.1rem;" onclick="promptDelete('${addr.id}')">Delete</button></div></div>`;
      list.appendChild(card);
    });
    const statEl = document.getElementById('statAddresses'); if (statEl) statEl.textContent = addresses.length;
  }
  function openAddressModal(id = null) {
    editingAddrId = id;
    ['addr-fullName','addr-phone','addr-line1','addr-line2','addr-city','addr-pincode'].forEach(fid => { const el=document.getElementById(fid); el.value=''; el.classList.remove('input-error','input-valid','shake'); });
    const stateEl = document.getElementById('addr-state'); stateEl.value=''; stateEl.classList.remove('input-error','input-valid');
    document.getElementById('addr-type').value = 'Home';
    document.querySelectorAll('#addrModal .field-error-msg').forEach(e => e.classList.add('hidden'));
    document.getElementById('addrModalTitle').textContent = id ? 'Edit Address' : 'Add New Address';
    if (id) { const a = addresses.find(x=>x.id===id); if (a) { document.getElementById('addr-fullName').value=a.fullName||''; document.getElementById('addr-phone').value=a.phone||''; document.getElementById('addr-line1').value=a.line1||a.street||''; document.getElementById('addr-line2').value=a.line2||''; document.getElementById('addr-city').value=a.city||''; document.getElementById('addr-pincode').value=a.pincode||''; document.getElementById('addr-type').value=a.addressType||'Home'; const sel=document.getElementById('addr-state'); for (const opt of sel.options){if(opt.value===a.state||opt.text===a.state){sel.value=opt.value;break;}} } }
    document.getElementById('addrModal').classList.add('open');
    setTimeout(() => document.getElementById('addr-fullName').focus(), 300);
  }
  function closeAddressModal() { document.getElementById('addrModal').classList.remove('open'); editingAddrId = null; }
  async function saveAddress() {
    const v1 = validateAddrField('addr-fullName','err-addr-fullName');
    const v2 = validatePhone();
    const v3 = validateAddrField('addr-line1','err-addr-line1');
    const v4 = validateAddrField('addr-city','err-addr-city');
    const v5 = validateState();
    const v6 = validatePincode();
    if (!v1||!v2||!v3||!v4||!v5||!v6) return;
    const fullName=document.getElementById('addr-fullName').value.trim(), phone=document.getElementById('addr-phone').value.trim(), line1=document.getElementById('addr-line1').value.trim(), line2=document.getElementById('addr-line2').value.trim(), city=document.getElementById('addr-city').value.trim(), state=document.getElementById('addr-state').value, pincode=document.getElementById('addr-pincode').value.trim(), addressType=document.getElementById('addr-type').value;
    const btn = document.getElementById('saveAddrBtn'); btn.disabled=true; btn.textContent='Saving…';
    try {
      const res = await fetch(editingAddrId?`/profile/address/${editingAddrId}`:'/profile/address', { method:editingAddrId?'PUT':'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({fullName,phone,line1,line2,city,state,pincode,addressType}) });
      const data = await res.json();
      if (data.success) { addresses=data.addresses.map(a=>({...a,id:a._id.toString()})); closeAddressModal(); renderAddresses(); showToast(editingAddrId?'Address updated.':'Address saved.','success'); }
      else showToast(data.message||'Failed to save address.','error');
    } catch { showToast('Network error. Please try again.','error'); }
    finally { btn.disabled=false; btn.textContent='Save Address'; }
  }
  function setDefaultAddr(id) { fetch(`/profile/address/${id}/default`,{method:'PATCH'}).then(r=>r.json()).then(data=>{if(data.success){addresses=data.addresses.map(a=>({...a,id:a._id.toString()}));renderAddresses();showToast('Default address updated.','success');}else showToast(data.message||'Failed.','error');}).catch(()=>showToast('Network error.','error')); }
  function editAddress(id) { openAddressModal(id); }
  function promptDelete(id) { deleteAddrId=id; document.getElementById('deleteModal').classList.add('open'); }
  function closeDeleteModal() { document.getElementById('deleteModal').classList.remove('open'); deleteAddrId=null; }
  function confirmDelete() { if (!deleteAddrId) return; fetch(`/profile/address/${deleteAddrId}`,{method:'DELETE'}).then(r=>r.json()).then(data=>{if(data.success){addresses=data.addresses.map(a=>({...a,id:a._id.toString()}));closeDeleteModal();renderAddresses();showToast('Address removed.','info');}else showToast(data.message||'Delete failed.','error');}).catch(()=>showToast('Network error.','error')); }
  document.getElementById('addrModal').addEventListener('click', e=>{if(e.target===document.getElementById('addrModal'))closeAddressModal();});
  document.getElementById('deleteModal').addEventListener('click', e=>{if(e.target===document.getElementById('deleteModal'))closeDeleteModal();});

  /* ════ REFERRAL ════ */
  function copyCode(code) {
    navigator.clipboard.writeText(code).then(() => {
      const btn = document.getElementById('copyCodeBtn');
      if (btn) { btn.classList.add('copied'); btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg> Copied!'; setTimeout(()=>{ btn.classList.remove('copied'); btn.innerHTML = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg> Copy Code'; }, 2000); }
      showToast('Referral code copied!', 'success');
    }).catch(() => showToast('Copy failed — please copy manually.', 'error'));
  }
  function copyLink() {
    const code = document.getElementById('refCodeDisplay') ? document.getElementById('refCodeDisplay').textContent.trim() : '';
    const link = window.location.origin + '/signup?ref=' + code;
    navigator.clipboard.writeText(link).then(() => showToast('Referral link copied!', 'success')).catch(() => showToast('Copy failed.', 'error'));
  }
  function shareWhatsApp() {
    const code = document.getElementById('refCodeDisplay') ? document.getElementById('refCodeDisplay').textContent.trim() : '';
    const text = encodeURIComponent('Hey! Use my referral code ' + code + ' when you sign up on Velmora Chroné and we both get a reward: ' + window.location.origin + '/signup?ref=' + code);
    window.open('https://wa.me/?text=' + text, '_blank');
  }
  function shareEmail() {
    const code = document.getElementById('refCodeDisplay') ? document.getElementById('refCodeDisplay').textContent.trim() : '';
    const subject = encodeURIComponent('Join Velmora Chroné — use my referral code');
    const body = encodeURIComponent('Hey,\n\nI\'ve been shopping on Velmora Chroné and thought you\'d love it too. Use my referral code ' + code + ' when you sign up and we both earn a wallet credit!\n\nSign up here: ' + window.location.origin + '/signup?ref=' + code + '\n\nCheers!');
    window.location.href = 'mailto:?subject=' + subject + '&body=' + body;
  }
  function shareNative() {
    const code = document.getElementById('refCodeDisplay') ? document.getElementById('refCodeDisplay').textContent.trim() : '';
    if (navigator.share) {
      navigator.share({ title: 'Velmora Chroné — Join with my referral', text: 'Use code ' + code + ' when you sign up!', url: window.location.origin + '/signup?ref=' + code }).catch(()=>{});
    } else { copyLink(); }
  }

  /* ── INIT ── */
  renderAddresses();
  const hash = window.location.hash.replace('#','');
  if (['details','edit','email','password','addresses','referral'].includes(hash)) switchTab(hash);
  history.pushState(null, null, window.location.href);
  window.addEventListener('popstate', () => history.pushState(null, null, window.location.href));
