      </button>
    </div>
    <a href="/logout" class="sidebar-logout">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
      Logout
    </a>
  </aside>

  <!-- MAIN -->
  <main class="profile-main">

    <!-- ── OVERVIEW PANEL ── -->
    <div class="panel active ink-reveal" id="panel-details">
      <p class="panel-title">Profile Overview</p>
      <div style="display:flex;align-items:flex-start;gap:1.5rem;flex-wrap:wrap;margin-bottom:2.5rem;">
        <div>
          <div class="avatar-wrap" onclick="document.getElementById('avatarInput').click()">
            <% if (user.profileImage && user.profileImage !== '/images/default-avatar.png') { %>
              <img id="avatarPreview" src="<%= user.profileImage %>"
                onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 96 96%22%3E%3Crect fill=%22%231a1a18%22 width=%2296%22 height=%2296%22/%3E%3C/svg%3E'"
                alt="Profile" class="avatar-img"/>
            <% } else { %>
              <div id="avatarPreview" class="avatar-default">
                <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                  <rect x="12" y="30" width="76" height="46" rx="6" fill="#2a2a28"/>
                  <rect x="35" y="22" width="22" height="10" rx="3" fill="#222220"/>
                  <rect x="16" y="26" width="8" height="5" rx="2" class="cam-fb"/>
                  <circle cx="74" cy="30" r="4" fill="#c9a96e"/>
                  <circle cx="37" cy="52" r="17" fill="#1a1a18" class="cam-sh"/>
                  <circle cx="37" cy="52" r="13" fill="#222220" class="cam-sh"/>
                  <circle cx="37" cy="52" r="8" fill="#0d0d0c" class="cam-sh cam-lp"/>
                  <ellipse cx="33" cy="48" rx="3" ry="2" fill="#c9a96e" opacity="0.18" class="cam-sh"/>
                  <circle cx="37" cy="52" r="14.5" fill="none" stroke="#c9a96e" stroke-width="0.8" class="cam-sh"/>
                  <circle cx="66" cy="44" r="1.5" fill="#c9a96e" opacity="0.5"/>
                  <circle cx="66" cy="52" r="1.5" fill="#c9a96e" opacity="0.3"/>
                  <circle cx="66" cy="60" r="1.5" fill="#c9a96e" opacity="0.2"/>
                </svg>
              </div>
            <% } %>
            <div class="avatar-overlay">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#c9a96e" stroke-width="1.5"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </div>
          </div>
          <input type="file" id="avatarInput" accept="image/*" style="display:none" onchange="uploadAvatar(event)"/>
          <p id="avatarStatus" style="font-size:0.44rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(245,242,235,0.18);margin-top:6px;text-align:center;">Click to change</p>
        </div>
        <div style="flex:1;min-width:160px;padding-top:4px;">
          <div class="profile-name-wrap">
            <h2 style="font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:400;color:#f5f2eb;line-height:1.1;margin-bottom:4px;"><%= user.name %></h2>
          </div>
          <p id="displayEmail" style="font-size:0.72rem;font-weight:300;color:rgba(245,242,235,0.35);margin-bottom:12px;letter-spacing:0.04em;margin-top:8px;"><%= user.email %></p>
          <% if (user.googleId && !user.password) { %><span class="google-badge">Google Account</span><% } %>
          <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1.1rem;">
            <div class="stat-pill">
              <span class="stat-num" id="statAddresses"><%= user.addresses ? user.addresses.length : 0 %></span>
              <span class="stat-label">Addresses</span>
            </div>
            <div class="stat-pill">
              <span class="stat-num" style="font-size:1rem;padding-top:4px;"><%= user.emailVerified ? '✓' : '—' %></span>
              <span class="stat-label">Verified</span>
            </div>
            <div class="stat-pill">
              <span class="stat-num" style="font-size:1.1rem;padding-top:4px;"><%= new Date(user.createdAt).getFullYear() %></span>
              <span class="stat-label">Since</span>
            </div>
            <div class="stat-pill" onclick="switchTab('referral')" style="cursor:pointer;">
              <span class="stat-num" style="font-size:1.1rem;padding-top:4px;"><%= (user.referrals && user.referrals.length) ? user.referrals.length : 0 %></span>
              <span class="stat-label">Referrals</span>
            </div>
          </div>
        </div>
      </div>
      <div class="rule" style="margin-bottom:2rem;"></div>
      <div class="info-grid">
        <div class="info-item"><p class="info-item-label">Full Name</p><p class="info-item-value"><%= user.name %></p></div>
        <div class="info-item"><p class="info-item-label">Email Address</p><p class="info-item-value"><%= user.email %></p></div>
        <div class="info-item"><p class="info-item-label">Account Type</p><p class="info-item-value"><%= user.googleId ? 'Google OAuth' : 'Email & Password' %></p></div>
        <div class="info-item"><p class="info-item-label">Member Since</p><p class="info-item-value"><%= new Date(user.createdAt).toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' }) %></p></div>
        <div class="info-item"><p class="info-item-label">Last Login</p><p class="info-item-value"><%= user.lastLogin ? new Date(user.lastLogin).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }) : '—' %></p></div>
        <div class="info-item"><p class="info-item-label">Role</p><p class="info-item-value" style="text-transform:capitalize;"><%= user.role %></p></div>
        <div class="info-item"><p class="info-item-label">Referral Code</p>
          <p class="info-item-value" style="display:flex;align-items:center;gap:8px;">
            <span style="font-family:'Cormorant Garamond',serif;font-size:1rem;color:#f0d9a8;letter-spacing:0.14em;"><%= user.referralCode || '—' %></span>
            <% if (user.referralCode) { %>
            <button onclick="copyCode('<%= user.referralCode %>')" style="background:none;border:none;cursor:pointer;color:rgba(201,169,110,0.45);transition:color 0.2s;padding:0;" onmouseover="this.style.color='#c9a96e'" onmouseout="this.style.color='rgba(201,169,110,0.45)'">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            </button>
            <% } %>
          </p>
        </div>
      </div>
      <div style="margin-top:2rem;display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
        <button class="btn-gold" onclick="switchTab('edit')">Edit Profile<span class="btn-arrow"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span></button>
        <button class="btn-dark" onclick="switchTab('addresses')">Manage Addresses</button>
        <button class="btn-dark" onclick="switchTab('referral')" style="gap:6px;">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          Refer &amp; Earn
        </button>
      </div>
    </div>

    <!-- ── EDIT PROFILE PANEL ── -->
    <div class="panel" id="panel-edit">
      <p class="panel-title">Edit Profile</p>
      <% if (locals.editError) { %><div class="flash-error"><%= editError %></div><% } %>
      <% if (locals.editSuccess) { %><div class="flash-success"><%= editSuccess %></div><% } %>
      <form action="/profile/update" method="POST" style="max-width:440px;" id="editProfileForm" novalidate>
        <div style="display:grid;gap:1.25rem;">
          <div class="form-group">
            <label class="vc-label" for="edit-name">Full Name</label>
            <input class="vc-input" id="edit-name" name="name" value="<%= user.name %>" placeholder="Your full name" required
              oninput="clearFieldError(this)" onblur="validateEditName()"/>
            <span class="field-error-msg hidden" id="err-edit-name">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Name cannot be empty.
            </span>
          </div>
          <div class="form-group">
            <label class="vc-label">Email Address</label>
            <input class="vc-input" value="<%= user.email %>" disabled/>
            <p style="font-size:0.48rem;color:rgba(245,242,235,0.18);margin-top:6px;letter-spacing:0.1em;">Use the Change Email tab to update your email.</p>
          </div>
        </div>
        <div style="margin-top:1.75rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
          <button type="button" class="btn-gold" onclick="submitEditProfile()">Save Changes<span class="btn-arrow"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span></button>
          <button type="button" class="btn-dark" onclick="switchTab('details')">Cancel</button>
        </div>
      </form>
    </div>

    <!-- ── CHANGE EMAIL PANEL ── -->
    <div class="panel" id="panel-email">
      <p class="panel-title">Change Email Address</p>
      <div id="email-step1" style="max-width:420px;">
        <p style="font-size:0.75rem;font-weight:300;color:rgba(245,242,235,0.35);line-height:1.85;margin-bottom:1.5rem;">Enter your new email. We'll send a 6-digit code to confirm the change.</p>
        <div style="margin-bottom:1.25rem;"><label class="vc-label">Current Email</label><input class="vc-input" value="<%= user.email %>" disabled/></div>
        <div class="form-group" style="margin-bottom:1.5rem;">
          <label class="vc-label" for="new-email">New Email Address</label>
          <input class="vc-input" id="new-email" type="email" placeholder="new@email.com"
            oninput="clearFieldError(this)" onblur="validateNewEmail()"/>
          <span class="field-error-msg hidden" id="err-new-email">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Enter a valid email address.
          </span>
        </div>
        <button class="btn-gold" id="sendOtpBtn" onclick="sendEmailOTP()">Send Verification Code<span class="btn-arrow"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span></button>
      </div>
      <div id="email-step2" style="display:none;max-width:420px;">
        <div style="display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;padding:1rem;border:1px solid rgba(74,222,128,0.15);background:rgba(74,222,128,0.04);border-radius:10px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#4ade80" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div><p style="font-size:0.7rem;color:rgba(245,242,235,0.75);">Verification code sent</p><p style="font-size:0.6rem;color:rgba(245,242,235,0.3);" id="otp-sent-to">Check your inbox</p></div>
        </div>
        <p style="font-size:0.7rem;color:rgba(245,242,235,0.35);margin-bottom:1.25rem;font-weight:300;">Enter the 6-digit code:</p>
        <div class="otp-row" style="margin-bottom:0.75rem;">
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,0)" onkeydown="otpBack(event,this,0)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,1)" onkeydown="otpBack(event,this,1)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,2)" onkeydown="otpBack(event,this,2)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,3)" onkeydown="otpBack(event,this,3)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,4)" onkeydown="otpBack(event,this,4)"/>
          <input class="otp-cell" maxlength="1" oninput="otpNext(this,5)" onkeydown="otpBack(event,this,5)"/>
        </div>
        <p id="otpError" style="display:none;font-size:0.6rem;color:#f87171;margin-bottom:1rem;"></p>
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-top:1rem;">
          <button class="btn-gold" id="verifyOtpBtn" onclick="verifyEmailOTP()">Verify &amp; Update<span class="btn-arrow"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span></button>
          <button class="btn-dark" id="resendOtpBtn" onclick="resendEmailOTP()" disabled style="font-size:0.48rem;">Resend <span id="resendTimer"></span></button>
        </div>
        <button onclick="resetEmailForm()" style="margin-top:1rem;background:none;border:none;font-size:0.48rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(245,242,235,0.2);cursor:pointer;transition:color 0.2s;" onmouseover="this.style.color='rgba(245,242,235,0.5)'" onmouseout="this.style.color='rgba(245,242,235,0.2)'">← Use different email</button>
      </div>
    </div>

    <!-- ── CHANGE PASSWORD PANEL ── -->
    <% if (user.password) { %>
    <div class="panel" id="panel-password">
      <p class="panel-title">Change Password</p>
      <form action="/change-password" method="POST" style="max-width:400px;" id="pwForm" novalidate>
        <div class="form-group" style="margin-bottom:1.25rem;">
          <label class="vc-label" for="pw-current">Current Password</label>
          <div style="position:relative;">
            <input class="vc-input" id="pw-current" name="oldPassword" type="password" placeholder="Current password"
              style="padding-right:2.75rem;" required
              oninput="clearFieldError(this)" onblur="validateCurrentPw()"/>
            <button type="button" onclick="togglePw('pw-current')" style="position:absolute;right:0.85rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.25);transition:color 0.2s;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <span class="field-error-msg hidden" id="err-pw-current">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Current password is required.
          </span>
        </div>
        <div class="form-group" style="margin-bottom:1.25rem;">
          <label class="vc-label" for="pw-new">New Password</label>
          <div style="position:relative;">
            <input class="vc-input" id="pw-new" name="newPassword" type="password" placeholder="Min. 8 characters"
              style="padding-right:2.75rem;" oninput="updateStrength(this.value); clearFieldError(this);" onblur="validateNewPw()" required/>
            <button type="button" onclick="togglePw('pw-new')" style="position:absolute;right:0.85rem;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:rgba(245,242,235,0.25);transition:color 0.2s;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
          </div>
          <div class="pw-bar-wrap"><div class="pw-bar" id="bar1"></div><div class="pw-bar" id="bar2"></div><div class="pw-bar" id="bar3"></div></div>
          <span class="field-error-msg hidden" id="err-pw-new">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Password must be at least 8 characters.
          </span>
          <p style="font-size:0.5rem;color:rgba(245,242,235,0.22);margin-top:4px;" id="pwStrengthLabel"></p>
        </div>
        <div class="form-group" style="margin-bottom:1.75rem;">
          <label class="vc-label" for="pw-confirm">Confirm New Password</label>
          <input class="vc-input" id="pw-confirm" name="confirmPassword" type="password" placeholder="Re-enter new password" required
            oninput="clearFieldError(this)" onblur="validateConfirmPw()"/>
          <span class="field-error-msg hidden" id="err-pw-confirm">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            Passwords do not match.
          </span>
        </div>
        <button type="button" class="btn-gold" onclick="submitPassword()">Update Password<span class="btn-arrow"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span></button>
      </form>
    </div>
    <% } %>

    <!-- ── ADDRESSES PANEL ── -->
    <div class="panel" id="panel-addresses">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem;flex-wrap:wrap;gap:1rem;">
        <p class="panel-title" style="margin-bottom:0;">Saved Addresses</p>
        <button class="btn-gold" onclick="openAddressModal()" style="font-size:0.48rem;padding:0.72rem 1.4rem;">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Address
        </button>
      </div>
      <script>
        const dbAddresses = <%- JSON.stringify(user.addresses || []) %>;
        let addresses = dbAddresses.map(a => ({ ...a, id: a._id ? a._id.toString() : String(Math.random()) }));
      </script>
      <div id="addressList" style="display:flex;flex-direction:column;gap:0.75rem;max-width:620px;"></div>
      <p id="noAddresses" style="font-size:0.75rem;font-weight:300;color:rgba(245,242,235,0.22);display:none;">No saved addresses. Add one above.</p>
    </div>

    <!-- ══════════════════════════════════════
         ── REFERRAL PANEL ──
    ══════════════════════════════════════ -->
    <div class="panel" id="panel-referral">
      <p class="panel-title">Refer &amp; Earn</p>

      <!-- intro blurb -->
      <p style="font-size:0.75rem;font-weight:300;color:rgba(245,242,235,0.35);line-height:1.9;margin-bottom:1.75rem;max-width:520px;">
        Share your personal code with friends. When they sign up and place their first order, both of you receive a reward credited straight to your wallets.
      </p>

      <!-- BIG CODE BOX -->
      <% if (user.referralCode) { %>
      <div class="ref-code-box">
        <div>
          <p style="font-family:'Jost',sans-serif;font-size:0.42rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(201,169,110,0.4);margin-bottom:8px;">Your Referral Code</p>
          <p class="ref-code-text" id="refCodeDisplay"><%= user.referralCode %></p>
        </div>
        <div style="display:flex;flex-direction:column;gap:8px;align-items:flex-end;">
          <button class="ref-copy-btn" id="copyCodeBtn" onclick="copyCode('<%= user.referralCode %>')">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
            Copy Code
          </button>
          <button class="ref-copy-btn" onclick="copyLink()">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            Copy Link
          </button>
        </div>
      </div>

      <!-- SHARE ROW -->
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:2rem;">
        <button class="ref-share-btn" onclick="shareWhatsApp()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          WhatsApp
        </button>
        <button class="ref-share-btn" onclick="shareEmail()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          Email
        </button>
        <button class="ref-share-btn" onclick="shareNative()">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          More
        </button>
      </div>
      <% } else { %>
      <div style="padding:1.5rem;border:1px solid rgba(245,242,235,0.06);border-radius:12px;text-align:center;margin-bottom:2rem;">
        <p style="font-size:0.72rem;font-weight:300;color:rgba(245,242,235,0.25);">No referral code assigned yet. Contact support to enable referrals on your account.</p>
      </div>
      <% } %>

      <!-- HOW IT WORKS -->
      <p style="font-family:'Jost',sans-serif;font-size:0.44rem;letter-spacing:0.28em;text-transform:uppercase;color:rgba(201,169,110,0.38);margin-bottom:0.9rem;">How it works</p>
      <div style="display:flex;flex-direction:column;gap:8px;max-width:540px;margin-bottom:2rem;">
        <div class="ref-how-step">
          <div class="ref-step-num">1</div>
          <div>
            <p style="font-size:0.75rem;font-weight:400;color:rgba(245,242,235,0.75);margin-bottom:3px;">Share your code</p>
            <p style="font-size:0.65rem;font-weight:300;color:rgba(245,242,235,0.3);line-height:1.7;">Send your unique referral code or link to friends and family.</p>
          </div>
        </div>
        <div class="ref-how-step">
          <div class="ref-step-num">2</div>
          <div>
            <p style="font-size:0.75rem;font-weight:400;color:rgba(245,242,235,0.75);margin-bottom:3px;">They sign up &amp; order</p>
            <p style="font-size:0.65rem;font-weight:300;color:rgba(245,242,235,0.3);line-height:1.7;">Your friend uses your code at signup and completes their first purchase.</p>
          </div>
        </div>
        <div class="ref-how-step">
          <div class="ref-step-num">3</div>
          <div>
            <p style="font-size:0.75rem;font-weight:400;color:rgba(245,242,235,0.75);margin-bottom:3px;">Both of you earn</p>
            <p style="font-size:0.65rem;font-weight:300;color:rgba(245,242,235,0.3);line-height:1.7;">A wallet credit is added automatically for both you and your friend.</p>
          </div>
        </div>
      </div>

      <!-- REFERRED FRIENDS LIST -->
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.9rem;">
        <p style="font-family:'Jost',sans-serif;font-size:0.44rem;letter-spacing:0.28em;text-transform:uppercase;color:rgba(201,169,110,0.38);">Referred Friends</p>
        <span style="font-family:'Jost',sans-serif;font-size:0.44rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(245,242,235,0.18);"><%= (user.referrals && user.referrals.length) || 0 %> total</span>
      </div>
      <div style="border:1px solid rgba(245,242,235,0.05);border-radius:12px;overflow:hidden;background:rgba(245,242,235,0.015);max-width:560px;">
        <% if (user.referrals && user.referrals.length > 0) { %>
          <% user.referrals.forEach(function(ref) { %>
          <div class="ref-friend-row">
            <div style="display:flex;align-items:center;gap:10px;">
              <div class="ref-friend-avatar"><%= (ref.name || ref.email || '?').charAt(0).toUpperCase() %></div>
              <div>
                <p style="font-size:0.72rem;font-weight:300;color:rgba(245,242,235,0.7);">
                  <%= ref.name || ref.email || 'Anonymous' %>
