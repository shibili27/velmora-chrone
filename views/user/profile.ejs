            </div>
            <span class="ref-status-pill <%= ref.hasOrdered ? 'joined' : 'pending' %>">
              <%= ref.hasOrdered ? 'Rewarded' : 'Pending' %>
            </span>
          </div>
          <% }) %>
        <% } else { %>
          <div style="padding:2rem;text-align:center;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(245,242,235,0.08)" stroke-width="1" style="display:block;margin:0 auto 10px;"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
            <p style="font-size:0.65rem;font-weight:300;color:rgba(245,242,235,0.18);">No referrals yet. Share your code to get started!</p>
