<script>
  // ── Flash auto-dismiss ────────────────────────────────────────────────────
  setTimeout(() => {
    ['flashSuccess','flashError'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.remove();
    });
  }, 4000);

  // ── Toast ─────────────────────────────────────────────────────────────────
  function showToast(message, type = 'success') {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast toast--${type}`;
    const icon = type === 'success'
      ? '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
      : '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
    toast.innerHTML = icon + '<span>' + message + '</span>';
    container.appendChild(toast);
    setTimeout(() => {
      toast.style.animation = 'slideOut 0.3s ease forwards';
      setTimeout(() => toast.remove(), 300);
    }, 3500);
  }

  // ── Modal helpers ─────────────────────────────────────────────────────────
  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }

  document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
  });

  // ── Field-level invalid + shake helpers (shared by create & edit) ─────────
  function triggerShake(el) {
    if (!el) return;
    el.classList.remove('shake');
    void el.offsetWidth; // restart animation even if mid-shake
    el.classList.add('shake');
    el.addEventListener('animationend', () => el.classList.remove('shake'), { once: true });
  }

  // field = 'Code' | 'DiscountType' | 'DiscountValue' | 'MaxDiscountCap' |
  //         'MinOrderValue' | 'ExpiryDate' | 'UsageLimit' | 'PerUserLimit' | 'Description'
  function setFieldInvalid(prefix, field, isInvalid, message) {
    const inputId = prefix + field;
    const errId   = inputId + 'Err';
    const input   = document.getElementById(inputId);
    const errEl   = document.getElementById(errId);
    if (input) {
      input.classList.toggle('invalid', !!isInvalid);
      if (isInvalid) triggerShake(input);
    }
    if (errEl) {
      errEl.textContent = isInvalid ? (message || '') : '';
      errEl.classList.toggle('show', !!isInvalid);
    }
  }

  const COUPON_FIELDS = [
    'Code', 'DiscountType', 'DiscountValue', 'MaxDiscountCap',
    'MinOrderValue', 'ExpiryDate', 'UsageLimit', 'PerUserLimit', 'Description'
  ];

  function clearFieldErrors(prefix) {
    COUPON_FIELDS.forEach(f => setFieldInvalid(prefix, f, false));
  }

  // Live-clear: as soon as the user edits a field, drop its red/shake state.
  function initLiveClear(prefix) {
    COUPON_FIELDS.forEach(field => {
      const el = document.getElementById(prefix + field);
      if (!el) return;
      const evt = el.tagName === 'SELECT' ? 'change' : 'input';
      el.addEventListener(evt, () => setFieldInvalid(prefix, field, false));
    });
  }

  // ── Discount type change (shared for create & edit) ───────────────────────
  function onTypeChange(prefix) {
    const type     = document.getElementById(prefix + 'DiscountType').value;
    const label    = document.getElementById(prefix + 'ValueLabel');
    const valInput = document.getElementById(prefix + 'DiscountValue');
    const capGroup = document.getElementById(prefix + 'CapGroup');

    if (type === 'flat') {
      label.textContent      = 'Discount Value (₹) *';
      valInput.placeholder   = '200';
      valInput.max           = '';
      capGroup.style.display = 'none';
    } else if (type === 'percentage') {
      label.textContent      = 'Discount Value (%) *';
      valInput.placeholder   = '10';
      valInput.max           = '100';
      capGroup.style.display = 'block';
    } else {
      // free shipping
      capGroup.style.display = 'none';
    }
  }

  // ── Shared validation: marks every blank/invalid field red + shaking ──────
  function validateCouponForm(e, prefix) {
    clearFieldErrors(prefix);
    const errEl = document.getElementById(prefix + 'ModalError');
    errEl.classList.remove('show');
    errEl.textContent = '';

    let ok = true;

    // Coupon code — required, format-checked, only on create (edit is read-only)
    if (prefix === 'create') {
      const code = document.getElementById('createCode').value.trim();
      if (!code) {
        setFieldInvalid('create', 'Code', true, 'Coupon code is required.');
        ok = false;
      } else if (!/^[A-Z0-9_-]{3,20}$/i.test(code)) {
        setFieldInvalid('create', 'Code', true, '3–20 chars — letters, numbers, _ and - only.');
        ok = false;
      }
    }

    // Discount type
    const typeEl = document.getElementById(prefix + 'DiscountType');
    const type   = typeEl ? typeEl.value : '';
    if (!type) {
      setFieldInvalid(prefix, 'DiscountType', true, 'Please select a discount type.');
      ok = false;
    }

    // Discount value (not required for free shipping)
    const valEl  = document.getElementById(prefix + 'DiscountValue');
    const valRaw = valEl ? valEl.value.trim() : '';
    if (type && type !== 'free_shipping') {
      const typeLabel = type === 'flat' ? 'a flat discount amount (₹)' : 'a percentage discount value';
      if (valRaw === '') {
        setFieldInvalid(prefix, 'DiscountValue', true, `Please enter ${typeLabel}.`);
        ok = false;
      } else {
        const val = parseFloat(valRaw);
        if (isNaN(val) || val <= 0) {
          setFieldInvalid(prefix, 'DiscountValue', true, `Enter ${typeLabel} greater than 0.`);
          ok = false;
        } else if (type === 'percentage' && val > 100) {
          setFieldInvalid(prefix, 'DiscountValue', true, 'Percentage discount cannot exceed 100.');
          ok = false;
        }
      }
    }

    // Max discount cap (percentage only, optional but must be positive if filled)
    const capEl  = document.getElementById(prefix + 'MaxDiscountCap');
    const capRaw = capEl ? capEl.value.trim() : '';
    if (type === 'percentage' && capRaw !== '') {
      const cap = parseFloat(capRaw);
      if (isNaN(cap) || cap <= 0) {
        setFieldInvalid(prefix, 'MaxDiscountCap', true, 'Max discount cap must be a positive number.');
        ok = false;
      }
    }

    // Min cart value (optional, cannot be negative)
    const minEl  = document.getElementById(prefix + 'MinOrderValue');
    const minRaw = minEl ? minEl.value.trim() : '';
    if (minRaw !== '') {
      const minVal = parseFloat(minRaw);
      if (isNaN(minVal) || minVal < 0) {
        setFieldInvalid(prefix, 'MinOrderValue', true, 'Minimum cart value cannot be negative.');
        ok = false;
      }
    }

    // Flat discount must be lower than min cart value
    // (prevents a coupon from discounting more than — or exactly as much as — the order is worth)
    if (type === 'flat' && valRaw !== '' && minRaw !== '') {
      const flatVal = parseFloat(valRaw);
      const minVal2 = parseFloat(minRaw);
      if (!isNaN(flatVal) && !isNaN(minVal2) && minVal2 > 0 && flatVal >= minVal2) {
        setFieldInvalid(prefix, 'DiscountValue', true, 'Flat discount must be lower than the minimum cart value.');
        setFieldInvalid(prefix, 'MinOrderValue', true, 'Minimum cart value must exceed the flat discount amount.');
        ok = false;
      }
    }

    // Expiry date — required, must be in the future
    const expiryEl = document.getElementById(prefix + 'ExpiryDate');
    const expiry   = expiryEl ? expiryEl.value : '';
    if (!expiry) {
      setFieldInvalid(prefix, 'ExpiryDate', true, 'Expiry date is required.');
      ok = false;
    } else if (new Date(expiry) <= new Date()) {
      setFieldInvalid(prefix, 'ExpiryDate', true, 'Expiry date must be a future date.');
      ok = false;
    }

    // Total usage limit (optional, must be a positive whole number if filled)
    const usageEl  = document.getElementById(prefix + 'UsageLimit');
    const usageRaw = usageEl ? usageEl.value.trim() : '';
    if (usageRaw !== '') {
      if (!/^\d+$/.test(usageRaw) || parseInt(usageRaw, 10) < 1) {
        setFieldInvalid(prefix, 'UsageLimit', true, 'Usage limit must be a whole number of 1 or more.');
        ok = false;
      }
    }

    // Per-user limit (required field with a default of 1, must stay >= 1)
    const peruserEl  = document.getElementById(prefix + 'PerUserLimit');
    const peruserRaw = peruserEl ? peruserEl.value.trim() : '';
    if (peruserRaw === '') {
      setFieldInvalid(prefix, 'PerUserLimit', true, 'Per-user limit is required.');
      ok = false;
    } else if (!/^\d+$/.test(peruserRaw) || parseInt(peruserRaw, 10) < 1) {
      setFieldInvalid(prefix, 'PerUserLimit', true, 'Per-user limit must be a whole number of 1 or more.');
      ok = false;
    }

    if (!ok) {
      e.preventDefault();
      errEl.textContent = 'Please fix the highlighted field(s) below.';
      errEl.classList.add('show');
      return false;
    }

    return true;
  }

  // ── CREATE modal ──────────────────────────────────────────────────────────
  function openCreateModal() {
    document.getElementById('createForm').reset();
    document.getElementById('createModalError').classList.remove('show');
    document.getElementById('createModalError').textContent = '';
    document.getElementById('createCapGroup').style.display = 'none';
    clearFieldErrors('create');
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    document.getElementById('createExpiryDate').min = tomorrow.toISOString().split('T')[0];
    document.getElementById('createModal').classList.add('open');
  }

  // ── EDIT modal ────────────────────────────────────────────────────────────
  function openEditModal(btn) {
    // Read all coupon data from safe data-* attributes (avoids inline JSON breakage)
    const d = btn.dataset;

    // Clear previous errors
    const errEl = document.getElementById('editModalError');
    errEl.classList.remove('show');
    errEl.textContent = '';
    clearFieldErrors('edit');

    // Set form action
    document.getElementById('editForm').action = '/admin/coupons/' + d.id + '/edit';

    // Populate fields
    document.getElementById('editCode').value          = d.code;
    document.getElementById('editDiscountType').value  = d.type;
    document.getElementById('editDiscountValue').value = d.value;
    document.getElementById('editMinOrderValue').value = d.min;
    document.getElementById('editUsageLimit').value    = d.usage;
    document.getElementById('editPerUserLimit').value  = d.peruser;
    document.getElementById('editDescription').value   = decodeURIComponent(d.desc || '');

    // Format expiry date as YYYY-MM-DD for <input type="date">
    const expiry = new Date(d.expiry);
    const yyyy   = expiry.getFullYear();
    const mm     = String(expiry.getMonth() + 1).padStart(2, '0');
    const dd     = String(expiry.getDate()).padStart(2, '0');
    document.getElementById('editExpiryDate').value = `${yyyy}-${mm}-${dd}`;

    // Allow any date from today onward
    const today = new Date();
    document.getElementById('editExpiryDate').min = today.toISOString().split('T')[0];

    // Handle cap group visibility
    const capGroup = document.getElementById('editCapGroup');
    const capInput = document.getElementById('editMaxDiscountCap');
    const valLabel = document.getElementById('editValueLabel');
    const valInput = document.getElementById('editDiscountValue');

    if (d.type === 'percentage') {
      capGroup.style.display = 'block';
      capInput.value         = d.cap;
      valLabel.textContent   = 'Discount Value (%) *';
      valInput.max           = '100';
    } else if (d.type === 'flat') {
      capGroup.style.display = 'none';
      capInput.value         = '';
      valLabel.textContent   = 'Discount Value (₹) *';
      valInput.max           = '';
    } else {
      capGroup.style.display = 'none';
      capInput.value         = '';
    }

    document.getElementById('editModal').classList.add('open');
  }

  // ── DELETE confirm ────────────────────────────────────────────────────────
  function openDeleteConfirm(btn) {
    const id   = btn.dataset.id;
    const code = btn.dataset.code;
    document.getElementById('deleteCodeLabel').textContent = code;
    document.getElementById('deleteForm').action = '/admin/coupons/' + id + '/delete';
    document.getElementById('deleteModal').classList.add('open');
  }

  function closeDeleteConfirm() {
    document.getElementById('deleteModal').classList.remove('open');
  }

  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteConfirm();
  });

  // ── Toggle active (AJAX) ──────────────────────────────────────────────────
  async function toggleStatus(id, checkbox) {
    const prev = checkbox.checked;
    try {
      const res  = await fetch('/admin/coupons/' + id + '/toggle', { method: 'POST' });
      const data = await res.json();
      if (!data.success) {
        checkbox.checked = prev;
        showToast(data.message || 'Failed to update status.', 'error');
      } else {
        showToast(data.isActive ? 'Coupon activated.' : 'Coupon deactivated.');
      }
    } catch {
      checkbox.checked = prev;
      showToast('Network error. Please try again.', 'error');
    }
  }

  // ── Init live-clear listeners ───────────────────────────────────────────────
  initLiveClear('create');
  initLiveClear('edit');
</script>
</body>
</html>
