    <div class="sidebar__footer">
      <div class="avatar"><%= adminName ? adminName.charAt(0).toUpperCase() : 'A' %></div>
      <div class="sidebar__footer-info">
        <div class="sidebar__footer-name"><%= adminName || 'Admin' %></div>
        <div class="sidebar__footer-role">Administrator</div>
      </div>
      <a href="/admin/logout" class="btn-logout" title="Logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <header class="topbar">
      <span class="topbar__title">Operational Administrator Hub</span>
    </header>

    <div class="content">

      <!-- Flash messages (from redirect) -->
      <% if (locals.success && success && success.length) { %>
        <div class="flash flash--success" id="flashSuccess">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <%= Array.isArray(success) ? success[0] : success %>
          <button class="flash__close" onclick="this.parentElement.remove()">×</button>
        </div>
      <% } %>
      <% if (locals.error && error && error.length) { %>
        <div class="flash flash--error" id="flashError">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <%= Array.isArray(error) ? error[0] : error %>
          <button class="flash__close" onclick="this.parentElement.remove()">×</button>
        </div>
      <% } %>

      <div class="page-header">
        <h1>Products</h1>
        <p>Manage your product catalogue — add, edit, block, or delete products.</p>
      </div>

      <div class="toolbar">
        <form class="search-form" method="GET" action="/admin/products">
          <input class="search-input" type="text" name="search" placeholder="Search products…" value="<%= search %>"/>
          <button type="submit" class="btn btn--teal">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
            Search
          </button>
          <% if (search) { %>
            <a href="/admin/products" class="btn btn--outline">Clear</a>
          <% } %>
        </form>
        <button class="btn btn--teal" onclick="openAddModal()">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Product
        </button>
      </div>

      <div class="card">
        <div class="card__header">
          <span class="card__title">All Products</span>
          <span style="font-size:12px;color:var(--text-light)"><%= total %> total</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Images</th>
                <th>Name</th>
                <th>Brand</th>
                <th>Category</th>
                <th>Colours</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (products.length > 0) { %>
                <% products.forEach((p, i) => { %>
                <tr class="<%= !p.isListed ? 'row--blocked' : '' %>">
                  <td style="color:var(--text-light)"><%= (page-1)*8+i+1 %></td>
                  <td>
                    <div class="thumb-row">
                      <%
                        const thumbImgs = (p.colorVariants && p.colorVariants.length > 0)
                          ? p.colorVariants.flatMap(v => v.images).slice(0,3)
                          : p.images.slice(0,3);
                      %>
                      <% thumbImgs.forEach(img => { %>
                        <img class="thumb" src="<%= img %>" alt="product" style="<%= !p.isListed ? 'opacity:0.5;filter:grayscale(0.4)' : '' %>"/>
                      <% }) %>
                    </div>
                  </td>
                  <td style="font-weight:500"><%= p.name %></td>
                  <td>
                    <% if (p.brand && p.brand.name) { %>
                      <span class="badge badge--brand"><%= p.brand.name %></span>
                    <% } else { %><span style="color:var(--text-light)">—</span><% } %>
                  </td>
                  <td><span class="badge badge--cat"><%= p.category ? p.category.name : '—' %></span></td>
                  <td>
                    <% if (p.colorVariants && p.colorVariants.length > 0) { %>
                      <div class="color-dots">
                        <% p.colorVariants.slice(0,6).forEach(v => { %>
                          <span class="color-dot" style="background:<%= v.hex %>;" title="<%= v.name %>"></span>
                        <% }) %>
                        <% if (p.colorVariants.length > 6) { %>
                          <span style="font-size:10px;color:var(--text-light)">+<%= p.colorVariants.length - 6 %></span>
                        <% } %>
                      </div>
                    <% } else { %><span style="color:var(--text-light)">—</span><% } %>
                  </td>
                  <td>&#8377;<%= p.price.toLocaleString() %></td>
                  <td><%= p.stock %></td>
                  <td>
                    <% if (p.isListed !== false) { %>
                      <span class="badge badge--active">Active</span>
                    <% } else { %>
                      <span class="badge badge--blocked">Blocked</span>
                    <% } %>
                  </td>
                  <td>
                    <div class="actions">
                      <!-- Edit -->
                      <button
                        class="btn-action btn-action--edit"
                        data-id="<%= p._id %>"
                        data-name="<%- JSON.stringify(p.name).replace(/"/g, '&quot;') %>"
                        data-desc="<%- JSON.stringify(p.description || '').replace(/"/g, '&quot;') %>"
                        data-price="<%= p.price %>"
                        data-cat="<%= p.category ? p.category._id : '' %>"
                        data-brand="<%= p.brand ? p.brand._id : '' %>"
                        data-variants="<%- JSON.stringify(p.colorVariants || []).replace(/"/g, '&quot;') %>"
                        onclick="openEditFromBtn(this)">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Edit
                      </button>

                      <!-- Block / Unblock -->
                      <% if (p.isListed !== false) { %>
                        <button
                          class="btn-action btn-action--block"
                          data-action="/admin/products/<%= p._id %>/block"
                          data-name="<%= p.name %>"
                          data-type="block"
                          onclick="openActionConfirm(this)">
                          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg>
                          Block
                        </button>
                      <% } else { %>
                        <button
                          class="btn-action btn-action--unblock"
                          data-action="/admin/products/<%= p._id %>/unblock"
                          data-name="<%= p.name %>"
                          data-type="unblock"
                          onclick="openActionConfirm(this)">
                          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                          Unblock
                        </button>
                      <% } %>

                      <!-- Delete -->
                      <button
                        class="btn-action btn-action--delete"
                        data-action="/admin/products/<%= p._id %>/delete"
                        data-name="<%= p.name %>"
                        data-type="delete"
                        onclick="openActionConfirm(this)">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m5 0V4h4v2"/></svg>
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="10"><div class="empty-state">No products found.</div></td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination">
          <a href="/admin/products?page=<%= page-1 %>&search=<%= search %>" class="page-btn <%= page===1?'disabled':'' %>">&#8592;</a>
          <% for(let p=1; p<=totalPages; p++) { %>
            <a href="/admin/products?page=<%= p %>&search=<%= search %>" class="page-btn <%= p===page?'active':'' %>"><%= p %></a>
          <% } %>
          <a href="/admin/products?page=<%= page+1 %>&search=<%= search %>" class="page-btn <%= page===totalPages?'disabled':'' %>">&#8594;</a>
        </div>
        <% } %>
      </div>

    </div>
    <footer class="footer">© 2026 Velmora Chroné. Admin Panel.</footer>
  </div>
</div>

<!-- ══ TOAST CONTAINER ══ -->
