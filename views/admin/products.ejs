<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script>

// ══ TOAST ══════════════════════════════════════════════════════════════════════
function showToast(message, type = 'success') {
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = `toast toast--${type}`;
  const icon = type === 'success'
    ? '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>'
    : '<svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>';
  toast.innerHTML = icon + '<span>' + escHtml(message) + '</span>';
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.animation = 'slideOut 0.3s ease forwards';
    setTimeout(() => toast.remove(), 300);
  }, 3500);
}

// Auto-dismiss flash messages after 4s
setTimeout(() => {
  ['flashSuccess', 'flashError'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.remove();
  });
}, 4000);

// ══ ACTION CONFIRM (block / unblock / delete) ══════════════════════════════════
const confirmConfig = {
  block: {
    iconClass: 'confirm-icon--orange',
    iconSvg:   '<circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/>',
    title:     'Block Product?',
    message:   name => `"<strong>${escHtml(name)}</strong>" will be hidden from customers immediately. You can unblock it at any time.`,
    btnClass:  'btn--outline',
    btnStyle:  'border-color:#fde68a;color:#d97706;background:#fef3c7',
    btnText:   'Yes, Block',
  },
  unblock: {
    iconClass: 'confirm-icon--green',
    iconSvg:   '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>',
    title:     'Unblock Product?',
    message:   name => `"<strong>${escHtml(name)}</strong>" will be visible to customers again.`,
    btnClass:  'btn--teal',
    btnStyle:  '',
    btnText:   'Yes, Unblock',
  },
  delete: {
    iconClass: 'confirm-icon--red',
    iconSvg:   '<polyline points="3 6 5 6 21 6"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m5 0V4h4v2"/>',
    title:     'Delete Product?',
    message:   name => `You are about to permanently delete "<strong>${escHtml(name)}</strong>". This action cannot be undone.`,
    btnClass:  'btn--danger',
    btnStyle:  '',
    btnText:   'Yes, Delete',
  },
};

function openActionConfirm(btn) {
  const type   = btn.dataset.type;
  const name   = btn.dataset.name;
  const action = btn.dataset.action;
  const cfg    = confirmConfig[type];
  if (!cfg) return;

  const icon = document.getElementById('confirmIcon');
  icon.className = 'confirm-icon ' + cfg.iconClass;
  document.getElementById('confirmIconSvg').innerHTML = cfg.iconSvg;
  document.getElementById('confirmTitle').textContent = cfg.title;
  document.getElementById('confirmMessage').innerHTML = cfg.message(name);

  const confirmBtn = document.getElementById('confirmBtn');
  confirmBtn.className = 'btn ' + cfg.btnClass;
  if (cfg.btnStyle) confirmBtn.style.cssText = cfg.btnStyle;
  else confirmBtn.removeAttribute('style');
  confirmBtn.textContent = cfg.btnText;

  document.getElementById('confirmForm').action = action;
  document.getElementById('confirmModal').classList.add('open');
}

function closeConfirm() {
  document.getElementById('confirmModal').classList.remove('open');
}
document.getElementById('confirmModal').addEventListener('click', function(e) {
  if (e.target === this) closeConfirm();
});

// ══ MODAL ══════════════════════════════════════════════════════════════════════
function showModalError(prefix, message) {
  const el = document.getElementById(prefix + 'ModalError');
  if (el) { el.textContent = message; el.classList.add('show'); }
}
function clearModalError(prefix) {
  const el = document.getElementById(prefix + 'ModalError');
  if (el) { el.textContent = ''; el.classList.remove('show'); }
}

// ══ VARIANT PRESETS ════════════════════════════════════════════════════════════
const PRESETS = [
  { hex: '#000000', name: 'Black'        },
  { hex: '#ffffff', name: 'White'        },
  { hex: '#c0c0c0', name: 'Silver'       },
  { hex: '#d4af37', name: 'Gold'         },
  { hex: '#c9956c', name: 'Rose Gold'    },
  { hex: '#1a1a2e', name: 'Navy'         },
  { hex: '#1b4332', name: 'Forest Green' },
  { hex: '#6b1c1c', name: 'Burgundy'     },
  { hex: '#4b3a2a', name: 'Brown'        },
  { hex: '#607d8b', name: 'Slate'        },
  { hex: '#e0c8a0', name: 'Champagne'    },
  { hex: '#2c2c54', name: 'Midnight'     },
];

function initPresets(prefix) {
  const row = document.getElementById(prefix + 'VPresets');
  if (!row) return;
  row.innerHTML = '';
  PRESETS.forEach(p => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'color-preset';
    btn.style.background = p.hex;
    if (p.hex === '#ffffff') btn.style.border = '2px solid #ccc';
    btn.title = p.name;
    btn.onclick = () => {
      document.querySelectorAll('#' + prefix + 'VPresets .color-preset').forEach(b => b.classList.remove('selected'));
      btn.classList.add('selected');
      document.getElementById(prefix + 'VNative').value = p.hex;
      document.getElementById(prefix + 'VHex').value    = p.hex;
      document.getElementById(prefix + 'VName').value   = p.name;
    };
    row.appendChild(btn);
  });
  const native = document.getElementById(prefix + 'VNative');
  const hexEl  = document.getElementById(prefix + 'VHex');
  native.addEventListener('input', () => { hexEl.value = native.value; });
  hexEl.addEventListener('input', () => {
    let v = hexEl.value.trim();
    if (!v.startsWith('#')) v = '#' + v;
    if (/^#[0-9a-fA-F]{6}$/.test(v)) native.value = v;
  });
}

const variantState = { add: [], edit: [] };
let activeTab      = { add: 0, edit: 0 };

function normaliseHex(raw) {
  let h = raw.trim();
  if (!h.startsWith('#')) h = '#' + h;
  if (/^#[0-9a-fA-F]{3}$/.test(h)) {
    h = '#' + h[1]+h[1]+h[2]+h[2]+h[3]+h[3];
  }
  return h.toLowerCase();
}

function addVariant(prefix) {
  let rawHex = document.getElementById(prefix + 'VHex').value.trim()
            || document.getElementById(prefix + 'VNative').value;
  const name  = document.getElementById(prefix + 'VName').value.trim();
  const stock = parseInt(document.getElementById(prefix + 'VStock').value) || 0;

  if (!/^#?([0-9a-fA-F]{3}|[0-9a-fA-F]{6})$/.test(rawHex.replace('#',''))) {
    showModalError(prefix, 'Enter a valid hex colour (e.g. #c9a96e).');
    return;
  }
  const hex = normaliseHex(rawHex);
  if (!name) { showModalError(prefix, 'Enter a colour label.'); return; }
  if (variantState[prefix].some(v => normaliseHex(v.hex) === hex)) {
    showModalError(prefix, 'A variant with that colour already exists.');
    return;
  }

  clearModalError(prefix);
  variantState[prefix].push({ name, hex, stock, images: [], existing: [] });
  activeTab[prefix] = variantState[prefix].length - 1;

  document.getElementById(prefix + 'VHex').value   = '';
  document.getElementById(prefix + 'VName').value  = '';
  document.getElementById(prefix + 'VStock').value = '';
  document.querySelectorAll('#' + prefix + 'VPresets .color-preset').forEach(b => b.classList.remove('selected'));

  renderVariantUI(prefix);
}

function removeVariant(prefix, idx) {
  variantState[prefix].splice(idx, 1);
  if (activeTab[prefix] >= variantState[prefix].length) {
    activeTab[prefix] = Math.max(0, variantState[prefix].length - 1);
  }
  renderVariantUI(prefix);
}

function switchTab(prefix, idx) {
  activeTab[prefix] = idx;
  renderVariantUI(prefix);
}

function renderVariantUI(prefix) {
  const tabs   = document.getElementById(prefix + 'VariantTabs');
  const panels = document.getElementById(prefix + 'VariantPanels');
  const empty  = document.getElementById(prefix + 'VariantEmpty');
  const state  = variantState[prefix];

  if (state.length === 0) {
    tabs.style.display  = 'none';
    panels.innerHTML    = '';
    empty.style.display = 'block';
    return;
  }

  empty.style.display = 'none';
  tabs.style.display  = 'flex';

  tabs.innerHTML = state.map((v, i) => `
    <button type="button"
      class="variant-tab ${i === activeTab[prefix] ? 'active' : ''}"
      onclick="switchTab('${prefix}', ${i})">
      <span class="variant-tab-swatch" style="background:${v.hex};${v.hex === '#ffffff' ? 'border:1.5px solid #ccc;' : ''}"></span>
      ${escHtml(v.name)}
      <span class="variant-tab-close" onclick="event.stopPropagation();removeVariant('${prefix}',${i})" title="Remove">✕</span>
    </button>
  `).join('');

  panels.innerHTML = state.map((v, i) => `
    <div class="variant-panel ${i === activeTab[prefix] ? 'active' : ''}">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
        <span style="width:20px;height:20px;border-radius:50%;background:${v.hex};border:1.5px solid rgba(0,0,0,0.12);display:inline-block;flex-shrink:0"></span>
        <span style="font-size:13px;font-weight:600;color:var(--text)">${escHtml(v.name)}</span>
        <span style="font-size:11px;color:var(--text-light)">${v.hex}</span>
        <div style="margin-left:auto;display:flex;align-items:center;gap:8px">
          <label style="font-size:10px;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;color:var(--text)">Stock</label>
          <input type="number" class="variant-stock-input" value="${v.stock}" min="0"
            onchange="updateVariantStock('${prefix}',${i},this.value)"
            oninput="updateVariantStock('${prefix}',${i},this.value)"/>
        </div>
      </div>
      <div class="variant-upload-zone" onclick="triggerVariantUpload('${prefix}',${i})">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5"/>
        </svg>
        <p>Click to add images for <strong>${escHtml(v.name)}</strong></p>
      </div>
      <input type="file" id="${prefix}VFileInput${i}" accept="image/*" multiple style="display:none"
        onchange="handleVariantFiles(event,'${prefix}',${i})"/>
      <div class="variant-preview-grid" id="${prefix}VGrid${i}">
        ${v.images.map((src, imgIdx) => `
          <div class="variant-preview-item">
            <img src="${src}" alt=""/>
            <button type="button" class="remove-vimg"
              onclick="removeVariantImage('${prefix}',${i},${imgIdx})">✕</button>
          </div>
        `).join('')}
      </div>
      <p class="variant-img-count ${v.images.length < 3 ? 'warn' : ''}">
        ${v.images.length} image${v.images.length !== 1 ? 's' : ''} ${v.images.length < 3 ? '— need at least 3' : '✓'}
      </p>
    </div>
  `).join('');
}

function updateVariantStock(prefix, idx, val) {
  variantState[prefix][idx].stock = parseInt(val) || 0;
}

function removeVariantImage(prefix, varIdx, imgIdx) {
  variantState[prefix][varIdx].images.splice(imgIdx, 1);
  variantState[prefix][varIdx].existing.splice(imgIdx, 1);
  renderVariantUI(prefix);
}

function triggerVariantUpload(prefix, idx) {
  document.getElementById(prefix + 'VFileInput' + idx).click();
}

let cropQueue = [], cropCtx = null, currentCropper = null, currentFileObj = null;

function handleVariantFiles(event, prefix, varIdx) {
  cropCtx   = { prefix, varIdx };
  cropQueue = Array.from(event.target.files);
  event.target.value = '';
  processNextCrop();
}

function processNextCrop() {
  if (cropQueue.length === 0) return;
  const file = cropQueue.shift();
  const reader = new FileReader();
  reader.onload = e => openCropper(e.target.result, file);
  reader.readAsDataURL(file);
}

function openCropper(src, file) {
  currentFileObj = file;
  const img = document.getElementById('cropperImage');
  img.src = src;
  document.getElementById('cropperModal').classList.add('open');
  if (currentCropper) { currentCropper.destroy(); currentCropper = null; }
  currentCropper = new Cropper(img, { aspectRatio: 1, viewMode: 1, autoCropArea: 0.9 });
}

function applyCrop() {
  if (!currentCropper) return;
  const canvas = currentCropper.getCroppedCanvas({ width: 800, height: 800 });
  const b64    = canvas.toDataURL('image/jpeg', 0.85);
  pushVariantImage(b64, false);
  closeCropper();
  processNextCrop();
}

function cancelCrop() {
  const reader = new FileReader();
  reader.onload = e => pushVariantImage(e.target.result, false);
  reader.readAsDataURL(currentFileObj);
  closeCropper();
  processNextCrop();
}

function closeCropper() {
  document.getElementById('cropperModal').classList.remove('open');
  if (currentCropper) { currentCropper.destroy(); currentCropper = null; }
}

function pushVariantImage(src, isExisting) {
  const { prefix, varIdx } = cropCtx;
  variantState[prefix][varIdx].images.push(src);
  variantState[prefix][varIdx].existing.push(isExisting);
  activeTab[prefix] = varIdx;
  renderVariantUI(prefix);
}

// ── Replace alert() with modal error messages ─────────────────────────────────
function submitForm(e, prefix) {
  e.preventDefault();
  clearModalError(prefix);
  const state = variantState[prefix];

  if (state.length === 0) {
    showModalError(prefix, 'Please add at least one colour variant before saving.');
    return;
  }

  for (const v of state) {
    if (v.images.length < 3) {
      showModalError(prefix, `"${v.name}" only has ${v.images.length} image(s). Each variant needs at least 3 images.`);
      return;
    }
  }

  const payload = state.map(v => ({
    name:           v.name,
    hex:            v.hex,
    stock:          v.stock,
    existingImages: v.images.filter((_, i) =>  v.existing[i]),
    newImages:      v.images.filter((_, i) => !v.existing[i]),
  }));

  document.getElementById(prefix + 'ColorVariantsInput').value = JSON.stringify(payload);

  const btn = document.getElementById(prefix + 'SubmitBtn');
  if (btn) {
    btn.classList.add('btn--loading');
    btn.textContent = prefix === 'add' ? 'Uploading…' : 'Saving…';
  }

  document.getElementById(prefix + 'Form').submit();
}

function openAddModal() {
  variantState.add = [];
  activeTab.add    = 0;
  document.getElementById('addForm').reset();
  document.getElementById('addBrandInput').value = '';
  clearModalError('add');
  renderVariantUI('add');
  document.getElementById('addModal').classList.add('open');
}

function openEditFromBtn(btn) {
  try {
    const id       = btn.dataset.id;
    const name     = JSON.parse(btn.dataset.name.replace(/&quot;/g, '"'));
    const desc     = JSON.parse(btn.dataset.desc.replace(/&quot;/g, '"'));
    const price    = btn.dataset.price;
    const catId    = btn.dataset.cat;
    const brand    = btn.dataset.brand || '';
    const variants = JSON.parse(btn.dataset.variants.replace(/&quot;/g, '"'));
    openEditModal(id, name, desc, price, catId, brand, variants);
  } catch(err) {
    console.error('Edit parse error:', err);
    showToast('Could not open editor. Please refresh the page.', 'error');
  }
}

function openEditModal(id, name, desc, price, catId, brand, variants) {
  document.getElementById('editForm').action = '/admin/products/' + id + '/edit';
  document.getElementById('editName').value  = name;
  document.getElementById('editDesc').value  = desc;
  document.getElementById('editPrice').value = price;
  document.getElementById('editBrand').value = brand;
  clearModalError('edit');
  setTimeout(() => { document.getElementById('editCategory').value = catId; }, 0);

  variantState.edit = variants.map(v => ({
    name:     v.name,
    hex:      normaliseHex(v.hex),
    stock:    v.stock || 0,
    images:   [...(v.images || [])],
    existing: (v.images || []).map(() => true),
  }));
  activeTab.edit = 0;
  renderVariantUI('edit');
  document.getElementById('editModal').classList.add('open');
}

function closeModal(id) {
  document.getElementById(id).classList.remove('open');
  cropQueue = [];
}

document.querySelectorAll('.modal-overlay').forEach(el => {
  el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
});

function escHtml(str) {
  return String(str)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

initPresets('add');
initPresets('edit');
renderVariantUI('add');
renderVariantUI('edit');
</script>
</body>

