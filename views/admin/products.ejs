<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal: #2d8c84; --teal-dark: #1f6e67; --teal-light: #e8f4f3;
      --sidebar-w: 220px; --bg: #f2f4f3; --white: #ffffff;
      --border: #e2e6e4; --text: #1a1f1e; --text-mid: #5a6461; --text-light: #9aa8a5;
      --green: #16a34a; --green-bg: #dcfce7; --red: #dc2626; --red-bg: #fee2e2;
      --blue: #2563eb; --blue-bg: #dbeafe; --orange: #d97706; --orange-bg: #fef3c7;
    }
    html, body { height: 100%; font-family: 'Jost', sans-serif; background: var(--bg); color: var(--text); }
    .layout { display: flex; min-height: 100vh; }

    .sidebar { width: var(--sidebar-w); background: var(--white); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
    .sidebar__brand { padding: 24px 20px 18px; border-bottom: 1px solid var(--border); }
    .sidebar__brand-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: 0.06em; color: var(--text); line-height: 1.2; }
    .sidebar__brand-sub { font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-top: 3px; }
    .sidebar__nav { flex: 1; padding: 14px 0; overflow-y: auto; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; font-size: 13px; font-weight: 500; color: var(--text-mid); text-decoration: none; transition: background 0.15s, color 0.15s; }
    .nav-item:hover { background: var(--teal-light); color: var(--teal); }
    .nav-item.active { background: var(--teal-light); color: var(--teal); border-right: 3px solid var(--teal); }
    .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar__footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .sidebar__footer-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .sidebar__footer-info { overflow: hidden; flex: 1; }
    .sidebar__footer-role { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); }
    .btn-logout { display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; border: 1px solid #fecaca; background: var(--red-bg); color: var(--red); cursor: pointer; flex-shrink: 0; transition: background 0.15s; text-decoration: none; }
    .btn-logout:hover { background: var(--red); color: #fff; border-color: var(--red); }
    .btn-logout svg { width: 14px; height: 14px; }

    .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar { background: var(--white); border-bottom: 1px solid var(--border); padding: 0 32px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar__title { font-size: 13px; font-weight: 500; color: var(--text-mid); }
    .content { padding: 32px; flex: 1; }
    .page-header { margin-bottom: 24px; }
    .page-header h1 { font-size: 22px; font-weight: 600; }
    .page-header p { font-size: 13px; color: var(--text-mid); margin-top: 4px; }

    /* ── Flash messages ── */
    .flash { padding: 12px 16px; border-radius: 4px; font-size: 13px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .flash--error   { background: #fdecea; color: #b00020; border: 1px solid #f5c6cb; }
    .flash--success { background: #e8f5e9; color: #1b5e20; border: 1px solid #c8e6c9; }
    .flash svg { width: 16px; height: 16px; flex-shrink: 0; }
    .flash__close { margin-left: auto; background: none; border: none; cursor: pointer; color: inherit; opacity: 0.6; font-size: 16px; padding: 0 4px; }
    .flash__close:hover { opacity: 1; }

    .toolbar { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .search-form { display: flex; align-items: center; gap: 8px; }
    .search-input { height: 38px; border: 1px solid var(--border); border-radius: 4px; padding: 0 14px; font-family: 'Jost', sans-serif; font-size: 13px; outline: none; width: 260px; transition: border-color 0.2s; }
    .search-input:focus { border-color: var(--teal); }
    .btn { display: inline-flex; align-items: center; gap: 6px; height: 38px; padding: 0 16px; border-radius: 4px; font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.06em; cursor: pointer; border: none; transition: opacity 0.15s; text-decoration: none; white-space: nowrap; }
    .btn svg { width: 14px; height: 14px; }
    .btn--teal    { background: var(--teal); color: #fff; }
    .btn--teal:hover { background: var(--teal-dark); }
    .btn--outline { background: none; border: 1px solid var(--border); color: var(--text-mid); }
    .btn--outline:hover { background: var(--bg); }
    .btn--danger  { background: var(--red); color: #fff; }
    .btn--danger:hover { background: #b91c1c; }

    .card { background: var(--white); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .card__header { padding: 16px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .card__title { font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-mid); }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #f8faf9; }
    th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: 12px 16px; font-size: 13px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: #fafcfb; }
    tbody tr.row--blocked { background: #fff8f8; }
    tbody tr.row--blocked:hover { background: #fff0f0; }

    .thumb-row { display: flex; gap: 4px; }
    .thumb { width: 38px; height: 38px; border-radius: 4px; object-fit: cover; border: 1px solid var(--border); }

    .badge { display: inline-flex; align-items: center; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
    .badge--cat   { background: var(--teal-light); color: var(--teal-dark); }
    .badge--brand { background: #f0ebfe; color: #5b21b6; }
    .badge--blocked { background: var(--red-bg); color: var(--red); }
    .badge--active  { background: var(--green-bg); color: var(--green); }

    .color-dots { display: flex; gap: 4px; flex-wrap: wrap; align-items: center; }
    .color-dot { width: 18px; height: 18px; border-radius: 50%; border: 1.5px solid rgba(0,0,0,0.12); flex-shrink: 0; }

    /* ── Action buttons ── */
    .actions { display: flex; gap: 5px; flex-wrap: wrap; }
    .btn-action { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 5px 9px; border-radius: 3px; border: 1px solid transparent; cursor: pointer; background: none; font-family: 'Jost', sans-serif; transition: opacity 0.15s; white-space: nowrap; }
    .btn-action:hover { opacity: 0.75; }
    .btn-action svg { width: 11px; height: 11px; }
    .btn-action--edit    { background: var(--blue-bg);   color: var(--blue);  border-color: #bfdbfe; }
    .btn-action--delete  { background: var(--red-bg);    color: var(--red);   border-color: #fecaca; }
    .btn-action--block   { background: var(--orange-bg); color: var(--orange);border-color: #fde68a; }
    .btn-action--unblock { background: var(--green-bg);  color: var(--green); border-color: #bbf7d0; }

    .pagination { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 20px; border-top: 1px solid var(--border); }
    .page-btn { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 4px; border: 1px solid var(--border); font-size: 13px; font-weight: 500; color: var(--text-mid); text-decoration: none; transition: background 0.15s; }
    .page-btn:hover { background: var(--teal-light); color: var(--teal); border-color: var(--teal); }
    .page-btn.active { background: var(--teal); color: #fff; border-color: var(--teal); }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }

    .empty-state { padding: 48px 24px; text-align: center; color: var(--text-light); font-size: 13px; }
    .footer { text-align: center; padding: 20px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); border-top: 1px solid var(--border); }

    /* ══ CONFIRM MODAL ══ */
    .confirm-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 400; align-items: center; justify-content: center; }
    .confirm-overlay.open { display: flex; }
    .confirm-box { background: var(--white); border-radius: 12px; padding: 32px 28px; max-width: 400px; width: 90%; box-shadow: 0 8px 40px rgba(0,0,0,0.18); text-align: center; animation: popIn 0.18s ease; }
    @keyframes popIn { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .confirm-icon { width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .confirm-icon--red    { background: var(--red-bg); }
    .confirm-icon--orange { background: var(--orange-bg); }
    .confirm-icon--green  { background: var(--green-bg); }
    .confirm-icon svg { width: 26px; height: 26px; }
    .confirm-icon--red    svg { color: var(--red); }
    .confirm-icon--orange svg { color: var(--orange); }
    .confirm-icon--green  svg { color: var(--green); }
    .confirm-box h3 { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .confirm-box p { font-size: 13px; color: var(--text-mid); line-height: 1.5; margin-bottom: 24px; }
    .confirm-box p strong { color: var(--text); font-weight: 600; }
    .confirm-actions { display: flex; gap: 10px; justify-content: center; }
    .confirm-actions .btn { min-width: 110px; justify-content: center; height: 40px; }

    /* ══ TOAST NOTIFICATION ══ */
    .toast-container { position: fixed; top: 20px; right: 20px; z-index: 500; display: flex; flex-direction: column; gap: 8px; pointer-events: none; }
    .toast { background: var(--white); border: 1px solid var(--border); border-radius: 6px; padding: 12px 16px; font-size: 13px; font-weight: 500; box-shadow: 0 4px 16px rgba(0,0,0,0.1); display: flex; align-items: center; gap: 10px; pointer-events: all; min-width: 260px; max-width: 380px; animation: slideIn 0.25s ease; }
    .toast--success { border-left: 3px solid var(--green); color: #1b5e20; }
    .toast--error   { border-left: 3px solid var(--red);   color: #b00020; }
    .toast svg { width: 16px; height: 16px; flex-shrink: 0; }
    @keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
    @keyframes slideOut { to { transform: translateX(110%); opacity: 0; } }

    /* ══ PRODUCT MODAL ══ */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 200; align-items: flex-start; justify-content: center; overflow-y: auto; padding: 40px 16px; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--white); border-radius: 8px; width: 100%; max-width: 780px; padding: 32px; margin: auto; }
    .modal__title { font-size: 16px; font-weight: 600; margin-bottom: 24px; color: var(--text); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text); margin-bottom: 6px; }
    .form-input { width: 100%; height: 40px; border: 1px solid var(--border); border-radius: 4px; padding: 0 14px; font-family: 'Jost', sans-serif; font-size: 13px; color: var(--text); outline: none; transition: border-color 0.2s; background: #fff; }
    .form-input:focus { border-color: var(--teal); }
    select.form-input { cursor: pointer; }
    textarea.form-input { height: 80px; padding: 10px 14px; resize: vertical; }
    .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }
    .modal-error { background: #fdecea; color: #b00020; border: 1px solid #f5c6cb; border-radius: 4px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px; display: none; }
    .modal-error.show { display: block; }

    .section-divider { font-size: 10px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-mid); padding: 10px 0 8px; border-bottom: 1px solid var(--border); margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
    .section-divider svg { width: 13px; height: 13px; color: var(--teal); }

    .variant-builder { border: 1px solid var(--border); border-radius: 6px; background: #fafcfb; margin-bottom: 16px; overflow: hidden; }
    .variant-builder-header { padding: 12px 16px; background: var(--teal-light); border-bottom: 1px solid var(--border); }
    .variant-builder-header span { font-size: 11px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--teal-dark); }
    .variant-add-row { padding: 14px 16px; display: flex; align-items: flex-end; gap: 10px; flex-wrap: wrap; border-bottom: 1px solid var(--border); background: #fff; }
    .variant-add-row .form-group { margin-bottom: 0; flex: 1; min-width: 120px; }
    .color-native-btn { width: 40px; height: 40px; border: 1px solid var(--border); border-radius: 4px; padding: 2px; cursor: pointer; background: none; flex-shrink: 0; }
    .variant-btn-add { height: 40px; padding: 0 16px; border-radius: 4px; background: var(--teal); color: #fff; border: none; font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; white-space: nowrap; flex-shrink: 0; }
    .variant-btn-add:hover { background: var(--teal-dark); }

    .variant-tabs { display: flex; border-bottom: 1px solid var(--border); overflow-x: auto; background: #fff; }
    .variant-tab { padding: 9px 14px; font-size: 11px; font-weight: 600; letter-spacing: 0.06em; cursor: pointer; border-right: 1px solid var(--border); display: flex; align-items: center; gap: 6px; white-space: nowrap; color: var(--text-mid); background: none; border-top: none; border-left: none; border-bottom: 3px solid transparent; transition: background 0.15s; font-family: 'Jost', sans-serif; }
    .variant-tab:hover { background: var(--teal-light); color: var(--teal); }
    .variant-tab.active { background: var(--teal-light); color: var(--teal); border-bottom-color: var(--teal); }
    .variant-tab-swatch { width: 12px; height: 12px; border-radius: 50%; border: 1.5px solid rgba(0,0,0,0.15); flex-shrink: 0; }
    .variant-tab-close { width: 14px; height: 14px; border-radius: 50%; background: rgba(220,38,38,0.08); border: 1px solid #fecaca; color: var(--red); font-size: 9px; cursor: pointer; display: flex; align-items: center; justify-content: center; margin-left: 2px; flex-shrink: 0; }
    .variant-tab-close:hover { background: var(--red); color: #fff; border-color: var(--red); }

    .variant-panel { display: none; padding: 16px; background: #fafcfb; }
    .variant-panel.active { display: block; }
    .variant-upload-zone { border: 2px dashed var(--border); border-radius: 6px; padding: 18px; text-align: center; cursor: pointer; transition: border-color 0.2s; background: #fff; }
    .variant-upload-zone:hover { border-color: var(--teal); }
    .variant-upload-zone p { font-size: 12px; color: var(--text-mid); margin-top: 6px; }
    .variant-upload-zone svg { width: 22px; height: 22px; color: var(--text-light); }
    .variant-preview-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin-top: 10px; }
    .variant-preview-item { position: relative; aspect-ratio: 1; }
    .variant-preview-item img { width: 100%; height: 100%; object-fit: cover; border-radius: 4px; border: 1px solid var(--border); }
    .variant-preview-item .remove-vimg { position: absolute; top: -5px; right: -5px; width: 16px; height: 16px; border-radius: 50%; background: var(--red); color: #fff; border: none; cursor: pointer; font-size: 9px; display: flex; align-items: center; justify-content: center; }
    .variant-img-count { font-size: 11px; color: var(--text-mid); margin-top: 5px; }
    .variant-img-count.warn { color: var(--red); font-weight: 600; }
    .variant-stock-input { width: 120px; height: 38px; border: 1px solid var(--border); border-radius: 4px; padding: 0 12px; font-family: 'Jost', sans-serif; font-size: 13px; outline: none; }
    .variant-stock-input:focus { border-color: var(--teal); }
    .variant-empty { padding: 24px; text-align: center; font-size: 12px; color: var(--text-light); }
    .variant-hint { font-size: 11px; color: var(--text-light); padding: 10px 16px; background: #fff; }

    .color-preset-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
    .color-preset { width: 22px; height: 22px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: transform 0.12s; flex-shrink: 0; outline: none; }
    .color-preset:hover { transform: scale(1.18); }
    .color-preset.selected { border-color: var(--text); box-shadow: 0 0 0 2px var(--white), 0 0 0 4px var(--text); }

    .cropper-modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.75); z-index: 300; align-items: center; justify-content: center; }
    .cropper-modal-overlay.open { display: flex; }
    .cropper-box { background: var(--white); border-radius: 8px; padding: 24px; max-width: 560px; width: 100%; }
    .cropper-box h3 { font-size: 15px; font-weight: 600; margin-bottom: 16px; }
    .cropper-container-wrap { max-height: 360px; overflow: hidden; }
    #cropperImage { display: block; max-width: 100%; }
    .cropper-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 16px; }

    .btn--loading { opacity: 0.7; pointer-events: none; }
    .btn--loading::after { content: ''; display: inline-block; width: 12px; height: 12px; border: 2px solid rgba(255,255,255,0.4); border-top-color: #fff; border-radius: 50%; animation: spin 0.6s linear infinite; margin-left: 8px; }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>
<div class="layout">

  <!-- Sidebar -->
 <aside class="sidebar">
    <div class="sidebar__brand">
      <div class="sidebar__brand-name">Velmora<br>Chroné</div>
      <div class="sidebar__brand-sub">Admin Dashboard</div>
    </div>
   <nav class="sidebar__nav">
