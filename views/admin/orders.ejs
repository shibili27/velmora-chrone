<div class="toast" id="toast"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
  (function () {
    const el = document.getElementById('topbarDate');
    if (el) el.textContent = new Date().toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  })();

  const STATUS_ORDER = ['confirmed', 'processing', 'dispatched', 'delivered'];
  const TERMINAL     = ['cancelled', 'returned', 'delivered'];

  function allowedNext(current) {
    if (TERMINAL.includes(current)) return [];
    const idx = STATUS_ORDER.indexOf(current);
    if (idx === -1) return STATUS_ORDER;
    return STATUS_ORDER.slice(idx + 1);
  }

  document.querySelectorAll('.status-select:not([disabled])').forEach(sel => {
    const current = sel.dataset.currentStatus || sel.value;
    sel.dataset.currentStatus = current;
    const allowed = allowedNext(current);
    Array.from(sel.options).forEach(opt => {
      const ok = opt.value === current || allowed.includes(opt.value);
      opt.disabled    = !ok;
      opt.style.color = !ok ? '#bbb' : '';
    });
  });

  function refreshSelectColor(sel) { sel.className = 'status-select s-' + sel.value; }

  async function updateStatus(sel) {
    const orderId   = sel.dataset.orderId;
    const newStatus = sel.value;
    const current   = sel.dataset.currentStatus;
    const allowed   = allowedNext(current);

    if (newStatus === current) return;
    if (!allowed.includes(newStatus)) {
      showToast('Cannot change from "' + current + '" to "' + newStatus + '"', 'error');
      sel.value = current;
      refreshSelectColor(sel);
      return;
    }

    refreshSelectColor(sel);

    try {
      const res  = await fetch(`/admin/orders/${orderId}/status`, {
        method : 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body   : JSON.stringify({ status: newStatus }),
      });
      const data = await res.json();
      if (data.success) {
        sel.dataset.currentStatus = newStatus;
        if (TERMINAL.includes(newStatus)) {
          sel.disabled = true;
          sel.title    = 'Order is ' + newStatus + ' — no further status changes allowed';
        } else {
          Array.from(sel.options).forEach(opt => {
            const ok = opt.value === newStatus || allowedNext(newStatus).includes(opt.value);
            opt.disabled    = !ok;
            opt.style.color = !ok ? '#bbb' : '';
          });
        }
        showToast('Status updated to "' + newStatus + '"', 'success');
      } else {
        showToast(data.message || 'Update failed', 'error');
        sel.value = current;
        refreshSelectColor(sel);
      }
    } catch {
      showToast('Network error', 'error');
      sel.value = current;
      refreshSelectColor(sel);
    }
  }

  function playNotifSound() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const t   = ctx.currentTime;
      [0, 0.18].forEach((delay, i) => {
        const osc  = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);
        osc.type = 'sine';
        osc.frequency.setValueAtTime(i === 0 ? 880 : 660, t + delay);
        gain.gain.setValueAtTime(0.3, t + delay);
        gain.gain.exponentialRampToValueAtTime(0.001, t + delay + 0.4);
        osc.start(t + delay);
        osc.stop(t + delay + 0.4);
      });
    } catch (_) {}
  }

  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = `toast ${type} show`;
    setTimeout(() => { t.className = 'toast'; }, 3500);
  }

  const STORAGE_KEY = 'vc_admin_notifs';
  const SEEN_KEY    = 'vc_seen_order_ids';

  function loadNotifications() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
  }
  function saveNotifications() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(notifications)); } catch (_) {}
  }
  function loadSeenIds() {
    try { return new Set(JSON.parse(localStorage.getItem(SEEN_KEY) || '[]')); } catch { return new Set(); }
  }
  function saveSeenIds(set) {
    try { localStorage.setItem(SEEN_KEY, JSON.stringify([...set].slice(-500))); } catch (_) {}
  }

  let notifications = loadNotifications();
  let seenIds       = loadSeenIds();
  let currentTab    = 'all';

  function getVisible() {
    if (currentTab === 'unread') return notifications.filter(n => !n.read);
    if (currentTab === 'read')   return notifications.filter(n =>  n.read);
    return notifications;
  }
  function unreadCount() { return notifications.filter(n => !n.read).length; }

  function updateBadge() {
    const badge = document.getElementById('notifCount');
    const count = unreadCount();
    badge.textContent   = count > 9 ? '9+' : count;
    badge.style.display = count > 0 ? 'flex' : 'none';
  }
  function updateFooter() {
    document.getElementById('notifFooterCount').textContent =
      `${notifications.length} total · ${unreadCount()} unread`;
  }
  function timeAgo(date) {
    const s = Math.floor((Date.now() - new Date(date)) / 1000);
    if (s < 60)   return 'just now';
    if (s < 3600) return Math.floor(s / 60) + 'm ago';
    return Math.floor(s / 3600) + 'h ago';
  }

  function renderList() {
    const list    = document.getElementById('notifList');
    const visible = getVisible();
    list.innerHTML = '';
    if (visible.length === 0) {
      list.innerHTML = `<div class="notif-empty">${
        currentTab === 'unread' ? 'No unread notifications' :
        currentTab === 'read'   ? 'No read notifications'   : 'No notifications'
      }</div>`;
      return;
    }
    visible.forEach(n => {
      const el = document.createElement('div');
      el.className  = 'notif-item' + (n.read ? ' read' : '');
      el.dataset.id = n.id;
      el.innerHTML  = `
        <div class="notif-item__dot"></div>
        <div class="notif-item__body-wrap">
          <div class="notif-item__top">
            <span class="notif-item__id">${n.orderNumber}</span>
            <span class="notif-item__time">${timeAgo(n.createdAt)}</span>
          </div>
          <div class="notif-item__info">
            ₹${Number(n.grandTotal).toLocaleString('en-IN')} &nbsp;·&nbsp; ${n.itemCount} item${n.itemCount !== 1 ? 's' : ''} &nbsp;·&nbsp; ${n.paymentMethod}
          </div>
          ${n.customerName ? `<div class="notif-item__customer">${n.customerName}</div>` : ''}
        </div>
        <div class="notif-item__actions">
          <button class="notif-mark-btn" onclick="toggleRead('${n.id}', event)">
            ${n.read ? 'Mark unread' : 'Mark read'}
          </button>
          <a href="/admin/orders/${n.id}" class="notif-view-btn" onclick="markOneRead('${n.id}')">View</a>
        </div>`;
      list.appendChild(el);
    });
  }

  function toggleRead(id, e) {
    e.preventDefault(); e.stopPropagation();
    const n = notifications.find(x => x.id === id);
    if (!n) return;
    n.read = !n.read;
    saveNotifications();
    updateBadge(); updateFooter(); renderList();
  }
  function markOneRead(id) {
    const n = notifications.find(x => x.id === id);
    if (n) { n.read = true; saveNotifications(); }
    updateBadge(); updateFooter();
  }
  function markAllRead() {
    notifications.forEach(n => { n.read = true; });
    saveNotifications();
    updateBadge(); updateFooter(); renderList();
  }
  function clearAll() {
    notifications = [];
    saveNotifications();
    updateBadge(); updateFooter(); renderList();
    document.getElementById('notifDropdown').classList.remove('open');
  }
  function switchTab(tab) {
    currentTab = tab;
    document.querySelectorAll('.notif-tab').forEach(t => t.classList.remove('active'));
    document.getElementById('tab' + tab.charAt(0).toUpperCase() + tab.slice(1)).classList.add('active');
    renderList();
  }
  function toggleDropdown() {
    document.getElementById('notifDropdown').classList.toggle('open');
  }
  document.addEventListener('click', (e) => {
    if (!document.getElementById('notifWrap').contains(e.target))
      document.getElementById('notifDropdown').classList.remove('open');
  });

  function addNotification(order) {
    const id = String(order._id);
    if (seenIds.has(id)) return;
    seenIds.add(id);
    saveSeenIds(seenIds);

    if (notifications.find(n => n.id === id)) {
      updateBadge(); updateFooter(); renderList();
      return;
    }

    notifications.unshift({
      id,
      orderNumber  : order.orderNumber || ('#' + id.slice(-6).toUpperCase()),
      grandTotal   : order.grandTotal  ?? order.pricing?.grandTotal ?? 0,
      itemCount    : order.itemCount   ?? order.items?.length ?? 0,
      paymentMethod: order.paymentMethod || 'COD',
      customerName : order.customerName || '',
      createdAt    : order.createdAt,
      read         : false,
    });
    saveNotifications();

    updateBadge(); updateFooter(); renderList();
    playNotifSound();
    showToast(`New order ${notifications[0].orderNumber} — ₹${Number(notifications[0].grandTotal).toLocaleString('en-IN')}`, 'success');

    injectOrderRow(order);
  }

  function injectOrderRow(order) {
    const tbody = document.getElementById('ordersTableBody');
    if (!tbody) return;
    const emptyRow = document.getElementById('emptyRow');
    if (emptyRow) emptyRow.remove();
    if (tbody.querySelector(`tr[data-order-id="${order._id}"]`)) return;

    const id     = String(order._id);
    const num    = order.orderNumber || ('#' + id.slice(-6).toUpperCase());
    const total  = order.grandTotal ?? order.pricing?.grandTotal ?? 0;
    const items  = order.itemCount  ?? order.items?.length ?? 0;
    const method = order.paymentMethod || 'COD';
    const name   = order.customerName || 'Customer';
    const email  = order.customerEmail || '';
    const date   = new Date(order.createdAt);

    const tr = document.createElement('tr');
    tr.dataset.orderId = id;
    tr.classList.add('new-order-flash');
    tr.innerHTML = `
      <td><span style="font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:600;color:var(--teal)">${num}</span></td>
      <td style="color:var(--text-mid);font-size:12px;white-space:nowrap">
        ${date.toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})}
        <div style="font-size:10px;color:var(--text-light)">${date.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'})}</div>
      </td>
      <td>
        <div class="user-cell">
          <div class="user-avatar">${name.charAt(0).toUpperCase()}</div>
          <div><div class="user-name">${name}</div><div class="user-email">${email}</div></div>
        </div>
      </td>
      <td style="color:var(--text-mid);font-size:12px">${items} item${items !== 1 ? 's' : ''}</td>
      <td style="font-weight:600">₹${Number(total).toLocaleString('en-IN')}</td>
      <td><span style="font-size:11px;background:var(--bg);padding:3px 8px;border-radius:4px;color:var(--text-mid);font-weight:500">${method}</span></td>
      <td>
        <select class="status-select s-confirmed" data-order-id="${id}" data-current-status="confirmed" onchange="updateStatus(this)">
          <option value="confirmed" selected>Confirmed</option>
          <option value="processing">Processing</option>
          <option value="dispatched">Dispatched</option>
          <option value="delivered">Delivered</option>
          <option value="cancelled" disabled style="color:#bbb">Cancelled</option>
          <option value="returned"  disabled style="color:#bbb">Returned</option>
        </select>
      </td>
      <td>
        <a href="/admin/orders/${id}" class="btn btn--outline" style="padding:6px 12px;font-size:11px">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
          View
        </a>
      </td>`;
    tbody.insertBefore(tr, tbody.firstChild);
  }

  const socket = io();
  socket.emit('join-admin');
  socket.on('new-order', (order) => addNotification(order));
  socket.on('disconnect', () => {
    const dot = document.getElementById('liveDot');
    if (dot) dot.style.color = 'var(--text-light)';
  });
  socket.on('connect', () => {
    const dot = document.getElementById('liveDot');
    if (dot) dot.style.color = 'var(--green)';
    socket.emit('join-admin');
  });

  async function pollRecent() {
    try {
      const res  = await fetch('/admin/orders/notify/recent');
      const data = await res.json();
      if (data.success) data.orders.forEach(addNotification);
    } catch (_) {}
  }
  pollRecent();
  setInterval(pollRecent, 30_000);

  updateBadge();
  updateFooter();
  renderList();
</script>
</body>
</html>
