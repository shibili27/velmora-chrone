        </div>
      </form>

      <div class="section-card">
        <div class="section-card__header">
          <span class="section-card__title">Orders</span>
          <span class="section-card__meta"><%= totalOrders %> total</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Items</th>
                <th>Amount</th>
                <th>Payment</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="ordersTableBody">
              <% if (orders && orders.length > 0) { %>
                <% orders.forEach(function(order) { %>
                <%
                  const isTerminal    = ['cancelled','returned','delivered'].includes(order.orderStatus);
                  const hasReturnPend = order.returnStatus === 'pending';
                %>
                <tr data-order-id="<%= order._id %>" class="<%= hasReturnPend ? 'return-pending' : '' %>">
                  <td>
                    <div style="display:flex;flex-direction:column;gap:3px">
                      <span style="font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:600;color:var(--teal)">
                        <%= order.orderNumber || '#' + order._id.toString().slice(-6).toUpperCase() %>
                      </span>
                      <% if (hasReturnPend) { %>
                        <span class="return-badge">
                          <span class="return-badge__dot"></span>
                          Return Requested
                        </span>
                      <% } else if (order.returnStatus === 'accepted') { %>
                        <span style="font-size:9px;color:var(--green);font-weight:600">Return Accepted</span>
                      <% } else if (order.returnStatus === 'rejected') { %>
                        <span style="font-size:9px;color:var(--red);font-weight:600">Return Rejected</span>
                      <% } %>
                    </div>
                  </td>
                  <td style="color:var(--text-mid);font-size:12px;white-space:nowrap">
                    <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
                    <div style="font-size:10px;color:var(--text-light)">
                      <%= new Date(order.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %>
                    </div>
                  </td>
                  <td>
                    <div class="user-cell">
                      <div class="user-avatar">
                        <%= order.user && order.user.name ? order.user.name.charAt(0).toUpperCase() : '?' %>
                      </div>
                      <div>
                        <div class="user-name"><%= order.user ? order.user.name : 'Deleted User' %></div>
                        <div class="user-email"><%= order.user ? order.user.email : '' %></div>
                      </div>
                    </div>
                  </td>
                  <td style="color:var(--text-mid);font-size:12px">
                    <%= order.items ? order.items.length : 0 %> item<%= (order.items && order.items.length !== 1) ? 's' : '' %>
                  </td>
                  <td style="font-weight:600">
                    ₹<%= order.pricing ? order.pricing.grandTotal.toLocaleString('en-IN') : '0' %>
                  </td>
                  <td>
                    <span style="font-size:11px;background:var(--bg);padding:3px 8px;border-radius:4px;color:var(--text-mid);font-weight:500">
                      <%= order.paymentMethod || 'COD' %>
                    </span>
                  </td>
                  <td>
                    <select
                      class="status-select s-<%= order.orderStatus %>"
                      data-order-id="<%= order._id %>"
                      data-current-status="<%= order.orderStatus %>"
                      onchange="updateStatus(this)"
                      <%= isTerminal ? 'disabled title="No further status changes allowed"' : '' %>
                    >
                      <option value="confirmed"  <%= order.orderStatus === 'confirmed'  ? 'selected' : '' %>>Confirmed</option>
                      <option value="processing" <%= order.orderStatus === 'processing' ? 'selected' : '' %>>Processing</option>
                      <option value="dispatched" <%= order.orderStatus === 'dispatched' ? 'selected' : '' %>>Dispatched</option>
                      <option value="delivered"  <%= order.orderStatus === 'delivered'  ? 'selected' : '' %>>Delivered</option>
                      <option value="cancelled"  <%= order.orderStatus === 'cancelled'  ? 'selected' : '' %>>Cancelled</option>
                      <option value="returned"   <%= order.orderStatus === 'returned'   ? 'selected' : '' %>>Returned</option>
                    </select>
                  </td>
                  <td>
                    <a href="/admin/orders/<%= order._id %>" class="btn btn--outline" style="padding:6px 12px;font-size:11px">
                      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                      View
                    </a>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr class="empty-row" id="emptyRow">
                  <td colspan="8">
                    <div style="display:flex;flex-direction:column;align-items:center;gap:10px">
                      <svg width="36" height="36" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.2" style="color:var(--border)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                      <span>No orders found</span>
                    </div>
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination">
          <div class="pagination__info">
            Showing <%= (currentPage - 1) * limit + 1 %>–<%= Math.min(currentPage * limit, totalOrders) %> of <%= totalOrders %> orders
          </div>
          <div class="pagination__pages">
            <% const qBase = `status=${currentStatus||'all'}&search=${currentSearch||''}&sort=${currentSort||'date_desc'}&from=${currentFrom||''}&to=${currentTo||''}&returnFilter=${currentReturnFilter||''}`; %>
            <% if (currentPage > 1) { %>
              <a href="/admin/orders?page=<%= currentPage-1 %>&<%= qBase %>" class="page-btn">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
              </a>
