            <option value="accepted"<%= currentReturnFilter === 'accepted' ? 'selected' : '' %>>Return Accepted</option>
            <option value="rejected"<%= currentReturnFilter === 'rejected' ? 'selected' : '' %>>Return Rejected</option>
