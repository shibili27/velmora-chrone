<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal: #2d8c84; --teal-dark: #1f6e67; --teal-light: #e8f4f3;
      --sidebar-w: 220px; --bg: #f2f4f3; --white: #ffffff;
      --border: #e2e6e4; --text: #1a1f1e; --text-mid: #5a6461; --text-light: #9aa8a5;
      --green: #16a34a; --green-bg: #dcfce7; --red: #dc2626; --red-bg: #fee2e2;
      --blue: #2563eb; --blue-bg: #dbeafe;
    }
    html, body { height: 100%; font-family: 'Jost', sans-serif; background: var(--bg); color: var(--text); }
    .layout { display: flex; min-height: 100vh; }

    .sidebar { width: var(--sidebar-w); background: var(--white); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
    .sidebar__brand { padding: 24px 20px 18px; border-bottom: 1px solid var(--border); }
    .sidebar__brand-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: 0.06em; color: var(--text); line-height: 1.2; }
    .sidebar__brand-sub { font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-top: 3px; }
    .sidebar__nav { flex: 1; padding: 14px 0; overflow-y: auto; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; font-size: 13px; font-weight: 500; color: var(--text-mid); text-decoration: none; transition: background 0.15s, color 0.15s; cursor: pointer; }
    .nav-item:hover { background: var(--teal-light); color: var(--teal); }
    .nav-item.active { background: var(--teal-light); color: var(--teal); border-right: 3px solid var(--teal); }
    .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar__footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .sidebar__footer-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar__footer-info { overflow: hidden; flex: 1; }
    .sidebar__footer-role { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); }
    .btn-logout { display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; border: 1px solid #fecaca; background: var(--red-bg); color: var(--red); cursor: pointer; flex-shrink: 0; transition: background 0.15s; text-decoration: none; }
    .btn-logout:hover { background: var(--red); color: #fff; border-color: var(--red); }
    .btn-logout svg { width: 14px; height: 14px; }

    .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar { background: var(--white); border-bottom: 1px solid var(--border); padding: 0 32px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar__title { font-size: 13px; font-weight: 500; color: var(--text-mid); letter-spacing: 0.04em; }
    .content { padding: 32px; flex: 1; }
    .page-header { margin-bottom: 24px; }
    .page-header h1 { font-size: 22px; font-weight: 600; }
    .page-header p { font-size: 13px; color: var(--text-mid); margin-top: 4px; }

    /* ── Flash ── */
    .flash { padding: 12px 16px; border-radius: 4px; font-size: 13px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px; }
    .flash--error   { background: #fdecea; color: #b00020; border: 1px solid #f5c6cb; }
    .flash--success { background: #e8f5e9; color: #1b5e20; border: 1px solid #c8e6c9; }
    .flash svg { width: 15px; height: 15px; flex-shrink: 0; }
    .flash__close { margin-left: auto; background: none; border: none; cursor: pointer; color: inherit; opacity: 0.6; font-size: 16px; line-height:1; padding: 0 4px; }
    .flash__close:hover { opacity: 1; }

    /* ── Toolbar ── */
    .toolbar { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 20px; flex-wrap: wrap; }
    .search-form { display: flex; align-items: center; gap: 8px; }
    .search-input { height: 38px; border: 1px solid var(--border); border-radius: 4px; padding: 0 14px; font-family: 'Jost', sans-serif; font-size: 13px; color: var(--text); outline: none; width: 260px; transition: border-color 0.2s; }
    .search-input:focus { border-color: var(--teal); }
    .btn { display: inline-flex; align-items: center; gap: 6px; height: 38px; padding: 0 16px; border-radius: 4px; font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.06em; cursor: pointer; border: none; transition: opacity 0.15s; text-decoration: none; white-space: nowrap; }
    .btn svg { width: 14px; height: 14px; }
    .btn--teal    { background: var(--teal); color: #fff; }
    .btn--teal:hover { background: var(--teal-dark); }
    .btn--outline { background: none; border: 1px solid var(--border); color: var(--text-mid); }
    .btn--outline:hover { background: var(--bg); }
    .btn--danger  { background: var(--red); color: #fff; }
    .btn--danger:hover { background: #b91c1c; }

    .card { background: var(--white); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .card__header { padding: 16px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .card__title { font-size: 12px; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-mid); }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #f8faf9; }
    th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); padding: 12px 24px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: 14px 24px; font-size: 13px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: #fafcfb; }

    .actions { display: flex; gap: 6px; }
    .btn-action { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 5px 10px; border-radius: 3px; border: 1px solid transparent; cursor: pointer; transition: opacity 0.15s; background: none; font-family: 'Jost', sans-serif; }
    .btn-action:hover { opacity: 0.75; }
    .btn-action svg { width: 12px; height: 12px; }
    .btn-action--edit   { background: var(--blue-bg);  color: var(--blue);  border-color: #bfdbfe; }
    .btn-action--delete { background: var(--red-bg);   color: var(--red);   border-color: #fecaca; }

    .pagination { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 20px; border-top: 1px solid var(--border); }
    .page-btn { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 4px; border: 1px solid var(--border); font-size: 13px; font-weight: 500; color: var(--text-mid); text-decoration: none; transition: background 0.15s, color 0.15s; }
    .page-btn:hover { background: var(--teal-light); color: var(--teal); border-color: var(--teal); }
    .page-btn.active { background: var(--teal); color: #fff; border-color: var(--teal); }
    .page-btn.disabled { opacity: 0.4; pointer-events: none; }

    .empty-state { padding: 48px 24px; text-align: center; color: var(--text-light); font-size: 13px; }

    /* ── Modal ── */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 200; align-items: center; justify-content: center; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--white); border-radius: 8px; width: 100%; max-width: 460px; padding: 32px; box-shadow: 0 4px 24px rgba(0,0,0,0.12); }
    .modal__title { font-size: 16px; font-weight: 600; margin-bottom: 20px; color: var(--text); }
    .modal-error { background: #fdecea; color: #b00020; border: 1px solid #f5c6cb; border-radius: 4px; padding: 10px 14px; font-size: 13px; margin-bottom: 16px; display: none; align-items: center; gap: 8px; }
    .modal-error.show { display: flex; }
    .modal-error svg { width: 15px; height: 15px; flex-shrink: 0; }
    .form-group { margin-bottom: 16px; }
    .form-label { display: block; font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text); margin-bottom: 6px; }
    .form-input { width: 100%; height: 40px; border: 1px solid var(--border); border-radius: 4px; padding: 0 14px; font-family: 'Jost', sans-serif; font-size: 13px; color: var(--text); outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
    .form-input:focus { border-color: var(--teal); }
    .form-input--error { border-color: var(--red) !important; background: #fff8f8 !important; box-shadow: 0 0 0 3px rgba(220,38,38,0.12); }
    .form-input--valid { border-color: var(--green); }
    textarea.form-input { height: 80px; padding: 10px 14px; resize: vertical; }
    .modal-footer { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }

    /* ── Field-level error text ── */
    .field-error-text {
      display: none;
      align-items: center;
      gap: 5px;
      font-size: 10.5px;
      font-weight: 500;
      color: var(--red);
      margin-top: 6px;
    }
    .field-error-text.show { display: flex; }
    .field-error-text svg { width: 11px; height: 11px; flex-shrink: 0; }
    .char-count { font-size: 10px; color: var(--text-light); text-align: right; margin-top: 4px; }
    .char-count.over { color: var(--red); font-weight: 600; }

    /* ── Shake animation ── */
    @keyframes shake {
      10%, 90% { transform: translateX(-1px); }
      20%, 80% { transform: translateX(2px); }
      30%, 50%, 70% { transform: translateX(-4px); }
      40%, 60% { transform: translateX(4px); }
    }
    .form-group.shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    .modal.shake { animation: shake 0.45s cubic-bezier(.36,.07,.19,.97) both; }

    /* ── Confirm overlay ── */
    .confirm-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 400; align-items: center; justify-content: center; }
    .confirm-overlay.open { display: flex; }
    .confirm-box { background: var(--white); border-radius: 12px; padding: 32px 28px; max-width: 380px; width: 90%; box-shadow: 0 8px 40px rgba(0,0,0,0.18); text-align: center; animation: popIn 0.18s ease; }
    @keyframes popIn { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .confirm-icon { width: 56px; height: 56px; border-radius: 50%; background: var(--red-bg); display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; }
    .confirm-icon svg { width: 26px; height: 26px; color: var(--red); }
    .confirm-box h3 { font-size: 17px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
    .confirm-box p { font-size: 13px; color: var(--text-mid); line-height: 1.5; margin-bottom: 24px; }
    .confirm-box p strong { color: var(--text); font-weight: 600; }
    .confirm-actions { display: flex; gap: 10px; justify-content: center; }
    .confirm-actions .btn { min-width: 110px; justify-content: center; height: 40px; }

    .footer { text-align: center; padding: 20px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); border-top: 1px solid var(--border); }
  </style>
</head>
<body>
<aside class="sidebar">
    <div class="sidebar__brand">
      <div class="sidebar__brand-name">Velmora<br>Chroné</div>
      <div class="sidebar__brand-sub">Admin Dashboard</div>
    </div>
    <nav class="sidebar__nav">
      <a href="/admin/dashboard" class="nav-item" >
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/orders" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>
      <a href="/admin/products" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
        Products
      </a>
      <a href="/admin/reviews" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
        Rating/Review
      </a>
      <a href="/admin/customers" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Customers
      </a>
      <a href="/admin/coupons" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        Coupons
      </a>
      <a href="/admin/offers" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        Offers
      </a>
      <a href="/admin/categories" class="nav-item active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Categories
      </a>
      <a href="/admin/brands"  class="nav-item ">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z"/></svg>
        Brands
      </a>
      <a href="/admin/refunds" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Refund/Return
      </a>
      <a href="/admin/banners" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Banner
      </a>
      <a href="/admin/referrals" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        Referral
      </a>
      <a href="/admin/sales-report" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Sales Report
      </a>
    </nav>
    <div class="sidebar__footer">
      <div class="avatar"><%= adminName ? adminName.charAt(0).toUpperCase() : 'A' %></div>
      <div class="sidebar__footer-info">
        <div class="sidebar__footer-name"><%= adminName || 'Admin' %></div>
        <div class="sidebar__footer-role">Administrator</div>
      </div>
      <a href="/admin/logout" class="btn-logout" title="Logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      </a>
    </div>
  </aside>

  <!-- Main -->
  <div class="main">
    <header class="topbar">
      <span class="topbar__title">Operational Administrator Hub</span>
    </header>

    <div class="content">

      <% const flashError   = Array.isArray(error)   ? error[0]   : error; %>
      <% const flashSuccess = Array.isArray(success) ? success[0] : success; %>

      <% if (flashSuccess) { %>
        <div class="flash flash--success" id="pageFlashSuccess">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <%= flashSuccess %>
          <button class="flash__close" onclick="this.parentElement.remove()">×</button>
        </div>
      <% } %>

      <div class="page-header">
        <h1>Categories</h1>
        <p>Add, edit, or remove product categories.</p>
      </div>

      <!-- Toolbar -->
      <div class="toolbar">
        <form class="search-form" method="GET" action="/admin/categories">
          <input class="search-input" type="text" name="search" placeholder="Search categories…" value="<%= search %>"/>
          <button type="submit" class="btn btn--teal">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" d="M21 21l-4.35-4.35"/></svg>
            Search
          </button>
          <% if (search) { %>
            <a href="/admin/categories" class="btn btn--outline">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              Clear
            </a>
          <% } %>
        </form>
        <button class="btn btn--teal" onclick="openAddModal()">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Add Category
        </button>
      </div>

      <!-- Table -->
      <div class="card">
        <div class="card__header">
          <span class="card__title">All Categories</span>
          <span style="font-size:12px;color:var(--text-light)"><%= total %> total</span>
        </div>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Name</th>
                <th>Description</th>
                <th>Created</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% if (categories.length > 0) { %>
                <% categories.forEach((cat, i) => { %>
                <tr>
                  <td style="color:var(--text-light)"><%= (page - 1) * 8 + i + 1 %></td>
                  <td style="font-weight:500"><%= cat.name %></td>
                  <td style="color:var(--text-mid)"><%= cat.description || '—' %></td>
                  <td style="color:var(--text-mid)"><%= new Date(cat.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) %></td>
                  <td>
                    <div class="actions">
                      <button class="btn-action btn-action--edit"
                        onclick="openEditModal(
                          '<%= cat._id %>',
                          '<%= cat.name.replace(/\\/g, '\\\\').replace(/'/g, `\\'`) %>',
                          '<%= (cat.description||'').replace(/\\/g, '\\\\').replace(/'/g, `\\'`).replace(/\n/g, '\\n') %>'
                        )">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Edit
                      </button>
                      <button class="btn-action btn-action--delete"
                        data-action="/admin/categories/<%= cat._id %>/delete"
                        data-name="<%= cat.name %>"
                        onclick="openDeleteConfirm(this)">
                        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m5 0V4h4v2"/></svg>
                        Delete
                      </button>
                    </div>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5"><div class="empty-state">No categories found.</div></td></tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination">
          <a href="/admin/categories?page=<%= page-1 %>&search=<%= search %>" class="page-btn <%= page===1?'disabled':'' %>">&#8592;</a>
          <% for(let p=1; p<=totalPages; p++) { %>
            <a href="/admin/categories?page=<%= p %>&search=<%= search %>" class="page-btn <%= p===page?'active':'' %>"><%= p %></a>
          <% } %>
          <a href="/admin/categories?page=<%= page+1 %>&search=<%= search %>" class="page-btn <%= page===totalPages?'disabled':'' %>">&#8594;</a>
        </div>
        <% } %>
      </div>

    </div>
    <footer class="footer">© 2026 Velmora Chroné. Admin Panel.</footer>
  </div>
</div>

<!-- ══ ADD MODAL ══ -->
<div class="modal-overlay" id="addModal">
  <div class="modal">
    <h2 class="modal__title">Add Category</h2>
    <!-- ✅ Duplicate / any server error shown here -->
    <div class="modal-error" id="addModalError">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span id="addModalErrorText"></span>
    </div>
    <form action="/admin/categories/add" method="POST" id="addForm" novalidate>
      <div class="form-group" id="addNameGroup">
        <label class="form-label">Name *</label>
        <input class="form-input" type="text" name="name" id="addName" maxlength="60" placeholder="e.g. Watches"/>
        <span class="field-error-text" id="addNameError">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
          <span class="err-text"></span>
        </span>
      </div>
      <div class="form-group" id="addDescGroup">
        <label class="form-label">Description</label>
        <textarea class="form-input" name="description" id="addDesc" maxlength="250" placeholder="Optional description…"></textarea>
        <div class="char-count" id="addDescCount">0 / 250</div>
        <span class="field-error-text" id="addDescError">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
          <span class="err-text"></span>
        </span>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn--outline" onclick="closeModal('addModal')">Cancel</button>
        <button type="submit" class="btn btn--teal">Add Category</button>
      </div>
    </form>
  </div>
</div>

<!-- ══ EDIT MODAL ══ -->
<div class="modal-overlay" id="editModal">
  <div class="modal">
    <h2 class="modal__title">Edit Category</h2>
    <div class="modal-error" id="editModalError">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <span id="editModalErrorText"></span>
    </div>
    <form id="editForm" method="POST" novalidate>
      <div class="form-group" id="editNameGroup">
        <label class="form-label">Name *</label>
        <input class="form-input" type="text" name="name" id="editName" maxlength="60"/>
        <span class="field-error-text" id="editNameError">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
          <span class="err-text"></span>
        </span>
      </div>
      <div class="form-group" id="editDescGroup">
        <label class="form-label">Description</label>
        <textarea class="form-input" name="description" id="editDesc" maxlength="250"></textarea>
        <div class="char-count" id="editDescCount">0 / 250</div>
        <span class="field-error-text" id="editDescError">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
          <span class="err-text"></span>
        </span>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn--outline" onclick="closeModal('editModal')">Cancel</button>
        <button type="submit" class="btn btn--teal">Save Changes</button>
      </div>
    </form>
  </div>
</div>

<!-- ══ DELETE CONFIRM ══ -->
<div class="confirm-overlay" id="confirmModal">
  <div class="confirm-box">
    <div class="confirm-icon">
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path stroke-linecap="round" stroke-linejoin="round" d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6m5 0V4h4v2"/></svg>
    </div>
    <h3>Delete Category?</h3>
    <p>You are about to delete <strong id="confirmCatName"></strong>. This action cannot be undone.</p>
    <div class="confirm-actions">
      <button class="btn btn--outline" onclick="closeDeleteConfirm()">Cancel</button>
      <form id="confirmDeleteForm" method="POST" style="margin:0">
        <button type="submit" class="btn btn--danger">Yes, Delete</button>
      </form>
    </div>
  </div>
</div>

<script>
  const serverError   = <%- JSON.stringify((Array.isArray(error)   ? error[0]   : error)   || '') %>;
  const serverSuccess = <%- JSON.stringify((Array.isArray(success) ? success[0] : success) || '') %>;

  // ── Validation constants ──────────────────────────────────────────────────
  const NAME_MIN = 2;
  const NAME_MAX = 60;
  const DESC_MAX = 250;

  // ── Keywords that mean "duplicate / already exists" ──────────────────────
  const DUPLICATE_KEYWORDS = ['already exists', 'duplicate', 'already taken', 'in use'];

  function isDuplicateError(msg) {
    const lower = (msg || '').toLowerCase();
    return DUPLICATE_KEYWORDS.some(k => lower.includes(k));
  }

  window.addEventListener('DOMContentLoaded', () => {
    // Auto-dismiss success flash
    const successEl = document.getElementById('pageFlashSuccess');
    if (successEl) setTimeout(() => successEl.remove(), 4000);

    if (serverError) {
      if (isDuplicateError(serverError)) {
        // ✅ Open the Add modal and show the error INSIDE it
        openAddModal(serverError);
        // Also highlight the name input
        const nameInput = document.getElementById('addName');
        if (nameInput) nameInput.classList.add('form-input--error');
      } else {
        // Non-duplicate errors (e.g. edit conflict) → page banner
        showPageError(serverError);
      }
    }

    // Live char counters
    updateCharCount('addDesc', 'addDescCount');
    updateCharCount('editDesc', 'editDescCount');
  });

  // ── Show error INSIDE the Add modal (server-side errors, e.g. duplicates) ──
  function showAddModalError(msg) {
    const box  = document.getElementById('addModalError');
    const text = document.getElementById('addModalErrorText');
    text.textContent = msg;
    box.classList.add('show');
  }

  // ── Show error INSIDE the Edit modal ─────────────────────────────────────
  function showEditModalError(msg) {
    const box  = document.getElementById('editModalError');
    const text = document.getElementById('editModalErrorText');
    text.textContent = msg;
    box.classList.add('show');
  }

  function showPageError(msg) {
    const existing = document.getElementById('dynamicErrorBanner');
    if (existing) existing.remove();
    const banner = document.createElement('div');
    banner.id = 'dynamicErrorBanner';
    banner.className = 'flash flash--error';
    banner.innerHTML = `
      <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      ${escHtml(msg)}
      <button class="flash__close" onclick="this.parentElement.remove()">×</button>
    `;
    const content = document.querySelector('.content');
    content.insertBefore(banner, content.firstChild);
    setTimeout(() => banner.remove(), 6000);
  }

  // ── Char counter ─────────────────────────────────────────────────────────
  function updateCharCount(inputId, counterId) {
    const el = document.getElementById(inputId);
    const counter = document.getElementById(counterId);
    if (!el || !counter) return;
    const len = el.value.length;
    counter.textContent = `${len} / ${DESC_MAX}`;
    counter.classList.toggle('over', len > DESC_MAX);
  }
  document.getElementById('addDesc').addEventListener('input', () => {
    updateCharCount('addDesc', 'addDescCount');
    validateField('add', 'desc');
  });
  document.getElementById('editDesc').addEventListener('input', () => {
    updateCharCount('editDesc', 'editDescCount');
    validateField('edit', 'desc');
  });

  // ── Field-level error helpers ────────────────────────────────────────────
  function showFieldError(prefix, field, message) {
    const input = document.getElementById(`${prefix}${cap(field)}`);
    const err = document.getElementById(`${prefix}${cap(field)}Error`);
    if (!input || !err) return;
    input.classList.add('form-input--error');
    input.classList.remove('form-input--valid');
    err.querySelector('.err-text').textContent = message;
    err.classList.add('show');
  }

  function clearFieldError(prefix, field) {
    const input = document.getElementById(`${prefix}${cap(field)}`);
    const err = document.getElementById(`${prefix}${cap(field)}Error`);
    if (!input || !err) return;
    input.classList.remove('form-input--error');
    err.classList.remove('show');
    err.querySelector('.err-text').textContent = '';
  }

  function markFieldValid(prefix, field) {
    const input = document.getElementById(`${prefix}${cap(field)}`);
    if (!input) return;
    input.classList.add('form-input--valid');
    input.classList.remove('form-input--error');
  }

  function cap(str) { return str.charAt(0).toUpperCase() + str.slice(1); }

  function shakeGroup(prefix, field) {
    const group = document.getElementById(`${prefix}${cap(field)}Group`);
    if (!group) return;
    group.classList.remove('shake');
    void group.offsetWidth;
    group.classList.add('shake');
    group.addEventListener('animationend', () => group.classList.remove('shake'), { once: true });
  }

  function shakeModal(modalId) {
    const modal = document.querySelector(`#${modalId} .modal`);
    if (!modal) return;
    modal.classList.remove('shake');
    void modal.offsetWidth;
    modal.classList.add('shake');
    modal.addEventListener('animationend', () => modal.classList.remove('shake'), { once: true });
  }

  // ── Core validators (shared by Add + Edit) ───────────────────────────────
  function validateField(prefix, field) {
    const input = document.getElementById(`${prefix}${cap(field)}`);
    if (!input) return true;
    const v = input.value.trim();

    if (field === 'name') {
      if (!v) { showFieldError(prefix, field, 'Category name is required.'); return false; }
      if (v.length < NAME_MIN) { showFieldError(prefix, field, `Name must be at least ${NAME_MIN} characters.`); return false; }
      if (v.length > NAME_MAX) { showFieldError(prefix, field, `Name cannot exceed ${NAME_MAX} characters.`); return false; }

      const letterCount = (v.match(/[a-zA-Z]/g) || []).length;
      if (letterCount < 2) {
        showFieldError(prefix, field, 'Name must contain real words, not just symbols or numbers.');
        return false;
      }
      // Blocks junk like "________", "--------", "........", "aaaaaaaa"
      if (/^(.)\1+$/.test(v)) {
        showFieldError(prefix, field, 'Name cannot be a single character repeated.');
        return false;
      }
      // Blocks names made only of underscores/dashes/dots/symbols
      if (/^[\s_\-.,!@#$%^&*()+=~`|\\/<>[\]{}:;'"?]+$/.test(v)) {
        showFieldError(prefix, field, 'Name cannot consist only of symbols.');
        return false;
      }
      clearFieldError(prefix, field); markFieldValid(prefix, field); return true;
    }

    if (field === 'desc') {
      if (v.length > DESC_MAX) { showFieldError(prefix, field, `Description cannot exceed ${DESC_MAX} characters.`); return false; }
      clearFieldError(prefix, field);
      if (v.length > 0) markFieldValid(prefix, field);
      return true;
    }

    return true;
  }

  function validateForm(prefix) {
    const fields = ['name', 'desc'];
    let allValid = true;
    const invalidFields = [];
    fields.forEach(f => {
      const ok = validateField(prefix, f);
      if (!ok) { allValid = false; invalidFields.push(f); }
    });

    if (!allValid) {
      invalidFields.forEach(f => shakeGroup(prefix, f));
      shakeModal(prefix === 'add' ? 'addModal' : 'editModal');
    }

    return allValid;
  }

  // ── Live validation while typing ─────────────────────────────────────────
  document.getElementById('addName').addEventListener('input', () => validateField('add', 'name'));
  document.getElementById('addName').addEventListener('blur',  () => validateField('add', 'name'));
  document.getElementById('editName').addEventListener('input', () => validateField('edit', 'name'));
  document.getElementById('editName').addEventListener('blur',  () => validateField('edit', 'name'));

  // ── Submit-time validation (blocks bad submissions) ──────────────────────
  document.getElementById('addForm').addEventListener('submit', function (e) {
    if (!validateForm('add')) {
      e.preventDefault();
      e.stopPropagation();
    }
  });
  document.getElementById('editForm').addEventListener('submit', function (e) {
    if (!validateForm('edit')) {
      e.preventDefault();
      e.stopPropagation();
    }
  });

  // ── Modals ────────────────────────────────────────────────────────────────
  function openAddModal(errorMsg) {
    // Clear previous state
    document.getElementById('addModalError').classList.remove('show');
    document.getElementById('addForm').reset();
    clearFieldError('add', 'name');
    clearFieldError('add', 'desc');
    document.getElementById('addName').classList.remove('form-input--valid');
    document.getElementById('addDesc').classList.remove('form-input--valid');
    updateCharCount('addDesc', 'addDescCount');

    document.getElementById('addModal').classList.add('open');

    // If called with a server error (e.g. from redirect), show it
    if (errorMsg) {
      showAddModalError(errorMsg);
      document.getElementById('addName').classList.add('form-input--error');
    }
  }

  function openEditModal(id, name, desc) {
    document.getElementById('editForm').action = '/admin/categories/' + id + '/edit';
    document.getElementById('editName').value  = name;
    document.getElementById('editDesc').value  = desc;

    // Clear previous error state
    document.getElementById('editModalError').classList.remove('show');
    clearFieldError('edit', 'name');
    clearFieldError('edit', 'desc');
    document.getElementById('editName').classList.remove('form-input--valid');
    document.getElementById('editDesc').classList.remove('form-input--valid');
    updateCharCount('editDesc', 'editDescCount');

    document.getElementById('editModal').classList.add('open');
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
  }

  // Clear name-field server-error highlight when user starts typing again
  document.getElementById('addName').addEventListener('input', function() {
    document.getElementById('addModalError').classList.remove('show');
  });
  document.getElementById('editName').addEventListener('input', function() {
    document.getElementById('editModalError').classList.remove('show');
  });

  // Close modals on backdrop click
  document.querySelectorAll('.modal-overlay').forEach(el => {
    el.addEventListener('click', e => { if (e.target === el) el.classList.remove('open'); });
  });

  // ── Delete confirm ────────────────────────────────────────────────────────
  function openDeleteConfirm(btn) {
    document.getElementById('confirmCatName').textContent = btn.dataset.name;
    document.getElementById('confirmDeleteForm').action   = btn.dataset.action;
    document.getElementById('confirmModal').classList.add('open');
  }
  function closeDeleteConfirm() {
    document.getElementById('confirmModal').classList.remove('open');
  }
  document.getElementById('confirmModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteConfirm();
  });

  function escHtml(str) {
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>
</body>

</html>
