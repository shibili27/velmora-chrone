<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate"/>
  <meta http-equiv="Pragma" content="no-cache"/>
  <meta http-equiv="Expires" content="0"/>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — Velmora Chroné Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --teal:       #2d8c84;
      --teal-dark:  #1f6e67;
      --teal-light: #e8f4f3;
      --sidebar-w:  220px;
      --bg:         #f2f4f3;
      --white:      #ffffff;
      --border:     #e2e6e4;
      --text:       #1a1f1e;
      --text-mid:   #5a6461;
      --text-light: #9aa8a5;
      --green:      #16a34a;
      --green-bg:   #dcfce7;
      --blue:       #2563eb;
      --blue-bg:    #dbeafe;
      --red:        #dc2626;
      --red-bg:     #fee2e2;
      --amber:      #d97706;
      --amber-bg:   #fef3c7;
      --purple:     #7c3aed;
      --purple-bg:  #ede9fe;
    }

    html, body { height: 100%; font-family: 'Jost', sans-serif; background: var(--bg); color: var(--text); }
    .layout { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar { width: var(--sidebar-w); background: var(--white); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
    .sidebar__brand { padding: 24px 20px 18px; border-bottom: 1px solid var(--border); }
    .sidebar__brand-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: 0.06em; color: var(--text); line-height: 1.2; }
    .sidebar__brand-sub { font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-top: 3px; }
    .sidebar__nav { flex: 1; padding: 14px 0; overflow-y: auto; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; font-size: 13px; font-weight: 500; color: var(--text-mid); text-decoration: none; transition: background 0.15s, color 0.15s; }
    .nav-item:hover { background: var(--teal-light); color: var(--teal); }
    .nav-item.active { background: var(--teal-light); color: var(--teal); border-right: 3px solid var(--teal); }
    .nav-item svg { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar__footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .sidebar__footer-info { overflow: hidden; flex: 1; }
    .sidebar__footer-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .sidebar__footer-role { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); }
    .btn-logout { display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; border: 1px solid #fecaca; background: var(--red-bg); color: var(--red); cursor: pointer; flex-shrink: 0; transition: background 0.15s; text-decoration: none; }
    .btn-logout:hover { background: var(--red); color: #fff; border-color: var(--red); }
    .btn-logout svg { width: 14px; height: 14px; }

    /* ── Main ── */
    .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

    /* ── Topbar ── */
    .topbar { background: var(--white); border-bottom: 1px solid var(--border); padding: 0 32px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar__title { font-size: 13px; font-weight: 500; color: var(--text-mid); letter-spacing: 0.04em; }
    .topbar__right { display: flex; align-items: center; gap: 12px; }
    .topbar__date { font-size: 11px; color: var(--text-light); letter-spacing: 0.04em; }

    /* ── Notification bell ── */
    .notif-wrap { position: relative; }
    .notif-bell { position: relative; background: none; border: 1px solid var(--border); border-radius: 6px; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-mid); transition: background 0.15s, color 0.15s; }
    .notif-bell:hover { background: var(--teal-light); color: var(--teal); border-color: var(--teal); }
    .notif-count { position: absolute; top: -5px; right: -5px; background: var(--red); color: #fff; font-size: 9px; font-weight: 700; min-width: 16px; height: 16px; border-radius: 8px; display: flex; align-items: center; justify-content: center; padding: 0 3px; border: 1.5px solid var(--white); }
    .notif-dropdown { position: absolute; top: calc(100% + 8px); right: 0; width: 320px; background: var(--white); border: 1px solid var(--border); border-radius: 8px; box-shadow: 0 8px 24px rgba(0,0,0,0.10); z-index: 200; display: none; overflow: hidden; }
    .notif-dropdown.open { display: block; }
    .notif-header { display: flex; align-items: center; justify-content: space-between; padding: 12px 16px; border-bottom: 1px solid var(--border); }
    .notif-header-left { font-size: 12px; font-weight: 600; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .notif-tabs { display: flex; gap: 4px; }
    .notif-tab { font-size: 10px; font-weight: 600; padding: 3px 8px; border-radius: 10px; border: 1px solid var(--border); background: var(--bg); color: var(--text-mid); cursor: pointer; transition: all 0.15s; }
    .notif-tab.active { background: var(--teal); color: #fff; border-color: var(--teal); }
    .notif-clear { background: none; border: none; font-family: 'Jost', sans-serif; font-size: 11px; color: var(--teal); cursor: pointer; font-weight: 500; white-space: nowrap; }
    .notif-clear:hover { text-decoration: underline; }
    .notif-list { max-height: 340px; overflow-y: auto; }
    .notif-empty { padding: 28px; text-align: center; font-size: 12px; color: var(--text-light); }
    .notif-item { display: flex; align-items: flex-start; gap: 10px; padding: 12px 16px; border-bottom: 1px solid var(--border); text-decoration: none; transition: background 0.12s; position: relative; background: #f0faf9; }
    .notif-item:last-child { border-bottom: none; }
    .notif-item:hover { background: var(--teal-light); }
    .notif-item.read { background: var(--white); }
    .notif-item.read:hover { background: var(--bg); }
    .notif-item__dot { width: 7px; height: 7px; border-radius: 50%; background: var(--teal); flex-shrink: 0; margin-top: 5px; }
    .notif-item.read .notif-item__dot { background: transparent; border: 1.5px solid var(--border); }
    .notif-item__body-wrap { flex: 1; min-width: 0; }
    .notif-item__top  { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2px; }
    .notif-item__id   { font-size: 12px; font-weight: 600; color: var(--teal); font-family: 'Cormorant Garamond', serif; }
    .notif-item.read .notif-item__id { color: var(--text-mid); }
    .notif-item__time { font-size: 10px; color: var(--text-light); }
    .notif-item__info { font-size: 11.5px; color: var(--text-mid); }
    .notif-item__customer { font-size: 10px; color: var(--text-light); margin-top: 1px; }
    .notif-item__actions { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; flex-shrink: 0; }
    .notif-mark-btn { font-size: 9px; font-weight: 600; color: var(--teal); background: none; border: 1px solid var(--teal-light); border-radius: 4px; padding: 2px 6px; cursor: pointer; white-space: nowrap; font-family: 'Jost', sans-serif; transition: background 0.12s; }
    .notif-mark-btn:hover { background: var(--teal-light); }
    .notif-item.read .notif-mark-btn { color: var(--text-light); border-color: var(--border); }
    .notif-view-btn { font-size: 9px; font-weight: 600; color: var(--text-mid); background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: 2px 6px; cursor: pointer; white-space: nowrap; font-family: 'Jost', sans-serif; text-decoration: none; transition: background 0.12s; }
    .notif-view-btn:hover { background: var(--border); }
    .notif-footer { padding: 10px 16px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }
    .notif-footer-count { font-size: 10px; color: var(--text-light); }

    /* ── Content ── */
    .content { padding: 32px; flex: 1; }

    /* ── Welcome banner ── */
    .welcome-banner {
      background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
      border-radius: 8px; padding: 28px 32px; margin-bottom: 28px;
      display: flex; align-items: center; justify-content: space-between;
      overflow: hidden; position: relative;
    }
    .welcome-banner::before { content: ''; position: absolute; right: -40px; top: -40px; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,0.05); }
    .welcome-banner::after  { content: ''; position: absolute; right: 60px; bottom: -60px; width: 160px; height: 160px; border-radius: 50%; background: rgba(255,255,255,0.04); }
    .welcome-banner__text { position: relative; z-index: 1; }
    .welcome-banner__greeting { font-size: 12px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.65); margin-bottom: 6px; }
    .welcome-banner__name { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #fff; line-height: 1.2; }
    .welcome-banner__sub { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 6px; }
    .welcome-banner__badges { position: relative; z-index: 1; display: flex; gap: 12px; }
    .welcome-banner__badge { background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); border-radius: 6px; padding: 12px 20px; text-align: center; min-width: 130px; }
    .welcome-banner__badge-label { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 4px; }
    .welcome-banner__badge-val { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #fff; }
    .welcome-banner__badge-val span { font-size: 12px; font-family: 'Jost', sans-serif; }

    /* ── Stat cards ── */
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 24px; }
    .stat-card { background: var(--white); border: 1px solid var(--border); border-radius: 6px; padding: 20px 22px; display: flex; flex-direction: column; gap: 12px; transition: box-shadow 0.2s; }
    .stat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .stat-card__top { display: flex; align-items: flex-start; justify-content: space-between; }
    .stat-card__icon { width: 38px; height: 38px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .stat-card__icon svg { width: 18px; height: 18px; }
    .stat-card__icon--teal  { background: var(--teal-light); color: var(--teal); }
    .stat-card__icon--green { background: var(--green-bg);   color: var(--green); }
    .stat-card__icon--blue  { background: var(--blue-bg);    color: var(--blue); }
    .stat-card__icon--amber { background: var(--amber-bg);   color: var(--amber); }
    .stat-card__trend { font-size: 10px; font-weight: 600; display: flex; align-items: center; gap: 3px; padding: 3px 7px; border-radius: 20px; }
    .stat-card__trend svg { width: 10px; height: 10px; }
    .stat-card__trend--up   { color: var(--green); background: var(--green-bg); }
    .stat-card__trend--down { color: var(--red);   background: var(--red-bg); }
    .stat-card__label { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-light); }
    .stat-card__value { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; color: var(--text); line-height: 1; }
    .stat-card__sub { font-size: 11px; color: var(--text-light); margin-top: 2px; }

    /* ── Section card ── */
    .section-card { background: var(--white); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .section-card__header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .section-card__title  { font-size: 13px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text); }
    .section-card__meta   { font-size: 11px; color: var(--text-light); }
    .section-card__link   { font-size: 11px; font-weight: 600; color: var(--teal); text-decoration: none; letter-spacing: 0.04em; }
    .section-card__link:hover { text-decoration: underline; }

    /* ── Chart filter pills ── */
    .chart-filters { display: flex; gap: 6px; }
    .chart-filter-btn {
      font-size: 11px; font-weight: 600; padding: 4px 12px; border-radius: 20px;
      border: 1px solid var(--border); background: var(--bg); color: var(--text-mid);
      cursor: pointer; font-family: 'Jost', sans-serif; transition: all 0.15s;
    }
    .chart-filter-btn:hover { border-color: var(--teal); color: var(--teal); }
    .chart-filter-btn.active { background: var(--teal); color: #fff; border-color: var(--teal); }

    /* ── Chart canvas wrapper ── */
    .chart-canvas-wrap { padding: 20px 24px; position: relative; height: 260px; }
    .chart-canvas-wrap canvas { width: 100% !important; height: 100% !important; }
    .chart-loading { position: absolute; inset: 0; display: none; align-items: center; justify-content: center; background: rgba(255,255,255,0.8); font-size: 12px; color: var(--text-light); }
    .chart-loading.visible { display: flex; }

    /* ── Chart legend ── */
    .chart-legend { display: flex; align-items: center; gap: 20px; padding: 0 24px 16px; }
    .chart-legend-item { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--text-mid); }
    .chart-legend-dot { width: 10px; height: 3px; border-radius: 2px; }

    /* ── Chart divider ── */
    .chart-divider { border: none; border-top: 1px solid var(--border); margin: 0 24px; }

    /* ── Rev rows ── */
    .rev-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 24px; border-bottom: 1px solid var(--border); font-size: 12px; }
    .rev-row:last-child { border-bottom: none; }
    .rev-row__label { color: var(--text-mid); }
    .rev-row__val { font-weight: 600; color: var(--text); }
    .rev-row__val--teal { color: var(--teal); }

    /* ── Two / Three col ── */
    .two-col   { display: grid; grid-template-columns: 1fr 1fr;  gap: 20px; margin-bottom: 24px; }
    .three-col { display: grid; grid-template-columns: 2fr 1fr;  gap: 20px; margin-bottom: 24px; }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #f8faf9; }
    th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); padding: 12px 20px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: 13px 20px; font-size: 12.5px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: #fafcfb; }

    /* ── Badges ── */
    .badge { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 600; padding: 3px 9px; border-radius: 20px; white-space: nowrap; letter-spacing: 0.04em; }
    .badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .badge--pending   { color: var(--amber); background: var(--amber-bg); }
    .badge--delivered { color: var(--green); background: var(--green-bg); }
    .badge--cancelled { color: var(--red);   background: var(--red-bg); }
    .badge--shipped   { color: var(--blue);  background: var(--blue-bg); }

    /* ── Activity feed ── */
    .activity-list { padding: 4px 0; }
    .activity-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px 24px; border-bottom: 1px solid var(--border); }
    .activity-item:last-child { border-bottom: none; }
    .activity-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 4px; }
    .activity-dot--teal  { background: var(--teal); }
    .activity-dot--green { background: var(--green); }
    .activity-dot--amber { background: var(--amber); }
    .activity-dot--red   { background: var(--red); }
    .activity-dot--blue  { background: var(--blue); }
    .activity-text { font-size: 12px; color: var(--text-mid); line-height: 1.5; flex: 1; }
    .activity-text strong { color: var(--text); font-weight: 600; }
    .activity-time { font-size: 10px; color: var(--text-light); white-space: nowrap; margin-top: 2px; }

    /* ── Top-10 rank rows ── */
    .rank-row { display: flex; align-items: center; gap: 12px; padding: 11px 24px; border-bottom: 1px solid var(--border); }
    .rank-row:last-child { border-bottom: none; }
    .rank-num { font-size: 11px; font-weight: 700; color: var(--text-light); width: 22px; flex-shrink: 0; text-align: center; }
    .rank-num--gold   { color: #b8860b; }
    .rank-num--silver { color: #6b7280; }
    .rank-num--bronze { color: #92400e; }
    .rank-thumb { width: 34px; height: 34px; border-radius: 4px; background: var(--teal-light); display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
    .rank-thumb img { width: 100%; height: 100%; object-fit: cover; }
    .rank-thumb svg { width: 15px; height: 15px; color: var(--teal); }
    .rank-info { flex: 1; min-width: 0; }
    .rank-name  { font-size: 12.5px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .rank-sub   { font-size: 10px; color: var(--text-light); margin-top: 1px; }
    .rank-right { text-align: right; flex-shrink: 0; }
    .rank-val   { font-size: 12px; font-weight: 600; color: var(--text); }
    .rank-units { font-size: 10px; color: var(--text-light); }

    /* ── Progress bars ── */
    .progress-section { padding: 16px 24px; display: flex; flex-direction: column; gap: 14px; }
    .progress-item__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
    .progress-item__label { font-size: 12px; color: var(--text-mid); }
    .progress-item__val   { font-size: 12px; font-weight: 600; color: var(--text); }
    .progress-track { height: 5px; background: var(--border); border-radius: 10px; overflow: hidden; }
    .progress-fill  { height: 100%; border-radius: 10px; }
    .progress-fill--teal  { background: var(--teal); }
    .progress-fill--green { background: var(--green); }
    .progress-fill--amber { background: var(--amber); }
    .progress-fill--blue  { background: var(--blue); }

    /* ── Ledger section ── */
    .ledger-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 24px; border-bottom: 1px solid var(--border); }
    .ledger-controls { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .ledger-select {
      font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 500;
      padding: 7px 12px; border: 1px solid var(--border); border-radius: 4px;
      background: var(--bg); color: var(--text); cursor: pointer; outline: none;
      transition: border-color 0.15s;
    }
    .ledger-select:focus { border-color: var(--teal); }
    .ledger-input {
      font-family: 'Jost', sans-serif; font-size: 12px;
      padding: 7px 12px; border: 1px solid var(--border); border-radius: 4px;
      background: var(--bg); color: var(--text); outline: none;
      transition: border-color 0.15s; width: 130px;
    }
    .ledger-input:focus { border-color: var(--teal); }
    .btn-ledger {
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 600;
      padding: 7px 16px; border-radius: 4px; border: none; cursor: pointer;
      text-decoration: none; transition: background 0.15s;
    }
    .btn-ledger--primary { background: var(--teal); color: #fff; }
    .btn-ledger--primary:hover { background: var(--teal-dark); }
    .btn-ledger--outline { background: var(--bg); color: var(--text-mid); border: 1px solid var(--border); }
    .btn-ledger--outline:hover { background: var(--teal-light); color: var(--teal); border-color: var(--teal); }
    .btn-ledger svg { width: 14px; height: 14px; }
    .ledger-stats-row { display: flex; gap: 0; border-bottom: 1px solid var(--border); }
    .ledger-stat { flex: 1; padding: 16px 24px; border-right: 1px solid var(--border); }
    .ledger-stat:last-child { border-right: none; }
    .ledger-stat__label { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); margin-bottom: 4px; }
    .ledger-stat__val { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: var(--text); }
    .ledger-stat__val--teal  { color: var(--teal); }
    .ledger-stat__val--red   { color: var(--red); }
    .ledger-stat__val--green { color: var(--green); }
    .ledger-table-wrap { overflow-x: auto; max-height: 380px; overflow-y: auto; }
    #ledger-loading { display: none; padding: 32px; text-align: center; font-size: 12px; color: var(--text-light); }
    #ledger-empty   { display: none; padding: 32px; text-align: center; font-size: 12px; color: var(--text-light); }

    /* ── Toast ── */
    .toast { position: fixed; bottom: 24px; right: 24px; background: var(--text); color: #fff; padding: 12px 18px; border-radius: 6px; font-size: 12.5px; font-weight: 500; z-index: 9999; transform: translateY(80px); opacity: 0; transition: transform 0.25s, opacity 0.25s; pointer-events: none; max-width: 320px; }
    .toast.show    { transform: translateY(0); opacity: 1; }
    .toast.success { background: var(--green); }
    .toast.error   { background: var(--red); }

    /* ── Footer ── */
    .page-footer { text-align: center; padding: 20px 32px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); border-top: 1px solid var(--border); }
  </style>
</head>
<body>
<div class="layout">

  <!-- ── Sidebar ── -->
  <aside class="sidebar">
    <div class="sidebar__brand">
      <div class="sidebar__brand-name">Velmora<br>Chroné</div>
      <div class="sidebar__brand-sub">Admin Dashboard</div>
    </div>
    <nav class="sidebar__nav">
      <a href="/admin/dashboard" class="nav-item active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/orders" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>
      <a href="/admin/products" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
        Products
      </a>
      <a href="/admin/reviews" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
        Rating/Review
      </a>
      <a href="/admin/customers" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Customers
      </a>
      <a href="/admin/coupons" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        Coupons
      </a>
      <a href="/admin/offers" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        Offers
      </a>
      <a href="/admin/categories" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Categories
      </a>
      <a href="/admin/brands" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z"/></svg>
        Brands
      </a>
      <a href="/admin/refunds" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Refund/Return
      </a>
      <a href="/admin/banners" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Banner
      </a>
      <a href="/admin/referrals" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        Referral
      </a>
      <a href="/admin/sales-report" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Sales Report
      </a>
    </nav>
    <div class="sidebar__footer">
      <div class="avatar"><%= adminName ? adminName.charAt(0).toUpperCase() : 'A' %></div>
      <div class="sidebar__footer-info">
        <div class="sidebar__footer-name"><%= adminName || 'Admin' %></div>
        <div class="sidebar__footer-role"><%= adminRole || 'Administrator' %></div>
      </div>
      <a href="/admin/logout" class="btn-logout" title="Logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      </a>
    </div>
  </aside>

  <!-- ── Main ── -->
  <div class="main">

    <header class="topbar">
      <span class="topbar__title">Operational Administrator Hub</span>
      <div class="topbar__right">
        <span class="topbar__date" id="topbarDate"></span>
        <div class="notif-wrap" id="notifWrap">
          <button class="notif-bell" id="notifBell" onclick="toggleDropdown()">
            <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6 6 0 10-12 0v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
            <span class="notif-count" id="notifCount" style="display:none">0</span>
          </button>
          <div class="notif-dropdown" id="notifDropdown">
            <div class="notif-header">
              <div class="notif-header-left">
                <span>New Orders</span>
                <div class="notif-tabs">
                  <button class="notif-tab active" id="tabAll"    onclick="switchTab('all')">All</button>
                  <button class="notif-tab"         id="tabUnread" onclick="switchTab('unread')">Unread</button>
                  <button class="notif-tab"         id="tabRead"   onclick="switchTab('read')">Read</button>
                </div>
              </div>
              <button onclick="markAllRead()" class="notif-clear">Mark all read</button>
            </div>
            <div class="notif-list" id="notifList">
              <div class="notif-empty">No new orders</div>
            </div>
            <div class="notif-footer">
              <span class="notif-footer-count" id="notifFooterCount">0 notifications</span>
              <button onclick="clearAll()" class="notif-clear">Clear all</button>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="content">

      <!-- ── Welcome Banner ── -->
      <div class="welcome-banner">
        <div class="welcome-banner__text">
          <div class="welcome-banner__greeting">Welcome back</div>
          <div class="welcome-banner__name"><%= adminName || 'Administrator' %></div>
          <div class="welcome-banner__sub">Here's what's happening with Velmora Chroné today.</div>
        </div>
        <div class="welcome-banner__badges">
          <div class="welcome-banner__badge">
            <div class="welcome-banner__badge-label">Today's Revenue</div>
            <div class="welcome-banner__badge-val"><span>₹</span><%= typeof todayRevenue !== 'undefined' ? todayRevenue.toLocaleString('en-IN') : '0' %></div>
          </div>
          <div class="welcome-banner__badge">
            <div class="welcome-banner__badge-label">Total Revenue</div>
            <div class="welcome-banner__badge-val"><span>₹</span><%= typeof totalRevenue !== 'undefined' ? totalRevenue.toLocaleString('en-IN') : '0' %></div>
          </div>
        </div>
      </div>

      <!-- ── Stat Cards ── -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--teal">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--<%= (typeof revenueGrowth !== 'undefined' && revenueGrowth >= 0) ? 'up' : 'down' %>">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="<%= (typeof revenueGrowth !== 'undefined' && revenueGrowth >= 0) ? 'M5 15l7-7 7 7' : 'M19 9l-7 7-7-7' %>"/></svg>
              <%= typeof revenueGrowth !== 'undefined' ? Math.abs(revenueGrowth) : '0' %>%
            </span>
          </div>
          <div>
            <div class="stat-card__label">Total Revenue</div>
            <div class="stat-card__value">₹<%= typeof totalRevenue !== 'undefined' ? totalRevenue.toLocaleString('en-IN') : '0' %></div>
            <div class="stat-card__sub">vs last month</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--blue">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--<%= (typeof ordersGrowth !== 'undefined' && ordersGrowth >= 0) ? 'up' : 'down' %>">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="<%= (typeof ordersGrowth !== 'undefined' && ordersGrowth >= 0) ? 'M5 15l7-7 7 7' : 'M19 9l-7 7-7-7' %>"/></svg>
              <%= typeof ordersGrowth !== 'undefined' ? Math.abs(ordersGrowth) : '0' %>%
            </span>
          </div>
          <div>
            <div class="stat-card__label">Total Orders</div>
            <div class="stat-card__value"><%= typeof totalOrders !== 'undefined' ? totalOrders.toLocaleString() : '0' %></div>
            <div class="stat-card__sub"><%= typeof pendingOrders !== 'undefined' ? pendingOrders : '0' %> pending</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--green">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--up">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              <%= typeof customersGrowth !== 'undefined' ? customersGrowth : '0' %>%
            </span>
          </div>
          <div>
            <div class="stat-card__label">Customers</div>
            <div class="stat-card__value"><%= typeof totalCustomers !== 'undefined' ? totalCustomers.toLocaleString() : '0' %></div>
            <div class="stat-card__sub"><%= typeof newCustomers !== 'undefined' ? newCustomers : '0' %> new this month</div>
          </div>
        </div>

        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--amber">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--down">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              <%= typeof outOfStock !== 'undefined' ? outOfStock : '0' %> out
            </span>
          </div>
          <div>
            <div class="stat-card__label">Products</div>
            <div class="stat-card__value"><%= typeof totalProducts !== 'undefined' ? totalProducts.toLocaleString() : '0' %></div>
            <div class="stat-card__sub">across all categories</div>
          </div>
        </div>
      </div>

      <!-- ── Revenue & Orders Chart ── -->
      <div class="section-card" style="margin-bottom:24px">
        <div class="section-card__header">
          <span class="section-card__title">Revenue &amp; Orders</span>
          <div class="chart-filters">
            <button class="chart-filter-btn" data-period="daily">Daily</button>
            <button class="chart-filter-btn" data-period="weekly">Weekly</button>
            <button class="chart-filter-btn active" data-period="monthly">Monthly</button>
            <button class="chart-filter-btn" data-period="yearly">Yearly</button>
          </div>
        </div>
        <div class="chart-canvas-wrap" style="position:relative">
          <canvas id="mainChart"></canvas>
          <div class="chart-loading" id="chartLoading">Loading…</div>
        </div>
        <div class="chart-legend">
          <div class="chart-legend-item">
            <div class="chart-legend-dot" style="background:#2d8c84"></div>
            Revenue (₹)
          </div>
          <div class="chart-legend-item">
            <div class="chart-legend-dot" style="background:#2563eb"></div>
            Orders (count)
          </div>
        </div>
        <hr class="chart-divider"/>
        <div style="display:flex;gap:0">
          <div class="rev-row" style="flex:1;border-right:1px solid var(--border)">
            <span class="rev-row__label">Avg. Order Value</span>
            <span class="rev-row__val rev-row__val--teal">₹<%= typeof avgOrderValue !== 'undefined' ? avgOrderValue.toLocaleString('en-IN') : '0' %></span>
          </div>
          <div class="rev-row" style="flex:1;border-right:1px solid var(--border)">
            <span class="rev-row__label">Highest Month</span>
            <span class="rev-row__val">₹<%= typeof highestMonth !== 'undefined' ? highestMonth.toLocaleString('en-IN') : '0' %></span>
          </div>
          <div class="rev-row" style="flex:1">
            <span class="rev-row__label">Delivered Orders</span>
            <span class="rev-row__val"><%= typeof deliveredOrders !== 'undefined' ? deliveredOrders : '0' %></span>
          </div>
        </div>
      </div>

      <!-- ── Top 10 Products + Order Status ── -->
      <div class="three-col">
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Top 10 — Products</span>
            <a href="/admin/products" class="section-card__link">View All →</a>
          </div>
          <% if (typeof topProducts !== 'undefined' && topProducts.length > 0) { %>
            <% topProducts.forEach(function(p, i) { %>
            <div class="rank-row">
              <div class="rank-num <%= i===0?'rank-num--gold':i===1?'rank-num--silver':i===2?'rank-num--bronze':'' %>">#<%= i+1 %></div>
              <div class="rank-thumb">
                <% if (p.images && p.images.length > 0) { %>
                  <img src="<%= p.images[0] %>" alt="<%= p.name %>"/>
                <% } else { %>
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
                <% } %>
              </div>
              <div class="rank-info">
                <div class="rank-name"><%= p.name %></div>
                <div class="rank-sub"><%= p.brand || '' %></div>
              </div>
              <div class="rank-right">
                <div class="rank-val">₹<%= p.totalRevenue ? p.totalRevenue.toLocaleString('en-IN') : '0' %></div>
                <div class="rank-units"><%= p.totalSold || 0 %> sold</div>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div style="padding:32px;text-align:center;font-size:12px;color:var(--text-light)">No product sales yet</div>
          <% } %>
        </div>

        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Order Status</span>
          </div>
          <div class="progress-section">
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Delivered</span>
                <span class="progress-item__val"><%= typeof deliveredOrders !== 'undefined' ? deliveredOrders : '0' %></span>
              </div>
              <div class="progress-track"><div class="progress-fill progress-fill--green" style="width:<%= typeof deliveredPct !== 'undefined' ? deliveredPct : 0 %>%"></div></div>
            </div>
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Pending</span>
                <span class="progress-item__val"><%= typeof pendingOrders !== 'undefined' ? pendingOrders : '0' %></span>
              </div>
              <div class="progress-track"><div class="progress-fill progress-fill--amber" style="width:<%= typeof pendingPct !== 'undefined' ? pendingPct : 0 %>%"></div></div>
            </div>
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Shipped</span>
                <span class="progress-item__val"><%= typeof shippedOrders !== 'undefined' ? shippedOrders : '0' %></span>
              </div>
              <div class="progress-track"><div class="progress-fill progress-fill--blue" style="width:<%= typeof shippedPct !== 'undefined' ? shippedPct : 0 %>%"></div></div>
            </div>
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Cancelled</span>
                <span class="progress-item__val"><%= typeof cancelledOrders !== 'undefined' ? cancelledOrders : '0' %></span>
              </div>
              <div class="progress-track"><div class="progress-fill" style="width:<%= typeof cancelledPct !== 'undefined' ? cancelledPct : 0 %>%;background:var(--red)"></div></div>
            </div>
          </div>
          <hr class="chart-divider"/>
          <div style="padding:14px 24px;display:flex;flex-direction:column;gap:10px;">
            <a href="/admin/orders" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;padding:9px 12px;border-radius:4px;background:var(--bg);font-size:12px;font-weight:500;color:var(--text-mid);transition:background 0.15s" onmouseover="this.style.background='var(--teal-light)';this.style.color='var(--teal)'" onmouseout="this.style.background='var(--bg)';this.style.color='var(--text-mid)'">
              <span>View All Orders</span>
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/admin/sales-report" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;padding:9px 12px;border-radius:4px;background:var(--bg);font-size:12px;font-weight:500;color:var(--text-mid);transition:background 0.15s" onmouseover="this.style.background='var(--teal-light)';this.style.color='var(--teal)'" onmouseout="this.style.background='var(--bg)';this.style.color='var(--text-mid)'">
              <span>Sales Report</span>
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/admin/customers" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;padding:9px 12px;border-radius:4px;background:var(--bg);font-size:12px;font-weight:500;color:var(--text-mid);transition:background 0.15s" onmouseover="this.style.background='var(--teal-light)';this.style.color='var(--teal)'" onmouseout="this.style.background='var(--bg)';this.style.color='var(--text-mid)'">
              <span>Manage Customers</span>
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>

      <!-- ── Top 10 Categories + Top 10 Brands ── -->
      <div class="two-col">
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Top 10 — Categories</span>
            <a href="/admin/categories" class="section-card__link">Manage →</a>
          </div>
          <% if (typeof topCategories !== 'undefined' && topCategories.length > 0) { %>
            <% topCategories.forEach(function(c, i) { %>
            <div class="rank-row">
              <div class="rank-num <%= i===0?'rank-num--gold':i===1?'rank-num--silver':i===2?'rank-num--bronze':'' %>">#<%= i+1 %></div>
              <div class="rank-thumb" style="background:var(--teal-light)">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="width:15px;height:15px;color:var(--teal)"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              </div>
              <div class="rank-info">
                <div class="rank-name"><%= c.name %></div>
                <div class="rank-sub"><%= c.productCount || 0 %> products</div>
              </div>
              <div class="rank-right">
                <div class="rank-val">₹<%= c.totalRevenue ? c.totalRevenue.toLocaleString('en-IN') : '0' %></div>
                <div class="rank-units"><%= c.totalSold || 0 %> sold</div>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div style="padding:32px;text-align:center;font-size:12px;color:var(--text-light)">No category sales data yet</div>
          <% } %>
        </div>

        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Top 10 — Brands</span>
            <a href="/admin/brands" class="section-card__link">Manage →</a>
          </div>
          <% if (typeof topBrands !== 'undefined' && topBrands.length > 0) { %>
            <% topBrands.forEach(function(b, i) { %>
            <div class="rank-row">
              <div class="rank-num <%= i===0?'rank-num--gold':i===1?'rank-num--silver':i===2?'rank-num--bronze':'' %>">#<%= i+1 %></div>
              <div class="rank-thumb" style="background:var(--purple-bg)">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" style="width:15px;height:15px;color:var(--purple)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z"/></svg>
              </div>
              <div class="rank-info">
                <div class="rank-name"><%= b.name %></div>
                <div class="rank-sub"><%= b.productCount || 0 %> products</div>
              </div>
              <div class="rank-right">
                <div class="rank-val">₹<%= b.totalRevenue ? b.totalRevenue.toLocaleString('en-IN') : '0' %></div>
                <div class="rank-units"><%= b.totalSold || 0 %> sold</div>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div style="padding:32px;text-align:center;font-size:12px;color:var(--text-light)">No brand sales data yet</div>
          <% } %>
        </div>
      </div>

      <!-- ── Recent Orders + Activity ── -->
      <div class="two-col">
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Recent Orders</span>
            <a href="/admin/orders" class="section-card__link">View All →</a>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>Order ID</th><th>Customer</th><th>Amount</th><th>Status</th></tr>
              </thead>
              <tbody>
                <% if (typeof recentOrders !== 'undefined' && recentOrders.length > 0) { %>
                  <% recentOrders.forEach(function(o) { %>
                  <tr>
                    <td style="font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:600;color:var(--teal)">#<%= o.orderId || o._id.toString().slice(-6).toUpperCase() %></td>
                    <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= o.userId && o.userId.name ? o.userId.name : 'Unknown' %></td>
                    <td style="font-weight:600">₹<%= o.totalAmount ? o.totalAmount.toLocaleString('en-IN') : '0' %></td>
                    <td>
                      <% const s = (o.status || '').toLowerCase(); %>
                      <% if (s === 'delivered') { %><span class="badge badge--delivered">Delivered</span>
                      <% } else if (s === 'confirmed' || s === 'pending') { %><span class="badge badge--pending">Confirmed</span>
                      <% } else if (s === 'dispatched' || s === 'processing') { %><span class="badge badge--shipped">Shipped</span>
                      <% } else if (s === 'cancelled') { %><span class="badge badge--cancelled">Cancelled</span>
                      <% } else { %><span class="badge badge--pending"><%= o.status || 'N/A' %></span><% } %>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" style="text-align:center;color:var(--text-light);padding:32px;font-size:12px">No recent orders</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Recent Activity</span>
            <span class="section-card__meta">Live</span>
          </div>
          <div class="activity-list">
            <% if (typeof recentActivity !== 'undefined' && recentActivity.length > 0) { %>
              <% recentActivity.forEach(function(a) { %>
              <div class="activity-item">
                <div class="activity-dot activity-dot--<%= a.color || 'teal' %>"></div>
                <div style="flex:1">
                  <div class="activity-text"><%- a.message %></div>
                  <div class="activity-time"><%= a.time %></div>
                </div>
              </div>
              <% }) %>
            <% } else { %>
              <div class="activity-item">
                <div class="activity-dot activity-dot--teal"></div>
                <div style="flex:1">
                  <div class="activity-text">Dashboard loaded successfully</div>
                  <div class="activity-time">Just now</div>
                </div>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- ── Quick Stats ── -->
      <div class="section-card" style="margin-bottom:24px">
        <div class="section-card__header"><span class="section-card__title">Quick Stats</span></div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:0">
          <div class="rev-row" style="flex-direction:column;align-items:flex-start;gap:2px;border-right:1px solid var(--border)">
            <span class="rev-row__label">Active Coupons</span>
            <span class="rev-row__val"><%= typeof activeCoupons !== 'undefined' ? activeCoupons : '0' %></span>
          </div>
          <div class="rev-row" style="flex-direction:column;align-items:flex-start;gap:2px;border-right:1px solid var(--border)">
            <span class="rev-row__label">Blocked Users</span>
            <span class="rev-row__val" style="color:var(--red)"><%= typeof blockedUsers !== 'undefined' ? blockedUsers : '0' %></span>
          </div>
          <div class="rev-row" style="flex-direction:column;align-items:flex-start;gap:2px;border-right:1px solid var(--border)">
            <span class="rev-row__label">Pending Refunds</span>
            <span class="rev-row__val" style="color:var(--amber)"><%= typeof pendingRefunds !== 'undefined' ? pendingRefunds : '0' %></span>
          </div>
          <div class="rev-row" style="flex-direction:column;align-items:flex-start;gap:2px">
            <span class="rev-row__label">Out of Stock</span>
            <span class="rev-row__val" style="color:var(--red)"><%= typeof outOfStock !== 'undefined' ? outOfStock : '0' %></span>
          </div>
        </div>
      </div>

      <!-- ── Ledger Book ── -->
      <div class="section-card" style="margin-bottom:24px" id="ledgerSection">
        <div class="ledger-header">
          <span class="section-card__title">
            <svg width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" style="vertical-align:-2px;margin-right:6px;color:var(--teal)"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z"/></svg>
            Ledger Book
          </span>
          <div class="ledger-controls">
            <select class="ledger-select" id="ledgerType">
              <option value="monthly">Monthly</option>
              <option value="custom">Custom Range</option>
            </select>
            <select class="ledger-select" id="ledgerYear" style="display:block">
              <% const thisYear = new Date().getFullYear(); %>
              <% for(let y = thisYear; y >= thisYear - 4; y--) { %>
                <option value="<%= y %>" <%= y === thisYear ? 'selected' : '' %>><%= y %></option>
              <% } %>
            </select>
            <select class="ledger-select" id="ledgerMonth" style="display:block">
              <% const mNames = ['January','February','March','April','May','June','July','August','September','October','November','December']; %>
              <% const curMonth = new Date().getMonth(); %>
              <% mNames.forEach(function(m, idx) { %>
                <option value="<%= idx+1 %>" <%= idx === curMonth ? 'selected' : '' %>><%= m %></option>
              <% }) %>
            </select>
            <input type="date" class="ledger-input" id="ledgerFrom" style="display:none" placeholder="From"/>
            <input type="date" class="ledger-input" id="ledgerTo"   style="display:none" placeholder="To"/>
            <button class="btn-ledger btn-ledger--outline" onclick="loadLedger()">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Load
            </button>
            <button class="btn-ledger btn-ledger--primary" onclick="downloadLedger()">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
              Download PDF
            </button>
          </div>
        </div>

        <div class="ledger-stats-row" id="ledgerStatsRow" style="display:none">
          <div class="ledger-stat"><div class="ledger-stat__label">Total Orders</div><div class="ledger-stat__val" id="lsTotalOrders">0</div></div>
          <div class="ledger-stat"><div class="ledger-stat__label">Gross Revenue</div><div class="ledger-stat__val ledger-stat__val--teal" id="lsGross">₹0</div></div>
          <div class="ledger-stat"><div class="ledger-stat__label">Discounts Given</div><div class="ledger-stat__val ledger-stat__val--red" id="lsDiscount">₹0</div></div>
          <div class="ledger-stat"><div class="ledger-stat__label">Net Revenue</div><div class="ledger-stat__val ledger-stat__val--green" id="lsNet">₹0</div></div>
          <div class="ledger-stat"><div class="ledger-stat__label">Refunds</div><div class="ledger-stat__val ledger-stat__val--red" id="lsRefunds">₹0</div></div>
        </div>

        <div id="ledger-loading">Loading ledger…</div>
        <div id="ledger-empty">No orders found for the selected period.</div>

        <div class="ledger-table-wrap">
          <table id="ledgerTable" style="display:none">
            <thead>
              <tr>
                <th>#</th><th>Date</th><th>Order ID</th><th>Customer</th>
                <th>Payment</th><th>Subtotal</th><th>Discount</th><th>Grand Total</th><th>Status</th>
              </tr>
            </thead>
            <tbody id="ledgerTbody"></tbody>
          </table>
        </div>
      </div>

    </div><!-- /.content -->
    <footer class="page-footer">© 2026 Velmora Chroné. All Rights Reserved. Admin Panel.</footer>
  </div><!-- /.main -->
</div><!-- /.layout -->

<div class="toast" id="toast"></div>

<script src="/socket.io/socket.io.js"></script>
<script>
  (function () {
    const el = document.getElementById('topbarDate');
    if (el) el.textContent = new Date().toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  })();

  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className   = `toast ${type} show`;
    setTimeout(() => { t.className = 'toast'; }, 3500);
  }

  // ── CHART ──────────────────────────────────────────────────────────────────
  let mainChart = null;
  const chartCtx = document.getElementById('mainChart').getContext('2d');

  function buildChart(labels, revenueData, ordersData) {
    if (mainChart) mainChart.destroy();
    mainChart = new Chart(chartCtx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Revenue (₹)', data: revenueData,
            borderColor: '#2d8c84', backgroundColor: 'rgba(45,140,132,0.08)',
            borderWidth: 2.5, pointBackgroundColor: '#2d8c84',
            pointRadius: 4, pointHoverRadius: 6, tension: 0.35, fill: true, yAxisID: 'yRevenue',
          },
          {
            label: 'Orders', data: ordersData,
            borderColor: '#2563eb', backgroundColor: 'rgba(37,99,235,0.06)',
            borderWidth: 2, pointBackgroundColor: '#2563eb',
            pointRadius: 4, pointHoverRadius: 6, tension: 0.35, fill: true,
            yAxisID: 'yOrders', borderDash: [5, 3],
          },
        ],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        interaction: { mode: 'index', intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1a1f1e',
            titleFont: { family: 'Jost', size: 11, weight: '600' },
            bodyFont:  { family: 'Jost', size: 11 },
            padding: 10,
            callbacks: {
              label(ctx) {
                if (ctx.datasetIndex === 0) return ' Revenue: ₹' + Number(ctx.parsed.y).toLocaleString('en-IN');
                return ' Orders: ' + ctx.parsed.y;
              },
            },
          },
        },
        scales: {
          x: { grid: { color: '#e2e6e4', lineWidth: 0.8 }, ticks: { font: { family: 'Jost', size: 10 }, color: '#9aa8a5' } },
          yRevenue: {
            position: 'left', grid: { color: '#e2e6e4', lineWidth: 0.8 },
            ticks: { font: { family: 'Jost', size: 10 }, color: '#2d8c84', callback: v => '₹' + (v >= 1000 ? (v/1000).toFixed(0) + 'K' : v) },
          },
          yOrders: {
            position: 'right', grid: { drawOnChartArea: false },
            ticks: { font: { family: 'Jost', size: 10 }, color: '#2563eb' },
          },
        },
      },
    });
  }

  async function fetchChartData(period) {
    const loading = document.getElementById('chartLoading');
    loading.classList.add('visible');
    try {
      const res  = await fetch(`/admin/dashboard/chart-data?period=${period}`);
      const data = await res.json();
      if (data.success) buildChart(data.labels, data.revenue, data.orders);
    } catch (e) {
      showToast('Failed to load chart data', 'error');
    } finally {
      loading.classList.remove('visible');
    }
  }

  document.querySelectorAll('.chart-filter-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.chart-filter-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      fetchChartData(this.dataset.period);
    });
  });

  fetchChartData('monthly');

  // ── LEDGER ─────────────────────────────────────────────────────────────────
  const ledgerTypeEl  = document.getElementById('ledgerType');
  const ledgerYearEl  = document.getElementById('ledgerYear');
  const ledgerMonthEl = document.getElementById('ledgerMonth');
  const ledgerFromEl  = document.getElementById('ledgerFrom');
  const ledgerToEl    = document.getElementById('ledgerTo');

  ledgerTypeEl.addEventListener('change', function () {
    const isCustom = this.value === 'custom';
    ledgerYearEl.style.display  = isCustom ? 'none'  : 'block';
    ledgerMonthEl.style.display = isCustom ? 'none'  : 'block';
    ledgerFromEl.style.display  = isCustom ? 'block' : 'none';
    ledgerToEl.style.display    = isCustom ? 'block' : 'none';
  });

  function getLedgerParams() {
    const type = ledgerTypeEl.value;
    if (type === 'custom') return `type=custom&from=${ledgerFromEl.value}&to=${ledgerToEl.value}`;
    return `type=monthly&year=${ledgerYearEl.value}&month=${ledgerMonthEl.value}`;
  }

  async function loadLedger() {
    const loadingEl = document.getElementById('ledger-loading');
    const emptyEl   = document.getElementById('ledger-empty');
    const tableEl   = document.getElementById('ledgerTable');
    const statsRow  = document.getElementById('ledgerStatsRow');
    const tbody     = document.getElementById('ledgerTbody');

    loadingEl.style.display = 'block';
    emptyEl.style.display   = 'none';
    tableEl.style.display   = 'none';
    statsRow.style.display  = 'none';

    try {
      const res  = await fetch(`/admin/dashboard/ledger?${getLedgerParams()}`);
      const data = await res.json();
      loadingEl.style.display = 'none';

      if (!data.success || !data.orders || data.orders.length === 0) { emptyEl.style.display = 'block'; return; }

      document.getElementById('lsTotalOrders').textContent = data.summary.totalOrders;
      document.getElementById('lsGross').textContent   = '₹' + Number(data.summary.grossRevenue).toLocaleString('en-IN');
      document.getElementById('lsDiscount').textContent = '₹' + Number(data.summary.totalDiscount).toLocaleString('en-IN');
      document.getElementById('lsNet').textContent      = '₹' + Number(data.summary.netRevenue).toLocaleString('en-IN');
      document.getElementById('lsRefunds').textContent  = '₹' + Number(data.summary.totalRefunds).toLocaleString('en-IN');
      statsRow.style.display = 'flex';

      tbody.innerHTML = '';
      const statusColors = { delivered:'badge--delivered', confirmed:'badge--pending', processing:'badge--shipped', dispatched:'badge--shipped', cancelled:'badge--cancelled', returned:'badge--pending' };
      data.orders.forEach((o, i) => {
        const disc = (o.itemDiscount || 0) + (o.couponDiscount || 0);
        tbody.innerHTML += `
          <tr>
            <td style="color:var(--text-light)">${i + 1}</td>
            <td style="white-space:nowrap;font-size:11px">${new Date(o.date).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})}</td>
            <td style="font-family:'Cormorant Garamond',serif;font-weight:600;color:var(--teal)">${o.orderNumber}</td>
            <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${o.customer||'Unknown'}</td>
            <td><span style="font-size:10px;font-weight:600;padding:2px 7px;border-radius:10px;background:var(--teal-light);color:var(--teal)">${o.paymentMethod}</span></td>
            <td style="font-weight:500">₹${Number(o.subtotal).toLocaleString('en-IN')}</td>
            <td style="color:var(--red)">${disc > 0 ? '-₹' + Number(disc).toLocaleString('en-IN') : '—'}</td>
            <td style="font-weight:600">₹${Number(o.grandTotal).toLocaleString('en-IN')}</td>
            <td><span class="badge ${statusColors[o.status]||'badge--pending'}">${o.status}</span></td>
          </tr>`;
      });
      tableEl.style.display = 'table';
    } catch (e) {
      loadingEl.style.display = 'none';
      showToast('Failed to load ledger', 'error');
    }
  }

  function downloadLedger() { window.open(`/admin/dashboard/ledger/pdf?${getLedgerParams()}`, '_blank'); }

  loadLedger();

  // ── NOTIFICATIONS ──────────────────────────────────────────────────────────
  function playNotifSound() {
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const t   = ctx.currentTime;
      [0, 0.18].forEach((delay, i) => {
        const osc = ctx.createOscillator(); const gain = ctx.createGain();
        osc.connect(gain); gain.connect(ctx.destination);
        osc.type = 'sine'; osc.frequency.setValueAtTime(i === 0 ? 880 : 660, t + delay);
        gain.gain.setValueAtTime(0.3, t + delay);
        gain.gain.exponentialRampToValueAtTime(0.001, t + delay + 0.4);
        osc.start(t + delay); osc.stop(t + delay + 0.4);
      });
    } catch (_) {}
  }

  const STORAGE_KEY = 'vc_admin_notifs';
  const SEEN_KEY    = 'vc_seen_order_ids';

  function loadNotifications() { try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; } }
  function saveNotifications() { try { localStorage.setItem(STORAGE_KEY, JSON.stringify(notifications)); } catch (_) {} }
  function loadSeenIds()       { try { return new Set(JSON.parse(localStorage.getItem(SEEN_KEY) || '[]')); } catch { return new Set(); } }
  function saveSeenIds(set)    { try { localStorage.setItem(SEEN_KEY, JSON.stringify([...set].slice(-500))); } catch (_) {} }

  let notifications = loadNotifications();
  let seenIds       = loadSeenIds();
  let currentTab    = 'all';

  function getVisible()   { if (currentTab==='unread') return notifications.filter(n=>!n.read); if (currentTab==='read') return notifications.filter(n=>n.read); return notifications; }
  function unreadCount()  { return notifications.filter(n => !n.read).length; }

  function updateBadge() {
    const badge = document.getElementById('notifCount');
    const count = unreadCount();
    badge.textContent   = count > 9 ? '9+' : count;
    badge.style.display = count > 0 ? 'flex' : 'none';
  }
  function updateFooter() {
    document.getElementById('notifFooterCount').textContent = notifications.length + ' total · ' + unreadCount() + ' unread';
  }
  function timeAgo(date) {
    const s = Math.floor((Date.now() - new Date(date)) / 1000);
    if (s < 60) return 'just now';
    if (s < 3600) return Math.floor(s / 60) + 'm ago';
    return Math.floor(s / 3600) + 'h ago';
  }
  function renderList() {
    const list = document.getElementById('notifList');
    const visible = getVisible();
    list.innerHTML = '';
    if (visible.length === 0) { list.innerHTML = `<div class="notif-empty">${currentTab==='unread'?'No unread notifications':currentTab==='read'?'No read notifications':'No new orders'}</div>`; return; }
    visible.forEach(n => {
      const el = document.createElement('div');
      el.className  = 'notif-item' + (n.read ? ' read' : '');
      el.dataset.id = n.id;
      el.innerHTML  = `
        <div class="notif-item__dot"></div>
        <div class="notif-item__body-wrap">
          <div class="notif-item__top">
            <span class="notif-item__id">${n.orderNumber}</span>
            <span class="notif-item__time">${timeAgo(n.createdAt)}</span>
          </div>
          <div class="notif-item__info">₹${Number(n.grandTotal).toLocaleString('en-IN')} &nbsp;·&nbsp; ${n.itemCount} item${n.itemCount!==1?'s':''} &nbsp;·&nbsp; ${n.paymentMethod}</div>
          ${n.customerName ? `<div class="notif-item__customer">${n.customerName}</div>` : ''}
        </div>
        <div class="notif-item__actions">
          <button class="notif-mark-btn" onclick="toggleRead('${n.id}',event)">${n.read?'Mark unread':'Mark read'}</button>
          <a href="/admin/orders/${n.id}" class="notif-view-btn" onclick="markOneRead('${n.id}')">View</a>
        </div>`;
      list.appendChild(el);
    });
  }
  function toggleRead(id, e) { e.preventDefault(); e.stopPropagation(); const n=notifications.find(x=>x.id===id); if(!n)return; n.read=!n.read; saveNotifications(); updateBadge(); updateFooter(); renderList(); }
  function markOneRead(id)   { const n=notifications.find(x=>x.id===id); if(n){n.read=true;saveNotifications();} updateBadge(); updateFooter(); }
  function markAllRead()     { notifications.forEach(n=>{n.read=true;}); saveNotifications(); updateBadge(); updateFooter(); renderList(); }
  function clearAll()        { notifications=[]; saveNotifications(); updateBadge(); updateFooter(); renderList(); document.getElementById('notifDropdown').classList.remove('open'); }
  function switchTab(tab)    { currentTab=tab; document.querySelectorAll('.notif-tab').forEach(t=>t.classList.remove('active')); document.getElementById('tab'+tab.charAt(0).toUpperCase()+tab.slice(1)).classList.add('active'); renderList(); }
  function toggleDropdown()  { document.getElementById('notifDropdown').classList.toggle('open'); }

  document.addEventListener('click', (e) => { if (!document.getElementById('notifWrap').contains(e.target)) document.getElementById('notifDropdown').classList.remove('open'); });

  function addNotification(order) {
    const id = String(order._id);
    if (seenIds.has(id)) return;
    seenIds.add(id); saveSeenIds(seenIds);
    if (notifications.find(n => n.id === id)) { updateBadge(); updateFooter(); renderList(); return; }
    notifications.unshift({ id, orderNumber: order.orderNumber||('#'+id.slice(-6).toUpperCase()), grandTotal: order.grandTotal??order.pricing?.grandTotal??0, itemCount: order.itemCount??order.items?.length??0, paymentMethod: order.paymentMethod||'COD', customerName: order.customerName||'', createdAt: order.createdAt, read: false });
    saveNotifications(); updateBadge(); updateFooter(); renderList();
    playNotifSound();
    showToast(`New order ${notifications[0].orderNumber} — ₹${Number(notifications[0].grandTotal).toLocaleString('en-IN')}`, 'success');
  }

  const socket = io();
  socket.emit('join-admin');
  socket.on('new-order', (order) => addNotification(order));

  async function pollRecent() {
    try { const res=await fetch('/admin/orders/notify/recent'); const data=await res.json(); if(data.success) data.orders.forEach(addNotification); } catch(_) {}
  }
  pollRecent();
  setInterval(pollRecent, 30_000);

  updateBadge(); updateFooter(); renderList();
</script>
</body>
</html>
