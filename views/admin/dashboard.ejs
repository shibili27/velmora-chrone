<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate"/>
  <meta http-equiv="Pragma" content="no-cache"/>
  <meta http-equiv="Expires" content="0"/>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — Velmora Chroné Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --teal:       #2d8c84;
      --teal-dark:  #1f6e67;
      --teal-light: #e8f4f3;
      --sidebar-w:  220px;
      --bg:         #f2f4f3;
      --white:      #ffffff;
      --border:     #e2e6e4;
      --text:       #1a1f1e;
      --text-mid:   #5a6461;
      --text-light: #9aa8a5;
      --green:      #16a34a;
      --green-bg:   #dcfce7;
      --blue:       #2563eb;
      --blue-bg:    #dbeafe;
      --red:        #dc2626;
      --red-bg:     #fee2e2;
      --amber:      #d97706;
      --amber-bg:   #fef3c7;
      --purple:     #7c3aed;
      --purple-bg:  #ede9fe;
    }

    html, body { height: 100%; font-family: 'Jost', sans-serif; background: var(--bg); color: var(--text); }
    .layout { display: flex; min-height: 100vh; }

    /* ── Sidebar ── */
    .sidebar {
      width: var(--sidebar-w);
      background: var(--white);
      border-right: 1px solid var(--border);
      display: flex; flex-direction: column;
      position: fixed; top: 0; left: 0; bottom: 0;
      z-index: 100;
    }
    .sidebar__brand { padding: 24px 20px 18px; border-bottom: 1px solid var(--border); }
    .sidebar__brand-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: 0.06em; color: var(--text); line-height: 1.2; }
    .sidebar__brand-sub  { font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-top: 3px; }
    .sidebar__nav { flex: 1; padding: 14px 0; overflow-y: auto; }
    .nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 20px; font-size: 13px; font-weight: 500;
      color: var(--text-mid); text-decoration: none;
      transition: background 0.15s, color 0.15s; cursor: pointer;
    }
    .nav-item:hover  { background: var(--teal-light); color: var(--teal); }
    .nav-item.active { background: var(--teal-light); color: var(--teal); border-right: 3px solid var(--teal); }
    .nav-item svg    { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar__footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .sidebar__footer-info { overflow: hidden; flex: 1; }
    .sidebar__footer-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar__footer-role { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); }
    .btn-logout { display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; border: 1px solid #fecaca; background: var(--red-bg); color: var(--red); cursor: pointer; flex-shrink: 0; transition: background 0.15s, border-color 0.15s; text-decoration: none; }
    .btn-logout:hover { background: var(--red); color: #fff; border-color: var(--red); }
    .btn-logout svg { width: 14px; height: 14px; }

    /* ── Main ── */
    .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }

    /* ── Topbar ── */
    .topbar { background: var(--white); border-bottom: 1px solid var(--border); padding: 0 32px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar__title { font-size: 13px; font-weight: 500; color: var(--text-mid); letter-spacing: 0.04em; }
    .topbar__right { display: flex; align-items: center; gap: 10px; }
    .topbar__date { font-size: 11px; color: var(--text-light); letter-spacing: 0.04em; }
    .topbar__bell { width: 34px; height: 34px; border-radius: 50%; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text-mid); background: none; transition: background 0.15s; }
    .topbar__bell:hover { background: var(--teal-light); color: var(--teal); }
    .topbar__bell svg { width: 16px; height: 16px; }

    /* ── Content ── */
    .content { padding: 32px; flex: 1; }

    /* ── Welcome banner ── */
    .welcome-banner {
      background: linear-gradient(135deg, var(--teal) 0%, var(--teal-dark) 100%);
      border-radius: 8px;
      padding: 28px 32px;
      margin-bottom: 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      overflow: hidden;
      position: relative;
    }
    .welcome-banner::before {
      content: '';
      position: absolute;
      right: -40px; top: -40px;
      width: 200px; height: 200px;
      border-radius: 50%;
      background: rgba(255,255,255,0.05);
    }
    .welcome-banner::after {
      content: '';
      position: absolute;
      right: 60px; bottom: -60px;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,0.04);
    }
    .welcome-banner__text { position: relative; z-index: 1; }
    .welcome-banner__greeting { font-size: 12px; font-weight: 500; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.65); margin-bottom: 6px; }
    .welcome-banner__name { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: #fff; line-height: 1.2; }
    .welcome-banner__sub { font-size: 12px; color: rgba(255,255,255,0.6); margin-top: 6px; }
    .welcome-banner__badge {
      position: relative; z-index: 1;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.2);
      border-radius: 6px;
      padding: 12px 20px;
      text-align: center;
      min-width: 130px;
    }
    .welcome-banner__badge-label { font-size: 9px; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 4px; }
    .welcome-banner__badge-val { font-family: 'Cormorant Garamond', serif; font-size: 22px; font-weight: 600; color: #fff; }
    .welcome-banner__badge-val span { font-size: 12px; font-family: 'Jost', sans-serif; }

    /* ── Stat cards ── */
    .stat-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      margin-bottom: 24px;
    }
    .stat-card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 20px 22px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      transition: box-shadow 0.2s;
    }
    .stat-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.06); }
    .stat-card__top { display: flex; align-items: flex-start; justify-content: space-between; }
    .stat-card__icon {
      width: 38px; height: 38px;
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }
    .stat-card__icon svg { width: 18px; height: 18px; }
    .stat-card__icon--teal   { background: var(--teal-light); color: var(--teal); }
    .stat-card__icon--green  { background: var(--green-bg);   color: var(--green); }
    .stat-card__icon--blue   { background: var(--blue-bg);    color: var(--blue); }
    .stat-card__icon--amber  { background: var(--amber-bg);   color: var(--amber); }
    .stat-card__trend {
      font-size: 10px; font-weight: 600;
      display: flex; align-items: center; gap: 3px;
      padding: 3px 7px; border-radius: 20px;
    }
    .stat-card__trend svg { width: 10px; height: 10px; }
    .stat-card__trend--up   { color: var(--green); background: var(--green-bg); }
    .stat-card__trend--down { color: var(--red);   background: var(--red-bg); }
    .stat-card__label { font-size: 11px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text-light); }
    .stat-card__value { font-family: 'Cormorant Garamond', serif; font-size: 28px; font-weight: 600; color: var(--text); line-height: 1; }
    .stat-card__sub { font-size: 11px; color: var(--text-light); margin-top: 2px; }

    /* ── Two-col grid ── */
    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 24px; }
    .three-col { display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 24px; }

    /* ── Section card ── */
    .section-card { background: var(--white); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .section-card__header { padding: 18px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .section-card__title  { font-size: 13px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text); }
    .section-card__meta   { font-size: 11px; color: var(--text-light); }
    .section-card__link   { font-size: 11px; font-weight: 600; color: var(--teal); text-decoration: none; letter-spacing: 0.04em; }
    .section-card__link:hover { text-decoration: underline; }

    /* ── Mini chart bars ── */
    .chart-area { padding: 20px 24px; }
    .chart-bars {
      display: flex;
      align-items: flex-end;
      gap: 6px;
      height: 100px;
    }
    .chart-bar-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6px; }
    .chart-bar {
      width: 100%;
      border-radius: 3px 3px 0 0;
      background: var(--teal-light);
      transition: background 0.15s;
      cursor: default;
      position: relative;
    }
    .chart-bar.active { background: var(--teal); }
    .chart-bar:hover  { background: var(--teal); }
    .chart-bar__label { font-size: 9px; color: var(--text-light); letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap; }
    .chart-divider { border: none; border-top: 1px solid var(--border); margin: 0 24px; }

    /* ── Revenue row ── */
    .rev-row { display: flex; align-items: center; justify-content: space-between; padding: 10px 24px; border-bottom: 1px solid var(--border); font-size: 12px; }
    .rev-row:last-child { border-bottom: none; }
    .rev-row__label { color: var(--text-mid); }
    .rev-row__val { font-weight: 600; color: var(--text); }
    .rev-row__val--teal { color: var(--teal); }

    /* ── Table ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #f8faf9; }
    th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); padding: 12px 20px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: 13px 20px; font-size: 12.5px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: #fafcfb; }

    /* Badges */
    .badge { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 600; padding: 3px 9px; border-radius: 20px; white-space: nowrap; letter-spacing: 0.04em; }
    .badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .badge--pending   { color: var(--amber); background: var(--amber-bg); }
    .badge--delivered { color: var(--green); background: var(--green-bg); }
    .badge--cancelled { color: var(--red);   background: var(--red-bg);   }
    .badge--shipped   { color: var(--blue);  background: var(--blue-bg);  }

    /* ── Activity list ── */
    .activity-list { padding: 4px 0; }
    .activity-item { display: flex; align-items: flex-start; gap: 12px; padding: 14px 24px; border-bottom: 1px solid var(--border); }
    .activity-item:last-child { border-bottom: none; }
    .activity-dot {
      width: 8px; height: 8px; border-radius: 50%;
      flex-shrink: 0; margin-top: 4px;
    }
    .activity-dot--teal   { background: var(--teal); }
    .activity-dot--green  { background: var(--green); }
    .activity-dot--amber  { background: var(--amber); }
    .activity-dot--red    { background: var(--red); }
    .activity-dot--blue   { background: var(--blue); }
    .activity-text { font-size: 12px; color: var(--text-mid); line-height: 1.5; flex: 1; }
    .activity-text strong { color: var(--text); font-weight: 600; }
    .activity-time { font-size: 10px; color: var(--text-light); white-space: nowrap; margin-top: 2px; }

    /* ── Top products ── */
    .product-row { display: flex; align-items: center; gap: 12px; padding: 13px 24px; border-bottom: 1px solid var(--border); }
    .product-row:last-child { border-bottom: none; }
    .product-rank { font-size: 10px; font-weight: 700; color: var(--text-light); width: 18px; flex-shrink: 0; }
    .product-img { width: 36px; height: 36px; border-radius: 4px; background: var(--teal-light); display: flex; align-items: center; justify-content: center; flex-shrink: 0; overflow: hidden; }
    .product-img svg { width: 16px; height: 16px; color: var(--teal); }
    .product-info { flex: 1; overflow: hidden; }
    .product-name { font-size: 12.5px; font-weight: 500; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .product-brand { font-size: 10px; color: var(--text-light); margin-top: 1px; }
    .product-sales { text-align: right; flex-shrink: 0; }
    .product-sales__val { font-size: 12px; font-weight: 600; color: var(--text); }
    .product-sales__units { font-size: 10px; color: var(--text-light); }

    /* ── Progress bars ── */
    .progress-section { padding: 16px 24px; display: flex; flex-direction: column; gap: 14px; }
    .progress-item__top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 5px; }
    .progress-item__label { font-size: 12px; color: var(--text-mid); }
    .progress-item__val { font-size: 12px; font-weight: 600; color: var(--text); }
    .progress-track { height: 5px; background: var(--border); border-radius: 10px; overflow: hidden; }
    .progress-fill { height: 100%; border-radius: 10px; }
    .progress-fill--teal   { background: var(--teal); }
    .progress-fill--green  { background: var(--green); }
    .progress-fill--amber  { background: var(--amber); }
    .progress-fill--blue   { background: var(--blue); }

    /* Footer */
    .page-footer { text-align: center; padding: 20px 32px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); border-top: 1px solid var(--border); }
  </style>
</head>
<body>

<div class="layout">

  <!-- ── Sidebar ── -->
  <aside class="sidebar">
    <div class="sidebar__brand">
      <div class="sidebar__brand-name">Velmora<br>Chroné</div>
      <div class="sidebar__brand-sub">Admin Dashboard</div>
    </div>
    <nav class="sidebar__nav">
      <a href="/admin/dashboard" class="nav-item active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/orders" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>
      <a href="/admin/products" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
        Products
      </a>
      <a href="/admin/reviews" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
        Rating/Review
      </a>
      <a href="/admin/customers" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Customers
      </a>
      <a href="/admin/coupons" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        Coupons
      </a>
      <a href="/admin/categories" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Categories
      </a>
      <a href="/admin/brands" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z"/></svg>
        Brands
      </a>
      <a href="/admin/refunds" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Refund/Return
      </a>
      <a href="/admin/banners" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Banner
      </a>
      <a href="/admin/referrals" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        Referral
      </a>
    </nav>
    <div class="sidebar__footer">
      <div class="avatar"><%= adminName ? adminName.charAt(0).toUpperCase() : 'A' %></div>
      <div class="sidebar__footer-info">
        <div class="sidebar__footer-name"><%= adminName || 'Admin' %></div>
        <div class="sidebar__footer-role"><%= adminRole || 'Administrator' %></div>
      </div>
      <a href="/admin/logout" class="btn-logout" title="Logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      </a>
    </div>
  </aside>

  <!-- ── Main ── -->
  <div class="main">

    <header class="topbar">
      <span class="topbar__title">Operational Administrator Hub</span>
      <div class="topbar__right">
        <span class="topbar__date" id="topbarDate"></span>
        <button class="topbar__bell" aria-label="Notifications">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
        </button>
      </div>
    </header>

    <div class="content">

      <!-- ── Welcome Banner ── -->
      <div class="welcome-banner">
        <div class="welcome-banner__text">
          <div class="welcome-banner__greeting">Welcome back</div>
          <div class="welcome-banner__name"><%= adminName || 'Administrator' %></div>
          <div class="welcome-banner__sub">Here's what's happening with Velmora Chroné today.</div>
        </div>
        <div class="welcome-banner__badge">
          <div class="welcome-banner__badge-label">Today's Revenue</div>
          <div class="welcome-banner__badge-val">
            <span>₹</span><%= typeof todayRevenue !== 'undefined' ? todayRevenue.toLocaleString('en-IN') : '0' %>
          </div>
        </div>
      </div>

      <!-- ── Stat Cards ── -->
      <div class="stat-grid">

        <!-- Total Revenue -->
        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--teal">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--up">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              <%= typeof revenueGrowth !== 'undefined' ? revenueGrowth : '0' %>%
            </span>
          </div>
          <div>
            <div class="stat-card__label">Total Revenue</div>
            <div class="stat-card__value">₹<%= typeof totalRevenue !== 'undefined' ? totalRevenue.toLocaleString('en-IN') : '0' %></div>
            <div class="stat-card__sub">vs last month</div>
          </div>
        </div>

        <!-- Total Orders -->
        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--blue">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--up">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              <%= typeof ordersGrowth !== 'undefined' ? ordersGrowth : '0' %>%
            </span>
          </div>
          <div>
            <div class="stat-card__label">Total Orders</div>
            <div class="stat-card__value"><%= typeof totalOrders !== 'undefined' ? totalOrders.toLocaleString() : '0' %></div>
            <div class="stat-card__sub"><%= typeof pendingOrders !== 'undefined' ? pendingOrders : '0' %> pending</div>
          </div>
        </div>

        <!-- Total Customers -->
        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--green">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--up">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
              <%= typeof customersGrowth !== 'undefined' ? customersGrowth : '0' %>%
            </span>
          </div>
          <div>
            <div class="stat-card__label">Customers</div>
            <div class="stat-card__value"><%= typeof totalCustomers !== 'undefined' ? totalCustomers.toLocaleString() : '0' %></div>
            <div class="stat-card__sub"><%= typeof newCustomers !== 'undefined' ? newCustomers : '0' %> new this month</div>
          </div>
        </div>

        <!-- Total Products -->
        <div class="stat-card">
          <div class="stat-card__top">
            <div class="stat-card__icon stat-card__icon--amber">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
            </div>
            <span class="stat-card__trend stat-card__trend--down">
              <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              <%= typeof outOfStock !== 'undefined' ? outOfStock : '0' %> out
            </span>
          </div>
          <div>
            <div class="stat-card__label">Products</div>
            <div class="stat-card__value"><%= typeof totalProducts !== 'undefined' ? totalProducts.toLocaleString() : '0' %></div>
            <div class="stat-card__sub">across all categories</div>
          </div>
        </div>

      </div><!-- /.stat-grid -->

      <!-- ── Row: Sales Chart + Revenue Summary ── -->
      <div class="three-col">

        <!-- Sales Chart -->
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Monthly Sales</span>
            <span class="section-card__meta">Last 7 months</span>
          </div>
          <div class="chart-area">
            <div class="chart-bars" id="salesChart">
              <!-- Rendered by JS from monthlySales data -->
            </div>
          </div>
          <hr class="chart-divider"/>
          <div class="rev-row">
            <span class="rev-row__label">Avg. Order Value</span>
            <span class="rev-row__val rev-row__val--teal">₹<%= typeof avgOrderValue !== 'undefined' ? avgOrderValue.toLocaleString('en-IN') : '0' %></span>
          </div>
          <div class="rev-row">
            <span class="rev-row__label">Highest Month</span>
            <span class="rev-row__val">₹<%= typeof highestMonth !== 'undefined' ? highestMonth.toLocaleString('en-IN') : '0' %></span>
          </div>
          <div class="rev-row">
            <span class="rev-row__label">Conversion Rate</span>
            <span class="rev-row__val"><%= typeof conversionRate !== 'undefined' ? conversionRate : '0' %>%</span>
          </div>
        </div>

        <!-- Revenue breakdown -->
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Order Status</span>
          </div>
          <div class="progress-section">
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Delivered</span>
                <span class="progress-item__val"><%= typeof deliveredOrders !== 'undefined' ? deliveredOrders : '0' %></span>
              </div>
              <div class="progress-track">
                <div class="progress-fill progress-fill--green" style="width: <%= typeof deliveredPct !== 'undefined' ? deliveredPct : 0 %>%"></div>
              </div>
            </div>
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Pending</span>
                <span class="progress-item__val"><%= typeof pendingOrders !== 'undefined' ? pendingOrders : '0' %></span>
              </div>
              <div class="progress-track">
                <div class="progress-fill progress-fill--amber" style="width: <%= typeof pendingPct !== 'undefined' ? pendingPct : 0 %>%"></div>
              </div>
            </div>
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Shipped</span>
                <span class="progress-item__val"><%= typeof shippedOrders !== 'undefined' ? shippedOrders : '0' %></span>
              </div>
              <div class="progress-track">
                <div class="progress-fill progress-fill--blue" style="width: <%= typeof shippedPct !== 'undefined' ? shippedPct : 0 %>%"></div>
              </div>
            </div>
            <div>
              <div class="progress-item__top">
                <span class="progress-item__label">Cancelled</span>
                <span class="progress-item__val"><%= typeof cancelledOrders !== 'undefined' ? cancelledOrders : '0' %></span>
              </div>
              <div class="progress-track">
                <div class="progress-fill" style="width: <%= typeof cancelledPct !== 'undefined' ? cancelledPct : 0 %>%; background: var(--red);"></div>
              </div>
            </div>
          </div>

          <hr class="chart-divider"/>

          <!-- Quick links -->
          <div style="padding: 14px 24px; display: flex; flex-direction: column; gap: 10px;">
            <a href="/admin/orders" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;padding:9px 12px;border-radius:4px;background:var(--bg);font-size:12px;font-weight:500;color:var(--text-mid);transition:background 0.15s;" onmouseover="this.style.background='var(--teal-light)';this.style.color='var(--teal)'" onmouseout="this.style.background='var(--bg)';this.style.color='var(--text-mid)'">
              <span>View All Orders</span>
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/admin/customers" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;padding:9px 12px;border-radius:4px;background:var(--bg);font-size:12px;font-weight:500;color:var(--text-mid);transition:background 0.15s;" onmouseover="this.style.background='var(--teal-light)';this.style.color='var(--teal)'" onmouseout="this.style.background='var(--bg)';this.style.color='var(--text-mid)'">
              <span>Manage Customers</span>
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
            <a href="/admin/products" style="display:flex;align-items:center;justify-content:space-between;text-decoration:none;padding:9px 12px;border-radius:4px;background:var(--bg);font-size:12px;font-weight:500;color:var(--text-mid);transition:background 0.15s;" onmouseover="this.style.background='var(--teal-light)';this.style.color='var(--teal)'" onmouseout="this.style.background='var(--bg)';this.style.color='var(--text-mid)'">
              <span>Manage Products</span>
              <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>

        </div>

      </div><!-- /.three-col -->

      <!-- ── Row: Recent Orders + Activity ── -->
      <div class="two-col" style="margin-bottom: 24px;">

        <!-- Recent Orders -->
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Recent Orders</span>
            <a href="/admin/orders" class="section-card__link">View All →</a>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Order ID</th>
                  <th>Customer</th>
                  <th>Amount</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
                <% if (typeof recentOrders !== 'undefined' && recentOrders.length > 0) { %>
                  <% recentOrders.forEach(function(o) { %>
                  <tr>
                    <td style="font-family:'Cormorant Garamond',serif;font-size:13px;font-weight:600;color:var(--teal)">#<%= o.orderId || o._id.toString().slice(-6).toUpperCase() %></td>
                    <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap"><%= o.userId && o.userId.name ? o.userId.name : 'Unknown' %></td>
                    <td style="font-weight:600">₹<%= o.totalAmount ? o.totalAmount.toLocaleString('en-IN') : '0' %></td>
                    <td>
                      <% const s = (o.status || '').toLowerCase(); %>
                      <% if (s === 'delivered') { %><span class="badge badge--delivered">Delivered</span>
                      <% } else if (s === 'pending') { %><span class="badge badge--pending">Pending</span>
                      <% } else if (s === 'shipped' || s === 'processing') { %><span class="badge badge--shipped">Shipped</span>
                      <% } else if (s === 'cancelled') { %><span class="badge badge--cancelled">Cancelled</span>
                      <% } else { %><span class="badge badge--pending"><%= o.status || 'N/A' %></span><% } %>
                    </td>
                  </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4" style="text-align:center;color:var(--text-light);padding:32px;font-size:12px">No recent orders</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Activity Feed -->
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Recent Activity</span>
            <span class="section-card__meta">Live</span>
          </div>
          <div class="activity-list">
            <% if (typeof recentActivity !== 'undefined' && recentActivity.length > 0) { %>
              <% recentActivity.forEach(function(a) { %>
              <div class="activity-item">
                <div class="activity-dot activity-dot--<%= a.color || 'teal' %>"></div>
                <div style="flex:1">
                  <div class="activity-text"><%- a.message %></div>
                  <div class="activity-time"><%= a.time %></div>
                </div>
              </div>
              <% }) %>
            <% } else { %>
              <!-- Placeholder activity items when no data -->
              <div class="activity-item">
                <div class="activity-dot activity-dot--teal"></div>
                <div style="flex:1">
                  <div class="activity-text">Dashboard loaded successfully</div>
                  <div class="activity-time">Just now</div>
                </div>
              </div>
            <% } %>
          </div>
        </div>

      </div>

      <!-- ── Top Products ── -->
      <div class="two-col">
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Top Selling Products</span>
            <a href="/admin/products" class="section-card__link">View All →</a>
          </div>
          <% if (typeof topProducts !== 'undefined' && topProducts.length > 0) { %>
            <% topProducts.forEach(function(p, i) { %>
            <div class="product-row">
              <div class="product-rank">#<%= i + 1 %></div>
              <div class="product-img">
                <% if (p.images && p.images.length > 0) { %>
                  <img src="<%= p.images[0] %>" alt="<%= p.name %>" style="width:100%;height:100%;object-fit:cover;border-radius:4px"/>
                <% } else { %>
                  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
                <% } %>
              </div>
              <div class="product-info">
                <div class="product-name"><%= p.name %></div>
                <div class="product-brand"><%= p.brand || p.category || '' %></div>
              </div>
              <div class="product-sales">
                <div class="product-sales__val">₹<%= p.totalRevenue ? p.totalRevenue.toLocaleString('en-IN') : '0' %></div>
                <div class="product-sales__units"><%= p.totalSold || 0 %> sold</div>
              </div>
            </div>
            <% }) %>
          <% } else { %>
            <div style="padding:32px 24px;text-align:center;color:var(--text-light);font-size:12px">No product data yet</div>
          <% } %>
        </div>

        <!-- Quick Stats summary -->
        <div class="section-card">
          <div class="section-card__header">
            <span class="section-card__title">Quick Stats</span>
          </div>
          <div style="padding: 8px 0;">
            <div class="rev-row">
              <span class="rev-row__label">Total Reviews</span>
              <span class="rev-row__val"><%= typeof totalReviews !== 'undefined' ? totalReviews : '0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Avg. Rating</span>
              <span class="rev-row__val rev-row__val--teal">⭐ <%= typeof avgRating !== 'undefined' ? avgRating : '0.0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Active Coupons</span>
              <span class="rev-row__val"><%= typeof activeCoupons !== 'undefined' ? activeCoupons : '0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Blocked Users</span>
              <span class="rev-row__val" style="color:var(--red)"><%= typeof blockedUsers !== 'undefined' ? blockedUsers : '0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Pending Refunds</span>
              <span class="rev-row__val" style="color:var(--amber)"><%= typeof pendingRefunds !== 'undefined' ? pendingRefunds : '0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Active Banners</span>
              <span class="rev-row__val"><%= typeof activeBanners !== 'undefined' ? activeBanners : '0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Total Categories</span>
              <span class="rev-row__val"><%= typeof totalCategories !== 'undefined' ? totalCategories : '0' %></span>
            </div>
            <div class="rev-row">
              <span class="rev-row__label">Total Brands</span>
              <span class="rev-row__val"><%= typeof totalBrands !== 'undefined' ? totalBrands : '0' %></span>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /.content -->

    <footer class="page-footer">
      © 2026 Velmora Chroné. All Rights Reserved. Admin Panel.
    </footer>
  </div><!-- /.main -->
</div>

<script>
  // ── Live date in topbar ──
  (function() {
    const el = document.getElementById('topbarDate');
    if (!el) return;
    const now = new Date();
    el.textContent = now.toLocaleDateString('en-IN', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
  })();

  // ── Sales chart bars ──
  (function() {
    const container = document.getElementById('salesChart');
    if (!container) return;

    // Data from server (monthlySales should be array of { label, value } objects)
    // Falls back to placeholder bars if not provided
    const raw = <%- typeof monthlySales !== 'undefined' ? JSON.stringify(monthlySales) : 'null' %>;

    const data = raw && raw.length > 0 ? raw : [
      { label: 'Nov', value: 30 },
      { label: 'Dec', value: 65 },
      { label: 'Jan', value: 45 },
      { label: 'Feb', value: 80 },
      { label: 'Mar', value: 55 },
      { label: 'Apr', value: 70 },
      { label: 'May', value: 90 }
    ];

    const max = Math.max(...data.map(d => d.value), 1);
    const lastIdx = data.length - 1;

    data.forEach(function(d, i) {
      const pct = Math.max((d.value / max) * 100, 4);
      const wrap = document.createElement('div');
      wrap.className = 'chart-bar-wrap';
      const bar = document.createElement('div');
      bar.className = 'chart-bar' + (i === lastIdx ? ' active' : '');
      bar.style.height = pct + 'px';
      bar.title = d.label + ': ' + d.value;
      const lbl = document.createElement('div');
      lbl.className = 'chart-bar__label';
      lbl.textContent = d.label;
      wrap.appendChild(bar);
      wrap.appendChild(lbl);
      container.appendChild(wrap);
    });
  })();
</script>

</body>
</html>
