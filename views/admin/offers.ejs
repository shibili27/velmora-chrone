<!DOCTYPE html>
<html lang="en">
<head>
  <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate"/>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Offers — Velmora Chroné Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --teal:       #2d8c84;
      --teal-dark:  #1f6e67;
      --teal-light: #e8f4f3;
      --sidebar-w:  220px;
      --bg:         #f2f4f3;
      --white:      #ffffff;
      --border:     #e2e6e4;
      --text:       #1a1f1e;
      --text-mid:   #5a6461;
      --text-light: #9aa8a5;
      --green:      #16a34a;
      --green-bg:   #dcfce7;
      --red:        #dc2626;
      --red-bg:     #fee2e2;
      --amber:      #d97706;
      --amber-bg:   #fef3c7;
      --purple:     #7c3aed;
      --purple-bg:  #ede9fe;
    }
    html, body { height: 100%; font-family: 'Jost', sans-serif; background: var(--bg); color: var(--text); }
    .layout { display: flex; min-height: 100vh; }

    .sidebar { width: var(--sidebar-w); background: var(--white); border-right: 1px solid var(--border); display: flex; flex-direction: column; position: fixed; top: 0; left: 0; bottom: 0; z-index: 100; }
    .sidebar__brand { padding: 24px 20px 18px; border-bottom: 1px solid var(--border); }
    .sidebar__brand-name { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; letter-spacing: 0.06em; color: var(--text); line-height: 1.2; }
    .sidebar__brand-sub  { font-size: 9px; font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase; color: var(--text-light); margin-top: 3px; }
    .sidebar__nav { flex: 1; padding: 14px 0; overflow-y: auto; }
    .nav-item { display: flex; align-items: center; gap: 10px; padding: 10px 20px; font-size: 13px; font-weight: 500; color: var(--text-mid); text-decoration: none; transition: background 0.15s, color 0.15s; }
    .nav-item:hover  { background: var(--teal-light); color: var(--teal); }
    .nav-item.active { background: var(--teal-light); color: var(--teal); border-right: 3px solid var(--teal); }
    .nav-item svg    { width: 16px; height: 16px; flex-shrink: 0; }
    .sidebar__footer { padding: 16px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 10px; }
    .avatar { width: 34px; height: 34px; border-radius: 50%; background: var(--teal); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 600; flex-shrink: 0; }
    .sidebar__footer-info { overflow: hidden; flex: 1; }
    .sidebar__footer-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .sidebar__footer-role { font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); }
    .btn-logout { display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; border: 1px solid #fecaca; background: var(--red-bg); color: var(--red); cursor: pointer; flex-shrink: 0; transition: background 0.15s; text-decoration: none; }
    .btn-logout:hover { background: var(--red); color: #fff; border-color: var(--red); }
    .btn-logout svg { width: 14px; height: 14px; }

    .main { margin-left: var(--sidebar-w); flex: 1; display: flex; flex-direction: column; min-height: 100vh; }
    .topbar { background: var(--white); border-bottom: 1px solid var(--border); padding: 0 32px; height: 56px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 50; }
    .topbar__title { font-size: 13px; font-weight: 500; color: var(--text-mid); letter-spacing: 0.04em; }
    .content { padding: 32px; flex: 1; }

    .page-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 24px; }
    .page-header__title { font-family: 'Cormorant Garamond', serif; font-size: 26px; font-weight: 600; color: var(--text); }
    .page-header__sub   { font-size: 12px; color: var(--text-light); margin-top: 3px; }

    .flash { padding: 11px 16px; border-radius: 6px; font-size: 12.5px; font-weight: 500; margin-bottom: 20px; display: flex; align-items: center; gap: 8px; }
    .flash--success { background: var(--green-bg); color: var(--green); border: 1px solid #bbf7d0; }
    .flash--error   { background: var(--red-bg);   color: var(--red);   border: 1px solid #fecaca; }

    .toolbar { background: var(--white); border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; margin-bottom: 16px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
    .search-wrap { position: relative; flex: 1; min-width: 200px; }
    .search-wrap svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: var(--text-light); pointer-events: none; }
    .search-input { width: 100%; padding: 8px 12px 8px 32px; border: 1px solid var(--border); border-radius: 5px; font-family: 'Jost', sans-serif; font-size: 12.5px; color: var(--text); background: var(--bg); outline: none; transition: border-color 0.15s; }
    .search-input:focus { border-color: var(--teal); background: var(--white); }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 14px; border-radius: 5px; font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 600; cursor: pointer; border: none; transition: background 0.15s, color 0.15s; text-decoration: none; white-space: nowrap; }
    .btn--teal    { background: var(--teal); color: #fff; }
    .btn--teal:hover { background: var(--teal-dark); }
    .btn--outline { background: var(--white); color: var(--text-mid); border: 1px solid var(--border); }
    .btn--outline:hover { background: var(--bg); color: var(--text); }
    .btn--danger-outline { background: var(--white); color: var(--red); border: 1px solid #fca5a5; }
    .btn--danger-outline:hover { background: var(--red-bg); }
    .btn svg { width: 13px; height: 13px; }

    .section-card { background: var(--white); border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    thead tr { background: #f8faf9; }
    th { font-size: 10px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); padding: 11px 16px; text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap; }
    td { padding: 13px 16px; font-size: 12.5px; color: var(--text); border-bottom: 1px solid var(--border); vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover { background: #fafcfb; }
    .empty-row td { text-align: center; padding: 48px; color: var(--text-light); font-size: 13px; }

    .badge { display: inline-flex; align-items: center; gap: 5px; font-size: 10px; font-weight: 600; padding: 3px 9px; border-radius: 20px; white-space: nowrap; }
    .badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
    .badge--live     { color: var(--green);  background: var(--green-bg); }
    .badge--upcoming { color: var(--purple); background: var(--purple-bg); }
    .badge--expired  { color: var(--text-light); background: var(--bg); }
    .badge--inactive { color: var(--red);    background: var(--red-bg); }
    .badge--product  { color: var(--teal);   background: var(--teal-light); }
    .badge--category { color: var(--amber);  background: var(--amber-bg); }

    .pagination { display: flex; align-items: center; justify-content: space-between; padding: 14px 20px; border-top: 1px solid var(--border); }
    .pagination__info  { font-size: 11px; color: var(--text-light); }
    .pagination__pages { display: flex; align-items: center; gap: 4px; }
    .page-btn { width: 30px; height: 30px; border-radius: 5px; border: 1px solid var(--border); background: var(--white); font-family: 'Jost', sans-serif; font-size: 12px; font-weight: 500; color: var(--text-mid); cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.15s; text-decoration: none; }
    .page-btn:hover { background: var(--teal-light); color: var(--teal); border-color: var(--teal); }
    .page-btn.active { background: var(--teal); color: #fff; border-color: var(--teal); }
    .page-btn.disabled { opacity: 0.4; cursor: default; pointer-events: none; }

    .page-footer { text-align: center; padding: 20px 32px; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-light); border-top: 1px solid var(--border); }

    /* ── Modal ── */
    .modal-backdrop { position: fixed; inset: 0; background: rgba(20,24,23,0.5); z-index: 500; display: none; align-items: center; justify-content: center; padding: 24px; }
    .modal-backdrop.open { display: flex; }
    .modal { background: var(--white); border-radius: 8px; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.25); }
    .modal__header { padding: 18px 22px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .modal__title { font-family: 'Cormorant Garamond', serif; font-size: 18px; font-weight: 600; color: var(--text); }
    .modal__close { width: 28px; height: 28px; border-radius: 6px; border: none; background: var(--bg); color: var(--text-mid); cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .modal__close:hover { background: var(--border); }
    .modal__body { padding: 20px 22px; display: flex; flex-direction: column; gap: 14px; }
    .modal__footer { padding: 14px 22px 20px; display: flex; gap: 10px; justify-content: flex-end; }

    .field { display: flex; flex-direction: column; gap: 6px; }
    .field label { font-size: 11px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; color: var(--text-mid); }
    .field input, .field select, .field textarea {
      padding: 9px 12px; border: 1px solid var(--border); border-radius: 5px;
      font-family: 'Jost', sans-serif; font-size: 13px; color: var(--text);
      background: var(--bg); outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    }
    .field input:focus, .field select:focus, .field textarea:focus { border-color: var(--teal); background: var(--white); }
    .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .field-checkbox { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text); }
    .field-checkbox input { width: 16px; height: 16px; accent-color: var(--teal); cursor: pointer; }
    .field-hint { font-size: 10.5px; color: var(--text-light); }

    /* ── Validation states ── */
    .field input.invalid, .field select.invalid, .field textarea.invalid {
      border-color: var(--red);
      background: var(--red-bg);
      box-shadow: 0 0 0 3px rgba(220,38,38,0.12);
    }
    .field input.valid, .field select.valid, .field textarea.valid {
      border-color: var(--green);
    }

    /* ── Shake animation ── */
    @keyframes shake {
      10%, 90% { transform: translateX(-1px); }
      20%, 80% { transform: translateX(2px); }
      30%, 50%, 70% { transform: translateX(-4px); }
      40%, 60% { transform: translateX(4px); }
    }
    .field.shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    .modal.shake { animation: shake 0.45s cubic-bezier(.36,.07,.19,.97) both; }
    .field-error {
      display: none;
      font-size: 10.5px;
      font-weight: 500;
      color: var(--red);
      align-items: center;
      gap: 5px;
    }
    .field-error.show { display: flex; }
    .field-error svg { width: 11px; height: 11px; flex-shrink: 0; }
    .char-count { font-size: 10px; color: var(--text-light); text-align: right; }
    .char-count.over { color: var(--red); font-weight: 600; }

    .toast { position: fixed; bottom: 24px; right: 24px; background: var(--text); color: #fff; padding: 12px 18px; border-radius: 6px; font-size: 12.5px; font-weight: 500; z-index: 9999; transform: translateY(80px); opacity: 0; transition: transform 0.25s, opacity 0.25s; pointer-events: none; }
    .toast.show { transform: translateY(0); opacity: 1; }
    .toast.toast--error { background: var(--red); }
  </style>
</head>
<body>
<div class="layout">

  <aside class="sidebar">
    <div class="sidebar__brand">
      <div class="sidebar__brand-name">Velmora<br>Chroné</div>
      <div class="sidebar__brand-sub">Admin Dashboard</div>
    </div>
 <nav class="sidebar__nav">
      <a href="/admin/dashboard" class="nav-item" >
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
        Dashboard
      </a>
      <a href="/admin/orders" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
        Orders
      </a>
      <a href="/admin/products" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/></svg>
        Products
      </a>
      <a href="/admin/reviews" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
        Rating/Review
      </a>
      <a href="/admin/customers" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Customers
      </a>
      <a href="/admin/coupons" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
        Coupons
      </a>
      <a href="/admin/offers" class="nav-item active">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        Offers
      </a>
      <a href="/admin/categories" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
        Categories
      </a>
      <a href="/admin/brands"  class="nav-item ">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 4H7a2 2 0 01-2-2V6a2 2 0 012-2h5l2 2h3a2 2 0 012 2v12a2 2 0 01-2 2z"/></svg>
        Brands
      </a>
      <a href="/admin/refunds" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Refund/Return
      </a>
      <a href="/admin/banners" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Banner
      </a>
      <a href="/admin/referrals" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        Referral
      </a>
      <a href="/admin/sales-report" class="nav-item">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        Sales Report
      </a>
    </nav>
    <div class="sidebar__footer">
      <div class="avatar"><%= adminName ? adminName.charAt(0).toUpperCase() : 'A' %></div>
      <div class="sidebar__footer-info">
        <div class="sidebar__footer-name"><%= adminName || 'Admin' %></div>
        <div class="sidebar__footer-role"><%= adminRole || 'Administrator' %></div>
      </div>
      <a href="/admin/logout" class="btn-logout" title="Logout">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
      </a>
    </div>
  </aside>

  <div class="main">
    <header class="topbar">
      <span class="topbar__title">Offer Management</span>
    </header>

    <div class="content">

      <% if (locals.success && success.length > 0) { %>
        <div class="flash flash--success">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <%= success[0] %>
        </div>
      <% } %>
      <% if (locals.error && error.length > 0) { %>
        <div class="flash flash--error">
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          <%= error[0] %>
        </div>
      <% } %>

      <div class="page-header">
        <div>
          <div class="page-header__title">Offers</div>
          <div class="page-header__sub">Manage product-specific and category-wide discounts</div>
        </div>
      </div>

      <form method="GET" action="/admin/offers" id="filterForm">
        <input type="hidden" name="page" value="1"/>
        <div class="toolbar">
          <div class="search-wrap">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35"/></svg>
            <input type="text" name="search" class="search-input" placeholder="Search offers by title…" value="<%= search || '' %>"/>
          </div>
          <button type="submit" class="btn btn--outline">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            Search
          </button>
          <button type="button" class="btn btn--teal" onclick="openAddModal()">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            New Offer
          </button>
        </div>
      </form>

      <div class="section-card">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Title</th>
                <th>Applies To</th>
                <th>Target</th>
                <th>Discount</th>
                <th>Validity</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (offers && offers.length > 0) { %>
                <% offers.forEach(function(offer) { %>
                <tr>
                  <td>
                    <div style="font-weight:600"><%= offer.title %></div>
                    <% if (offer.description) { %>
                      <div style="font-size:10.5px;color:var(--text-light);margin-top:2px;max-width:220px"><%= offer.description %></div>
                    <% } %>
                  </td>
                  <td>
                    <span class="badge badge--<%= offer.appliesTo %>">
                      <%= offer.appliesTo === 'product' ? 'Product' : 'Category' %>
                    </span>
                  </td>
                  <td><%= offer.targetName %></td>
                  <td style="font-weight:600">
                    <%= offer.discountType === 'percentage' ? offer.discountValue + '% off' : '₹' + offer.discountValue.toLocaleString('en-IN') + ' off' %>
                  </td>
                  <td style="font-size:11.5px;color:var(--text-mid);white-space:nowrap">
                    <%= new Date(offer.startDate).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
                    &nbsp;–&nbsp;
                    <%= new Date(offer.endDate).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
                  </td>
                  <td>
                    <% if (!offer.isActive) { %>
                      <span class="badge badge--inactive">Inactive</span>
                    <% } else if (offer.isExpired) { %>
                      <span class="badge badge--expired">Expired</span>
                    <% } else if (offer.isUpcoming) { %>
                      <span class="badge badge--upcoming">Upcoming</span>
                    <% } else if (offer.isLive) { %>
                      <span class="badge badge--live">Live</span>
                    <% } %>
                  </td>
                  <td>
                    <div style="display:flex;gap:6px">
                      <button
                        class="btn btn--outline"
                        style="padding:6px 10px;font-size:11px"
                        onclick='openEditModal(<%- JSON.stringify({
                          _id: offer._id, title: offer.title, description: offer.description,
                          appliesTo: offer.appliesTo, targetId: offer.targetId,
                          discountType: offer.discountType, discountValue: offer.discountValue,
                          startDate: offer.startDate, endDate: offer.endDate, isActive: offer.isActive,
                        }) %>)'
                      >Edit</button>
                      <form method="POST" action="/admin/offers/<%= offer._id %>/toggle" style="display:inline">
                        <button type="submit" class="btn btn--outline" style="padding:6px 10px;font-size:11px">
                          <%= offer.isActive ? 'Deactivate' : 'Activate' %>
                        </button>
                      </form>
                      <form method="POST" action="/admin/offers/<%= offer._id %>/delete" style="display:inline" onsubmit="return confirm('Delete this offer permanently?')">
                        <button type="submit" class="btn btn--danger-outline" style="padding:6px 10px;font-size:11px">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
              <% } else { %>
                <tr class="empty-row">
                  <td colspan="7">No offers found. Create your first offer to get started.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>

        <% if (totalPages > 1) { %>
        <div class="pagination">
          <div class="pagination__info">Page <%= page %> of <%= totalPages %> — <%= total %> total</div>
          <div class="pagination__pages">
            <% for (let p = 1; p <= totalPages; p++) { %>
              <a href="/admin/offers?page=<%= p %>&search=<%= search || '' %>" class="page-btn <%= p === page ? 'active' : '' %>"><%= p %></a>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>

    </div>
    <footer class="page-footer">© 2026 Velmora Chroné. All Rights Reserved. Admin Panel.</footer>
  </div>
</div>

<!-- ── Add/Edit Modal ── -->
<div class="modal-backdrop" id="offerModalBackdrop">
  <div class="modal">
    <div class="modal__header">
      <span class="modal__title" id="modalTitle">New Offer</span>
      <button class="modal__close" onclick="closeModal()">
        <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <form method="POST" id="offerForm" action="/admin/offers/add" novalidate>
      <div class="modal__body">

        <div class="field">
          <label>Title</label>
          <input type="text" name="title" id="f_title" placeholder="e.g. Summer Sale — Watches" maxlength="100"/>
          <span class="field-error" id="err_title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
            <span class="err-text"></span>
          </span>
        </div>

        <div class="field">
          <label>Description (optional)</label>
          <textarea name="description" id="f_description" rows="2" maxlength="300" placeholder="Internal note about this offer"></textarea>
          <div class="char-count" id="count_description">0 / 300</div>
          <span class="field-error" id="err_description">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
            <span class="err-text"></span>
          </span>
        </div>

        <div class="field-row">
          <div class="field">
            <label>Applies To</label>
            <select name="appliesTo" id="f_appliesTo" onchange="updateTargetOptions(); clearError('appliesTo');">
              <option value="">Select…</option>
              <option value="product">Product</option>
              <option value="category">Category</option>
            </select>
            <span class="field-error" id="err_appliesTo">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span class="err-text"></span>
            </span>
          </div>
          <div class="field">
            <label>Target</label>
            <select name="targetId" id="f_targetId"></select>
            <span class="field-error" id="err_targetId">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span class="err-text"></span>
            </span>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label>Discount Type</label>
            <select name="discountType" id="f_discountType" onchange="onDiscountTypeChange()">
              <option value="">Select…</option>
              <option value="percentage">Percentage (%)</option>
              <option value="flat">Flat Amount (₹)</option>
            </select>
            <span class="field-error" id="err_discountType">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span class="err-text"></span>
            </span>
          </div>
          <div class="field">
            <label>Discount Value</label>
            <input type="number" name="discountValue" id="f_discountValue" min="0" step="0.01" placeholder="e.g. 20"/>
            <span class="field-error" id="err_discountValue">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span class="err-text"></span>
            </span>
          </div>
        </div>

        <div class="field-row">
          <div class="field">
            <label>Start Date</label>
            <input type="date" name="startDate" id="f_startDate"/>
            <span class="field-error" id="err_startDate">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span class="err-text"></span>
            </span>
          </div>
          <div class="field">
            <label>End Date</label>
            <input type="date" name="endDate" id="f_endDate"/>
            <span class="field-error" id="err_endDate">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
              <span class="err-text"></span>
            </span>
          </div>
        </div>

        <label class="field-checkbox">
          <input type="checkbox" name="isActive" id="f_isActive" checked/>
          Active immediately
        </label>
        <div class="field-hint">Only one active offer is allowed per product or category at a time.</div>
      </div>
      <div class="modal__footer">
        <button type="button" class="btn btn--outline" onclick="closeModal()">Cancel</button>
        <button type="submit" class="btn btn--teal" id="submitBtn">Create Offer</button>
      </div>
    </form>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  // Data injected from server for populating the target dropdown client-side
  const PRODUCTS   = <%- JSON.stringify((products || []).map(p => ({ id: p._id, name: p.name }))) %>;
  const CATEGORIES = <%- JSON.stringify((categories || []).map(c => ({ id: c._id, name: c.name }))) %>;

  const MAX_PERCENTAGE   = 90;      // sane upper cap for percentage offers
  const MAX_FLAT_AMOUNT  = 500000;  // sane upper cap for flat ₹ offers (adjust as needed)
  const TITLE_MIN        = 3;
  const TITLE_MAX        = 100;
  const DESCRIPTION_MAX  = 300;

  // ── Target dropdown population ──
  function updateTargetOptions(selectedTargetId) {
    const appliesTo = document.getElementById('f_appliesTo').value;
    const targetSel = document.getElementById('f_targetId');
    const list = appliesTo === 'product' ? PRODUCTS : appliesTo === 'category' ? CATEGORIES : [];

    targetSel.innerHTML = '<option value="">Select…</option>' + list.map(item =>
      `<option value="${item.id}">${escapeHtml(item.name)}</option>`
    ).join('');

    if (selectedTargetId) targetSel.value = selectedTargetId;
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str == null ? '' : String(str);
    return div.innerHTML;
  }

  function onDiscountTypeChange() {
    clearError('discountType');
    const type = document.getElementById('f_discountType').value;
    const valueInput = document.getElementById('f_discountValue');
    if (type === 'percentage') {
      valueInput.setAttribute('max', MAX_PERCENTAGE);
      valueInput.placeholder = `e.g. 20 (max ${MAX_PERCENTAGE}%)`;
    } else if (type === 'flat') {
      valueInput.setAttribute('max', MAX_FLAT_AMOUNT);
      valueInput.placeholder = `e.g. 500 (max ₹${MAX_FLAT_AMOUNT.toLocaleString('en-IN')})`;
    } else {
      valueInput.removeAttribute('max');
      valueInput.placeholder = 'e.g. 20';
    }
    validateField('discountValue');
  }

  // ── Modal open/close ──
  function openAddModal() {
    document.getElementById('modalTitle').textContent = 'New Offer';
    document.getElementById('submitBtn').textContent   = 'Create Offer';
    document.getElementById('offerForm').action        = '/admin/offers/add';

    document.getElementById('f_title').value         = '';
    document.getElementById('f_description').value   = '';
    document.getElementById('f_appliesTo').value      = '';
    document.getElementById('f_discountType').value   = '';
    document.getElementById('f_discountValue').value  = '';
    document.getElementById('f_startDate').value      = '';
    document.getElementById('f_endDate').value        = '';
    document.getElementById('f_isActive').checked     = true;

    updateTargetOptions();
    updateCharCount();
    clearAllErrors();
    document.getElementById('offerModalBackdrop').classList.add('open');
  }

  function openEditModal(offer) {
    document.getElementById('modalTitle').textContent = 'Edit Offer';
    document.getElementById('submitBtn').textContent   = 'Save Changes';
    document.getElementById('offerForm').action        = `/admin/offers/${offer._id}/edit`;

    document.getElementById('f_title').value         = offer.title || '';
    document.getElementById('f_description').value   = offer.description || '';
    document.getElementById('f_appliesTo').value      = offer.appliesTo || '';
    document.getElementById('f_discountType').value   = offer.discountType || '';
    document.getElementById('f_discountValue').value  = offer.discountValue;
    document.getElementById('f_startDate').value      = toDateInputValue(offer.startDate);
    document.getElementById('f_endDate').value        = toDateInputValue(offer.endDate);
    document.getElementById('f_isActive').checked     = !!offer.isActive;

    updateTargetOptions(offer.targetId);
    onDiscountTypeChange();
    updateCharCount();
    clearAllErrors();
    document.getElementById('offerModalBackdrop').classList.add('open');
  }

  function toDateInputValue(dateStr) {
    const d = new Date(dateStr);
    return d.toISOString().slice(0, 10);
  }

  function closeModal() {
    document.getElementById('offerModalBackdrop').classList.remove('open');
  }

  document.getElementById('offerModalBackdrop').addEventListener('click', (e) => {
    if (e.target.id === 'offerModalBackdrop') closeModal();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // ── Character counter for description ──
  function updateCharCount() {
    const desc = document.getElementById('f_description');
    const counter = document.getElementById('count_description');
    const len = desc.value.length;
    counter.textContent = `${len} / ${DESCRIPTION_MAX}`;
    counter.classList.toggle('over', len > DESCRIPTION_MAX);
  }
  document.getElementById('f_description').addEventListener('input', () => {
    updateCharCount();
    validateField('description');
  });

  // ── Error helpers ──
  function showError(field, message) {
    const input = document.getElementById(`f_${field}`);
    const err = document.getElementById(`err_${field}`);
    if (!input || !err) return;
    input.classList.add('invalid');
    input.classList.remove('valid');
    err.querySelector('.err-text').textContent = message;
    err.classList.add('show');
  }

  // Shake a single field's wrapper (the .field div containing label/input/error)
  function shakeField(field) {
    const input = document.getElementById(`f_${field}`);
    if (!input) return;
    const wrapper = input.closest('.field');
    if (!wrapper) return;
    wrapper.classList.remove('shake');
    // force reflow so the animation can retrigger even if already applied
    void wrapper.offsetWidth;
    wrapper.classList.add('shake');
    wrapper.addEventListener('animationend', () => wrapper.classList.remove('shake'), { once: true });
  }

  // Shake the whole modal box (used once on a failed submit for extra emphasis)
  function shakeModal() {
    const modal = document.querySelector('.modal');
    if (!modal) return;
    modal.classList.remove('shake');
    void modal.offsetWidth;
    modal.classList.add('shake');
    modal.addEventListener('animationend', () => modal.classList.remove('shake'), { once: true });
  }

  function clearError(field) {
    const input = document.getElementById(`f_${field}`);
    const err = document.getElementById(`err_${field}`);
    if (!input || !err) return;
    input.classList.remove('invalid');
    err.classList.remove('show');
    err.querySelector('.err-text').textContent = '';
  }

  function markValid(field) {
    const input = document.getElementById(`f_${field}`);
    if (!input) return;
    input.classList.add('valid');
    input.classList.remove('invalid');
  }

  function clearAllErrors() {
    ['title', 'description', 'appliesTo', 'targetId', 'discountType', 'discountValue', 'startDate', 'endDate']
      .forEach(f => {
        clearError(f);
        const input = document.getElementById(`f_${f}`);
        if (input) input.classList.remove('valid');
      });
  }

  // ── Per-field validators ──
  function validateField(field) {
    const val = (id) => document.getElementById(`f_${id}`).value;

    switch (field) {
      case 'title': {
        const v = val('title').trim();
        if (!v) { showError('title', 'Title is required.'); return false; }
        if (v.length < TITLE_MIN) { showError('title', `Title must be at least ${TITLE_MIN} characters.`); return false; }
        if (v.length > TITLE_MAX) { showError('title', `Title cannot exceed ${TITLE_MAX} characters.`); return false; }
        // Must contain at least a couple of real letters — blocks junk like "____", "----", "....", "1111"
        const letterCount = (v.match(/[a-zA-Z]/g) || []).length;
        if (letterCount < 2) {
          showError('title', 'Title must contain real words, not just symbols or numbers.');
          return false;
        }
        // Reject titles made up of a single character repeated (e.g. "________", "aaaaaaaa")
        if (/^(.)\1+$/.test(v)) {
          showError('title', 'Title cannot be a single character repeated.');
          return false;
        }
        // Block titles that are only underscores/dashes/dots/symbols with no meaningful text
        if (/^[\s_\-.,!@#$%^&*()+=~`|\\/<>[\]{}:;'"?]+$/.test(v)) {
          showError('title', 'Title cannot consist only of symbols.');
          return false;
        }
        clearError('title'); markValid('title'); return true;
      }
      case 'description': {
        const v = val('description');
        if (v.length > DESCRIPTION_MAX) { showError('description', `Description cannot exceed ${DESCRIPTION_MAX} characters.`); return false; }
        clearError('description');
        if (v.trim().length > 0) markValid('description');
        return true;
      }
      case 'appliesTo': {
        const v = val('appliesTo');
        if (!v) { showError('appliesTo', 'Please select what this offer applies to.'); return false; }
        clearError('appliesTo'); markValid('appliesTo'); return true;
      }
      case 'targetId': {
        const v = val('targetId');
        const appliesTo = val('appliesTo');
        if (!appliesTo) { showError('targetId', 'Select "Applies To" first.'); return false; }
        if (!v) { showError('targetId', `Please select a ${appliesTo === 'product' ? 'product' : 'category'}.`); return false; }
        clearError('targetId'); markValid('targetId'); return true;
      }
      case 'discountType': {
        const v = val('discountType');
        if (!v) { showError('discountType', 'Please select a discount type.'); return false; }
        clearError('discountType'); markValid('discountType'); return true;
      }
      case 'discountValue': {
        const raw = val('discountValue');
        const type = val('discountType');
        if (raw === '') { showError('discountValue', 'Discount value is required.'); return false; }
        const num = Number(raw);
        if (isNaN(num)) { showError('discountValue', 'Discount value must be a number.'); return false; }
        if (num <= 0) { showError('discountValue', 'Discount value must be greater than 0.'); return false; }
        if (type === 'percentage' && num > MAX_PERCENTAGE) {
          showError('discountValue', `Percentage discount cannot exceed ${MAX_PERCENTAGE}%.`); return false;
        }
        if (type === 'flat' && num > MAX_FLAT_AMOUNT) {
          showError('discountValue', `Flat discount cannot exceed ₹${MAX_FLAT_AMOUNT.toLocaleString('en-IN')}.`); return false;
        }
        clearError('discountValue'); markValid('discountValue'); return true;
      }
      case 'startDate': {
        const v = val('startDate');
        if (!v) { showError('startDate', 'Start date is required.'); return false; }
        clearError('startDate'); markValid('startDate');
        // Re-check end date relationship whenever start date changes
        if (val('endDate')) validateField('endDate');
        return true;
      }
      case 'endDate': {
        const v = val('endDate');
        const start = val('startDate');
        if (!v) { showError('endDate', 'End date is required.'); return false; }
        if (start) {
          const startD = new Date(start);
          const endD = new Date(v);
          if (endD <= startD) { showError('endDate', 'End date must be after the start date.'); return false; }
        }
        clearError('endDate'); markValid('endDate'); return true;
      }
      default:
        return true;
    }
  }

  function validateWholeForm() {
    const fields = ['title', 'description', 'appliesTo', 'targetId', 'discountType', 'discountValue', 'startDate', 'endDate'];
    let allValid = true;
    const invalidFields = [];
    fields.forEach(f => {
      const ok = validateField(f);
      if (!ok) { allValid = false; invalidFields.push(f); }
    });

    if (!allValid) {
      invalidFields.forEach(f => shakeField(f));
      shakeModal();
    }

    return allValid;
  }

  // ── Live validation as user interacts ──
  ['title'].forEach(f => {
    document.getElementById(`f_${f}`).addEventListener('input', () => validateField(f));
    document.getElementById(`f_${f}`).addEventListener('blur', () => validateField(f));
  });
  ['appliesTo', 'discountType'].forEach(f => {
    document.getElementById(`f_${f}`).addEventListener('change', () => validateField(f));
  });
  document.getElementById('f_targetId').addEventListener('change', () => validateField('targetId'));
  document.getElementById('f_discountValue').addEventListener('input', () => validateField('discountValue'));
  document.getElementById('f_startDate').addEventListener('change', () => validateField('startDate'));
  document.getElementById('f_endDate').addEventListener('change', () => validateField('endDate'));

  // ── Submit-time validation (blocks bad submissions) ──
  document.getElementById('offerForm').addEventListener('submit', function (e) {
    if (!validateWholeForm()) {
      e.preventDefault();
      e.stopPropagation();
      showToast('Please fix the highlighted fields before submitting.', true);
      const firstInvalid = document.querySelector('.field input.invalid, .field select.invalid, .field textarea.invalid');
      if (firstInvalid) firstInvalid.focus();
    }
  });

  // ── Toast ──
  function showToast(message, isError) {
    const toast = document.getElementById('toast');
    toast.textContent = message;
    toast.classList.toggle('toast--error', !!isError);
    toast.classList.add('show');
    clearTimeout(window.__toastTimer);
    window.__toastTimer = setTimeout(() => toast.classList.remove('show'), 3000);
  }

  // Initialize target dropdown on first load
  updateTargetOptions();
</script>
</body>
</html>
